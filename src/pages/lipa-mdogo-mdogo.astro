/* ═══════════════════════════════════════════════
   SVG PHONE PLACEHOLDER (large, bold, brand-coloured)
═══════════════════════════════════════════════ */
const BRAND_COLORS = {
  Oppo:"#1A7A52", Samsung:"#1428A0", Tecno:"#C62828",
  Infinix:"#6A1B9A", Itel:"#E65100"
};
function makeSVG(p){
  const c = encodeURIComponent(BRAND_COLORS[p.brand] || "#424242");
  const lc = encodeURIComponent(BRAND_COLORS[p.brand] || "#424242");
  const ini = p.name.split(' ').map(w=>w[0]).join('').slice(0,2).toUpperCase();
  // Realistic-looking phone silhouette SVG
  return `data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 200 340' width='200' height='340'%3E`+
    `%3Crect width='200' height='340' fill='%23F8F8FA'/%3E`+
    // phone body
    `%3Crect x='52' y='28' width='96' height='186' rx='16' ry='16' fill='${c}'/%3E`+
    // screen
    `%3Crect x='62' y='42' width='76' height='140' rx='5' ry='5' fill='%23fff' opacity='.18'/%3E`+
    // notch/camera pill
    `%3Crect x='82' y='32' width='36' height='7' rx='3.5' fill='%23000' opacity='.25'/%3E`+
    // home bar
    `%3Crect x='82' y='203' width='36' height='4' rx='2' fill='%23fff' opacity='.35'/%3E`+
    // brand initial
    `%3Ctext x='100' y='140' text-anchor='middle' dominant-baseline='middle' fill='%23fff' opacity='.55' font-size='38' font-family='Open Sans,sans-serif' font-weight='800'%3E${ini}%3C/text%3E`+
    // brand label below phone
    `%3Ctext x='100' y='268' text-anchor='middle' fill='${lc}' font-size='13' font-family='Open Sans,sans-serif' font-weight='700' opacity='.7'%3E${p.brand}%3C/text%3E`+
    `%3C/svg%3E`;
}

/* ═══════════════════════════════════════════════
   STATE
═══════════════════════════════════════════════ */
const S = { filters:{}, sort:'default', page:1, view:'grid', pp:20 };

/* ═══════════════════════════════════════════════
   URL SYNC
═══════════════════════════════════════════════ */
function readURL(){
  const p = new URLSearchParams(location.search);
  S.filters = {};
  ['brand','storage','seller','deposit'].forEach(k => {
    if(p.get(k)) S.filters[k] = p.get(k).split(',');
  });
  if(p.get('sort'))   S.sort = p.get('sort');
  if(p.get('page'))   S.page = parseInt(p.get('page')) || 1;
  if(p.get('view'))   S.view = p.get('view');
  if(p.get('pp'))     S.pp   = parseInt(p.get('pp')) || 20;
}
function pushURL(){
  const p = new URLSearchParams();
  ['brand','storage','seller','deposit'].forEach(k => {
    if(S.filters[k]?.length) p.set(k, S.filters[k].join(','));
  });
  if(S.sort !== 'default') p.set('sort', S.sort);
  if(S.page > 1)           p.set('page', S.page);
  if(S.view !== 'grid')    p.set('view', S.view);
  if(S.pp !== 20)          p.set('pp', S.pp);
  history.pushState({}, '', p.toString()
    ? `${location.pathname}?${p}`
    : location.pathname);
}

/* ═══════════════════════════════════════════════
   FILTER DEFINITIONS
═══════════════════════════════════════════════ */
const DEPOSIT_DEFS = {
  under20k: { label:'Under KSh 20,000', fn: d => d < 20000 },
  under30k: { label:'Under KSh 30,000', fn: d => d < 30000 },
  under40k: { label:'Under KSh 40,000', fn: d => d < 40000 },
  ksh2k_4k: { label:'KSh 2,000 – 4,000', fn: d => d >= 2000 && d <= 4000 },
};
const toNum = s => parseFloat((s || '').replace(/[^\d.]/g,'')) || 0;

function applyFilters(){
  let r = [...products];
  if(S.filters.brand?.length)
    r = r.filter(p => S.filters.brand.includes(p.brand));
  if(S.filters.storage?.length)
    r = r.filter(p => S.filters.storage.includes(p.storage));
  if(S.filters.seller?.length)
    r = r.filter(p => S.filters.seller.includes(p.seller));
  if(S.filters.deposit?.length)
    r = r.filter(p => {
      const d = toNum(p.deposit);
      return S.filters.deposit.some(k => DEPOSIT_DEFS[k]?.fn(d));
    });
  // sort
  if(S.sort === 'price_asc')  r.sort((a,b)=>toNum(a.totalPrice)-toNum(b.totalPrice));
  if(S.sort === 'price_desc') r.sort((a,b)=>toNum(b.totalPrice)-toNum(a.totalPrice));
  if(S.sort === 'rating')     r.sort((a,b)=>(b.reviews?.r||0)-(a.reviews?.r||0));
  if(S.sort === 'popularity') r.sort((a,b)=>(b.reviews?.n||0)-(a.reviews?.n||0));
  return r;
}

/* ═══════════════════════════════════════════════
   SIDEBAR HTML
═══════════════════════════════════════════════ */
function computeCounts(){
  // count UNFILTERED products per option
  const B={}, St={}, Se={}, Dp={under20k:0,under30k:0,under40k:0,ksh2k_4k:0};
  products.forEach(p => {
    B[p.brand]   = (B[p.brand]   || 0) + 1;
    St[p.storage] = (St[p.storage] || 0) + 1;
    Se[p.seller]  = (Se[p.seller]  || 0) + 1;
    const d = toNum(p.deposit);
    if(d < 20000) Dp.under20k++;
    if(d < 30000) Dp.under30k++;
    if(d < 40000) Dp.under40k++;
    if(d >= 2000 && d <= 4000) Dp.ksh2k_4k++;
  });
  return { B, St, Se, Dp };
}

function makeSidebarHTML(){
  const { B, St, Se, Dp } = computeCounts();
  const totalActive = Object.values(S.filters).flat().length;

  function section(title, key, items){
    return `
    <div class="fsec">
      <div class="fsec-hd" onclick="toggleSec(this)" role="button" aria-expanded="true">
        Filter By ${title}
        <span class="chev"></span>
      </div>
      <div class="fsec-body">
        ${items.map(([val, label, cnt]) => {
          const checked = (S.filters[key]||[]).includes(val) ? 'checked' : '';
          return `
          <div class="fopt">
            <label>
              <input type="checkbox" data-key="${key}" data-val="${val}" ${checked}/>
              ${label}
            </label>
            <span class="fcnt">${cnt}</span>
          </div>`;
        }).join('')}
      </div>
    </div>`;
  }

  const storageOrder = ['64GB','128GB','256GB','512GB','1TB'];
  const sortedStorage = Object.entries(St)
    .sort((a,b)=> (storageOrder.indexOf(a[0])+1||99) - (storageOrder.indexOf(b[0])+1||99));

  return `
  <div class="sb">
    <div class="sb-hd">
      <span class="sb-hd-title">Phones</span>
      <button class="sb-clear ${totalActive ? 'show' : ''}" onclick="clearAll()">
        Clear all${totalActive ? ` (${totalActive})` : ''}
      </button>
    </div>
    ${section('Storage', 'storage', sortedStorage.map(([v,c])=>[v,v,c]))}
    ${section('Deposit', 'deposit', Object.entries(DEPOSIT_DEFS).map(([k,d])=>[k,d.label,Dp[k]]))}
    ${section('Brand',   'brand',   Object.entries(B).sort((a,b)=>a[0].localeCompare(b[0])).map(([v,c])=>[v,v,c]))}
    ${section('Seller',  'seller',  Object.entries(Se).sort().map(([v,c])=>[v,v,c]))}
  </div>`;
}

function bindCheckboxes(){
  document.querySelectorAll('input[type=checkbox][data-key]').forEach(cb => {
    cb.addEventListener('change', e => {
      const k = e.target.dataset.key;
      const v = e.target.dataset.val;
      if(!S.filters[k]) S.filters[k] = [];
      if(e.target.checked){
        if(!S.filters[k].includes(v)) S.filters[k].push(v);
      } else {
        S.filters[k] = S.filters[k].filter(x => x !== v);
        if(!S.filters[k].length) delete S.filters[k];
      }
      S.page = 1;
      pushURL();
      render();
    });
  });
}

/* ═══════════════════════════════════════════════
   CARD HTML
═══════════════════════════════════════════════ */
function renderStars(r){
  const full = Math.floor(r);
  const half = r % 1 >= 0.5 ? 1 : 0;
  return '★'.repeat(full) + (half ? '½' : '');
}

function cardHTML(p, idx){
  const src = p.image || makeSVG(p);
  const delay = Math.min(idx * 28, 280);
  return `
  <article class="card" role="listitem" style="animation-delay:${delay}ms"
    itemscope itemtype="https://schema.org/Product">
    <a class="card-a" href="/${p.slug}" aria-label="View ${p.name}">

      <div class="cimg">
        <img
          src="${src}"
          alt="${p.name} – lipa mdogo mdogo Nairobi Kenya"
          loading="lazy"
          width="400"
          height="500"
          onerror="this.onerror=null;this.src='${makeSVG(p)}'"
          itemprop="image"
        />
        ${p.status  ? `<span class="b-new">${p.status}</span>`   : ''}
        ${p.discount ? `<span class="b-disc">${p.discount}</span>` : ''}
        <button class="wish-btn" id="wish-${p.id}"
          onclick="toggleWish(event,${p.id})"
          aria-label="Save ${p.name} to wishlist">
          <svg viewBox="0 0 24 24">
            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06
              a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78
              1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
          </svg>
        </button>
      </div>

      <div class="cbody">
        <h3 class="cname" itemprop="name">${p.name}</h3>

        <div class="cspecs">
          <span class="cspec">${p.storage}</span>
          <span class="cspec">${p.display}</span>
          <span class="cspec">${p.battery}</span>
        </div>

        <div class="cprices"
          itemprop="offers" itemscope itemtype="https://schema.org/Offer">
          <meta itemprop="priceCurrency" content="KES"/>
          <meta itemprop="price"         content="${toNum(p.totalPrice)}"/>
          <meta itemprop="availability"  content="https://schema.org/InStock"/>
          <div class="cprice-was">Was ${p.totalPrice}</div>
          <div class="cprice-from">
            ${p.from} <small>/ min deposit</small>
          </div>
          <div class="cplans">
            <div class="cplan">
              <div class="cplan-lbl">Deposit</div>
              <div class="cplan-val">${p.deposit}</div>
            </div>
            <div class="cplan">
              <div class="cplan-lbl">Daily</div>
              <div class="cplan-val">${p.daily}</div>
            </div>
          </div>
        </div>

        <div class="cfoot">
          <span class="cseller">
            <svg viewBox="0 0 24 24">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/>
            </svg>
            ${p.seller}
          </span>
          ${p.reviews ? `
          <div class="cstars">
            <span class="cstars-s">${renderStars(p.reviews.r)}</span>
            <span class="cstars-n">(${p.reviews.n})</span>
          </div>` : ''}
        </div>
      </div>

    </a>
  </article>`;
}

/* ═══════════════════════════════════════════════
   ACTIVE FILTER CHIPS
═══════════════════════════════════════════════ */
const DEP_LABELS = {
  under20k:'Under KSh 20k', under30k:'Under KSh 30k',
  under40k:'Under KSh 40k', ksh2k_4k:'KSh 2k–4k deposit'
};
function renderTags(){
  const chips = [];
  Object.entries(S.filters).forEach(([key, vals]) => {
    (vals||[]).forEach(v => {
      const label = key === 'deposit' ? (DEP_LABELS[v]||v) : v;
      chips.push(`
        <span class="atag">
          ${key}: <strong>${label}</strong>
          <button class="atag-x"
            onclick="removeFilter('${key}','${v}')"
            aria-label="Remove ${label} filter">×</button>
        </span>`);
    });
  });
  document.getElementById('aTags').innerHTML = chips.join('');
}

/* ═══════════════════════════════════════════════
   PAGINATION
═══════════════════════════════════════════════ */
function renderPagination(total){
  const pages = Math.max(1, Math.ceil(total / S.pp));
  const el = document.getElementById('pagi');
  if(pages <= 1){ el.innerHTML = ''; return; }

  const p = S.page;
  let html = '';
  // prev
  html += `<a class="ppage${p===1?' dis':''}" href="#"
    onclick="goPage(event,${p-1})" aria-label="Previous page">‹</a>`;
  // pages
  for(let i=1; i<=pages; i++){
    if(i===1 || i===pages || Math.abs(i-p)<=1){
      html += `<a class="ppage${i===p?' on':''}" href="#"
        onclick="goPage(event,${i})" aria-label="Page ${i}"
        ${i===p?'aria-current="page"':''}>${i}</a>`;
    } else if(Math.abs(i-p)===2){
      html += `<span class="ppage dots">…</span>`;
    }
  }
  // next
  html += `<a class="ppage${p===pages?' dis':''}" href="#"
    onclick="goPage(event,${p+1})" aria-label="Next page">›</a>`;
  el.innerHTML = html;
}

/* ═══════════════════════════════════════════════
   MAIN RENDER
═══════════════════════════════════════════════ */
function render(){
  // 1. filter + sort
  const all   = applyFilters();
  const total = all.length;
  const pages = Math.max(1, Math.ceil(total / S.pp));
  if(S.page > pages) S.page = pages;
  const slice = all.slice((S.page-1)*S.pp, S.page*S.pp);

  // 2. result count
  document.getElementById('tbCount').textContent =
    `${total} product${total!==1?'s':''}`;

  // 3. grid
  const grid = document.getElementById('pgrid');
  grid.className = 'pgrid' + (S.view==='list' ? ' lv' : '');
  grid.innerHTML = slice.length
    ? slice.map((p,i) => cardHTML(p,i)).join('')
    : `<div class="empty">
        <div class="empty-icon">
          <svg viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        </div>
        <h3>No phones found</h3>
        <p>Try removing some filters to see more results.</p>
        <button class="empty-btn" onclick="clearAll()">Clear All Filters</button>
       </div>`;

  // 4. pagination
  renderPagination(total);

  // 5. active tags
  renderTags();

  // 6. filter badge
  const fc = Object.values(S.filters).flat().length;
  const badge = document.getElementById('fcBadge');
  badge.textContent = fc;
  badge.classList.toggle('show', fc > 0);

  // 7. sidebars (both desktop + drawer share same HTML)
  const sbHtml = makeSidebarHTML();
  document.getElementById('deskSb').innerHTML = sbHtml;
  document.getElementById('drwBody').innerHTML = sbHtml;
  bindCheckboxes();

  // 8. sync toolbar controls
  document.getElementById('sortSel').value = S.sort;
  document.getElementById('vGrid').className = 'vw-btn' + (S.view==='grid'?' on':'');
  document.getElementById('vGrid').setAttribute('aria-pressed', S.view==='grid');
  document.getElementById('vList').className = 'vw-btn' + (S.view==='list'?' on':'');
  document.getElementById('vList').setAttribute('aria-pressed', S.view==='list');

  // 9. sync pp buttons
  document.querySelectorAll('.pp-btn').forEach(b => {
    b.classList.toggle('on', parseInt(b.dataset.pp) === S.pp);
  });

  // 10. re-apply wishlist state
  Object.keys(wishSet).forEach(id => {
    const btn = document.getElementById(`wish-${id}`);
    if(btn) btn.classList.add('wished');
  });
}

/* ═══════════════════════════════════════════════
   WISHLIST (in-memory)
═══════════════════════════════════════════════ */
const wishSet = {};
function toggleWish(e, id){
  e.preventDefault();
  e.stopPropagation();
  const btn = document.getElementById(`wish-${id}`);
  if(!btn) return;
  if(wishSet[id]){
    delete wishSet[id];
    btn.classList.remove('wished');
  } else {
    wishSet[id] = true;
    btn.classList.add('wished');
    const svg = btn.querySelector('svg path');
    if(svg){ svg.style.fill='#D32F2F'; svg.style.stroke='#D32F2F'; }
  }
}

/* ═══════════════════════════════════════════════
   ACTIONS
═══════════════════════════════════════════════ */
function goPage(e, n){
  e.preventDefault();
  const tot = Math.ceil(applyFilters().length / S.pp);
  if(n < 1 || n > tot) return;
  S.page = n;
  pushURL();
  render();
  window.scrollTo({ top: 0, behavior:'smooth' });
}

function removeFilter(key, val){
  S.filters[key] = (S.filters[key]||[]).filter(v => v !== val);
  if(!S.filters[key].length) delete S.filters[key];
  S.page = 1;
  pushURL();
  render();
}

function clearAll(){
  S.filters = {};
  S.page = 1;
  pushURL();
  render();
}

function setView(v){
  S.view = v;
  pushURL();
  render();
}

function setPP(btn, n){
  S.pp = n;
  S.page = 1;
  pushURL();
  render();
}

function toggleSec(hd){
  hd.classList.toggle('closed');
  hd.nextElementSibling.classList.toggle('hidden');
}

function openSb(){
  document.getElementById('drwOvl').classList.add('on');
  document.getElementById('drw').classList.add('on');
  document.body.style.overflow = 'hidden';
  document.getElementById('mobSbBtn').setAttribute('aria-expanded','true');
}
function closeSb(){
  document.getElementById('drwOvl').classList.remove('on');
  document.getElementById('drw').classList.remove('on');
  document.body.style.overflow = '';
  document.getElementById('mobSbBtn').setAttribute('aria-expanded','false');
}

/* ═══════════════════════════════════════════════
   INIT
═══════════════════════════════════════════════ */
document.addEventListener('DOMContentLoaded', () => {
  readURL();

  document.getElementById('sortSel').addEventListener('change', e => {
    S.sort = e.target.value;
    S.page = 1;
    pushURL();
    render();
  });

  window.addEventListener('popstate', () => {
    readURL();
    render();
  });

  render();
});
</script>
</body>
</html>