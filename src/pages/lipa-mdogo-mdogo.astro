    <a href="/${p.slug}" aria-label="${p.name}">
      <div class="pimg">
        <img src="${img}" alt="${p.name} lipa mdogo mdogo Kenya" loading="lazy" width="200" height="200" onerror="this.src='${phoneSVG(p)}'" itemprop="image"/>
        ${p.status?`<span class="badge-new">${p.status}</span>`:''}
        ${p.discount?`<span class="badge-disc">${p.discount}</span>`:''}
        <button class="wishlist-btn" onclick="toggleWish(event,${p.id})" aria-label="Wishlist ${p.name}">
          <svg width="13" height="13" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </button>
      </div>
      <div class="pbody">
        <h3 class="pname" itemprop="name">${p.name}</h3>
        <div class="pspecs">
          <span class="pspec">${p.storage}</span>
          <span class="pspec">${p.phonedisplay}</span>
          <span class="pspec">${p.battery}</span>
        </div>
        <div class="pprices" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
          <meta itemprop="priceCurrency" content="KES"/>
          <meta itemprop="price" content="${p.totalPrice.replace(/[^\d]/g,'')}"/>
          <div class="pprice-was">Was ${p.totalPrice}</div>
          <div class="pprice-main">${p.from}<span style="font-size:10px;font-weight:400;color:var(--text-3)"> / deposit</span></div>
          <div class="pplan-row">
            <div class="pplan"><div class="pplan-lbl">Deposit</div><div class="pplan-val">${p.deposit}</div></div>
            <div class="pplan"><div class="pplan-lbl">Daily</div><div class="pplan-val">${p.daily}</div></div>
          </div>
        </div>
        <div class="pseller">
          <span class="pseller-n">
            <svg width="10" height="10" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/></svg>
            ${p.seller}
          </span>
          ${p.reviews?`<div class="prating"><span class="pstars">${stars(p.reviews.averageRating)}</span><span class="pratcnt">(${p.reviews.reviewCount})</span></div>`:''}
        </div>
      </div>
    </a>
  </article>`;
}

// ── FULL RENDER ──
function render(){
  const all=filtered();
  const total=all.length;
  const pages=Math.max(1,Math.ceil(total/S.perPage));
  if(S.page>pages)S.page=pages;
  const slice=all.slice((S.page-1)*S.perPage,S.page*S.perPage);

  // result count
  document.getElementById('resultCt').textContent=`${total} product${total!==1?'s':''}`;

  // grid
  const grid=document.getElementById('pgrid');
  grid.className='pgrid'+(S.view==='list'?' list-view':'');
  grid.innerHTML=slice.length
    ?slice.map((p,i)=>cardHTML(p,i)).join('')
    :`<div class="empty"><svg width="48" height="48" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg><h3>No phones found</h3><p>Try removing some filters</p><button onclick="clearAll()">Clear Filters</button></div>`;

  // pagination
  const pagi=document.getElementById('pagi');
  if(pages<=1){pagi.innerHTML='';} else {
    let h='';
    const p=S.page;
    h+=`<a class="ppage${p===1?' dis':''}" href="#" onclick="pg(event,${p-1})">‹</a>`;
    for(let i=1;i<=pages;i++){
      if(i===1||i===pages||Math.abs(i-p)<=1)h+=`<a class="ppage${i===p?' on':''}" href="#" onclick="pg(event,${i})">${i}</a>`;
      else if(Math.abs(i-p)===2)h+=`<span style="padding:0 3px;color:var(--text-3)">…</span>`;
    }
    h+=`<a class="ppage${p===pages?' dis':''}" href="#" onclick="pg(event,${p+1})">›</a>`;
    pagi.innerHTML=h;
  }

  // active tags
  const depLabels={under20k:'Under 20k',under30k:'Under 30k',under40k:'Under 40k',ksh2k_4k:'Deposit 2k–4k'};
  const tags=[];
  Object.entries(S.filters).forEach(([k,vals])=>(vals||[]).forEach(v=>{
    const lbl=k==='deposit'?depLabels[v]||v:v;
    tags.push(`<span class="atag">${k}: ${lbl}<button onclick="rmFilter('${k}','${v}')" aria-label="Remove">×</button></span>`);
  }));
  document.getElementById('aTags').innerHTML=tags.join('');

  // filter badge
  const fc=Object.values(S.filters).flat().length;
  const fb=document.getElementById('fbadge');
  fb.textContent=fc;
  fb.style.display=fc?'flex':'none';

  // sidebars
  const sh=sidebarHTML();
  document.getElementById('desktopSidebar').innerHTML=sh;
  document.getElementById('drawerBody').innerHTML=sh;
  bindCBs();

  // sync sort
  document.getElementById('sortSel').value=S.sort;
  // sync view btns
  document.getElementById('vgrid').className='vbtn'+(S.view==='grid'?' on':'');
  document.getElementById('vlist').className='vbtn'+(S.view==='list'?' on':'');
}

// ── ACTIONS ──
function pg(e,n){
  e.preventDefault();
  const all=filtered();
  const pages=Math.ceil(all.length/S.perPage);
  if(n<1||n>pages)return;
  S.page=n;pushURL();render();
  window.scrollTo({top:0,behavior:'smooth'});
}
function rmFilter(k,v){
  S.filters[k]=S.filters[k].filter(x=>x!==v);
  if(!S.filters[k].length)delete S.filters[k];
  S.page=1;pushURL();render();
}
function clearAll(){
  S.filters={};S.search='';S.page=1;
  const si=document.getElementById('searchInput');
  if(si)si.value='';
  pushURL();render();
}
function setView(v){S.view=v;pushURL();render();}
function setPerPage(btn,n){
  document.querySelectorAll('.show-num').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  S.perPage=n;S.page=1;pushURL();render();
}
function toggleSec(h){h.classList.toggle('col');h.nextElementSibling.classList.toggle('hide');}
function openSidebar(){
  document.getElementById('overlay').classList.add('on');
  document.getElementById('drawer').classList.add('on');
  document.body.style.overflow='hidden';
}
function closeSidebar(){
  document.getElementById('overlay').classList.remove('on');
  document.getElementById('drawer').classList.remove('on');
  document.body.style.overflow='';
}
function doSearch(){
  S.search=document.getElementById('searchInput').value;
  S.page=1;pushURL();render();
}
function filterBrand(e,brand){
  e.preventDefault();
  document.querySelectorAll('.nav-link').forEach(l=>l.classList.remove('active'));
  e.target.classList.add('active');
  S.filters.brand=[brand];S.page=1;pushURL();render();
}
function toggleWish(e,id){
  e.preventDefault();e.stopPropagation();
  const btn=e.currentTarget;
  btn.style.color='#E02020';
  btn.querySelector('svg').setAttribute('fill','#E02020');
}

// ── INIT ──
document.addEventListener('DOMContentLoaded',()=>{
  readURL();
  document.getElementById('sortSel').addEventListener('change',e=>{S.sort=e.target.value;S.page=1;pushURL();render();});
  const si=document.getElementById('searchInput');
  si.value=S.search;
  let t;
  si.addEventListener('input',e=>{clearTimeout(t);t=setTimeout(()=>{S.search=e.target.value;S.page=1;pushURL();render();},320);});
  si.addEventListener('keydown',e=>{if(e.key==='Enter')doSearch();});
  window.addEventListener('popstate',()=>{readURL();si.value=S.search;render();});
  render();
});
</script>
</body>
</html>