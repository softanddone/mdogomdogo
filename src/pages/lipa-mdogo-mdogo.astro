            <span class="filter-option-label">KSh 10K+</span>
          </div>
          <span class="filter-option-count" id="cnt-above10k">–</span>
        </label>
      </div>
    </div>

  </div>
  <div class="drawer-footer">
    <button class="btn-clear" id="drawer-clear-btn">Clear All</button>
    <button class="btn-apply" id="drawer-apply-btn">Apply Filters</button>
  </div>
</div>

<script>
  // ─── DEPOSIT FILTER RANGES ───────────────────────────────────────────────
  const DEPOSIT_RANGES = {
    'all':      [0, Infinity],
    'under3k':  [0, 2999],
    '3k-5k':    [3000, 5000],
    '5k-8k':    [5001, 8000],
    '8k-10k':   [8001, 10000],
    'above10k': [10001, Infinity],
  };

  const DRAWER_DEPOSIT_RANGES = {
    'under2k':  [0, 1999],
    '2k-4k':    [2000, 4000],
    'under3k':  [0, 2999],
    '3k-5k':    [3000, 5000],
    '5k-8k':    [5001, 8000],
    '8k-10k':   [8001, 10000],
    'above10k': [10001, Infinity],
  };

  function getPageSize() {
    if (window.innerWidth <= 560) return 8;
    if (window.innerWidth <= 800) return 9;
    if (window.innerWidth <= 1100) return 8;
    return 10;
  }

  const grid             = document.getElementById('all-phones-grid');
  const noResultsMsg     = document.getElementById('no-results-msg');
  const paginationWrap   = document.getElementById('pagination-wrap');
  const allPhonesSection = document.getElementById('all-phones-section');

  let currentFilter   = 'all';
  let currentPage     = 1;
  let drawerDepositFilters = new Set();
  let drawerStorageFilters = new Set();
  let useDrawerFilters     = false;

  let allCards = Array.from(grid.querySelectorAll('.card[data-deposit]'));

  // ─── CART COUNT ─────────────────────────────────────────────────────────
  let cartCount = 0;
  function updateCartBadge() {
    const badge = document.getElementById('cart-badge');
    if (badge) { badge.textContent = cartCount; badge.style.display = cartCount > 0 ? '' : 'none'; }
  }
  updateCartBadge();

  // ─── CORE: filter + paginate ─────────────────────────────────────────────
  function applyFilterAndPage(filterKey, page, scrollToSection) {
    currentFilter   = filterKey;
    currentPage     = page;
    useDrawerFilters = false;

    const [min, max] = DEPOSIT_RANGES[filterKey] ?? [0, Infinity];
    const matching    = allCards.filter(c => { const d = parseInt(c.dataset.deposit, 10) || 0; return d >= min && d <= max; });
    const nonMatching = allCards.filter(c => { const d = parseInt(c.dataset.deposit, 10) || 0; return !(d >= min && d <= max); });

    nonMatching.forEach(c => c.classList.add('hidden'));
    paginateCards(matching, page, scrollToSection);
  }

  function applyDrawerFilterSet(page, scrollToSection) {
    useDrawerFilters = true;
    currentPage      = page;

    const matching = allCards.filter(card => {
      const deposit  = parseInt(card.dataset.deposit, 10) || 0;
      const storage  = (card.dataset.storage ?? '').toUpperCase();

      // Deposit check (OR across selected deposit filters)
      let depositOk = drawerDepositFilters.size === 0;
      if (!depositOk) {
        for (const key of drawerDepositFilters) {
          const [mn, mx] = DRAWER_DEPOSIT_RANGES[key] ?? [0, Infinity];
          if (deposit >= mn && deposit <= mx) { depositOk = true; break; }
        }
      }

      // Storage check (OR across selected storage filters)
      let storageOk = drawerStorageFilters.size === 0;
      if (!storageOk) {
        for (const s of drawerStorageFilters) {
          if (storage.includes(s.toUpperCase())) { storageOk = true; break; }
        }
      }

      return depositOk && storageOk;
    });

    allCards.forEach(c => c.classList.add('hidden'));
    paginateCards(matching, page, scrollToSection);
  }

  function paginateCards(matching, page, scrollToSection) {
    const pageSize   = getPageSize();
    const totalPages = Math.max(1, Math.ceil(matching.length / pageSize));
    if (page > totalPages) page = totalPages;
    currentPage = page;

    const startIdx = (page - 1) * pageSize;
    const endIdx   = startIdx + pageSize;

    matching.forEach((c, i) => {
      if (i >= startIdx && i < endIdx) {
        c.classList.remove('hidden');
        c.style.animationDelay = ((i - startIdx) * 0.05) + 's';
        c.style.animation = 'none';
        void c.offsetWidth;
        c.style.animation = '';
      } else {
        c.classList.add('hidden');
      }
    });

    noResultsMsg.classList.toggle('visible', matching.length === 0);
    renderPagination(totalPages, matching.length);
    if (scrollToSection) allPhonesSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // ─── PAGINATION RENDER ────────────────────────────────────────────────────
  function renderPagination(totalPages, totalItems) {
    paginationWrap.innerHTML = '';
    if (totalPages <= 1) return;

    const pageSize  = getPageSize();
    const startItem = (currentPage - 1) * pageSize + 1;
    const endItem   = Math.min(currentPage * pageSize, totalItems);

    const prevBtn = document.createElement('button');
    prevBtn.className = 'page-btn prev-next';
    prevBtn.textContent = '← Prev';
    prevBtn.disabled = currentPage === 1;
    prevBtn.addEventListener('click', () => { if (currentPage > 1) goToPage(currentPage - 1); });
    paginationWrap.appendChild(prevBtn);

    buildPageRange(currentPage, totalPages).forEach(item => {
      if (item === '…') {
        const el = document.createElement('span');
        el.className = 'page-ellipsis';
        el.textContent = '…';
        paginationWrap.appendChild(el);
      } else {
        const btn = document.createElement('button');
        btn.className = 'page-btn' + (item === currentPage ? ' active' : '');
        btn.textContent = item;
        btn.addEventListener('click', () => goToPage(item));
        paginationWrap.appendChild(btn);
      }
    });

    const nextBtn = document.createElement('button');
    nextBtn.className = 'page-btn prev-next';
    nextBtn.textContent = 'Next →';
    nextBtn.disabled = currentPage === totalPages;
    nextBtn.addEventListener('click', () => { if (currentPage < totalPages) goToPage(currentPage + 1); });
    paginationWrap.appendChild(nextBtn);

    const info = document.createElement('span');
    info.className = 'page-info';
    info.textContent = `Showing ${startItem}–${endItem} of ${totalItems}`;
    paginationWrap.appendChild(info);
  }

  function goToPage(page) {
    if (useDrawerFilters) applyDrawerFilterSet(page, true);
    else applyFilterAndPage(currentFilter, page, true);
  }

  function buildPageRange(current, total) {
    if (total <= 7) return Array.from({length: total}, (_, i) => i + 1);
    const pages = [1];
    if (current > 3) pages.push('…');
    for (let p = Math.max(2, current - 1); p <= Math.min(total - 1, current + 1); p++) pages.push(p);
    if (current < total - 2) pages.push('…');
    pages.push(total);
    return pages;
  }

  // ─── FILTER CHIP CLICK ────────────────────────────────────────────────────
  document.querySelectorAll('.filter-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
      applyFilterAndPage(chip.dataset.filter ?? 'all', 1, true);
    });
  });

  // ─── SORT SELECT ─────────────────────────────────────────────────────────
  document.querySelector('.sort-select').addEventListener('change', function () {
    allCards.sort((a, b) => {
      const dA = parseInt(a.dataset.deposit, 10) || 0;
      const dB = parseInt(b.dataset.deposit, 10) || 0;
      const rA = parseFloat(a.querySelector('.rating-count')?.textContent.replace(/[()]/g, '') || '0');
      const rB = parseFloat(b.querySelector('.rating-count')?.textContent.replace(/[()]/g, '') || '0');
      if (this.value === 'Deposit: Low to High') return dA - dB;
      if (this.value === 'Deposit: High to Low') return dB - dA;
      if (this.value === 'Best Rated')           return rB - rA;
      return 0;
    });
    allCards.forEach(card => grid.appendChild(card));
    grid.appendChild(noResultsMsg);
    applyFilterAndPage(currentFilter, 1, true);
  });

  // ─── WISHLIST ────────────────────────────────────────────────────────────
  document.querySelectorAll('.wishlist-btn').forEach(btn => {
    btn.addEventListener('click', e => {
      e.preventDefault(); e.stopPropagation();
      btn.textContent = btn.textContent === '🤍' ? '❤️' : '🤍';
    });
  });

  // ─── CART ────────────────────────────────────────────────────────────────
  document.querySelectorAll('.btn-cart').forEach(btn => {
    btn.addEventListener('click', e => {
      e.preventDefault(); e.stopPropagation();
      const original = btn.textContent;
      btn.textContent = '✓ Added!';
      btn.style.background = '#00b96b';
      cartCount++;
      updateCartBadge();
      setTimeout(() => { btn.textContent = original; btn.style.background = ''; }, 1400);
    });
  });

  document.querySelectorAll('.btn-buy').forEach(btn => btn.addEventListener('click', e => e.stopPropagation()));

  // ─── BOTTOM TAB HELPERS ───────────────────────────────────────────────────
  document.getElementById('tab-home').addEventListener('click', () => {
    window.scrollTo({ top: 0, behavior: 'smooth' });
  });
  document.getElementById('tab-shop').addEventListener('click', () => {
    allPhonesSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
  });
  document.getElementById('tab-filters').addEventListener('click', openFilterDrawer);

  // ─── FILTER DRAWER ────────────────────────────────────────────────────────
  const drawerEl  = document.getElementById('filter-drawer');
  const overlayEl = document.getElementById('filter-overlay');

  function openFilterDrawer() {
    drawerEl.classList.add('open');
    overlayEl.classList.add('open');
    document.body.style.overflow = 'hidden';
    buildStorageOptions();
    updateDepositCounts();
  }
  function closeFilterDrawer() {
    drawerEl.classList.remove('open');
    overlayEl.classList.remove('open');
    document.body.style.overflow = '';
  }
  function clearDrawerFilters() {
    drawerDepositFilters.clear();
    drawerStorageFilters.clear();
    document.querySelectorAll('#drawer-body input[type="checkbox"]').forEach(cb => cb.checked = false);
  }
  function applyDrawerFilters() {
    drawerDepositFilters.clear();
    document.querySelectorAll('#deposit-options input:checked').forEach(cb => drawerDepositFilters.add(cb.value));
    drawerStorageFilters.clear();
    document.querySelectorAll('#storage-options input:checked').forEach(cb => drawerStorageFilters.add(cb.value));

    closeFilterDrawer();
    if (drawerDepositFilters.size > 0 || drawerStorageFilters.size > 0) {
      document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
      applyDrawerFilterSet(1, true);
    } else {
      document.querySelector('.filter-chip[data-filter="all"]').classList.add('active');
      applyFilterAndPage('all', 1, true);
    }
  }

  document.getElementById('drawer-close-btn').addEventListener('click', closeFilterDrawer);
  document.getElementById('drawer-clear-btn').addEventListener('click', clearDrawerFilters);
  document.getElementById('drawer-apply-btn').addEventListener('click', applyDrawerFilters);
  document.getElementById('filter-overlay').addEventListener('click', closeFilterDrawer);

  // Build storage checkboxes dynamically from product data
  function buildStorageOptions() {
    const storageContainer = document.getElementById('storage-options');
    if (storageContainer.dataset.built) return;
    storageContainer.dataset.built = '1';

    const storageCounts = {};
    allCards.forEach(card => {
      const s = card.dataset.storage;
      if (s) storageCounts[s] = (storageCounts[s] || 0) + 1;
    });

    const order = ['64GB','128GB','256GB','512GB','1TB'];
    const keys  = [...new Set([...order.filter(k => storageCounts[k]), ...Object.keys(storageCounts).filter(k => !order.includes(k))])];

    if (keys.length === 0) {
      storageContainer.innerHTML = '<p style="color:var(--text-light);font-size:13px;padding:8px 0">No storage data available</p>';
      return;
    }
    storageContainer.innerHTML = keys.map(k => `
      <label class="filter-option">
        <div class="filter-option-left">
          <input type="checkbox" name="storage" value="${k}" ${drawerStorageFilters.has(k) ? 'checked' : ''} />
          <span class="filter-option-label">${k}</span>
        </div>
        <span class="filter-option-count">${storageCounts[k]}</span>
      </label>`).join('');
  }

  function updateDepositCounts() {
    const counts = { under2k:0, '2k-4k':0, under3k:0, '3k-5k':0, '5k-8k':0, '8k-10k':0, above10k:0 };
    allCards.forEach(card => {
      const d = parseInt(card.dataset.deposit, 10) || 0;
      if (d < 2000)              counts.under2k++;
      if (d >= 2000 && d <= 4000) counts['2k-4k']++;
      if (d < 3000)              counts.under3k++;
      if (d >= 3000 && d <= 5000) counts['3k-5k']++;
      if (d >= 5001 && d <= 8000) counts['5k-8k']++;
      if (d >= 8001 && d <= 10000) counts['8k-10k']++;
      if (d > 10000)             counts.above10k++;
    });
    const map = { under2k:'cnt-under2k', '2k-4k':'cnt-2k4k', under3k:'cnt-under3k', '3k-5k':'cnt-3k5k', '5k-8k':'cnt-5k8k', '8k-10k':'cnt-8k10k', above10k:'cnt-above10k' };
    Object.entries(map).forEach(([k, id]) => { const el = document.getElementById(id); if (el) el.textContent = counts[k]; });
    // Restore checked state from current filters
    document.querySelectorAll('#deposit-options input').forEach(cb => { cb.checked = drawerDepositFilters.has(cb.value); });
  }

  // ─── RESIZE ──────────────────────────────────────────────────────────────
  let resizeTimer;
  window.addEventListener('resize', () => {
    clearTimeout(resizeTimer);
    resizeTimer = setTimeout(() => {
      if (useDrawerFilters) applyDrawerFilterSet(1, false);
      else applyFilterAndPage(currentFilter, 1, false);
    }, 250);
  });

  // ─── INIT ────────────────────────────────────────────────────────────────
  applyFilterAndPage('all', 1, false);

  // ─── COOKIE CONSENT LOGIC ─────────────────────────────────────────────────
  const COOKIE_KEY = 'mdogo_cookie_consent';

  function setCookie(name, value, days) {
    const expires = new Date(Date.now() + days * 864e5).toUTCString();
    document.cookie = `${name}=${encodeURIComponent(JSON.stringify(value))}; expires=${expires}; path=/; SameSite=Lax`;
  }
  function getCookie(name) {
    const match = document.cookie.match(new RegExp('(?:^|; )' + name + '=([^;]*)'));
    try { return match ? JSON.parse(decodeURIComponent(match[1])) : null; } catch { return null; }
  }

  function fireAnalytics() {
    // Update GA4 consent
    if (typeof gtag === 'function') {
      gtag('consent', 'update', { analytics_storage: 'granted' });
      gtag('event', 'page_view');
    }
  }
  function fireMarketing() {
    // Fire Meta Pixel
    if (typeof fbq === 'undefined' && window._fbPixelId) {
      fbq('init', window._fbPixelId);
      fbq('track', 'PageView');
    }
    // Fire TikTok Pixel
    if (typeof ttq !== 'undefined' && window._ttPixelId) {
      ttq.load(window._ttPixelId);
      ttq.page();
    }
    // Update GA4 ad consent
    if (typeof gtag === 'function') {
      gtag('consent', 'update', { ad_storage: 'granted', ad_user_data: 'granted', ad_personalization: 'granted' });
    }
  }

  function applyConsent(prefs) {
    if (prefs.analytics) fireAnalytics();
    if (prefs.marketing) fireMarketing();
  }

  function grantAll() {
    const prefs = { analytics: true, marketing: true };
    setCookie(COOKIE_KEY, prefs, 365);
    applyConsent(prefs);
    hideBanner();
  }
  function rejectAll() {
    setCookie(COOKIE_KEY, { analytics: false, marketing: false }, 365);
    hideBanner();
  }
  function savePrefs() {
    const prefs = {
      analytics: document.getElementById('pref-analytics').checked,
      marketing: document.getElementById('pref-marketing').checked,
    };
    setCookie(COOKIE_KEY, prefs, 365);
    applyConsent(prefs);
    closeModal();
    hideBanner();
  }

  function hideBanner() {
    const b = document.getElementById('cookie-banner');
    b.classList.remove('visible');
    setTimeout(() => b.style.display = 'none', 400);
  }
  function openModal() {
    document.getElementById('cookie-modal-overlay').classList.add('open');
    // Pre-fill toggles from saved prefs
    const saved = getCookie(COOKIE_KEY);
    if (saved) {
      document.getElementById('pref-analytics').checked = !!saved.analytics;
      document.getElementById('pref-marketing').checked = !!saved.marketing;
    }
  }
  function closeModal() {
    document.getElementById('cookie-modal-overlay').classList.remove('open');
  }

  // Wire up buttons
  document.getElementById('cookie-accept').addEventListener('click', grantAll);
  document.getElementById('cookie-reject').addEventListener('click', rejectAll);
  document.getElementById('cookie-settings-btn').addEventListener('click', openModal);
  document.getElementById('cookie-save-prefs').addEventListener('click', savePrefs);
  document.getElementById('cookie-modal-overlay').addEventListener('click', e => {
    if (e.target === e.currentTarget) closeModal();
  });

  // Show banner only if no consent saved yet; otherwise re-apply saved prefs silently
  const savedPrefs = getCookie(COOKIE_KEY);
  if (savedPrefs) {
    applyConsent(savedPrefs);
  } else {
    setTimeout(() => document.getElementById('cookie-banner').classList.add('visible'), 800);
  }
</script>
</body>
</html>
