---

<!DOCTYPE html>
<html lang="en-KE">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta name="keywords" content="lipa mdogo mdogo phones, buy phone on credit nairobi, smartphones kenya installments, phone loan nairobi, mkopa phones, watu simu kenya, cheap phones nairobi" />
  <link rel="canonical" href={canonicalURL} />
  
  <!-- Open Graph -->
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:locale" content="en_KE" />
  <meta property="og:site_name" content="Mdogo Mdogo Deals" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />

  <!-- Geo -->
  <meta name="geo.region" content="KE-30" />
  <meta name="geo.placename" content="Nairobi" />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet" />

  <!-- Structured Data: ItemList -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Lipa Mdogo Mdogo Phones in Nairobi",
    "description": pageDescription,
    "url": canonicalURL,
    "numberOfItems": products.length,
    "itemListElement": products.map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "url": `https://mdogomdogodeals.co.ke/${p.slug}`,
      "name": p.name
    }))
  })} />

  <!-- Structured Data: WebPage -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebPage",
    "name": pageTitle,
    "description": pageDescription,
    "url": canonicalURL,
    "inLanguage": "en-KE",
    "breadcrumb": {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://mdogomdogodeals.co.ke" },
        { "@type": "ListItem", "position": 2, "name": "Phones", "item": canonicalURL }
      ]
    }
  })} />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --green: #00c853;
      --green-dark: #009624;
      --green-light: #e8f5e9;
      --accent: #ff6f00;
      --accent-light: #fff3e0;
      --text: #1a1a2e;
      --text-muted: #6b7280;
      --border: #e5e7eb;
      --bg: #f8f9fa;
      --white: #ffffff;
      --card-shadow: 0 2px 12px rgba(0,0,0,0.08);
      --card-shadow-hover: 0 8px 30px rgba(0,0,0,0.14);
      --radius: 14px;
      --sidebar-w: 230px;
      --font-display: 'Syne', sans-serif;
      --font-body: 'DM Sans', sans-serif;
    }

    html { scroll-behavior: smooth; }
    body {
      font-family: var(--font-body);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
    }

    /* ===== LAYOUT ===== */
    .page-wrapper {
      display: flex;
      gap: 0;
      max-width: 1400px;
      margin: 0 auto;
      padding: 0 16px 100px;
      align-items: flex-start;
    }

    /* ===== SIDEBAR DESKTOP ===== */
    .sidebar {
      width: var(--sidebar-w);
      flex-shrink: 0;
      position: sticky;
      top: 16px;
      background: var(--white);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      padding: 20px 16px;
      display: none;
    }
    @media (min-width: 768px) {
      .sidebar { display: block; }
    }

    .sidebar-title {
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--text-muted);
      margin-bottom: 10px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--border);
    }

    .filter-section { margin-bottom: 20px; }
    .filter-section-title {
      font-family: var(--font-display);
      font-size: 12px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.1em;
      color: var(--green-dark);
      margin-bottom: 8px;
    }

    .filter-option {
      display: flex;
      align-items: center;
      gap: 8px;
      padding: 5px 6px;
      border-radius: 8px;
      cursor: pointer;
      transition: background 0.15s;
    }
    .filter-option:hover { background: var(--green-light); }
    .filter-option input[type="checkbox"] {
      accent-color: var(--green);
      width: 15px; height: 15px;
      cursor: pointer;
    }
    .filter-option label {
      font-size: 13px;
      color: var(--text);
      cursor: pointer;
      flex: 1;
      display: flex;
      justify-content: space-between;
    }
    .filter-count {
      font-size: 11px;
      color: var(--text-muted);
      background: var(--bg);
      padding: 1px 6px;
      border-radius: 20px;
    }

    /* ===== MAIN CONTENT ===== */
    .main-content { flex: 1; min-width: 0; padding: 0 0 0 0; }
    @media (min-width: 768px) { .main-content { padding-left: 20px; } }

    /* ===== TOP BAR ===== */
    .top-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 18px;
      gap: 10px;
      flex-wrap: wrap;
    }

    .page-heading {
      font-family: var(--font-display);
      font-size: clamp(20px, 4vw, 28px);
      font-weight: 800;
      color: var(--text);
    }
    .page-heading span { color: var(--green); }

    .results-count {
      font-size: 13px;
      color: var(--text-muted);
      margin-left: 4px;
    }

    .sort-select {
      font-family: var(--font-body);
      font-size: 13px;
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 7px 12px;
      background: var(--white);
      color: var(--text);
      cursor: pointer;
      outline: none;
    }

    /* ===== ACTIVE FILTERS ===== */
    .active-filters {
      display: flex;
      gap: 6px;
      flex-wrap: wrap;
      margin-bottom: 14px;
    }
    .filter-tag {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      background: var(--green-light);
      color: var(--green-dark);
      font-size: 12px;
      font-weight: 600;
      padding: 4px 10px;
      border-radius: 20px;
      cursor: pointer;
      border: 1px solid #a5d6a7;
      transition: background 0.15s;
    }
    .filter-tag:hover { background: #c8e6c9; }
    .filter-tag .remove { font-size: 14px; line-height: 1; }
    .clear-all {
      font-size: 12px;
      color: var(--accent);
      font-weight: 600;
      cursor: pointer;
      padding: 4px 10px;
      border-radius: 20px;
      border: 1px solid #ffcc80;
      background: var(--accent-light);
    }

    /* ===== PRODUCT GRID ===== */
    .products-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }
    @media (min-width: 640px) {
      .products-grid { grid-template-columns: repeat(3, 1fr); gap: 14px; }
    }
    @media (min-width: 1024px) {
      .products-grid { grid-template-columns: repeat(4, 1fr); gap: 16px; }
    }

    /* ===== PRODUCT CARD ===== */
    .product-card {
      background: var(--white);
      border-radius: var(--radius);
      overflow: hidden;
      border: 1px solid var(--border);
      box-shadow: var(--card-shadow);
      transition: transform 0.22s ease, box-shadow 0.22s ease;
      position: relative;
      display: flex;
      flex-direction: column;
    }
    .product-card:hover {
      transform: translateY(-4px);
      box-shadow: var(--card-shadow-hover);
    }
    .product-card a { text-decoration: none; color: inherit; display: flex; flex-direction: column; flex: 1; }

    .badge-new {
      position: absolute;
      top: 8px; left: 8px;
      background: var(--green);
      color: white;
      font-size: 10px;
      font-weight: 700;
      font-family: var(--font-display);
      padding: 2px 8px;
      border-radius: 20px;
      letter-spacing: 0.05em;
      z-index: 2;
    }
    .badge-discount {
      position: absolute;
      top: 8px; right: 8px;
      background: var(--accent);
      color: white;
      font-size: 10px;
      font-weight: 700;
      font-family: var(--font-display);
      padding: 2px 8px;
      border-radius: 20px;
      z-index: 2;
    }

    .card-image-wrap {
      position: relative;
      background: linear-gradient(135deg, #f0f4f8 0%, #e8f5e9 100%);
      aspect-ratio: 4/5;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 10px;
    }
    .card-image-wrap img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      transition: transform 0.3s ease;
    }
    .product-card:hover .card-image-wrap img {
      transform: scale(1.05);
    }

    .card-body {
      padding: 10px 11px 12px;
      display: flex;
      flex-direction: column;
      gap: 4px;
      flex: 1;
    }

    .card-name {
      font-family: var(--font-display);
      font-size: clamp(12px, 2.5vw, 14px);
      font-weight: 700;
      color: var(--text);
      line-height: 1.3;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .card-storage {
      font-size: 11px;
      color: var(--text-muted);
      background: var(--bg);
      display: inline-block;
      padding: 2px 7px;
      border-radius: 5px;
      font-weight: 500;
      width: fit-content;
    }

    .card-pricing {
      margin-top: 4px;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .price-from {
      font-size: 10px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }

    .price-deposit {
      font-family: var(--font-display);
      font-size: clamp(15px, 3vw, 18px);
      font-weight: 800;
      color: var(--green-dark);
      line-height: 1;
    }

    .price-daily {
      font-size: 11px;
      color: var(--accent);
      font-weight: 600;
    }

    .price-total {
      font-size: 11px;
      color: var(--text-muted);
      text-decoration: line-through;
    }

    .card-cta {
      margin-top: 8px;
      background: var(--green);
      color: white;
      border: none;
      border-radius: 8px;
      padding: 8px 12px;
      font-family: var(--font-display);
      font-size: 12px;
      font-weight: 700;
      cursor: pointer;
      width: 100%;
      letter-spacing: 0.03em;
      transition: background 0.15s;
      text-align: center;
      display: block;
      text-decoration: none;
    }
    .card-cta:hover { background: var(--green-dark); }

    .stars {
      display: flex;
      align-items: center;
      gap: 3px;
      font-size: 11px;
    }
    .stars-icons { color: #f59e0b; letter-spacing: -1px; }
    .stars-count { color: var(--text-muted); }

    /* ===== EMPTY STATE ===== */
    .empty-state {
      grid-column: 1/-1;
      text-align: center;
      padding: 60px 20px;
    }
    .empty-state h3 {
      font-family: var(--font-display);
      font-size: 20px;
      font-weight: 700;
      color: var(--text-muted);
      margin-bottom: 8px;
    }
    .empty-state p { font-size: 14px; color: var(--text-muted); }

    /* ===== PAGINATION ===== */
    .pagination {
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 6px;
      margin-top: 32px;
      flex-wrap: wrap;
    }
    .page-btn {
      width: 38px; height: 38px;
      display: flex; align-items: center; justify-content: center;
      border-radius: 8px;
      border: 1px solid var(--border);
      background: var(--white);
      color: var(--text);
      font-size: 14px;
      font-family: var(--font-display);
      font-weight: 600;
      cursor: pointer;
      transition: all 0.15s;
    }
    .page-btn:hover:not(:disabled) { border-color: var(--green); color: var(--green); }
    .page-btn.active { background: var(--green); color: white; border-color: var(--green); }
    .page-btn:disabled { opacity: 0.4; cursor: not-allowed; }
    .page-info { font-size: 13px; color: var(--text-muted); padding: 0 8px; }

    /* ===== MOBILE FILTER BOTTOM SHEET ===== */
    .mobile-filter-fab {
      display: flex;
      position: fixed;
      bottom: 0; left: 0; right: 0;
      z-index: 100;
      background: var(--white);
      border-top: 1px solid var(--border);
      padding: 10px 20px;
      gap: 10px;
    }
    @media (min-width: 768px) { .mobile-filter-fab { display: none; } }

    .fab-btn {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      background: var(--text);
      color: var(--white);
      border: none;
      border-radius: 10px;
      padding: 12px;
      font-family: var(--font-display);
      font-size: 14px;
      font-weight: 700;
      cursor: pointer;
      letter-spacing: 0.03em;
    }
    .fab-btn.secondary {
      background: var(--white);
      color: var(--text);
      border: 1px solid var(--border);
    }
    .fab-count {
      background: var(--green);
      color: white;
      font-size: 11px;
      font-weight: 800;
      width: 18px; height: 18px;
      border-radius: 50%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
    }

    /* ===== MOBILE BOTTOM SHEET OVERLAY ===== */
    .sheet-overlay {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: 200;
      backdrop-filter: blur(2px);
    }
    .sheet-overlay.open { display: block; }

    .filter-sheet {
      position: fixed;
      bottom: 0; left: 0; right: 0;
      background: var(--white);
      border-radius: 20px 20px 0 0;
      z-index: 201;
      padding: 0 20px 30px;
      max-height: 80vh;
      overflow-y: auto;
      transform: translateY(100%);
      transition: transform 0.3s cubic-bezier(0.32, 0.72, 0, 1);
    }
    .filter-sheet.open { transform: translateY(0); }

    .sheet-handle {
      width: 40px; height: 4px;
      background: var(--border);
      border-radius: 2px;
      margin: 14px auto 18px;
    }
    .sheet-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 20px;
    }
    .sheet-heading {
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 800;
    }
    .sheet-close {
      background: var(--bg);
      border: none;
      border-radius: 8px;
      padding: 6px 12px;
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 600;
      cursor: pointer;
      color: var(--text-muted);
    }
    .sheet-apply {
      width: 100%;
      margin-top: 20px;
      background: var(--green);
      color: white;
      border: none;
      border-radius: 12px;
      padding: 14px;
      font-family: var(--font-display);
      font-size: 15px;
      font-weight: 800;
      cursor: pointer;
      letter-spacing: 0.02em;
    }

    /* SEO text section */
    .seo-intro {
      padding: 20px 0 4px;
    }
    .seo-intro h1 {
      font-family: var(--font-display);
      font-size: clamp(18px, 3.5vw, 26px);
      font-weight: 800;
      margin-bottom: 8px;
      color: var(--text);
    }
    .seo-intro p {
      font-size: 14px;
      color: var(--text-muted);
      line-height: 1.6;
      max-width: 600px;
    }

    /* Breadcrumb */
    .breadcrumb {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: var(--text-muted);
      margin-bottom: 16px;
      flex-wrap: wrap;
    }
    .breadcrumb a { color: var(--text-muted); text-decoration: none; }
    .breadcrumb a:hover { color: var(--green); }
    .breadcrumb .sep { color: var(--border); }
    .breadcrumb .current { color: var(--text); font-weight: 600; }

    /* URL params indicator */
    .url-filter-bar {
      background: var(--green-light);
      border: 1px solid #a5d6a7;
      border-radius: 10px;
      padding: 10px 14px;
      margin-bottom: 14px;
      font-size: 13px;
      color: var(--green-dark);
      font-weight: 500;
      display: none;
    }
    .url-filter-bar.show { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
  </style>
</head>
<body>

<div style="padding: 20px 16px 0; max-width: 1400px; margin: 0 auto;">
  <!-- Breadcrumb -->
  <nav class="breadcrumb" aria-label="Breadcrumb">
    <a href="/">Home</a>
    <span class="sep">›</span>
    <span class="current">Lipa Mdogo Mdogo Phones</span>
  </nav>

  <!-- SEO H1 -->
  <div class="seo-intro">
    <h1>Buy Phones on Credit in Nairobi — Lipa Mdogo Mdogo</h1>
    <p>Shop the latest smartphones with flexible installment payments. Small deposit, daily or weekly payments. Oppo, Samsung, Tecno, Infinix & more. Delivered in Nairobi same day.</p>
  </div>
</div>

<!-- URL Filter Indicator -->
<div style="max-width: 1400px; margin: 0 auto; padding: 0 16px;">
  <div class="url-filter-bar" id="urlFilterBar">
    <svg width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
    <span id="urlFilterText"></span>
  </div>
</div>

<div class="page-wrapper">
  <!-- Desktop Sidebar -->
  <aside class="sidebar" aria-label="Filter products">
    <div class="sidebar-title">Filters</div>
    <div id="desktopFilters">
      <!-- Filters rendered by JS -->
    </div>
  </aside>

  <!-- Main Content -->
  <main class="main-content">
    <!-- Top Bar -->
    <div class="top-bar">
      <div>
        <span class="page-heading">Phones <span id="resultCount" class="results-count"></span></span>
      </div>
      <select class="sort-select" id="sortSelect" aria-label="Sort products">
        <option value="default">Sort by latest</option>
        <option value="rating">Sort by rating</option>
        <option value="deposit-low">Deposit: Low to High</option>
        <option value="deposit-high">Deposit: High to Low</option>
        <option value="price-low">Price: Low to High</option>
        <option value="price-high">Price: High to Low</option>
      </select>
    </div>

    <!-- Active Filters -->
    <div class="active-filters" id="activeFilters"></div>

    <!-- Product Grid -->
    <div class="products-grid" id="productsGrid" role="list" aria-label="Phone products"></div>

    <!-- Pagination -->
    <nav class="pagination" id="pagination" aria-label="Product pages"></nav>
  </main>
</div>

<!-- Mobile Bottom Bar -->
<div class="mobile-filter-fab">
  <button class="fab-btn" onclick="openFilterSheet()" aria-label="Open filters">
    <svg width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><polygon points="22 3 2 3 10 12.46 10 19 14 21 14 12.46 22 3"/></svg>
    Filters
    <span class="fab-count" id="filterCountBadge" style="display:none">0</span>
  </button>
  <button class="fab-btn secondary" onclick="clearAllFilters()" aria-label="Clear all filters">Clear</button>
</div>

<!-- Mobile Filter Sheet -->
<div class="sheet-overlay" id="sheetOverlay" onclick="closeFilterSheet()"></div>
<div class="filter-sheet" id="filterSheet" role="dialog" aria-modal="true" aria-label="Filter options">
  <div class="sheet-handle"></div>
  <div class="sheet-top">
    <span class="sheet-heading">Filter Phones</span>
    <button class="sheet-close" onclick="closeFilterSheet()">Close ✕</button>
  </div>
  <div id="mobileFilters"></div>
  <button class="sheet-apply" onclick="applyMobileFilters()">Show Results</button>
</div>

<!-- Inline product data for JS -->
<script define:vars={{ products, allStorages, depositRanges }}>
  // ========== STATE ==========
  const PER_PAGE = 20;
  let state = {
    storages: [],
    deposits: [],
    sort: 'default',
    page: 1,
  };

  // ========== INIT ==========
  function init() {
    readURLParams();
    renderFilters();
    renderProducts();
    syncURLFilterBar();
  }

  // ========== URL PARAMS ==========
  function readURLParams() {
    const params = new URLSearchParams(window.location.search);
    state.storages = params.getAll('storage');
    state.deposits = params.getAll('deposit');
    state.sort = params.get('sort') || 'default';
    state.page = parseInt(params.get('page') || '1', 10);
    document.getElementById('sortSelect').value = state.sort;
  }

  function pushURL() {
    const params = new URLSearchParams();
    state.storages.forEach(s => params.append('storage', s));
    state.deposits.forEach(d => params.append('deposit', d));
    if (state.sort !== 'default') params.set('sort', state.sort);
    if (state.page > 1) params.set('page', state.page);
    const newURL = params.toString() ? `${window.location.pathname}?${params}` : window.location.pathname;
    history.pushState({}, '', newURL);
    syncURLFilterBar();
  }

  function syncURLFilterBar() {
    const bar = document.getElementById('urlFilterBar');
    const txt = document.getElementById('urlFilterText');
    const parts = [];
    if (state.storages.length) parts.push(`Storage: ${state.storages.join(', ')}`);
    if (state.deposits.length) {
      const labels = state.deposits.map(v => depositRanges.find(r=>r.value===v)?.label || v);
      parts.push(`Deposit: ${labels.join(', ')}`);
    }
    if (parts.length) {
      bar.classList.add('show');
      txt.textContent = 'Filtering by: ' + parts.join(' · ');
    } else {
      bar.classList.remove('show');
    }
  }

  // ========== FILTER LOGIC ==========
  function getFilteredProducts() {
    let list = [...products];

    if (state.storages.length) {
      list = list.filter(p => state.storages.includes(p.storage));
    }

    if (state.deposits.length) {
      list = list.filter(p => {
        const dep = parseFloat((p.deposit || '').replace(/[^\d.]/g, '')) || 0;
        return state.deposits.some(v => {
          const range = depositRanges.find(r => r.value === v);
          return range && dep < range.max;
        });
      });
    }

    // Sort
    if (state.sort === 'rating') {
      list.sort((a,b) => (b.reviews?.averageRating||0) - (a.reviews?.averageRating||0));
    } else if (state.sort === 'deposit-low') {
      list.sort((a,b) => parseFloat((a.deposit||'').replace(/[^\d.]/g,'')) - parseFloat((b.deposit||'').replace(/[^\d.]/g,'')));
    } else if (state.sort === 'deposit-high') {
      list.sort((a,b) => parseFloat((b.deposit||'').replace(/[^\d.]/g,'')) - parseFloat((a.deposit||'').replace(/[^\d.]/g,'')));
    } else if (state.sort === 'price-low') {
      list.sort((a,b) => parseFloat((a.totalPrice||'').replace(/[^\d.]/g,'')) - parseFloat((b.totalPrice||'').replace(/[^\d.]/g,'')));
    } else if (state.sort === 'price-high') {
      list.sort((a,b) => parseFloat((b.totalPrice||'').replace(/[^\d.]/g,'')) - parseFloat((a.totalPrice||'').replace(/[^\d.]/g,'')));
    }

    return list;
  }

  // ========== RENDER FILTERS ==========
  function renderFilters() {
    const filtered = getFilteredProducts();

    // Count per storage
    const storageCounts = {};
    allStorages.forEach(s => {
      storageCounts[s] = products.filter(p => p.storage === s).length;
    });

    // Count per deposit range
    const depositCounts = {};
    depositRanges.forEach(r => {
      depositCounts[r.value] = products.filter(p => {
        const dep = parseFloat((p.deposit||'').replace(/[^\d.]/g,'')) || 0;
        return dep < r.max;
      }).length;
    });

    const html = `
      <div class="filter-section">
        <div class="filter-section-title">Storage</div>
        ${allStorages.map(s => `
          <div class="filter-option">
            <input type="checkbox" id="desk-st-${s}" value="${s}" ${state.storages.includes(s)?'checked':''} onchange="toggleFilter('storage','${s}',this.checked)">
            <label for="desk-st-${s}">${s} <span class="filter-count">${storageCounts[s]||0}</span></label>
          </div>
        `).join('')}
      </div>
      <div class="filter-section">
        <div class="filter-section-title">Deposit Range</div>
        ${depositRanges.map(r => `
          <div class="filter-option">
            <input type="checkbox" id="desk-dep-${r.value}" value="${r.value}" ${state.deposits.includes(r.value)?'checked':''} onchange="toggleFilter('deposit','${r.value}',this.checked)">
            <label for="desk-dep-${r.value}">${r.label} <span class="filter-count">${depositCounts[r.value]||0}</span></label>
          </div>
        `).join('')}
      </div>
    `;

    document.getElementById('desktopFilters').innerHTML = html;
    renderMobileFilters(storageCounts, depositCounts);
  }

  function renderMobileFilters(storageCounts, depositCounts) {
    const html = `
      <div class="filter-section">
        <div class="filter-section-title">Filter By Storage</div>
        ${allStorages.map(s => `
          <div class="filter-option">
            <input type="checkbox" id="mob-st-${s}" value="${s}" ${state.storages.includes(s)?'checked':''} onchange="toggleFilter('storage','${s}',this.checked)">
            <label for="mob-st-${s}">${s} <span class="filter-count">${storageCounts[s]||0}</span></label>
          </div>
        `).join('')}
      </div>
      <div class="filter-section">
        <div class="filter-section-title">Filter By Deposit</div>
        ${depositRanges.map(r => `
          <div class="filter-option">
            <input type="checkbox" id="mob-dep-${r.value}" value="${r.value}" ${state.deposits.includes(r.value)?'checked':''} onchange="toggleFilter('deposit','${r.value}',this.checked)">
            <label for="mob-dep-${r.value}">${r.label} <span class="filter-count">${depositCounts[r.value]||0}</span></label>
          </div>
        `).join('')}
      </div>
    `;
    document.getElementById('mobileFilters').innerHTML = html;
  }

  // ========== TOGGLE FILTER ==========
  function toggleFilter(type, value, checked) {
    if (type === 'storage') {
      if (checked) { if (!state.storages.includes(value)) state.storages.push(value); }
      else { state.storages = state.storages.filter(v => v !== value); }
    } else if (type === 'deposit') {
      if (checked) { if (!state.deposits.includes(value)) state.deposits.push(value); }
      else { state.deposits = state.deposits.filter(v => v !== value); }
    }
    state.page = 1;
    syncFilterCheckboxes();
    renderProducts();
    renderActiveFilters();
    updateFilterBadge();
    pushURL();
  }

  function syncFilterCheckboxes() {
    allStorages.forEach(s => {
      const d = document.getElementById('desk-st-'+s);
      const m = document.getElementById('mob-st-'+s);
      if (d) d.checked = state.storages.includes(s);
      if (m) m.checked = state.storages.includes(s);
    });
    depositRanges.forEach(r => {
      const d = document.getElementById('desk-dep-'+r.value);
      const m = document.getElementById('mob-dep-'+r.value);
      if (d) d.checked = state.deposits.includes(r.value);
      if (m) m.checked = state.deposits.includes(r.value);
    });
  }

  function clearAllFilters() {
    state.storages = [];
    state.deposits = [];
    state.page = 1;
    syncFilterCheckboxes();
    renderProducts();
    renderActiveFilters();
    updateFilterBadge();
    pushURL();
  }

  // ========== ACTIVE FILTER TAGS ==========
  function renderActiveFilters() {
    const cont = document.getElementById('activeFilters');
    let tags = [];
    state.storages.forEach(s => {
      tags.push(`<span class="filter-tag" onclick="toggleFilter('storage','${s}',false)">${s} <span class="remove">×</span></span>`);
    });
    state.deposits.forEach(v => {
      const label = depositRanges.find(r=>r.value===v)?.label || v;
      tags.push(`<span class="filter-tag" onclick="toggleFilter('deposit','${v}',false)">${label} <span class="remove">×</span></span>`);
    });
    if (tags.length) tags.push(`<span class="clear-all" onclick="clearAllFilters()">Clear all</span>`);
    cont.innerHTML = tags.join('');
  }

  function updateFilterBadge() {
    const count = state.storages.length + state.deposits.length;
    const badge = document.getElementById('filterCountBadge');
    if (count > 0) { badge.style.display = 'flex'; badge.textContent = count; }
    else { badge.style.display = 'none'; }
  }

  // ========== RENDER PRODUCTS ==========
  function renderProducts() {
    const filtered = getFilteredProducts();
    const total = filtered.length;
    const totalPages = Math.max(1, Math.ceil(total / PER_PAGE));
    state.page = Math.min(state.page, totalPages);
    const start = (state.page - 1) * PER_PAGE;
    const pageItems = filtered.slice(start, start + PER_PAGE);

    document.getElementById('resultCount').textContent = `(${total})`;

    const grid = document.getElementById('productsGrid');

    if (pageItems.length === 0) {
      grid.innerHTML = `
        <div class="empty-state">
          <h3>No phones found</h3>
          <p>Try adjusting your filters to see more results.</p>
        </div>`;
      document.getElementById('pagination').innerHTML = '';
      return;
    }

    grid.innerHTML = pageItems.map(p => {
      const stars = renderStars(p.reviews?.averageRating || 0);
      return `
        <article class="product-card" role="listitem" itemscope itemtype="https://schema.org/Product">
          ${p.status === 'New' ? '<span class="badge-new" aria-label="New product">NEW</span>' : ''}
          ${p.discount ? `<span class="badge-discount" aria-label="Discount">${p.discount}</span>` : ''}
          <a href="/${p.slug}" title="${p.fullname || p.name} - Lipa Mdogo Mdogo">
            <div class="card-image-wrap">
              <img
                src="${p.image}"
                alt="${p.name} lipa mdogo mdogo phone nairobi"
                loading="lazy"
                decoding="async"
                width="300"
                height="375"
                itemprop="image"
                onerror="this.style.opacity='0.3'"
              />
            </div>
            <div class="card-body">
              <div class="card-name" itemprop="name">${p.name}</div>
              ${p.storage ? `<span class="card-storage">${p.storage}</span>` : ''}
              ${p.reviews?.reviewCount > 0 ? `
                <div class="stars" itemprop="aggregateRating" itemscope itemtype="https://schema.org/AggregateRating">
                  <span class="stars-icons" aria-label="${p.reviews.averageRating} stars">${stars}</span>
                  <span class="stars-count" itemprop="reviewCount">(${p.reviews.reviewCount})</span>
                  <meta itemprop="ratingValue" content="${p.reviews.averageRating}" />
                </div>
              ` : ''}
              <div class="card-pricing">
                <div class="price-from">Deposit from</div>
                <div class="price-deposit" itemprop="offers" itemscope itemtype="https://schema.org/Offer">
                  <meta itemprop="priceCurrency" content="KES" />
                  <meta itemprop="price" content="${(p.deposit||'').replace(/[^\d.]/g,'')}" />
                  ${p.deposit}
                </div>
                <div class="price-daily">+ ${p.daily}/day</div>
                <div class="price-total">Total: ${p.totalPrice}</div>
              </div>
              <span class="card-cta" role="button">Buy on Credit →</span>
            </div>
          </a>
        </article>
      `;
    }).join('');

    renderPagination(totalPages);
    renderActiveFilters();
    updateFilterBadge();
  }

  function renderStars(rating) {
    let html = '';
    for (let i = 1; i <= 5; i++) {
      html += i <= Math.round(rating) ? '★' : '☆';
    }
    return html;
  }

  // ========== PAGINATION ==========
  function renderPagination(totalPages) {
    if (totalPages <= 1) { document.getElementById('pagination').innerHTML = ''; return; }

    let html = `<button class="page-btn" onclick="goToPage(${state.page-1})" ${state.page===1?'disabled':''} aria-label="Previous page">‹</button>`;

    for (let i = 1; i <= totalPages; i++) {
      if (totalPages > 7) {
        if (i === 1 || i === totalPages || (i >= state.page - 1 && i <= state.page + 1)) {
          html += `<button class="page-btn ${i===state.page?'active':''}" onclick="goToPage(${i})" aria-label="Page ${i}" aria-current="${i===state.page?'page':''}">${i}</button>`;
        } else if (i === state.page - 2 || i === state.page + 2) {
          html += `<span class="page-info">…</span>`;
        }
      } else {
        html += `<button class="page-btn ${i===state.page?'active':''}" onclick="goToPage(${i})" aria-label="Page ${i}" aria-current="${i===state.page?'page':''}">${i}</button>`;
      }
    }

    html += `<button class="page-btn" onclick="goToPage(${state.page+1})" ${state.page===totalPages?'disabled':''} aria-label="Next page">›</button>`;
    document.getElementById('pagination').innerHTML = html;
  }

  function goToPage(p) {
    const filtered = getFilteredProducts();
    const totalPages = Math.max(1, Math.ceil(filtered.length / PER_PAGE));
    if (p < 1 || p > totalPages) return;
    state.page = p;
    pushURL();
    renderProducts();
    window.scrollTo({ top: 0, behavior: 'smooth' });
  }

  // ========== SORT ==========
  document.getElementById('sortSelect').addEventListener('change', function() {
    state.sort = this.value;
    state.page = 1;
    pushURL();
    renderProducts();
  });

  // ========== MOBILE SHEET ==========
  function openFilterSheet() {
    document.getElementById('sheetOverlay').classList.add('open');
    document.getElementById('filterSheet').classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeFilterSheet() {
    document.getElementById('sheetOverlay').classList.remove('open');
    document.getElementById('filterSheet').classList.remove('open');
    document.body.style.overflow = '';
  }
  function applyMobileFilters() {
    closeFilterSheet();
  }

  // ========== POPSTATE (back/forward) ==========
  window.addEventListener('popstate', () => {
    readURLParams();
    syncFilterCheckboxes();
    renderProducts();
    syncURLFilterBar();
  });

  // ========== RUN ==========
  init();
</script>

</body>
</html>