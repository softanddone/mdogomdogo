// Collect unique storage values
const allStorages = [...new Set(products.map(p => p.storage).filter(Boolean))].sort((a,b) => {
  const numA = parseInt(a); const numB = parseInt(b);
  return numB - numA;
});

// Deposit ranges
const depositRanges = [
  { label: "Under 2k", value: "under-2k", max: 2000 },
  { label: "Under 3k", value: "under-3k", max: 3000 },
  { label: "Under 4k", value: "under-4k", max: 4000 },
