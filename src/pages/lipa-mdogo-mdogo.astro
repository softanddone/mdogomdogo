---
import { products } from '../data/product2.js';

// Helper: render star rating
function renderStars(rating) {
  const full = Math.floor(rating);
  const half = rating % 1 >= 0.5;
  const empty = 5 - full - (half ? 1 : 0);
  return '★'.repeat(full) + (half ? '½' : '') + '☆'.repeat(empty);
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Mdogomdogo Deals — Lipa Mdogo Mdogo Phones</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --orange: #ff6000;
      --orange-light: #ff8533;
      --orange-pale: #fff4ed;
      --red: #e62e2e;
      --gold: #f5a623;
      --navy: #0d1b2a;
      --dark: #1a1a2e;
      --white: #ffffff;
      --gray-1: #f7f8fa;
      --gray-2: #ebebeb;
      --gray-3: #b0b0b0;
      --text: #222;
      --text-light: #666;
      --badge-new: #00b96b;
      --badge-hot: #e62e2e;
      --badge-sale: #ff6000;
    }

    body {
      font-family: 'Barlow', sans-serif;
      background: var(--gray-1);
      color: var(--text);
      min-height: 100vh;
    }

    /* ─── TOP BANNER ─── */
    .top-banner {
      background: var(--navy);
      color: #fff;
      text-align: center;
      padding: 9px 16px;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 0.03em;
    }
    .top-banner span { color: var(--gold); font-weight: 700; }

    /* ─── SITE HEADER ─── */
    .site-header {
      background: var(--orange);
      padding: 14px 24px 0;
      display: flex;
      align-items: flex-end;
      gap: 32px;
    }
    .logo {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 32px;
      font-weight: 900;
      color: #fff;
      letter-spacing: -0.5px;
      line-height: 1;
      padding-bottom: 12px;
      flex-shrink: 0;
    }
    .logo span { color: var(--gold); }
    .logo sub {
      display: block;
      font-size: 11px;
      font-weight: 600;
      letter-spacing: 0.08em;
      color: rgba(255,255,255,0.75);
      margin-top: 2px;
    }
    .header-cats {
      display: flex;
      gap: 2px;
      flex: 1;
      overflow: hidden;
    }
    .header-cats a {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 15px;
      font-weight: 700;
      color: rgba(255,255,255,0.88);
      text-decoration: none;
      padding: 8px 14px 12px;
      border-radius: 6px 6px 0 0;
      transition: background 0.15s, color 0.15s;
      white-space: nowrap;
      letter-spacing: 0.04em;
    }
    .header-cats a:hover, .header-cats a.active {
      background: var(--gray-1);
      color: var(--orange);
    }

    /* ─── FILTER STRIP ─── */
    .filter-strip {
      background: #fff;
      border-bottom: 1px solid var(--gray-2);
      padding: 10px 24px;
      display: flex;
      align-items: center;
      gap: 10px;
      flex-wrap: wrap;
    }
    .filter-label {
      font-size: 12px;
      font-weight: 600;
      color: var(--text-light);
      text-transform: uppercase;
      letter-spacing: 0.07em;
      margin-right: 4px;
    }
    .filter-chip {
      border: 1.5px solid var(--gray-2);
      background: var(--gray-1);
      color: var(--text);
      border-radius: 20px;
      padding: 5px 14px;
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      transition: all 0.15s;
    }
    .filter-chip:hover { border-color: var(--orange); color: var(--orange); background: var(--orange-pale); }
    .filter-chip.active { border-color: var(--orange); background: var(--orange); color: #fff; }
    .sort-select {
      margin-left: auto;
      border: 1.5px solid var(--gray-2);
      border-radius: 20px;
      padding: 5px 14px;
      font-size: 13px;
      font-weight: 500;
      background: var(--gray-1);
      color: var(--text);
      cursor: pointer;
      outline: none;
    }

    /* ─── MAIN LAYOUT ─── */
    .page-body {
      max-width: 1280px;
      margin: 0 auto;
      padding: 24px 20px 60px;
    }

    /* ─── PROMO STRIP ─── */
    .promo-strip {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 10px;
      margin-bottom: 22px;
    }
    .promo-tile {
      background: linear-gradient(135deg, var(--orange) 0%, #ff3c00 100%);
      color: #fff;
      border-radius: 10px;
      padding: 14px 16px;
      display: flex;
      align-items: center;
      gap: 12px;
      cursor: pointer;
      transition: transform 0.15s, box-shadow 0.15s;
      box-shadow: 0 2px 10px rgba(255,96,0,0.25);
    }
    .promo-tile:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(255,96,0,0.35); }
    .promo-tile.navy { background: linear-gradient(135deg, var(--navy) 0%, #162640 100%); box-shadow: 0 2px 10px rgba(13,27,42,0.25); }
    .promo-tile.navy:hover { box-shadow: 0 6px 20px rgba(13,27,42,0.35); }
    .promo-tile.gold { background: linear-gradient(135deg, #c47d00 0%, var(--gold) 100%); box-shadow: 0 2px 10px rgba(245,166,35,0.3); }
    .promo-tile.gold:hover { box-shadow: 0 6px 20px rgba(245,166,35,0.4); }
    .promo-tile.green { background: linear-gradient(135deg, #007a46 0%, #00b96b 100%); box-shadow: 0 2px 10px rgba(0,185,107,0.25); }
    .promo-tile.green:hover { box-shadow: 0 6px 20px rgba(0,185,107,0.35); }
    .promo-icon { font-size: 28px; }
    .promo-info { line-height: 1.3; }
    .promo-info strong { display: block; font-family: 'Barlow Condensed', sans-serif; font-size: 16px; font-weight: 900; letter-spacing: 0.03em; }
    .promo-info span { font-size: 11.5px; opacity: 0.85; }

    /* ─── SECTION TITLE ─── */
    .section-head {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
    }
    .section-head h2 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 22px;
      font-weight: 900;
      letter-spacing: 0.02em;
      color: var(--navy);
    }
    .section-head .line {
      flex: 1;
      height: 2px;
      background: var(--gray-2);
      border-radius: 2px;
    }
    .section-head .line::before {
      content: '';
      display: block;
      width: 60px;
      height: 2px;
      background: var(--orange);
      border-radius: 2px;
    }
    .section-head .see-all {
      font-size: 13px;
      font-weight: 600;
      color: var(--orange);
      text-decoration: none;
      white-space: nowrap;
    }
    .section-head .see-all:hover { text-decoration: underline; }

    /* ─── PRODUCT GRID ─── */
    .product-grid {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 12px;
      margin-bottom: 36px;
    }

    /* ─── PRODUCT CARD ─── */
    .card {
      background: #fff;
      border-radius: 10px;
      overflow: hidden;
      border: 1.5px solid var(--gray-2);
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
      cursor: pointer;
      position: relative;
      display: flex;
      flex-direction: column;
      animation: fadeUp 0.4s ease both;
    }
    .card:hover {
      border-color: var(--orange);
      box-shadow: 0 8px 28px rgba(255,96,0,0.12);
      transform: translateY(-3px);
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .card:nth-child(1)  { animation-delay: 0.05s; }
    .card:nth-child(2)  { animation-delay: 0.10s; }
    .card:nth-child(3)  { animation-delay: 0.15s; }
    .card:nth-child(4)  { animation-delay: 0.20s; }
    .card:nth-child(5)  { animation-delay: 0.25s; }
    .card:nth-child(6)  { animation-delay: 0.08s; }
    .card:nth-child(7)  { animation-delay: 0.13s; }
    .card:nth-child(8)  { animation-delay: 0.18s; }
    .card:nth-child(9)  { animation-delay: 0.23s; }
    .card:nth-child(10) { animation-delay: 0.28s; }

    /* badge */
    .badge {
      position: absolute;
      top: 10px;
      left: 10px;
      z-index: 2;
      padding: 3px 9px;
      border-radius: 4px;
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 12px;
      font-weight: 800;
      letter-spacing: 0.07em;
      text-transform: uppercase;
      color: #fff;
    }
    .badge-new  { background: var(--badge-new); }
    .badge-hot  { background: var(--badge-hot); }
    .badge-sale { background: var(--badge-sale); }
    .badge-installment { background: var(--navy); }

    .wishlist-btn {
      position: absolute;
      top: 10px;
      right: 10px;
      z-index: 2;
      background: rgba(255,255,255,0.9);
      border: none;
      border-radius: 50%;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      font-size: 16px;
      transition: background 0.15s, transform 0.15s;
      box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }
    .wishlist-btn:hover { background: #fff; transform: scale(1.12); }

    /* image */
    .card-img {
      width: 100%;
      aspect-ratio: 1 / 1;
      object-fit: contain;
      padding: 20px;
      background: var(--gray-1);
      transition: transform 0.3s;
    }
    .card:hover .card-img { transform: scale(1.05); }

    /* body */
    .card-body {
      padding: 12px 12px 10px;
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .card-brand {
      font-size: 11px;
      font-weight: 600;
      color: var(--text-light);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      margin-bottom: 3px;
    }
    .card-name {
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
      line-height: 1.35;
      margin-bottom: 6px;
      flex: 1;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .card-specs {
      display: flex;
      gap: 5px;
      flex-wrap: wrap;
      margin-bottom: 8px;
    }
    .spec-tag {
      background: var(--gray-1);
      border: 1px solid var(--gray-2);
      color: var(--text-light);
      border-radius: 4px;
      padding: 2px 7px;
      font-size: 11px;
      font-weight: 500;
    }

    /* rating */
    .card-rating {
      display: flex;
      align-items: center;
      gap: 5px;
      margin-bottom: 9px;
    }
    .stars { color: var(--gold); font-size: 13px; letter-spacing: -1px; }
    .rating-count { font-size: 11.5px; color: var(--text-light); }

    /* price */
    .card-price {
      display: flex;
      align-items: baseline;
      gap: 7px;
      flex-wrap: wrap;
      margin-bottom: 6px;
    }
    .price-current {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: 22px;
      font-weight: 900;
      color: var(--orange);
      letter-spacing: -0.5px;
    }
    .price-original {
      font-size: 13px;
      color: var(--gray-3);
      text-decoration: line-through;
    }
    .price-save {
      font-size: 11.5px;
      font-weight: 700;
      color: var(--badge-new);
    }
    .installment-note {
      font-size: 11.5px;
      color: var(--navy);
      font-weight: 600;
      background: #e8f0fe;
      padding: 3px 8px;
      border-radius: 4px;
      margin-bottom: 10px;
      display: inline-block;
    }

    /* CTA */
    .card-cta {
      display: flex;
      gap: 7px;
      margin-top: auto;
    }
    .btn-cart {
      flex: 1;
      background: var(--orange);
      color: #fff;
      border: none;
      border-radius: 6px;
      padding: 9px 10px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.15s, transform 0.1s;
      font-family: 'Barlow', sans-serif;
    }
    .btn-cart:hover { background: var(--orange-light); transform: scale(1.02); }
    .btn-buy {
      flex: 1;
      background: var(--navy);
      color: #fff;
      border: none;
      border-radius: 6px;
      padding: 9px 10px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.15s, transform 0.1s;
      font-family: 'Barlow', sans-serif;
    }
    .btn-buy:hover { background: #162640; transform: scale(1.02); }

    /* ─── TRUST BAR ─── */
    .trust-bar {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-top: 12px;
      margin-bottom: 36px;
    }
    .trust-item {
      background: #fff;
      border: 1.5px solid var(--gray-2);
      border-radius: 10px;
      padding: 16px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .trust-icon { font-size: 26px; }
    .trust-text strong { display: block; font-size: 14px; font-weight: 700; color: var(--text); }
    .trust-text span { font-size: 12px; color: var(--text-light); }

    /* ─── FEATURED DEAL CARD ─── */
    .deal-card {
      grid-column: span 2;
      background: linear-gradient(135deg, var(--navy) 0%, #162640 100%);
      color: #fff;
      border-radius: 10px;
      padding: 24px;
      display: flex;
      align-items: center;
      gap: 20px;
      overflow: hidden;
      position: relative;
      border: none;
      cursor: pointer;
      transition: box-shadow 0.2s, transform 0.15s;
    }
    .deal-card:hover { box-shadow: 0 10px 36px rgba(13,27,42,0.3); transform: translateY(-3px); }
    .deal-card::before {
      content: '';
      position: absolute;
      top: -40px; right: -40px;
      width: 180px; height: 180px;
      border-radius: 50%;
      background: rgba(255,96,0,0.18);
    }
    .deal-card .card-img { background: transparent; padding: 0; flex-shrink: 0; width: 130px; height: 130px; }
    .deal-info { position: relative; }
    .deal-tag {
      display: inline-block;
      background: var(--orange);
      color: #fff;
      padding: 3px 10px;
      border-radius: 4px;
      font-size: 11px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 0.07em;
      margin-bottom: 8px;
    }
    .deal-info h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 20px; font-weight: 900; margin-bottom: 4px; }
    .deal-info .deal-price { font-family: 'Barlow Condensed', sans-serif; font-size: 28px; font-weight: 900; color: var(--gold); }
    .deal-info .deal-orig { font-size: 13px; color: rgba(255,255,255,0.5); text-decoration: line-through; margin-left: 8px; }
    .deal-info .deal-install { font-size: 12.5px; color: rgba(255,255,255,0.8); margin-top: 4px; }
    .deal-cta { margin-top: 14px; background: var(--orange); color: #fff; border: none; border-radius: 6px; padding: 9px 20px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: 'Barlow', sans-serif; transition: background 0.15s; }
    .deal-cta:hover { background: var(--orange-light); }

    /* ─── RESPONSIVE ─── */
    @media (max-width: 1100px) {
      .product-grid { grid-template-columns: repeat(4, 1fr); }
      .promo-strip { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 800px) {
      .product-grid { grid-template-columns: repeat(3, 1fr); }
      .trust-bar { grid-template-columns: repeat(2, 1fr); }
      .site-header { padding: 12px 16px 0; }
      .header-cats { display: none; }
      .deal-card { grid-column: span 3; }
    }
    @media (max-width: 560px) {
      .product-grid { grid-template-columns: repeat(2, 1fr); }
      .promo-strip { grid-template-columns: 1fr 1fr; }
      .trust-bar { grid-template-columns: 1fr 1fr; }
      .deal-card { grid-column: span 2; }
    }
  </style>
</head>
<body>

<!-- TOP BANNER -->
<div class="top-banner">
  🚀 Free Delivery in Nairobi CBD &nbsp;|&nbsp; <span>Lipa Mdogo Mdogo</span> — Pay small daily/weekly instalments &nbsp;|&nbsp; ☎ 0100028823
</div>

<!-- SITE HEADER -->
<header class="site-header">
  <div class="logo">
    Mdogomdogo<span>Deals</span>
    <sub>KENYA · NAIROBI</sub>
  </div>
  <nav class="header-cats">
    <a href="#" class="active">All Phones</a>
    <a href="#">Samsung</a>
    <a href="#">iPhone</a>
    <a href="#">Tecno</a>
    <a href="#">Infinix</a>
    <a href="#">Vivo</a>
    <a href="#">Nokia</a>
    <a href="#">Accessories</a>
  </nav>
</header>

<!-- FILTER STRIP -->
<div class="filter-strip">
  <span class="filter-label">Filter:</span>
  <button class="filter-chip active">All</button>
  <button class="filter-chip">Under KSh 10K</button>
  <button class="filter-chip">10K – 30K</button>
  <button class="filter-chip">30K – 60K</button>
  <button class="filter-chip">60K+</button>
  <button class="filter-chip">Installments Only</button>
  <button class="filter-chip">5G Phones</button>
  <button class="filter-chip">New Arrivals</button>
  <select class="sort-select">
    <option>Sort: Featured</option>
    <option>Price: Low to High</option>
    <option>Price: High to Low</option>
    <option>Best Rated</option>
    <option>Most Popular</option>
  </select>
</div>

<!-- PAGE BODY -->
<main class="page-body">

  <!-- PROMO STRIP -->
  <div class="promo-strip">
    <div class="promo-tile">
      <div class="promo-icon">📦</div>
      <div class="promo-info">
        <strong>Free Delivery</strong>
        <span>Same-day </span>
      </div>
    </div>
    <div class="promo-tile navy">
      <div class="promo-icon">💳</div>
      <div class="promo-info">
        <strong>Lipa Mdogo Mdogo</strong>
        <span>From KSh 2000</span>
      </div>
    </div>
    <div class="promo-tile gold">
      <div class="promo-icon">🔒</div>
      <div class="promo-info">
        <strong>12-Month Warranty</strong>
        <span>Genuine manufacturer warranty</span>
      </div>
    </div>
    <div class="promo-tile green">
      <div class="promo-icon">🔄</div>
      <div class="promo-info">
        <strong>48 hrs Returns</strong>
        <span>No questions asked</span>
      </div>
    </div>
  </div>

  <!-- FEATURED DEALS — uses first product as the Deal of the Day -->
  <div class="section-head">
    <h2>🔥 Flash Deals</h2>
    <div class="line"></div>
    <a href="#" class="see-all">See All Deals →</a>
  </div>

  <div class="product-grid" style="margin-bottom:36px;">

    <!-- DEAL CARD: first product -->
    {products.slice(0, 1).map((p) => (
      <a href={`/phones/${p.slug}`} class="deal-card" style="text-decoration:none;">
        <img class="card-img" src={p.source} alt={p.name} />
        <div class="deal-info">
          <span class="deal-tag">⚡ Deal of the Day</span>
          <h3>{p.fullname}</h3>
          <div>
            <span class="deal-price">{p.totalPrice}</span>
            {p.discount && <span class="deal-orig">{p.discount} off</span>}
          </div>
          <div class="deal-install">Or {p.daily}/day on installment · Deposit {p.deposit}</div>
          <button class="deal-cta">Buy Now on M-Pesa</button>
        </div>
      </a>
    ))}

    <!-- Remaining flash deal cards: products 2–4 -->
    {products.slice(1, 4).map((p, i) => {
      const badgeClass = i === 0 ? 'badge-hot' : i === 1 ? 'badge-new' : 'badge-sale';
      const badgeLabel = i === 0 ? 'HOT' : i === 1 ? 'NEW' : 'SALE';

      // Build spec tags from available fields
      const specs = [
        p.processor?.split(' ').slice(-2).join(' '),
        p.camera?.split(',')[0],
        p.battery?.split(',')[0],
      ].filter(Boolean).slice(0, 3);

      const rating = p.reviews?.averageRating ?? 4.5;
      const reviewCount = p.reviews?.reviewCount ?? 0;
      const fullStars = Math.floor(rating);
      const emptyStars = 5 - fullStars;

      return (
        <a href={`/phones/${p.slug}`} class="card" style="text-decoration:none; color:inherit;">
          <span class={`badge ${badgeClass}`}>{badgeLabel}</span>
          <button class="wishlist-btn" data-id={p.id}>🤍</button>
          <img class="card-img" src={p.source} alt={p.name} />
          <div class="card-body">
            <div class="card-brand">{p.brand}</div>
            <div class="card-name">{p.fullname}</div>
            <div class="card-specs">
              {specs.map(s => <span class="spec-tag">{s}</span>)}
            </div>
            <div class="card-rating">
              <span class="stars">
                {'★'.repeat(fullStars)}{'☆'.repeat(emptyStars)}
              </span>
              <span class="rating-count">({reviewCount})</span>
            </div>
            <div class="card-price">
              <span class="price-current">{p.deposit}</span>
              {p.discount && <span class="price-save">{p.discount}</span>}
            </div>
            <div class="installment-note">💳 From {p.from}/wk · Deposit {p.deposit}</div>
            <div class="card-cta">
              <button class="btn-cart">🛒 Cart</button>
              <button class="btn-buy">Buy Now</button>
            </div>
          </div>
        </a>
      );
    })}

  </div>

  <!-- ALL PHONES SECTION — all products from data file -->
  <div class="section-head">
    <h2>📱 All Phones</h2>
    <div class="line"></div>
    <a href="#" class="see-all">View All →</a>
  </div>

  <div class="product-grid">
    {products.map((p, i) => {
      const statusLower = p.status?.toLowerCase();
      const badgeClass = statusLower === 'new' ? 'badge-new' : statusLower === 'hot' ? 'badge-hot' : 'badge-sale';
      const badgeLabel = p.status ?? 'NEW';

      // Parse spec tags: display, processor short form, battery
      const specs = [
        p.phonedisplay,
        p.processor?.split(' ').slice(-2).join(' '),
        p.battery?.split(',')[0],
      ].filter(Boolean).slice(0, 3);

      const rating = p.reviews?.averageRating ?? 4.5;
      const reviewCount = p.reviews?.reviewCount ?? 0;
      const fullStars = Math.floor(rating);
      const emptyStars = 5 - fullStars;

      return (
        <a href={`/phones/${p.slug}`} class="card" style="text-decoration:none; color:inherit;">
          <span class={`badge ${badgeClass}`}>{badgeLabel}</span>
          <button class="wishlist-btn" data-id={p.id}>🤍</button>
          <img class="card-img" src={p.source} alt={p.name} />
          <div class="card-body">
            <div class="card-brand">{p.brand}</div>
            <div class="card-name">{p.fullname}</div>
            <div class="card-specs">
              {specs.map(s => <span class="spec-tag">{s}</span>)}
            </div>
            <div class="card-rating">
              <span class="stars">
                {'★'.repeat(fullStars)}{'☆'.repeat(emptyStars)}
              </span>
              <span class="rating-count">({reviewCount})</span>
            </div>
            <div class="card-price">
              <span class="price-current">{p.totalPrice}</span>
              {p.discount && <span class="price-save">{p.discount}</span>}
            </div>
            <div class="installment-note">💳 From {p.from}/wk · Deposit {p.deposit}</div>
            <div class="card-cta">
              <button class="btn-cart">🛒 Cart</button>
              <button class="btn-buy">Buy Now</button>
            </div>
          </div>
        </a>
      );
    })}
  </div>

  <!-- TRUST BAR -->
  <div class="trust-bar">
    <div class="trust-item">
      <span class="trust-icon">🏪</span>
      <div class="trust-text">
        <strong>Verified Nairobi Store</strong>
        <span>Tom Mboya St, Moi Ave & Online</span>
      </div>
    </div>
    <div class="trust-item">
      <span class="trust-icon">📲</span>
      <div class="trust-text">
        <strong>M-Pesa Installments</strong>
        <span>Pay weekly, no credit check</span>
      </div>
    </div>
    <div class="trust-item">
      <span class="trust-icon">🛡️</span>
      <div class="trust-text">
        <strong>100% Genuine Phones</strong>
        <span>All phones brand new & sealed</span>
      </div>
    </div>
    <div class="trust-item">
      <span class="trust-icon">☎️</span>
      <div class="trust-text">
        <strong>Support via WhatsApp</strong>
        <span>0700 123 456 · Mon–Sat 8am–8pm</span>
      </div>
    </div>
  </div>

</main>

<script>
  // Filter chips toggle
  document.querySelectorAll('.filter-chip').forEach(chip => {
    chip.addEventListener('click', () => {
      document.querySelectorAll('.filter-chip').forEach(c => c.classList.remove('active'));
      chip.classList.add('active');
    });
  });

  // Wishlist toggle — stop propagation so the <a> link doesn't fire
  document.querySelectorAll('.wishlist-btn').forEach(btn => {
    btn.addEventListener('click', e => {
      e.preventDefault();
      e.stopPropagation();
      btn.textContent = btn.textContent === '🤍' ? '❤️' : '🤍';
    });
  });

  // Cart button feedback — stop propagation so the <a> link doesn't fire
  document.querySelectorAll('.btn-cart').forEach(btn => {
    btn.addEventListener('click', e => {
      e.preventDefault();
      e.stopPropagation();
      const original = btn.textContent;
      btn.textContent = '✓ Added!';
      btn.style.background = '#00b96b';
      setTimeout(() => {
        btn.textContent = original;
        btn.style.background = '';
      }, 1400);
    });
  });

  // Buy Now — stop propagation so the <a> link doesn't fire
  document.querySelectorAll('.btn-buy').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
    });
  });
</script>
</body>
</html>