<!-- ═══════════════════════════════════════════════════════════════════════════
     FILTER PANE — slide-up sheet triggered by the Filter nav button
════════════════════════════════════════════════════════════════════════════ -->

<!-- Dark overlay behind the pane -->
<div
  class="filter-overlay"
  id="filterOverlay"
  aria-hidden="true"
></div>

<!-- The pane itself -->
<div
  class="filter-pane"
  id="filterPane"
  role="dialog"
  aria-modal="true"
  aria-label="Filter phones"
>
  <!-- Drag handle (visual only) -->
  <div class="filter-pane-handle" aria-hidden="true"></div>

  <!-- Header -->
  <div class="filter-pane-header">
    <span class="filter-pane-title">🔍 Filter Phones</span>
    <button class="filter-pane-close" id="filterPaneClose" aria-label="Close filter panel">✕</button>
  </div>

  <!-- ── Deposit filter ── -->
  <div class="filter-section">
    <div class="filter-section-title">💳 Deposit Range</div>
    <div class="filter-chips" id="depositChips">
      <span class="filter-chip" data-type="deposit" data-key="">All</span>
      <span class="filter-chip" data-type="deposit" data-key="under-3k">Under KSh 3K</span>
      <span class="filter-chip" data-type="deposit" data-key="3k-5k">KSh 3K – 5K</span>
      <span class="filter-chip" data-type="deposit" data-key="5k-8k">KSh 5K – 8K</span>
      <span class="filter-chip" data-type="deposit" data-key="8k-10k">KSh 8K – 10K</span>
      <span class="filter-chip" data-type="deposit" data-key="above-10k">KSh 10K+</span>
    </div>
  </div>

  <div class="filter-divider"></div>

  <!-- ── Brand filter — chips injected dynamically by JS ── -->
  <div class="filter-section">
    <div class="filter-section-title">📱 Brand</div>
    <div class="filter-chips" id="brandChips">
      <span class="filter-chip" data-type="brand" data-key="">All Brands</span>
      <!-- JS appends one chip per brand, reading from the existing brand nav -->
    </div>
  </div>

  <!-- ── Footer: Reset + Apply ── -->
  <div class="filter-pane-footer">
    <button class="filter-reset-btn" id="filterResetBtn">Reset</button>
    <button class="filter-apply-btn" id="filterApplyBtn">Apply Filters</button>
  </div>
</div>


<!-- ═══════════════════════════════════════════════════════════════════════════
     FILTER PANE — CLIENT SCRIPT
     • Reads current slug to pre-select active chips
     • Builds brand chips from the existing desktop brand nav (single source of truth)
     • Navigates to the correct combined slug on Apply
     • Swipe-down gesture closes the pane
════════════════════════════════════════════════════════════════════════════ -->
<script>
(function () {
  'use strict';

  // ── Deposit key list (must match filter-config.js) ──────────────────────
  const DEPOSIT_KEYS = ['under-3k', '3k-5k', '5k-8k', '8k-10k', 'above-10k'];

  // ── Parse the current URL slug to pre-select filters ───────────────────
  // URL format: /filter/<slug>  where slug is one of:
  //   "all" | "<depositKey>" | "<brandSlug>" | "<brandSlug>-<depositKey>"
  function parseSlug(s) {
    if (!s || s === 'all') return { deposit: '', brand: '' };
    for (const dk of DEPOSIT_KEYS) {
      if (s === dk)                    return { deposit: dk, brand: '' };
      if (s.endsWith('-' + dk))        return { deposit: dk, brand: s.slice(0, -(dk.length + 1)) };
    }
    return { deposit: '', brand: s };
  }

  const rawSlug   = window.location.pathname.replace(/^\/filter\//, '').split('/')[0] || 'all';
  const current   = parseSlug(rawSlug);
  let selDeposit  = current.deposit;
  let selBrand    = current.brand;

  // ── Dynamically build brand chips from the existing desktop brand nav ──
  // This keeps brands perfectly in sync with ALL_BRANDS without duplication.
  const brandNav        = document.querySelector('.filter-nav[aria-label="Filter by brand"]');
  const brandNavLinks   = brandNav ? brandNav.querySelectorAll('.filter-nav-link') : [];
  const brandChipsWrap  = document.getElementById('brandChips');

  brandNavLinks.forEach(link => {
    const label = link.textContent.trim();
    if (label === 'All Brands') return; // already in HTML
    const key = label.toLowerCase().replace(/\s+/g, '-');
    const chip = document.createElement('span');
    chip.className   = 'filter-chip';
    chip.dataset.type = 'brand';
    chip.dataset.key  = key;
    chip.textContent  = label;
    brandChipsWrap.appendChild(chip);
  });

  // ── Reflect active state on chips ─────────────────────────────────────
  function syncChips() {
    document.querySelectorAll('#filterPane .filter-chip[data-type="deposit"]').forEach(c => {
      c.classList.toggle('active', c.dataset.key === selDeposit);
    });
    document.querySelectorAll('#filterPane .filter-chip[data-type="brand"]').forEach(c => {
      c.classList.toggle('active', c.dataset.key === selBrand);
    });
  }
  syncChips();

  // ── Chip click: toggle selection ──────────────────────────────────────
  document.getElementById('filterPane').addEventListener('click', e => {
    const chip = e.target.closest('.filter-chip');
    if (!chip) return;
    const { type, key } = chip.dataset;
    if (type === 'deposit') selDeposit = (selDeposit === key) ? '' : key;
    if (type === 'brand')   selBrand   = (selBrand   === key) ? '' : key;
    syncChips();
  });

  // ── Build destination URL ──────────────────────────────────────────────
  function buildUrl() {
    if (selBrand && selDeposit) return `/filter/${selBrand}-${selDeposit}`;
    if (selBrand)               return `/filter/${selBrand}`;
    if (selDeposit)             return `/filter/${selDeposit}`;
    return '/filter/all';
  }

  // ── Elements ──────────────────────────────────────────────────────────
  const overlay  = document.getElementById('filterOverlay');
  const pane     = document.getElementById('filterPane');
  const openBtn  = document.getElementById('mobileFilterBtn');
  const closeBtn = document.getElementById('filterPaneClose');

  // ── Open / close helpers ──────────────────────────────────────────────
  function openPane() {
    overlay.classList.add('open');
    pane.classList.add('open');
    openBtn.setAttribute('aria-expanded', 'true');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closePane() {
    overlay.classList.remove('open');
    pane.classList.remove('open');
    openBtn.setAttribute('aria-expanded', 'false');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  openBtn.addEventListener('click', openPane);
  closeBtn.addEventListener('click', closePane);
  overlay.addEventListener('click', closePane);

  // Close on Escape key
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && pane.classList.contains('open')) closePane();
  });

  // ── Swipe-down gesture to dismiss ─────────────────────────────────────
  let touchStartY = 0;
  pane.addEventListener('touchstart', e => {
    touchStartY = e.touches[0].clientY;
  }, { passive: true });
  pane.addEventListener('touchend', e => {
    if (e.changedTouches[0].clientY - touchStartY > 80) closePane();
  }, { passive: true });

  // ── Apply button → navigate ───────────────────────────────────────────
  document.getElementById('filterApplyBtn').addEventListener('click', () => {
    window.location.href = buildUrl();
  });

  // ── Reset button → clear selections ──────────────────────────────────
  document.getElementById('filterResetBtn').addEventListener('click', () => {
    selDeposit = '';
    selBrand   = '';
    syncChips();
  });

  // ── Highlight the Filter button when a filter is currently active ──────
  if (selDeposit || selBrand) {
    openBtn.classList.add('filter-active');
  }

})();
</script>

</body>
</html>
