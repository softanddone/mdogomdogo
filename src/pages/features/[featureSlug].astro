---
// src/pages/features/[featureSlug].astro

import { products } from '../../data/product2.js';
import {
  FEATURE_FILTERS,
  COMBO_PAIRS,
  comboHref,
  featureHref,
  featureBrandSlug,
  getProductFeatures,
} from '../../data/feature-config.js';
import { ALL_BRANDS } from '../../data/filter-config.js';
import Gift from '../../components/Gift.astro';
import Nav from '../../components/Nav.astro';

// ─── getStaticPaths ───────────────────────────────────────────────────────────

export async function getStaticPaths() {
  const { products }      = await import('../../data/product2.js');
  const { FEATURE_FILTERS, COMBO_PAIRS, featureBrandSlug } = await import('../../data/feature-config.js');
  const { ALL_BRANDS }    = await import('../../data/filter-config.js');

  const paths = [];

  // 1. Feature-only  →  /features/5g-phones-kenya
  for (const feat of FEATURE_FILTERS) {
    const filtered = products.filter(feat.match);
    if (!filtered.length) continue;
    paths.push({
      params: { featureSlug: `${feat.key}-phones-kenya` },
      props:  { primaryFeature: feat, secondaryFeature: null, brandFilter: null, filteredProducts: filtered, label: feat.h1 },
    });
  }

  // 2. Brand x Feature  →  /features/xiaomi-5g-phones-kenya
  for (const brand of ALL_BRANDS) {
    for (const feat of FEATURE_FILTERS) {
      const filtered = products.filter(p => feat.match(p) && p.brand?.toLowerCase() === brand.toLowerCase());
      if (!filtered.length) continue;
      paths.push({
        params: { featureSlug: `${featureBrandSlug(brand)}-${feat.key}-phones-kenya` },
        props:  { primaryFeature: feat, secondaryFeature: null, brandFilter: brand, filteredProducts: filtered, label: `${brand} ${feat.h1}` },
      });
    }
  }

  // 3. Feature x Feature combos  →  /features/5g-gaming-phones-kenya
  for (const [keyA, keyB] of COMBO_PAIRS) {
    const featA = FEATURE_FILTERS.find(f => f.key === keyA);
    const featB = FEATURE_FILTERS.find(f => f.key === keyB);
    if (!featA || !featB) continue;
    const filtered = products.filter(p => featA.match(p) && featB.match(p));
    if (!filtered.length) continue;

    // 3a. Feature x Feature (no brand)
    paths.push({
      params: { featureSlug: `${keyA}-${keyB}-phones-kenya` },
      props:  { primaryFeature: featA, secondaryFeature: featB, brandFilter: null, filteredProducts: filtered, label: `${featA.label} & ${featB.label} Phones in Kenya` },
    });

    // 3b. Brand x Feature x Feature
    for (const brand of ALL_BRANDS) {
      const brandFiltered = filtered.filter(p => p.brand?.toLowerCase() === brand.toLowerCase());
      if (!brandFiltered.length) continue;
      paths.push({
        params: { featureSlug: `${featureBrandSlug(brand)}-${keyA}-${keyB}-phones-kenya` },
        props:  { primaryFeature: featA, secondaryFeature: featB, brandFilter: brand, filteredProducts: brandFiltered, label: `${brand} ${featA.label} & ${featB.label} Phones in Kenya` },
      });
    }
  }

  return paths;
}

// ─── PAGE DATA ────────────────────────────────────────────────────────────────

const { featureSlug } = Astro.params;
const { primaryFeature, secondaryFeature, brandFilter, filteredProducts, label } = Astro.props;

const CARDS_PER_PAGE = 20;
const totalPages     = Math.ceil(filteredProducts.length / CARDS_PER_PAGE);

const pageTitle    = `${label} — Buy on Installments | MdogomdogoDeals Nairobi`;
const metaDesc     = `${primaryFeature.description} ${filteredProducts.length} phones available. No credit check. Free delivery in Nairobi CBD.`;
const canonicalUrl = `https://mdogomdogodeals.co.ke/features/${featureSlug}`;

const breadcrumbs = [
  { label: 'Home',       href: '/' },
  { label: 'All Phones', href: '/phones/lipa-mdogo-mdogo-nairobi' },
  { label: 'Features',   href: '/features/5g-phones-kenya' },
  ...(brandFilter      ? [{ label: `${brandFilter} Phones`,  href: `/phones/${brandFilter.toLowerCase()}` }] : []),
  { label: primaryFeature.label,  href: featureHref(primaryFeature.key) },
  ...(secondaryFeature ? [{ label: secondaryFeature.label,   href: featureHref(secondaryFeature.key) }] : []),
];

const hasFilters = !!(brandFilter || secondaryFeature);

const relatedFeatureLinks = FEATURE_FILTERS
  .filter(f => f.key !== primaryFeature.key && f.key !== secondaryFeature?.key)
  .filter(f => products.filter(f.match).length > 0)
  .slice(0, 8);

const allFeatureBrands = ALL_BRANDS.filter(b =>
  products.some(p => primaryFeature.match(p) && p.brand?.toLowerCase() === b.toLowerCase())
);

const crossLinks = FEATURE_FILTERS
  .filter(f => f.key !== primaryFeature.key && f.key !== secondaryFeature?.key)
  .filter(f => {
    const href = comboHref(primaryFeature.key, f.key);
    if (!href) return false;
    return products.filter(p => primaryFeature.match(p) && f.match(p)).length > 0;
  })
  .slice(0, 5);

function renderStars(rating) {
  const full = Math.floor(rating);
  return '★'.repeat(full) + '☆'.repeat(5 - full);
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={metaDesc} />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={pageTitle} />
  <meta property="og:description" content={metaDesc} />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:site_name"   content="MdogomdogoDeals" />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": label,
    "description": metaDesc,
    "numberOfItems": filteredProducts.length,
    "itemListElement": filteredProducts.slice(0, 20).map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "Product",
        "name": p.fullname ?? p.name,
        "brand": { "@type": "Brand", "name": p.brand },
        "image": p.source,
        "url": `https://mdogomdogodeals.co.ke/${p.slug}`,
        "offers": {
          "@type": "Offer",
          "priceCurrency": "KES",
          "price": p.deposit?.replace(/[^0-9]/g, '') ?? "0",
          "availability": "https://schema.org/InStock",
          "seller": { "@type": "Organization", "name": "MdogomdogoDeals" }
        }
      }
    }))
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbs.map((b, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": b.label,
      "item": `https://mdogomdogodeals.co.ke${b.href}`
    }))
  })} />

  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;600;700;900&family=Barlow:wght@400;500;600&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --primary: #1a73e8; --primary-dark: #1557b0; --primary-light: #e8f0fe;
      --gold: #f5a623; --navy: #0d1b2a; --green: #00b96b; --red: #e53935;
      --gray-1: #f5f7fa; --gray-2: #e8eaed; --gray-3: #9aa0a6;
      --text: #202124; --text-light: #5f6368;
      --badge-new: #00b96b; --badge-hot: #e53935; --badge-sale: #1a73e8;
      --border: #e8eaed;
      --shadow: 0 2px 12px rgba(0,0,0,0.07);
      --radius: 10px;
    }
    body { font-family: 'Barlow', sans-serif; background: var(--gray-1); color: var(--text); }

    /* ── Breadcrumbs ── */
    .breadcrumb-bar { background: #fff; border-bottom: 1px solid var(--border); padding: 10px 16px; }
    .breadcrumb-list { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; list-style: none; }
    .breadcrumb-list li { font-size: 13px; color: var(--text-light); }
    .breadcrumb-list li a { color: var(--primary); text-decoration: none; font-weight: 500; }
    .breadcrumb-list li a:hover { text-decoration: underline; }
    .breadcrumb-list li.sep { color: var(--gray-3); }

    /* ══════════════════════════════════════════
       PAGE HEADER (with mobile filter toggle)
    ══════════════════════════════════════════ */
    .page-header-strip {
      background: #fff;
      border-bottom: 1px solid var(--border);
      padding: 20px 24px;
    }
    .page-header-inner {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
    }

    /* Mobile filter toggle button */
    .filter-drawer-toggle {
      display: none;
      align-items: center; gap: 7px;
      background: #fff; border: 1.5px solid var(--border);
      border-radius: 8px; padding: 8px 14px;
      font-family: 'Barlow', sans-serif; font-size: 13.5px; font-weight: 600;
      color: var(--text); cursor: pointer; white-space: nowrap;
      flex-shrink: 0;
      transition: border-color 0.15s, color 0.15s;
      position: relative;
    }
    .filter-drawer-toggle:hover { border-color: var(--primary); color: var(--primary); }
    .filter-active-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--primary);
      position: absolute; top: 6px; right: 6px;
    }
    @media (max-width: 900px) {
      .filter-drawer-toggle { display: inline-flex; }
    }

    /* Active filter chips */
    .active-chips-bar {
      max-width: 1400px;
      margin: 12px auto 0;
      display: flex; align-items: center; flex-wrap: wrap; gap: 7px;
    }
    .active-chip {
      display: inline-flex; align-items: center; gap: 6px;
      background: var(--primary-light); border: 1.5px solid var(--primary);
      color: var(--primary); border-radius: 999px; padding: 5px 13px;
      font-size: 13px; font-weight: 600; text-decoration: none;
      transition: background 0.15s;
    }
    .active-chip:hover { background: #d2e3fc; }
    .chip-clear {
      display: inline-flex; align-items: center;
      font-size: 13px; color: var(--red); font-weight: 600;
      text-decoration: none; padding: 5px 13px; border-radius: 999px;
      border: 1.5px solid var(--red); background: #fdecea;
      transition: opacity 0.15s;
    }
    .chip-clear:hover { opacity: 0.75; }

    /* ══════════════════════════════════════════
       MAIN LAYOUT — sidebar + content
    ══════════════════════════════════════════ */
    .features-layout {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      align-items: flex-start;
      padding: 24px 20px;
    }

    /* ══════════════════════════════════════════
       FILTER SIDEBAR
    ══════════════════════════════════════════ */
    .filter-sidebar {
      width: 230px;
      flex-shrink: 0;
      background: #fff;
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      overflow-y: auto;
      max-height: calc(100vh - 32px);
      position: sticky;
      top: 16px;
      align-self: flex-start;
      margin-right: 20px;
      z-index: 10;
    }

    /* Sidebar header */
    .fs-head {
      display: flex; align-items: center; gap: 8px;
      padding: 14px 16px 12px;
      border-bottom: 1px solid var(--border);
    }
    .fs-title { font-family: 'Barlow Condensed', sans-serif; font-size: 16px; font-weight: 900; color: var(--navy); flex: 1; letter-spacing: 0.03em; text-transform: uppercase; }
    .fs-clear { font-size: 12px; color: var(--red); font-weight: 600; text-decoration: none; }
    .fs-clear:hover { text-decoration: underline; }
    .fs-close {
      display: none;
      background: none; border: none;
      font-size: 18px; color: var(--gray-3);
      cursor: pointer; line-height: 1; padding: 2px 4px;
    }

    /* Accordion groups */
    .filter-group { border-bottom: 1px solid var(--border); }
    .filter-group:last-of-type { border-bottom: none; }

    .fg-toggle {
      width: 100%; display: flex; align-items: center; justify-content: space-between;
      padding: 12px 16px; background: none; border: none;
      cursor: pointer; font-family: 'Barlow', sans-serif; text-align: left;
    }
    .fg-toggle-label { font-size: 13px; font-weight: 700; color: var(--text); }
    .fg-arrow { font-size: 16px; color: var(--gray-3); transition: transform 0.2s; line-height: 1; }
    .fg-toggle.open .fg-arrow { transform: rotate(90deg); }

    .fg-body { padding: 6px 12px 12px; }

    /* Filter pills */
    .fp-wrap { display: flex; flex-direction: column; gap: 3px; }
    .fp {
      display: block; padding: 6px 10px; border-radius: 6px;
      font-size: 13px; font-weight: 500; color: var(--text-light);
      text-decoration: none; transition: background 0.12s, color 0.12s;
    }
    .fp:hover { background: var(--primary-light); color: var(--primary); }
    .fp.fp-active { background: var(--primary); color: #fff; font-weight: 700; }

    /* Combo pills — distinct navy style */
    .fp.fp-combo { color: var(--navy); font-weight: 600; }
    .fp.fp-combo:hover { background: var(--primary-light); color: var(--primary); }
    .fp.fp-combo.fp-active { background: var(--navy); color: #fff; }

    /* Quick picks */
    .fs-quicklinks { padding: 12px 16px 14px; }
    .fs-ql-head {
      display: block; font-size: 10px; font-weight: 700; color: var(--gray-3);
      text-transform: uppercase; letter-spacing: 0.09em; margin-bottom: 8px;
    }
    .fs-ql-link {
      display: block; font-size: 12.5px; color: var(--primary); font-weight: 600;
      text-decoration: none; padding: 4px 0;
    }
    .fs-ql-link:hover { text-decoration: underline; }

    /* ── Mobile overlay ── */
    .filter-overlay {
      display: none;
      position: fixed; inset: 0; z-index: 9998;
      background: rgba(0,0,0,0.45);
    }
    .filter-overlay.overlay-show { display: block; }

    /* ── Mobile drawer ── */
    @media (max-width: 900px) {
      .features-layout { padding-top: 0; }

      .filter-sidebar {
        position: fixed;
        top: 0; left: 0; bottom: 0;
        width: 280px;
        max-width: 85vw;
        max-height: 100vh;
        z-index: 9999;
        border-radius: 0;
        border: none;
        border-right: 1.5px solid var(--border);
        transform: translateX(-110%);
        transition: transform 0.28s cubic-bezier(0.4,0,0.2,1);
        overflow-y: auto;
        margin-right: 0;
      }
      .filter-sidebar.drawer-open { transform: translateX(0); }
      .fs-close { display: block; }
    }

    /* ══════════════════════════════════════════
       CONTENT AREA
    ══════════════════════════════════════════ */
    .features-main { flex: 1; min-width: 0; }

    /* ── Feature hero ── */
    .feature-hero {
      background: var(--navy); border-radius: 12px;
      padding: 28px 32px; margin-bottom: 20px;
    }
    .feature-hero h1 {
      font-family: 'Barlow Condensed', sans-serif;
      font-size: clamp(22px, 3.5vw, 30px);
      font-weight: 900; color: #fff;
      margin-bottom: 8px; line-height: 1.15;
    }
    .feature-hero p { font-size: 14px; color: rgba(255,255,255,0.72); max-width: 640px; line-height: 1.65; }
    .hero-meta { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 16px; }
    .hero-tag {
      display: inline-flex; align-items: center;
      background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.18);
      border-radius: 4px; padding: 4px 10px;
      font-size: 12px; font-weight: 600; color: #fff; letter-spacing: 0.03em;
    }
    .result-count {
      display: inline-block; background: var(--primary); color: #fff;
      border-radius: 4px; padding: 3px 10px;
      font-size: 13px; font-weight: 700; margin-left: 10px; vertical-align: middle;
    }

    /* ── Product grid ── */
    .product-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; }
    @media (max-width: 1200px) { .product-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 900px)  { .product-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 480px)  { .product-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; } }

    .card { display: none; flex-direction: column; background: #fff; border-radius: var(--radius); overflow: hidden; border: 1.5px solid var(--border); transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s; position: relative; text-decoration: none; color: inherit; }
    .card.visible { display: flex; }
    .card:hover { border-color: var(--primary); box-shadow: 0 8px 28px rgba(26,115,232,0.12); transform: translateY(-3px); }

    .badge { position: absolute; top: 10px; left: 10px; z-index: 2; padding: 3px 9px; border-radius: 4px; font-family: 'Barlow Condensed', sans-serif; font-size: 12px; font-weight: 800; letter-spacing: 0.07em; text-transform: uppercase; color: #fff; }
    .badge-new  { background: var(--badge-new); }
    .badge-hot  { background: var(--badge-hot); }
    .badge-sale { background: var(--badge-sale); }
    .feat-pill { position: absolute; top: 10px; right: 10px; z-index: 2; background: var(--navy); color: #fff; border-radius: 4px; padding: 2px 7px; font-size: 10px; font-weight: 700; letter-spacing: 0.04em; text-transform: uppercase; }

    .card-img-wrap { width: 100%; aspect-ratio: 4/3; overflow: hidden; background: var(--gray-1); display: flex; align-items: center; justify-content: center; }
    .card-img { width: 100%; height: 100%; object-fit: contain; object-position: center; display: block; transition: transform 0.3s; }
    .card:hover .card-img { transform: scale(1.05); }

    .card-body { padding: 12px 12px 10px; flex: 1; display: flex; flex-direction: column; }
    .card-brand { font-size: 11px; font-weight: 600; color: var(--text-light); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 3px; }
    .card-name { font-size: 14px; font-weight: 600; color: var(--text); line-height: 1.35; margin-bottom: 6px; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .card-specs { display: flex; gap: 5px; flex-wrap: wrap; margin-bottom: 8px; }
    .spec-tag { background: var(--gray-1); border: 1px solid var(--border); color: var(--text-light); border-radius: 4px; padding: 2px 7px; font-size: 11px; }
    .spec-tag.highlight { background: var(--primary-light); border-color: var(--primary); color: var(--primary); font-weight: 700; }

    .stars { color: var(--gold); font-size: 13px; }
    .rating-count { font-size: 11.5px; color: var(--text-light); }
    .card-rating { display: flex; align-items: center; gap: 5px; margin-bottom: 9px; }

    .price-current { font-family: 'Barlow Condensed', sans-serif; font-size: 22px; font-weight: 900; color: var(--primary); }
    .price-save { font-size: 11.5px; font-weight: 700; color: var(--green); }
    .card-price { display: flex; align-items: baseline; gap: 7px; flex-wrap: wrap; margin-bottom: 6px; }
    .installment-note { font-size: 11.5px; color: var(--primary-dark); font-weight: 600; background: var(--primary-light); padding: 3px 8px; border-radius: 4px; margin-bottom: 10px; display: inline-block; }

    .card-cta { display: flex; gap: 7px; margin-top: auto; }
    .btn-cart { flex: 1; background: var(--primary); color: #fff; border: none; border-radius: 6px; padding: 9px 10px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: 'Barlow', sans-serif; }
    .btn-cart:hover { background: var(--primary-dark); }
    .btn-buy  { flex: 1; background: var(--navy); color: #fff; border: none; border-radius: 6px; padding: 9px 10px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: 'Barlow', sans-serif; }
    .btn-buy:hover { background: #162640; }

    .empty-state { grid-column: 1/-1; text-align: center; padding: 60px 20px; }
    .empty-state h2 { font-family: 'Barlow Condensed', sans-serif; font-size: 22px; color: var(--text-light); margin-bottom: 8px; }
    .empty-state a { color: var(--primary); font-weight: 600; }

    /* ── Pagination ── */
    .pagination-wrap { padding: 4px 0 32px; }
    .pagination-info { text-align: center; font-size: 13px; color: var(--text-light); margin-bottom: 14px; }
    .pagination-bar { display: flex; align-items: center; justify-content: center; gap: 5px; flex-wrap: wrap; }
    .page-btn { display: inline-flex; align-items: center; justify-content: center; min-width: 40px; height: 40px; padding: 0 12px; border: 1.5px solid var(--border); background: #fff; color: var(--text); border-radius: 8px; font-size: 14px; font-weight: 600; font-family: 'Barlow', sans-serif; cursor: pointer; transition: all 0.15s; }
    .page-btn:hover { border-color: var(--primary); color: var(--primary); background: var(--primary-light); }
    .page-btn.active { border-color: var(--primary); background: var(--primary); color: #fff; cursor: default; pointer-events: none; }
    .page-btn.disabled { opacity: 0.35; cursor: not-allowed; pointer-events: none; }
    .page-ellipsis { display: inline-flex; align-items: flex-end; justify-content: center; width: 32px; height: 40px; color: var(--text-light); font-size: 16px; padding-bottom: 4px; }

    /* ── Internal links ── */
    .internal-links { padding: 0 0 36px; }
    .il-section { margin-bottom: 28px; }
    .il-section h2 { font-family: 'Barlow Condensed', sans-serif; font-size: 17px; font-weight: 900; color: var(--navy); margin-bottom: 10px; text-transform: uppercase; letter-spacing: 0.04em; }
    .il-grid { display: flex; flex-wrap: wrap; gap: 7px; }
    .il-link { display: inline-flex; align-items: center; gap: 4px; background: #fff; border: 1.5px solid var(--border); border-radius: 6px; padding: 7px 13px; font-size: 13px; font-weight: 600; color: var(--text); text-decoration: none; transition: all 0.15s; }
    .il-link:hover { border-color: var(--primary); color: var(--primary); background: var(--primary-light); }
    .il-link .cnt { font-size: 11px; color: var(--text-light); margin-left: 2px; }
    .il-link.combo { border-color: var(--navy); color: var(--navy); }
    .il-link.combo:hover { border-color: var(--primary); color: var(--primary); background: var(--primary-light); }

    /* ── SEO section ── */
    .seo-section { padding: 0 0 56px; }
    .seo-section hr { border: none; border-top: 1px solid var(--border); margin-bottom: 28px; }
    .seo-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px 40px; }
    .seo-col h3 { font-family: 'Barlow Condensed', sans-serif; font-size: 14px; font-weight: 700; color: var(--text-light); text-transform: uppercase; letter-spacing: 0.07em; margin-bottom: 10px; }
    .seo-col p  { font-size: 13px; color: var(--text-light); line-height: 1.75; }
    .seo-col p a { color: var(--text-light); text-decoration: underline; text-decoration-color: var(--border); text-underline-offset: 2px; }
    .seo-col p a:hover { color: var(--primary); text-decoration-color: var(--primary); }
    .seo-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 16px; }
    .seo-tag { display: inline-block; background: #fff; border: 1px solid var(--border); border-radius: 6px; padding: 4px 10px; font-size: 12px; color: var(--text-light); text-decoration: none; transition: all 0.12s; }
    .seo-tag:hover { border-color: var(--primary); color: var(--primary); }

    @media (max-width: 700px) { .seo-grid { grid-template-columns: 1fr; gap: 20px; } }
    @media (max-width: 560px) { .feature-hero { padding: 20px; } }
  </style>
</head>
<body>

  <Gift/>
  <Nav/>

  <!-- ── Breadcrumbs ── -->
  <nav class="breadcrumb-bar" aria-label="Breadcrumb">
    <ol class="breadcrumb-list">
      {breadcrumbs.map((b, i) => (
        <>
          {i > 0 && <li class="sep">›</li>}
          <li>{i < breadcrumbs.length - 1 ? <a href={b.href}>{b.label}</a> : b.label}</li>
        </>
      ))}
    </ol>
  </nav>

  <!-- ── Page header strip ── -->
  <div class="page-header-strip">
    <div class="page-header-inner">
      <div><!-- spacer so toggle sits to the right --></div>

      <!-- Mobile filter toggle -->
      <button class="filter-drawer-toggle" id="filterToggleBtn" type="button" aria-label="Open filters">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" style="flex-shrink:0">
          <line x1="1" y1="3.5" x2="13" y2="3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="3" y1="7" x2="11" y2="7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          <line x1="5" y1="10.5" x2="9" y2="10.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        Filters
        {hasFilters && <span class="filter-active-dot"></span>}
      </button>
    </div>

    <!-- Active filter chips -->
    {hasFilters && (
      <div class="active-chips-bar">
        {brandFilter && (
          <a href={featureHref(primaryFeature.key)} class="active-chip">
            {brandFilter}
            <svg width="11" height="11" viewBox="0 0 11 11" fill="none" style="flex-shrink:0">
              <line x1="1.5" y1="1.5" x2="9.5" y2="9.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              <line x1="9.5" y1="1.5" x2="1.5" y2="9.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
          </a>
        )}
        {secondaryFeature && (
          <a href={featureHref(primaryFeature.key)} class="active-chip">
            {secondaryFeature.label}
            <svg width="11" height="11" viewBox="0 0 11 11" fill="none" style="flex-shrink:0">
              <line x1="1.5" y1="1.5" x2="9.5" y2="9.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
              <line x1="9.5" y1="1.5" x2="1.5" y2="9.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
            </svg>
          </a>
        )}
        <a href={featureHref(primaryFeature.key)} class="chip-clear">Clear all</a>
      </div>
    )}
  </div>

  <!-- ── Main layout: sidebar + content ── -->
  <div class="features-layout">

    <!-- Overlay (mobile) -->
    <div class="filter-overlay" id="filterOverlay"></div>

    <!-- ── Filter Sidebar ── -->
    <aside class="filter-sidebar" id="filterSidebar" aria-label="Filter phones by feature">

      <!-- Header -->
      <div class="fs-head">
        <span class="fs-title">Filters</span>
        {hasFilters && <a href={featureHref(primaryFeature.key)} class="fs-clear">Clear</a>}
        <button class="fs-close" id="filterCloseBtn" type="button" aria-label="Close filters">&#10005;</button>
      </div>

      <!-- ── Feature ── -->
      <div class="filter-group">
        <button class="fg-toggle open" type="button" data-group="feature">
          <span class="fg-toggle-label">Feature</span>
          <span class="fg-arrow" style="transform: rotate(90deg)">›</span>
        </button>
        <div class="fg-body">
          <div class="fp-wrap">
            {FEATURE_FILTERS.map(feat => (
              <a
                href={featureHref(feat.key)}
                class={`fp${feat.key === primaryFeature.key ? ' fp-active' : ''}`}
              >
                {feat.label}
              </a>
            ))}
          </div>
        </div>
      </div>

      <!-- ── Brand ── -->
      {allFeatureBrands.length > 1 && (
        <div class="filter-group">
          <button class="fg-toggle open" type="button" data-group="brand">
            <span class="fg-toggle-label">Brand</span>
            <span class="fg-arrow" style="transform: rotate(90deg)">›</span>
          </button>
          <div class="fg-body">
            <div class="fp-wrap">
              <a
                href={featureHref(primaryFeature.key)}
                class={`fp${!brandFilter ? ' fp-active' : ''}`}
              >
                All Brands
              </a>
              {allFeatureBrands.map(brand => (
                <a
                  href={featureHref(primaryFeature.key, brand)}
                  class={`fp${brandFilter?.toLowerCase() === brand.toLowerCase() ? ' fp-active' : ''}`}
                >
                  {brand}
                </a>
              ))}
            </div>
          </div>
        </div>
      )}

      <!-- ── Combine with ── -->
      {crossLinks.length > 0 && (
        <div class="filter-group">
          <button class="fg-toggle open" type="button" data-group="combo">
            <span class="fg-toggle-label">Combine with</span>
            <span class="fg-arrow" style="transform: rotate(90deg)">›</span>
          </button>
          <div class="fg-body">
            <div class="fp-wrap">
              {crossLinks.map(feat => {
                const href = comboHref(primaryFeature.key, feat.key);
                if (!href) return null;
                const isActive = secondaryFeature?.key === feat.key;
                return (
                  <a
                    href={href}
                    class={`fp fp-combo${isActive ? ' fp-active' : ''}`}
                  >
                    {primaryFeature.label} + {feat.label}
                  </a>
                );
              })}
            </div>
          </div>
        </div>
      )}

      <!-- ── Quick picks ── -->
      <div class="fs-quicklinks">
        <span class="fs-ql-head">Quick picks</span>
        <a href="/features/5g-phones-kenya"        class="fs-ql-link">5G Phones</a>
        <a href="/features/gaming-phones-kenya"    class="fs-ql-link">Gaming Phones</a>
        <a href="/features/amoled-phones-kenya"    class="fs-ql-link">AMOLED Display</a>
        <a href="/features/120hz-phones-kenya"     class="fs-ql-link">120Hz Refresh</a>
        <a href="/phones/deposit-under-5000"       class="fs-ql-link">Deposit under 5K</a>
        <a href="/phones/lipa-mdogo-mdogo-nairobi" class="fs-ql-link">All Installment Phones</a>
      </div>

    </aside>

    <!-- ── Content area ── -->
    <main class="features-main" id="featuresMain">

      <!-- Feature hero -->
      <div class="feature-hero">
        <h1>
          {label}
          <span class="result-count">{filteredProducts.length} phones</span>
        </h1>
        <p>{primaryFeature.description}</p>
        <div class="hero-meta">
          <span class="hero-tag">No Credit Check</span>
          <span class="hero-tag">Free Delivery — Nairobi CBD</span>
          <span class="hero-tag">Pay via M-Pesa</span>
          {brandFilter      && <span class="hero-tag">{brandFilter} Only</span>}
          {secondaryFeature && <span class="hero-tag">{secondaryFeature.label} Included</span>}
        </div>
      </div>

      <!-- Product grid -->
      <div class="product-grid" id="product-grid">
        {filteredProducts.length === 0 ? (
          <div class="empty-state">
            <h2>No phones found for this filter</h2>
            <p><a href="/phones/lipa-mdogo-mdogo-nairobi">View all phones</a> or try a different feature.</p>
          </div>
        ) : filteredProducts.map((p, i) => {
          const statusLower = p.status?.toLowerCase();
          const badgeClass  = statusLower === 'new' ? 'badge-new' : statusLower === 'hot' ? 'badge-hot' : 'badge-sale';
          const specs = [p.phonedisplay, p.processor?.split(' ').slice(-2).join(' '), p.battery?.split(',')[0]].filter(Boolean).slice(0, 3);
          const rating      = p.reviews?.averageRating ?? 4.5;
          const reviewCount = p.reviews?.reviewCount   ?? 0;
          const highlightSpec = (s) => {
            if (!s) return false;
            if (primaryFeature.key === '5g'           && s.includes('5G'))                   return true;
            if (primaryFeature.key === 'amoled'       && s.toLowerCase().includes('amoled'))  return true;
            if (primaryFeature.key === '120hz'        && s.includes('120'))                   return true;
            if (primaryFeature.key === '108mp-camera' && s.includes('108'))                   return true;
            return false;
          };
          return (
            <a href={`/${p.slug}`} class="card" data-index={i}>
              <span class={`badge ${badgeClass}`}>{p.status ?? 'NEW'}</span>
              <span class="feat-pill">{primaryFeature.label}</span>
              <div class="card-img-wrap">
                <img
                  class="card-img"
                  src={p.source}
                  alt={`${p.fullname ?? p.name} — ${primaryFeature.label} phone on installments in Kenya`}
                  loading="lazy"
                  width="300"
                  height="225"
                  decoding="async"
                />
              </div>
              <div class="card-body">
                <div class="card-brand">{p.brand}</div>
                <div class="card-name">{p.fullname}</div>
                <div class="card-specs">
                  {specs.map(s => <span class={`spec-tag${highlightSpec(s) ? ' highlight' : ''}`}>{s}</span>)}
                </div>
                <div class="card-rating">
                  <span class="stars">{renderStars(rating)}</span>
                  <span class="rating-count">({reviewCount})</span>
                </div>
                <div class="card-price">
                  <span class="price-current">{p.deposit}</span>
                  {p.discount && <span class="price-save">{p.discount}</span>}
                </div>
                <div class="installment-note">Small daily instalments · Deposit {p.deposit}</div>
                <div class="card-cta">
                  <button class="btn-cart">Add to Cart</button>
                  <button class="btn-buy">Buy Now</button>
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <!-- Pagination -->
      {filteredProducts.length > CARDS_PER_PAGE && (
        <div class="pagination-wrap" id="pagination-wrap">
          <p class="pagination-info" id="pagination-info"></p>
          <div class="pagination-bar" id="pagination-bar"></div>
        </div>
      )}

      <!-- Internal links -->
      <section class="internal-links" aria-label="Related phone categories">

        {allFeatureBrands.length > 0 && (
          <div class="il-section">
            <h2>{primaryFeature.label} Phones by Brand</h2>
            <div class="il-grid">
              {allFeatureBrands.map(brand => {
                const cnt = products.filter(p => primaryFeature.match(p) && p.brand?.toLowerCase() === brand.toLowerCase()).length;
                return (
                  <a href={featureHref(primaryFeature.key, brand)} class="il-link">
                    {brand} {primaryFeature.label} <span class="cnt">({cnt})</span>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        {brandFilter && (
          <div class="il-section">
            <h2>More {brandFilter} Phones</h2>
            <div class="il-grid">
              <a href={`/phones/${brandFilter.toLowerCase()}`} class="il-link">All {brandFilter} Phones</a>
              {FEATURE_FILTERS.filter(f => f.key !== primaryFeature.key).map(feat => {
                const cnt = products.filter(p => feat.match(p) && p.brand?.toLowerCase() === brandFilter.toLowerCase()).length;
                if (!cnt) return null;
                return (
                  <a href={featureHref(feat.key, brandFilter)} class="il-link">
                    {brandFilter} {feat.label} <span class="cnt">({cnt})</span>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        {crossLinks.length > 0 && (
          <div class="il-section">
            <h2>Popular Combinations with {primaryFeature.label}</h2>
            <div class="il-grid">
              {crossLinks.map(feat => {
                const href = comboHref(primaryFeature.key, feat.key);
                if (!href) return null;
                const cnt = products.filter(p => primaryFeature.match(p) && feat.match(p)).length;
                return (
                  <a href={href} class="il-link combo">
                    {primaryFeature.label} + {feat.label} <span class="cnt">({cnt})</span>
                  </a>
                );
              })}
            </div>
          </div>
        )}

        <div class="il-section">
          <h2>Other Feature Categories</h2>
          <div class="il-grid">
            {relatedFeatureLinks.map(feat => {
              const cnt = products.filter(feat.match).length;
              return (
                <a href={featureHref(feat.key)} class="il-link">
                  {feat.h1} <span class="cnt">({cnt})</span>
                </a>
              );
            })}
          </div>
        </div>

        <div class="il-section">
          <h2>{primaryFeature.label} Phones by Deposit</h2>
          <div class="il-grid">
            <a href="/phones/deposit-under-3000"       class="il-link">Deposit Under KSh 3,000</a>
            <a href="/phones/deposit-under-5000"       class="il-link">Deposit Under KSh 5,000</a>
            <a href="/phones/deposit-under-10000"      class="il-link">Deposit Under KSh 10,000</a>
            <a href="/phones/lipa-mdogo-mdogo-nairobi" class="il-link">All Lipa Mdogo Mdogo Phones</a>
          </div>
        </div>

      </section>

      <!-- SEO content -->
      <section class="seo-section" aria-label={`About ${primaryFeature.label} phones in Kenya`}>
        <hr />
        <div class="seo-grid">
          <div class="seo-col">
            <h3>{primaryFeature.label} Phones in Kenya</h3>
            <p>
              {primaryFeature.description}
              {brandFilter
                ? ` Browse all ${brandFilter} ${primaryFeature.label} phones on installments, or explore other brands below.`
                : ` Pay a small deposit and spread the rest weekly or daily via M-Pesa. No guarantor needed.`
              }
            </p>
            <div class="seo-tags">
              <a href={featureHref(primaryFeature.key)} class="seo-tag">{primaryFeature.label} phone Kenya</a>
              <a href={featureHref(primaryFeature.key)} class="seo-tag">{primaryFeature.label} phone Nairobi</a>
              <a href="/phones/lipa-mdogo-mdogo-nairobi" class="seo-tag">buy phone pay later Kenya</a>
              <a href="/phones/deposit-under-5000"        class="seo-tag">deposit under 5000</a>
              <a href="/phones/lipa-mdogo-mdogo-nairobi" class="seo-tag">lipa mdogo mdogo Nairobi</a>
            </div>
          </div>
          <div class="seo-col">
            <h3>Popular Brands</h3>
            <p>
              Looking for a specific brand?
              <a href="/features/samsung-5g-phones-kenya">Samsung 5G</a>,
              <a href="/features/xiaomi-5g-phones-kenya">Xiaomi 5G</a>,
              <a href="/features/tecno-gaming-phones-kenya">Tecno Gaming</a>, and
              <a href="/features/infinix-amoled-phones-kenya">Infinix AMOLED</a>
              are among the most searched phone categories in Kenya on installments.
            </p>
            <div class="seo-tags">
              {allFeatureBrands.slice(0, 6).map(brand => (
                <a href={featureHref(primaryFeature.key, brand)} class="seo-tag">
                  {brand} {primaryFeature.label}
                </a>
              ))}
            </div>
          </div>
          <div class="seo-col">
            <h3>How It Works</h3>
            <p>
              Order online and get same-day delivery in Nairobi CBD.
              Pay a deposit via M-Pesa, then choose <a href="/phones/lipa-mdogo-mdogo-nairobi">daily, weekly, or monthly</a> installments —
              whichever fits your budget. No hidden charges, no credit check.
            </p>
            <div class="seo-tags">
              <a href="/phones/lipa-mdogo-mdogo-nairobi" class="seo-tag">phone installment delivery Nairobi</a>
              <a href="/phones/lipa-mdogo-mdogo-nairobi" class="seo-tag">online order phone Kenya</a>
              <a href="/phones/storage-128gb"             class="seo-tag">128GB installment phone</a>
              <a href="/phones/storage-256gb"             class="seo-tag">256GB pay later Kenya</a>
              <a href="/phones/deposit-under-10000"       class="seo-tag">deposit below 10000</a>
            </div>
          </div>
        </div>
      </section>

    </main>
  </div>

  <!-- ── Scripts ── -->
  <script define:vars={{ totalPages, CARDS_PER_PAGE, totalProducts: filteredProducts.length }}>
  (function () {
    // ── Pagination ──────────────────────────────────────────────────────────
    const cards  = Array.from(document.querySelectorAll('#product-grid .card'));
    const infoEl = document.getElementById('pagination-info');
    const barEl  = document.getElementById('pagination-bar');

    if (!cards.length || totalPages <= 1) {
      cards.forEach(c => c.classList.add('visible'));
    } else {
      let currentPage = 1;

      function showPage(page) {
        currentPage = page;
        const start = (page - 1) * CARDS_PER_PAGE;
        const end   = start + CARDS_PER_PAGE;
        cards.forEach((c, i) => c.classList.toggle('visible', i >= start && i < end));
        infoEl.textContent = `Showing ${start + 1}–${Math.min(end, totalProducts)} of ${totalProducts} phones`;
        buildBar(page);
        document.getElementById('product-grid').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      function buildBar(active) {
        barEl.innerHTML = '';
        const make = (label, page, cls) => {
          const btn = document.createElement('button');
          btn.className = 'page-btn' + (cls ? ' ' + cls : '');
          btn.innerHTML = label;
          if (page !== null) btn.addEventListener('click', () => showPage(page));
          return btn;
        };
        const dot = () => { const s = document.createElement('span'); s.className = 'page-ellipsis'; s.textContent = '…'; return s; };
        const prev = make('&#8592;', active - 1);
        if (active === 1) prev.classList.add('disabled');
        barEl.appendChild(prev);
        const nums = [...new Set([1, totalPages, active, active - 1, active + 1].filter(p => p >= 1 && p <= totalPages))].sort((a, b) => a - b);
        let last = 0;
        nums.forEach(p => {
          if (p - last > 1) barEl.appendChild(dot());
          barEl.appendChild(make(p, p, p === active ? 'active' : ''));
          last = p;
        });
        const next = make('&#8594;', active + 1);
        if (active === totalPages) next.classList.add('disabled');
        barEl.appendChild(next);
      }

      showPage(1);
    }

    // ── Accordion toggles ───────────────────────────────────────────────────
    document.querySelectorAll('.fg-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const body  = btn.nextElementSibling;
        const arrow = btn.querySelector('.fg-arrow');
        const isOpen = btn.classList.toggle('open');
        body.style.display    = isOpen ? '' : 'none';
        arrow.style.transform = isOpen ? 'rotate(90deg)' : 'rotate(0deg)';
      });
    });

    // ── Drawer (mobile) ─────────────────────────────────────────────────────
    const sidebar   = document.getElementById('filterSidebar');
    const overlay   = document.getElementById('filterOverlay');
    const toggleBtn = document.getElementById('filterToggleBtn');
    const closeBtn  = document.getElementById('filterCloseBtn');

    function openDrawer() {
      sidebar.classList.add('drawer-open');
      overlay.classList.add('overlay-show');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      sidebar.classList.remove('drawer-open');
      overlay.classList.remove('overlay-show');
      document.body.style.overflow = '';
    }

    toggleBtn?.addEventListener('click', openDrawer);
    closeBtn?.addEventListener('click', closeDrawer);
    overlay?.addEventListener('click', closeDrawer);

    // Close on any filter link click inside sidebar
    sidebar?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeDrawer);
    });
  })();
  </script>

</body>
</html>
