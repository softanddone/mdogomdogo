---
export const prerender = true;

import { products } from "../data/offerproduct";
import Related from "../components/Related.astro"

export async function getStaticPaths() {
  return products.map((product) => ({
    params: { offer: product.slug },
  }));
}

const { offer } = Astro.params;
const currentProduct = products.find((p) => p.slug === offer);

if (!currentProduct) {
  return Astro.redirect("/404");
}

const productList = [currentProduct];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  
  <title>{currentProduct.name + " | Lipa Mdogo Mdogo Kenya"}</title>

  <meta name="description" content={`Buy ${currentProduct.name} on Lipa Mdogo Mdogo in Nairobi & Kiambu. Pay slowly, own it easily. Home delivery available.`} />
  <link rel="canonical" href={`https://mdogomdogodeals.co.ke/${currentProduct.slug}`} />

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;0,9..40,600;1,9..40,300&display=swap" rel="stylesheet">

  <!-- Open Graph -->
  <meta property="og:type" content="product" />
