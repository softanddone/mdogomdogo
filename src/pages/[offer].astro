    --c-border:    #E5E3DC;
    --c-ink:       #141210;
    --c-ink-2:     #6B6860;
    --c-ink-3:     #A09E9A;
    --c-accent:    #1A6B3C;
    --c-accent-bg: #EBF5EF;
    --c-wa:        #25D366;
    --c-wa-dark:   #1EAF55;
    --c-amber:     #92400E;
    --c-amber-bg:  #FEF3C7;
    --c-blue:      #1E40AF;
    --c-blue-bg:   #EFF6FF;
    --c-blue-bdr:  #BFDBFE;
    --shadow-s:    0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
    --shadow-m:    0 4px 12px rgba(0,0,0,.08);
    --shadow-l:    0 12px 32px rgba(0,0,0,.1);
    --r-s: 8px;
    --r-m: 12px;
    --r-l: 16px;
    --r-xl: 20px;
    --ease: cubic-bezier(.4,0,.2,1);
    --font-head: 'Sora', sans-serif;
    --font-body: 'DM Sans', sans-serif;
  }

  /* ===== RESET ===== */
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  ul { list-style: none; }
  a { text-decoration: none; }
  button { font-family: inherit; cursor: pointer; }

  body {
    font-family: var(--font-body);
    background: var(--c-bg);
    color: var(--c-ink);
    -webkit-font-smoothing: antialiased;
    display: flex;
    flex-direction: column;
    align-items: center;
    width: 100vw;
    overflow-x: hidden;
  }

  /* ===== LAYOUT ===== */
  .pg-container {
    width: 100%;
    max-width: 1360px;
    padding: 0 16px 120px;
  }

  .pg-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
  }

  /* ===== TOP BAR ===== */
  .pg-topbar {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 0 14px;
  }
  .pg-topbar-spacer { flex: 1; }

  .pg-call-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    color: var(--c-ink);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    padding: 9px 14px;
    border-radius: var(--r-s);
    box-shadow: var(--shadow-s);
    transition: box-shadow .2s var(--ease), transform .2s var(--ease);
  }
  .pg-call-btn:hover {
    box-shadow: var(--shadow-m);
    transform: translateY(-1px);
  }

  .pg-share-btn {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    background: transparent;
    border: 1px solid var(--c-border);
    color: var(--c-ink-2);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    padding: 9px 14px;
    border-radius: var(--r-s);
    transition: background .2s, color .2s;
  }
  .pg-share-btn:hover {
    background: var(--c-surface);
    color: var(--c-ink);
  }

  /* ===== IMAGE CAROUSEL ===== */
  .pg-image-col { position: relative; }

  .pg-carousel {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    background: var(--c-surface);
    border-radius: var(--r-xl);
    overflow: hidden;
    border: 1px solid var(--c-border);
    box-shadow: var(--shadow-l);
  }

  .pg-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity .55s var(--ease);
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .pg-slide.active {
    opacity: 1;
    animation: pgFade .55s var(--ease);
  }
  @keyframes pgFade {
    from { opacity: 0; transform: scale(.98); }
    to   { opacity: 1; transform: scale(1); }
  }

  .pg-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 24px;
    user-select: none;
    -webkit-user-drag: none;
  }

  .pg-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(255,255,255,.92);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(0,0,0,.08);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-m);
    color: var(--c-ink);
    transition: transform .25s var(--ease), box-shadow .25s var(--ease), background .2s;
    z-index: 5;
  }
  .pg-nav:hover {
    background: #fff;
    transform: translateY(-50%) scale(1.08);
    box-shadow: var(--shadow-l);
  }
  .pg-nav:active { transform: translateY(-50%) scale(.95); }
  .pg-nav--prev { left: 12px; }
  .pg-nav--next { right: 12px; }

  .pg-dots {
    position: absolute;
    bottom: 14px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    background: rgba(0,0,0,.35);
    backdrop-filter: blur(10px);
    padding: 7px 12px;
    border-radius: 99px;
    z-index: 5;
  }

  .pg-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    background: rgba(255,255,255,.45);
    padding: 0;
    cursor: pointer;
    transition: background .3s, width .3s var(--ease);
  }
  .pg-dot.active {
    background: #fff;
    width: 18px;
    border-radius: 3px;
  }

  /* ===== MOBILE TRUST ROW ===== */
  .pg-trust-row {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-top: 14px;
  }

  .pg-trust-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 12px 14px;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r-s);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--c-ink);
    box-shadow: var(--shadow-s);
  }
  .pg-trust-item svg { color: var(--c-accent); flex-shrink: 0; }

  /* ===== DETAILS COLUMN ===== */
  .pg-details-col {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  /* ===== HEADER ===== */
  .pg-header { display: flex; flex-direction: column; gap: 10px; }

  .pg-badges { display: flex; flex-wrap: wrap; gap: 8px; }

  .pg-badge {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    padding: 6px 12px;
    border-radius: 99px;
    font-family: var(--font-body);
    font-size: 11.5px;
    font-weight: 700;
    letter-spacing: .02em;
    text-transform: uppercase;
  }
  .pg-badge--green {
    background: var(--c-accent-bg);
    color: var(--c-accent);
  }
  .pg-badge--amber {
    background: var(--c-amber-bg);
    color: var(--c-amber);
  }

  .pg-title {
    font-family: var(--font-head);
    font-size: 26px;
    font-weight: 800;
    color: var(--c-ink);
    line-height: 1.2;
    letter-spacing: -.025em;
  }

  /* ===== PRICING ===== */
  .pg-pricing {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r-xl);
    padding: 22px 20px 18px;
    box-shadow: var(--shadow-m);
  }

  .pg-pricing-label {
    font-family: var(--font-head);
    font-size: 17px;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -.01em;
    margin-bottom: 4px;
  }
  .pg-pricing-sub {
    font-family: var(--font-body);
    font-size: 13px;
    color: var(--c-ink-2);
    margin-bottom: 18px;
  }

  .pg-pricing-grid {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 16px;
  }

  .pg-pricing-block {
    border-radius: var(--r-m);
    padding: 16px;
    border: 1.5px solid transparent;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .pg-pricing-block--deposit {
    background: var(--c-blue-bg);
    border-color: var(--c-blue-bdr);
  }
  .pg-pricing-block--daily {
    background: var(--c-accent-bg);
    border-color: #A7F3D0;
  }

  .pg-block-label {
    font-family: var(--font-body);
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--c-ink-2);
  }

  .pg-block-amount {
    display: flex;
    align-items: baseline;
    gap: 3px;
    margin: 2px 0;
  }

  .pg-block-currency {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    color: var(--c-ink-2);
  }

  .pg-block-num {
    font-family: var(--font-head);
    font-size: 18px;
    /* font-weight: 800; */
    color: var(--c-ink);
    letter-spacing: -.03em;
    line-height: 1;
  }

  .pg-block-per {
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--c-ink-2);
  }

  .pg-block-tag {
    font-family: var(--font-body);
    font-size: 10.5px;
    font-weight: 700;
    color: var(--c-ink-3);
    text-transform: uppercase;
    letter-spacing: .06em;
  }

  .pg-pricing-divider {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 4px;
  }
  .pg-divider-line { flex: 1; height: 1px; background: var(--c-border); }
  .pg-divider-word {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 700;
    color: var(--c-ink-3);
    text-transform: uppercase;
    letter-spacing: .1em;
  }

  .pg-pricing-perks {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding-top: 16px;
    border-top: 1px solid var(--c-border);
  }

  .pg-perk {
    display: flex;
    align-items: center;
    gap: 9px;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--c-ink);
  }
  .pg-perk svg { color: var(--c-accent); flex-shrink: 0; }

  /* ===== CTA ROW ===== */
  .pg-cta-row {
    display: flex;
    gap: 10px;
  }

  .pg-cta-primary {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    background: var(--c-wa);
    color: #fff;
    font-family: var(--font-head);
    font-size: 15px;
    font-weight: 700;
    padding: 15px 20px;
    border-radius: var(--r-m);
    box-shadow: 0 4px 18px rgba(37,211,102,.3);
    transition: background .25s, box-shadow .25s, transform .25s var(--ease);
    letter-spacing: -.01em;
  }
  .pg-cta-primary:hover {
    background: var(--c-wa-dark);
    box-shadow: 0 6px 24px rgba(37,211,102,.4);
    transform: translateY(-2px);
  }
  .pg-cta-primary:active { transform: translateY(0); }

  .pg-cta-share {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: var(--c-surface);
    color: var(--c-ink);
    border: 1px solid var(--c-border);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    padding: 15px 18px;
    border-radius: var(--r-m);
    box-shadow: var(--shadow-s);
    transition: box-shadow .2s, transform .2s var(--ease);
  }
  .pg-cta-share:hover {
    box-shadow: var(--shadow-m);
    transform: translateY(-1px);
  }

  /* ===== SECTIONS ===== */
  .pg-section {
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r-l);
    padding: 18px;
    box-shadow: var(--shadow-s);
  }

  .pg-section-title {
    display: flex;
    align-items: center;
    gap: 10px;
    font-family: var(--font-head);
    font-size: 16px;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -.01em;
    margin-bottom: 14px;
  }

  .pg-section-bar {
    width: 3px;
    height: 18px;
    background: var(--c-accent);
    border-radius: 2px;
    flex-shrink: 0;
  }

  /* ===== HOW IT WORKS ===== */
  .pg-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .pg-step {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 14px;
    background: var(--c-bg);
    border-radius: var(--r-s);
    border: 1px solid var(--c-border);
    transition: box-shadow .2s, transform .2s var(--ease);
  }
  .pg-step:hover { box-shadow: var(--shadow-m); transform: translateY(-2px); }

  .pg-step-num {
    font-family: var(--font-head);
    font-size: 11px;
    font-weight: 800;
    color: #fff;
    background: var(--c-ink);
    width: 30px;
    height: 30px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    letter-spacing: .02em;
  }

  .pg-step-body h4 {
    font-family: var(--font-head);
    font-size: 13px;
    font-weight: 700;
    color: var(--c-ink);
    margin-bottom: 4px;
  }

  .pg-step-body p {
    font-family: var(--font-body);
    font-size: 12.5px;
    color: var(--c-ink-2);
    line-height: 1.5;
  }

  /* ===== DESCRIPTION ===== */
  .pg-description {
    font-family: var(--font-body);
    font-size: 14px;
    line-height: 1.75;
    color: var(--c-ink-2);
  }

  /* ===== FEATURES ===== */
  .pg-features {
    display: grid;
    grid-template-columns: 1fr;
    gap: 8px;
  }

  .pg-feature {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    padding: 11px 12px;
    background: var(--c-bg);
    border-radius: var(--r-s);
    border: 1px solid var(--c-border);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 500;
    color: var(--c-ink);
    line-height: 1.55;
    transition: transform .2s var(--ease), box-shadow .2s;
  }
  .pg-feature:hover { transform: translateX(3px); box-shadow: var(--shadow-s); }
  .pg-feature svg { color: var(--c-accent); flex-shrink: 0; margin-top: 2px; }

  /* ===== DELIVERY ===== */
  .pg-delivery {
    display: flex;
    gap: 16px;
    background: var(--c-blue-bg);
    border: 1px solid var(--c-blue-bdr);
    border-radius: var(--r-l);
    padding: 18px;
  }

  .pg-delivery-icon {
    width: 46px;
    height: 46px;
    background: var(--c-blue);
    border-radius: var(--r-s);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: #fff;
  }

  .pg-delivery-text h4 {
    font-family: var(--font-head);
    font-size: 15px;
    font-weight: 700;
    color: var(--c-blue);
    margin-bottom: 8px;
  }
  .pg-delivery-text p {
    font-family: var(--font-body);
    font-size: 13px;
    color: #1e3a8a;
    line-height: 1.6;
    margin-bottom: 4px;
  }
  .pg-delivery-text strong { font-weight: 700; }
  .pg-delivery-note {
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid var(--c-blue-bdr);
    font-family: var(--font-body);
    font-size: 12.5px;
    font-weight: 700;
    color: var(--c-blue);
  }

  /* ===== TRUST CARDS desktop ===== */
  .pg-trust-cards {
    display: grid;
    grid-template-columns: 1fr;
    gap: 10px;
  }

  .pg-trust-card {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px;
    background: var(--c-surface);
    border: 1px solid var(--c-border);
    border-radius: var(--r-m);
    box-shadow: var(--shadow-s);
    transition: box-shadow .2s, transform .2s var(--ease);
  }
  .pg-trust-card:hover { box-shadow: var(--shadow-m); transform: translateY(-2px); }

  .pg-trust-icon {
    width: 44px;
    height: 44px;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: var(--r-s);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: var(--c-ink);
  }

  .pg-trust-card h4 {
    font-family: var(--font-head);
    font-size: 13px;
    font-weight: 700;
    color: var(--c-ink);
    margin-bottom: 2px;
  }
  .pg-trust-card p {
    font-family: var(--font-body);
    font-size: 12px;
    color: var(--c-ink-2);
  }

  /* ===== MOBILE STICKY CTA ===== */
  .pg-sticky {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    background: rgba(255,255,255,.95);
    backdrop-filter: blur(16px);
    border-top: 1px solid var(--c-border);
    padding: 12px 16px;
    box-shadow: 0 -4px 20px rgba(0,0,0,.07);
    z-index: 900;
  }

  .pg-sticky-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    max-width: 1360px;
    margin: 0 auto;
  }

  .pg-sticky-prices { display: flex; flex-direction: column; gap: 1px; }

  .pg-sticky-dep {
    font-family: var(--font-head);
    font-size: 17px;
    font-weight: 800;
    color: var(--c-ink);
    letter-spacing: -.025em;
  }

  .pg-sticky-day {
    font-family: var(--font-body);
    font-size: 11px;
    font-weight: 500;
    color: var(--c-ink-2);
  }

  .pg-sticky-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    background: var(--c-wa);
    color: #fff;
    font-family: var(--font-head);
    font-size: 14px;
    font-weight: 700;
    padding: 12px 20px;
    border-radius: var(--r-m);
    box-shadow: 0 4px 14px rgba(37,211,102,.3);
    flex-shrink: 0;
    transition: background .2s;
  }
  .pg-sticky-btn:active { background: var(--c-wa-dark); transform: scale(.97); }

  /* ===== SHARE MODAL ===== */
  .pg-modal {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 1500;
    align-items: flex-end;
    justify-content: center;
    padding: 0;
  }
  .pg-modal.active { display: flex; }

  .pg-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,.5);
    backdrop-filter: blur(4px);
  }

  .pg-modal-box {
    position: relative;
    background: var(--c-surface);
    border-radius: 20px 20px 0 0;
    padding: 24px 20px 32px;
    width: 100%;
    max-width: 540px;
    box-shadow: var(--shadow-l);
    animation: pgSlideUp .3s var(--ease);
  }

  @keyframes pgSlideUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .pg-modal-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 18px;
  }
  .pg-modal-head h3 {
    font-family: var(--font-head);
    font-size: 17px;
    font-weight: 700;
    color: var(--c-ink);
    letter-spacing: -.01em;
  }

  .pg-modal-close {
    width: 32px;
    height: 32px;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: var(--r-s);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--c-ink-2);
    transition: background .2s, color .2s;
  }
  .pg-modal-close:hover { background: var(--c-border); color: var(--c-ink); }

  .pg-modal-options { display: flex; flex-direction: column; gap: 8px; }

  .pg-modal-opt {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px;
    background: var(--c-bg);
    border: 1px solid var(--c-border);
    border-radius: var(--r-m);
    font-family: var(--font-body);
    font-size: 14px;
    font-weight: 600;
    color: var(--c-ink);
    transition: background .2s, transform .2s var(--ease);
    text-align: left;
  }
  .pg-modal-opt:hover { background: var(--c-border); transform: translateX(3px); }

  .pg-opt-icon {
    width: 40px;
    height: 40px;
    border-radius: var(--r-s);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .pg-opt-icon--wa   { background: #dcfce7; color: #16a34a; }
  .pg-opt-icon--fb   { background: #dbeafe; color: #2563eb; }
  .pg-opt-icon--tw   { background: #f1f5f9; color: #0f172a; }
  .pg-opt-icon--copy { background: var(--c-border); color: var(--c-ink); }

  /* ===== TOAST ===== */
  .pg-toast {
    position: fixed;
    bottom: 100px;
    left: 50%;
    transform: translateX(-50%) translateY(12px);
    background: var(--c-ink);
    color: #fff;
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    padding: 11px 18px;
    border-radius: 99px;
    display: flex;
    align-items: center;
    gap: 8px;
    opacity: 0;
    pointer-events: none;
    transition: all .4s var(--ease);
    z-index: 2000;
    white-space: nowrap;
  }
  .pg-toast.show {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
  }
  .pg-toast svg { color: var(--c-wa); }

  /* ===== UTILITIES ===== */
  .mobile-only  { display: flex; }
  .desktop-only { display: none; }

  /* ===== RESPONSIVE ===== */
  @media (min-width: 540px) {
    .pg-trust-row { flex-direction: row; }
    .pg-trust-item { flex: 1; }
    .pg-steps { grid-template-columns: repeat(2, 1fr); }
    .pg-features { grid-template-columns: repeat(2, 1fr); }
    .pg-modal-box { border-radius: var(--r-xl); }
  }

  @media (min-width: 768px) {
    .pg-container { padding: 0 24px; }
    .pg-grid { grid-template-columns: 1fr 1fr; gap: 40px; align-items: start; }
    .pg-image-col .pg-carousel { position: sticky; top: 24px; }
    .pg-title { font-size: 30px; }
    .pg-block-num { font-size: 18px; }
    .pg-steps { grid-template-columns: repeat(2, 1fr); }
    .pg-features { grid-template-columns: repeat(2, 1fr); }
    .pg-trust-row.mobile-only { display: none; }
    .pg-sticky { display: none; }
    .desktop-only { display: flex; }
    .pg-cta-row { display: flex; }
    .pg-img { padding: 36px; }
    .pg-modal { align-items: center; }
    .pg-modal-box { border-radius: var(--r-xl); max-width: 420px; }
  }

  @media (min-width: 1024px) {
    .pg-grid { grid-template-columns: 540px 1fr; gap: 56px; }
    .pg-details-col { gap: 20px; }
    .pg-trust-cards { grid-template-columns: 1fr; }
    .pg-title { font-size: 34px; }
  }
</style>

<script>
  document.addEventListener("contextmenu", e => e.preventDefault());
  document.addEventListener("dragstart", e => {
    if ((e.target as HTMLElement).tagName === "IMG") e.preventDefault();
  });

  // Carousel
  const slides     = document.querySelectorAll<HTMLElement>('.pg-slide');
  const dots       = document.querySelectorAll<HTMLButtonElement>('.pg-dot');
  const prevBtn    = document.querySelector<HTMLButtonElement>('.pg-nav--prev');
  const nextBtn    = document.querySelector<HTMLButtonElement>('.pg-nav--next');
  const carousel   = document.getElementById('carousel');

  let current = 0;
  let timer: number | null = null;

  function goto(i: number) {
    slides[current].classList.remove('active');
    dots[current]?.classList.remove('active');
    current = (i + slides.length) % slides.length;
    slides[current].classList.add('active');
    dots[current]?.classList.add('active');
  }

  function start() {
    if (slides.length > 1) timer = window.setInterval(() => goto(current + 1), 3500);
  }
  function stop() { if (timer) { clearInterval(timer); timer = null; } }
  function reset() { stop(); start(); }

  prevBtn?.addEventListener('click', () => { goto(current - 1); reset(); });
  nextBtn?.addEventListener('click', () => { goto(current + 1); reset(); });
  dots.forEach((d, i) => d.addEventListener('click', () => { goto(i); reset(); }));
  carousel?.addEventListener('mouseenter', stop);
  carousel?.addEventListener('mouseleave', start);
  start();

  // Share Modal
  const shareModal   = document.getElementById('shareModal')!;
  const closeModal   = document.getElementById('closeModal')!;
  const backdrop     = document.querySelector('.pg-modal-backdrop')!;
  const toast        = document.getElementById('toast')!;

  function openModal()  { shareModal.classList.add('active'); }
  function closeModal2(){ shareModal.classList.remove('active'); }

  document.getElementById('shareBtn')?.addEventListener('click', openModal);
  document.getElementById('shareBtn2')?.addEventListener('click', openModal);
  closeModal.addEventListener('click', closeModal2);
  backdrop.addEventListener('click', closeModal2);

  const url   = encodeURIComponent(window.location.href);
  const title = encodeURIComponent(document.title);

  const waShare = document.getElementById('whatsappShare');
  const fbShare = document.getElementById('facebookShare');
  const twShare = document.getElementById('twitterShare');
  const cpLink  = document.getElementById('copyLink');

  if (waShare) waShare.setAttribute('href', `https://wa.me/?text=${title}%20${url}`);
  if (fbShare) fbShare.setAttribute('href', `https://www.facebook.com/sharer/sharer.php?u=${url}`);
  if (twShare) twShare.setAttribute('href', `https://twitter.com/intent/tweet?url=${url}&text=${title}`);

  cpLink?.addEventListener('click', async () => {
    try {
      await navigator.clipboard.writeText(window.location.href);
      closeModal2();
      toast.classList.add('show');
      setTimeout(() => toast.classList.remove('show'), 3000);
    } catch (e) {
      console.error('Copy failed', e);
    }
  });
</script>

</body>
</html>
