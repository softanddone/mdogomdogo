---
import { products } from '../data/product2.js';
import {
  ALL_BRANDS,
  DEPOSIT_FILTERS,
  STORAGE_FILTERS,
  brandSlug,
  parseDeposit,
} from '../data/filter-config.js';
import Gift from '../components/Gift.astro';
import Nav from '../components/Nav.astro';

const featured    = products.slice(0, 5);
const flashDeals  = products.filter(p => p.discount).slice(0, 4);
const budgetPicks = products.filter(p => parseDeposit(p.deposit) < 5000).slice(0, 5);
const samsungList = products.filter(p => p.brand?.toLowerCase() === 'samsung').slice(0, 5);
const tecnoList   = products.filter(p => p.brand?.toLowerCase() === 'tecno').slice(0, 5);
const infinixList = products.filter(p => p.brand?.toLowerCase() === 'infinix').slice(0, 5);

function renderStars(rating) {
  const full = Math.floor(rating ?? 4.5);
  return '★'.repeat(full) + '☆'.repeat(5 - full);
}

const pageTitle = 'MdogomdogoDeals — Lipa Mdogo Mdogo Phones Nairobi | Pay Weekly via M-Pesa';
const metaDesc  = 'Buy smartphones on installments in Nairobi. Pay a small deposit from KSh 2,000 and spread the rest weekly via M-Pesa. Samsung, Tecno, Infinix — no credit check, free delivery Nairobi CBD.';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={metaDesc} />
  <link rel="canonical" href="https://mdogomdogodeals.co.ke/" />
  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={pageTitle} />
  <meta property="og:description" content={metaDesc} />
  <meta property="og:url"         content="https://mdogomdogodeals.co.ke/" />
  <meta property="og:site_name"   content="MdogomdogoDeals" />

  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* — Warm, trustworthy palette — */
      --ink:        #1a1f2e;
      --ink-mid:    #2d3444;
      --ink-light:  #5a6478;
      --ink-faint:  #9aa3b2;

      --blue:       #1a56db;
      --blue-dark:  #1341b0;
      --blue-bg:    #eef3ff;
      --blue-line:  #c5d5fb;

      --green:      #0a7c3e;
      --green-bg:   #edfaf3;

      --red:        #c92424;
      --red-bg:     #fff2f2;

      --canvas:     #ffffff;
      --surface:    #f4f6f9;
      --border:     #dce1ea;
      --border-mid: #eaecf0;

      --radius-sm: 6px;
      --radius-md: 10px;
      --radius-lg: 14px;
      --shadow-sm: 0 1px 3px rgba(26,31,46,0.08);
      --shadow-md: 0 4px 18px rgba(26,31,46,0.1);
      --shadow-lg: 0 10px 36px rgba(26,31,46,0.13);
    }

    body { font-family: 'Inter', sans-serif; background: var(--canvas); color: var(--ink-mid); -webkit-font-smoothing: antialiased; }
    a { text-decoration: none; color: inherit; }
    img { display: block; }

    /* TOP BAR */
    .top-bar {
      background: #1a2744;
      color: #8fa3c0;
      font-size: 12px;
      font-weight: 500;
      padding: 6px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }
    .top-bar-pills { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; }
    .top-pill { display: flex; align-items: center; gap: 5px; background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.14); border-radius: 20px; padding: 3px 10px; font-size: 11.5px; color: #d4e0f0; white-space: nowrap; }
    .top-pill svg { width: 10px; height: 10px; color: #7eb3e8; flex-shrink: 0; }
    .top-bar-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
    .top-phone { font-size: 11.5px; color: #d4e0f0; font-weight: 600; white-space: nowrap; }
    .top-wa { background: #1a7a35; color: #fff; border-radius: 6px; padding: 5px 12px; font-size: 11.5px; font-weight: 600; display: flex; align-items: center; gap: 5px; white-space: nowrap; }
    .top-wa svg { width: 12px; height: 12px; }
    @media (max-width: 700px) {
      .top-bar {
        flex-direction: column;
        align-items: stretch;
        gap: 0;
        padding: 0;
      }
      /* Row 1 — pills, left-aligned, full width */
      .top-bar-pills {
        justify-content: flex-start;
        gap: 5px;
        padding: 7px 14px;
        flex-wrap: wrap;
      }
      .top-pill {
        font-size: 11px;
        padding: 3px 9px;
      }
      /* Row 2 — phone and WhatsApp as two equal blocks */
      .top-bar-right {
        display: grid;
        grid-template-columns: 1fr 1fr;
        border-top: 1px solid rgba(255,255,255,0.1);
      }
      .top-phone {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        padding: 8px 12px;
        border-right: 1px solid rgba(255,255,255,0.1);
        font-size: 12px;
        font-weight: 700;
        color: #d4e0f0;
      }
      .top-wa {
        justify-content: center;
        border-radius: 0;
        padding: 8px 12px;
        font-size: 12px;
      }
    }

    /* SITE HEADER */
    .site-header { background: var(--canvas); border-bottom: 1px solid var(--border); padding: 13px 24px; display: flex; align-items: center; justify-content: space-between; gap: 16px; position: sticky; top: 0; z-index: 100; box-shadow: var(--shadow-sm); }
    .logo { font-size: 20px; font-weight: 800; color: var(--ink); letter-spacing: -0.5px; white-space: nowrap; }
    .logo em { color: var(--blue); font-style: normal; }
    .logo-badge { display: inline-block; background: var(--blue); color: #fff; font-size: 9px; font-weight: 700; padding: 2px 6px; border-radius: 4px; margin-left: 5px; letter-spacing: 0.05em; vertical-align: middle; text-transform: uppercase; }
    .header-search { flex: 1; max-width: 480px; display: flex; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-md); overflow: hidden; transition: border-color 0.15s, box-shadow 0.15s; }
    .header-search:focus-within { border-color: var(--blue); box-shadow: 0 0 0 3px rgba(26,86,219,0.1); background: var(--canvas); }
    .header-search input { flex: 1; border: none; outline: none; padding: 10px 14px; font-size: 14px; font-family: 'Inter', sans-serif; color: var(--ink-mid); background: transparent; }
    .header-search input::placeholder { color: var(--ink-faint); }
    .header-search button { background: var(--blue); border: none; color: #fff; padding: 0 18px; cursor: pointer; font-size: 13px; font-family: 'Inter', sans-serif; font-weight: 600; white-space: nowrap; transition: background 0.15s; }
    .header-search button:hover { background: var(--blue-dark); }
    .header-right { display: flex; align-items: center; gap: 16px; }
    .header-contact .label { font-size: 10px; color: var(--ink-faint); text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 1px; }
    .header-contact .number { font-size: 17px; font-weight: 800; color: var(--ink); letter-spacing: -0.3px; }

    /* MAIN NAV */
    .main-nav { background: var(--canvas); border-bottom: 1px solid var(--border); }
    .main-nav ul { max-width: 1320px; margin: 0 auto; padding: 0 24px; list-style: none; display: flex; align-items: center; overflow-x: auto; scrollbar-width: none; }
    .main-nav ul::-webkit-scrollbar { display: none; }
    .main-nav li a { display: block; padding: 12px 14px; font-size: 13px; font-weight: 500; color: var(--ink-light); border-bottom: 2px solid transparent; margin-bottom: -1px; white-space: nowrap; transition: color 0.15s, border-color 0.15s; }
    .main-nav li a:hover { color: var(--blue); border-bottom-color: var(--blue-line); }
    .main-nav li a.active { color: var(--blue); border-bottom-color: var(--blue); font-weight: 600; }

    /* HERO */
    .hero { background: linear-gradient(160deg, #0e1629 0%, #132048 55%, #1a3575 100%); padding: 48px 24px 44px; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 700px 500px at 85% 50%, rgba(26,86,219,0.18) 0%, transparent 70%); pointer-events: none; }
    .hero-inner { max-width: 1320px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; position: relative; z-index: 1; }
    .hero-eyebrow { display: inline-flex; align-items: center; gap: 6px; background: rgba(255,255,255,0.07); border: 1px solid rgba(255,255,255,0.14); border-radius: 20px; padding: 4px 12px; font-size: 11.5px; font-weight: 600; color: #d4e5f5; letter-spacing: 0.04em; text-transform: uppercase; margin-bottom: 14px; }
    .hero-eyebrow svg { width: 10px; height: 10px; color: #7eb3e8; }
    .hero-text h1 { font-size: 42px; font-weight: 800; color: #fff; line-height: 1.1; margin-bottom: 16px; letter-spacing: -1px; }
    .hero-text h1 em { font-style: normal; color: #90c0ff; }
    .hero-text p { font-size: 15px; color: #8fa5c5; margin-bottom: 28px; line-height: 1.7; max-width: 440px; }
    .hero-text p strong { color: #d4e5f5; font-weight: 600; }
    .hero-btns { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 32px; }
    .btn-hero { background: var(--blue); color: #fff; border-radius: var(--radius-md); padding: 12px 28px; font-size: 14px; font-weight: 700; display: inline-flex; align-items: center; gap: 6px; transition: background 0.15s, transform 0.15s; letter-spacing: -0.2px; font-family: 'Inter', sans-serif; }
    .btn-hero:hover { background: var(--blue-dark); transform: translateY(-1px); }
    .btn-hero svg { width: 14px; height: 14px; }
    .btn-hero-ghost { background: rgba(255,255,255,0.08); color: #c9d1d9; border: 1px solid rgba(255,255,255,0.18); border-radius: var(--radius-md); padding: 11px 24px; font-size: 14px; font-weight: 600; font-family: 'Inter', sans-serif; display: inline-block; transition: background 0.15s; }
    .btn-hero-ghost:hover { background: rgba(255,255,255,0.13); }
    .hero-stats { display: flex; gap: 24px; flex-wrap: wrap; }
    .hero-stat .num { font-size: 26px; font-weight: 800; color: #fff; letter-spacing: -0.5px; line-height: 1.2; }
    .hero-stat .lbl { font-size: 12px; color: #6b88aa; margin-top: 1px; }
    .hero-right { display: flex; flex-direction: column; gap: 12px; }
    .dep-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .dep-card { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.12); border-radius: var(--radius-md); padding: 16px; text-align: center; transition: background 0.15s, border-color 0.15s; cursor: pointer; }
    .dep-card:hover { background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.3); }
    .dep-card .amount { font-size: 20px; font-weight: 800; color: #fff; }
    .dep-card .sublabel { font-size: 11px; color: #6b88aa; margin-top: 3px; }
    .hero-badges { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
    .hero-badge { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: var(--radius-sm); padding: 10px 8px; text-align: center; }
    .hero-badge svg { width: 18px; height: 18px; color: #7eb3e8; margin: 0 auto 5px; }
    .hero-badge span { display: block; font-size: 11px; color: #8fa5c5; line-height: 1.4; font-weight: 500; }

    /* FLASH DEALS BAR */
    .flash-bar { background: var(--red); padding: 0 24px; display: flex; align-items: stretch; gap: 0; overflow: hidden; }
    .flash-label { background: #a40e26; color: #fff; font-size: 13px; font-weight: 700; padding: 10px 18px; display: flex; align-items: center; gap: 6px; white-space: nowrap; flex-shrink: 0; font-family: 'Inter', sans-serif; }
    .flash-label svg { width: 14px; height: 14px; animation: pulse 1s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }
    .flash-items { display: flex; align-items: center; gap: 0; overflow-x: auto; scrollbar-width: none; flex: 1; }
    .flash-items::-webkit-scrollbar { display: none; }
    .flash-item { display: flex; align-items: center; gap: 10px; padding: 8px 16px; border-right: 1px solid rgba(255,255,255,0.15); white-space: nowrap; transition: background 0.15s; }
    .flash-item:hover { background: rgba(255,255,255,0.1); }
    .flash-item img { width: 36px; height: 36px; object-fit: contain; border-radius: 4px; background: rgba(255,255,255,0.15); }
    .flash-item-name { font-size: 12.5px; color: #fff; font-weight: 500; max-width: 120px; overflow: hidden; text-overflow: ellipsis; }
    .flash-item-price { font-size: 14px; font-weight: 700; color: #fff; }
    .flash-badge { background: rgba(255,255,255,0.2); color: #fff; font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 3px; }

    /* TRUST BAR */
    .trust-bar { background: var(--canvas); border-bottom: 1px solid var(--border); padding: 0 24px; }
    .trust-inner { max-width: 1320px; margin: 0 auto; display: flex; align-items: stretch; }
    .trust-item { display: flex; align-items: center; gap: 10px; font-size: 12.5px; font-weight: 600; color: var(--ink-mid); padding: 12px 20px; border-right: 1px solid var(--border-mid); flex: 1; }
    .trust-item:last-child { border-right: none; }
    .trust-item strong { display: block; font-size: 12.5px; font-weight: 700; color: var(--ink); }
    .trust-item span { color: var(--ink-light); }
    .trust-icon { width: 32px; height: 32px; background: var(--green-bg); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .trust-icon svg { width: 14px; height: 14px; color: var(--green); }

    /* PAGE WRAP */
    .page-wrap { max-width: 1320px; margin: 0 auto; padding: 0 24px; }

    /* SECTION HEADS */
    .section-head { display: flex; align-items: center; justify-content: space-between; padding-top: 32px; margin-bottom: 16px; }
    .section-head-left { display: flex; align-items: center; gap: 10px; }
    .section-head h2 { font-size: 19px; font-weight: 700; color: var(--ink); letter-spacing: -0.4px; }
    .section-rule { border: none; border-top: 1px solid var(--border-mid); margin: 4px 0 0; }
    .tag { display: inline-block; font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 4px; letter-spacing: 0.04em; text-transform: uppercase; }
    .tag-blue  { background: var(--blue-bg); color: var(--blue); }
    .tag-red   { background: var(--red-bg); color: var(--red); }
    .tag-ink   { background: var(--surface); color: var(--ink-light); }
    .see-all { font-size: 13px; font-weight: 600; color: var(--blue); display: flex; align-items: center; gap: 4px; }
    .see-all:hover { text-decoration: underline; }
    .see-all svg { width: 14px; height: 14px; }

    /* BRAND GRID */
    .brand-grid {
      display: grid;
      grid-template-columns: repeat(8, 1fr);
      gap: 10px;
      margin-bottom: 8px;
    }
    .brand-chip { background: var(--canvas); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 14px 8px 10px; text-align: center; transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s; cursor: pointer; display: flex; flex-direction: column; align-items: center; justify-content: center; min-width: 0; }
    .brand-chip:hover { border-color: var(--blue); box-shadow: var(--shadow-md); transform: translateY(-2px); }
    .brand-logo-wrap { display: flex; align-items: center; justify-content: center; height: 46px; margin-bottom: 6px; overflow: hidden; width: 100%; }
    .brand-logo-wrap svg, .brand-logo-wrap img { max-width: 100%; height: auto; }
    .brand-chip-sub { font-size: 11px; color: var(--ink-faint); font-weight: 500; }
    /* On small screens: horizontal scroll row, each chip a fixed width */
    @media (max-width: 900px) {
      .brand-grid {
        display: flex;
        flex-wrap: nowrap;
        overflow-x: auto;
        gap: 8px;
        padding-bottom: 6px;
        scrollbar-width: none;
        -webkit-overflow-scrolling: touch;
      }
      .brand-grid::-webkit-scrollbar { display: none; }
      .brand-chip {
        flex: 0 0 90px;
        min-width: 90px;
      }
      .brand-logo-wrap { height: 38px; }
    }
    @media (max-width: 500px) {
      .brand-chip { flex: 0 0 78px; min-width: 78px; padding: 10px 6px 8px; }
      .brand-logo-wrap { height: 32px; }
      .brand-chip-sub { font-size: 10px; }
    }

    /* PRODUCT CARD */
    .product-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; margin-bottom: 8px; }
    .card { display: flex; flex-direction: column; background: var(--canvas); border-radius: var(--radius-lg); border: 1px solid var(--border); overflow: hidden; position: relative; transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s cubic-bezier(0.34,1.56,0.64,1); text-decoration: none; color: inherit; }
    .card:hover { border-color: var(--blue-line); box-shadow: var(--shadow-lg); transform: translateY(-4px); }
    .card-badge { position: absolute; top: 10px; left: 10px; z-index: 3; padding: 3px 8px; border-radius: 5px; font-size: 10px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: #fff; line-height: 1; }
    .badge-new  { background: var(--green); }
    .badge-hot  { background: var(--red); }
    .badge-sale { background: var(--blue); }
    .card-discount { position: absolute; top: 10px; right: 10px; z-index: 3; background: var(--red); color: #fff; font-size: 10.5px; font-weight: 700; padding: 3px 8px; border-radius: 5px; line-height: 1.4; }
    .card-img-wrap { width: 100%; aspect-ratio: 4/3; background: var(--surface); display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0; }
    .card-img { width: 85%; height: 85%; object-fit: contain; object-position: center; transition: transform 0.35s cubic-bezier(0.34,1.2,0.64,1); }
    .card:hover .card-img { transform: scale(1.06); }
    .card-body { padding: 13px 13px 11px; flex: 1; display: flex; flex-direction: column; }
    .card-brand { font-size: 10px; font-weight: 700; color: var(--blue); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 4px; }
    .card-name { font-size: 13.5px; font-weight: 500; color: var(--ink-mid); line-height: 1.4; margin-bottom: 8px; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .card-specs { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 9px; }
    .spec-pill { background: var(--surface); border: 1px solid var(--border-mid); color: var(--ink-light); border-radius: 4px; padding: 2px 7px; font-size: 10.5px; font-weight: 500; white-space: nowrap; }
    .card-rating { display: flex; align-items: center; gap: 5px; margin-bottom: 10px; }
    .stars { color: #c08000; font-size: 12px; letter-spacing: 0.5px; }
    .rating-count { font-size: 11px; color: var(--ink-faint); }
    .card-price { margin-bottom: 6px; }
    .price-deposit { font-size: 23px; font-weight: 800; color: var(--blue); letter-spacing: -0.5px; line-height: 1; }
    .price-label { font-size: 11px; color: var(--ink-faint); font-weight: 400; margin-left: 3px; }
    .installment-note { font-size: 11px; color: var(--green); font-weight: 600; background: var(--green-bg); padding: 4px 9px; border-radius: 5px; margin-bottom: 11px; display: inline-block; line-height: 1.5; }
    .card-cta { display: flex; gap: 6px; margin-top: auto; }
    .btn-cart { flex: 1; background: var(--blue); color: #fff; border: none; border-radius: var(--radius-sm); padding: 9px 8px; font-size: 12.5px; font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif; transition: background 0.15s; }
    .btn-cart:hover { background: var(--blue-dark); }
    .btn-buy { flex: 1; background: var(--ink); color: #fff; border: none; border-radius: var(--radius-sm); padding: 9px 8px; font-size: 12.5px; font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif; transition: background 0.15s; }
    .btn-buy:hover { background: #24292f; }

    /* BUDGET PICKS */
    .budget-section { background: #0e1629; border-radius: var(--radius-lg); padding: 28px 24px; margin: 28px 0; }
    .budget-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
    .budget-head h2 { font-size: 19px; font-weight: 700; color: #fff; letter-spacing: -0.3px; }
    .budget-head h2 span { color: #90c0ff; }
    .budget-see-all { font-size: 12.5px; color: #6b88aa; font-weight: 500; }
    .budget-see-all:hover { color: #90c0ff; }
    .budget-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px; }
    .budget-card { background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: var(--radius-md); overflow: hidden; transition: background 0.15s, border-color 0.15s, transform 0.2s cubic-bezier(0.34,1.3,0.64,1); text-decoration: none; color: inherit; display: flex; flex-direction: column; }
    .budget-card:hover { background: rgba(255,255,255,0.09); border-color: rgba(255,255,255,0.25); transform: translateY(-3px); }
    .budget-img-wrap { background: rgba(255,255,255,0.07); aspect-ratio: 4/3; display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .budget-img { width: 80%; height: 80%; object-fit: contain; transition: transform 0.3s; }
    .budget-card:hover .budget-img { transform: scale(1.06); }
    .budget-body { padding: 10px 11px; flex: 1; display: flex; flex-direction: column; }
    .budget-name { font-size: 12px; font-weight: 500; color: #c8daf0; line-height: 1.4; margin-bottom: 7px; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .budget-deposit { font-size: 18px; font-weight: 800; color: #90c0ff; }
    .budget-deposit-lbl { font-size: 10px; color: #6b88aa; }
    .budget-cta { width: 100%; background: rgba(126,182,255,0.1); border: 1px solid rgba(144,192,255,0.25); color: #90c0ff; padding: 8px; font-size: 12px; font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif; transition: background 0.15s; text-align: center; display: block; }
    .budget-cta:hover { background: rgba(126,182,255,0.18); }

    /* PROMO BANNERS */
    .promo-banners { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin: 28px 0; }
    .promo-banner { border-radius: var(--radius-lg); padding: 24px 28px; display: flex; align-items: center; justify-content: space-between; gap: 16px; overflow: hidden; position: relative; }
    .promo-banner-a { background: linear-gradient(135deg, #161c2d 0%, #1e3a6e 100%); border: 1px solid rgba(26,86,219,0.3); }
    .promo-banner-b { background: linear-gradient(135deg, #0e1629 0%, #132048 100%); border: 1px solid rgba(144,192,255,0.15); }
    .promo-text h3 { font-size: 16px; font-weight: 700; color: #fff; margin-bottom: 6px; letter-spacing: -0.3px; }
    .promo-text p { font-size: 13px; color: rgba(255,255,255,0.6); line-height: 1.5; }
    .promo-badge { background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.15); border-radius: var(--radius-md); padding: 12px 16px; text-align: center; flex-shrink: 0; }
    .promo-badge .big { font-size: 22px; font-weight: 800; color: #fff; line-height: 1; }
    .promo-badge .small { font-size: 10px; color: rgba(255,255,255,0.6); margin-top: 3px; }
    .promo-btn { display: inline-block; margin-top: 14px; background: rgba(255,255,255,0.15); color: #fff; border-radius: 6px; padding: 7px 16px; font-size: 12.5px; font-weight: 600; transition: background 0.15s; }
    .promo-btn:hover { background: rgba(255,255,255,0.22); }

    /* HOW IT WORKS */
    .how-section { background: var(--surface); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 36px 24px; }
    .how-inner { max-width: 1320px; margin: 0 auto; }
    .how-header { text-align: center; margin-bottom: 28px; }
    .how-header h2 { font-size: 22px; font-weight: 700; color: var(--ink); margin-bottom: 6px; letter-spacing: -0.4px; }
    .how-header p { font-size: 14px; color: var(--ink-light); }
    .how-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; position: relative; }
    .how-grid::before { content: ''; position: absolute; top: 22px; left: calc(12.5% + 17px); right: calc(12.5% + 17px); height: 2px; background: linear-gradient(90deg, var(--blue-line) 0%, var(--blue) 100%); z-index: 0; }
    .how-card { background: var(--canvas); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 20px 16px 16px; text-align: center; position: relative; z-index: 1; transition: box-shadow 0.15s, transform 0.15s; }
    .how-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
    .how-num { width: 44px; height: 44px; border-radius: 10px; font-size: 20px; font-weight: 800; display: flex; align-items: center; justify-content: center; margin: 0 auto 12px; }
    .how-num-1 { background: var(--blue); color: #fff; }
    .how-num-2 { background: var(--blue-bg); color: var(--blue); border: 1px solid var(--blue-line); }
    .how-num-3 { background: var(--blue-bg); color: var(--blue); border: 1px solid var(--blue-line); }
    .how-num-4 { background: var(--ink); color: #fff; }
    .how-title { font-size: 13.5px; font-weight: 700; color: var(--ink); margin-bottom: 6px; }
    .how-desc { font-size: 12.5px; color: var(--ink-light); line-height: 1.65; }

    /* WHY */
    .why-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 32px; }
    .why-card { background: var(--canvas); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 20px 16px; transition: box-shadow 0.15s, transform 0.15s; }
    .why-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
    .why-icon-wrap { width: 38px; height: 38px; background: var(--blue-bg); border-radius: var(--radius-sm); display: flex; align-items: center; justify-content: center; margin-bottom: 12px; }
    .why-icon-wrap svg { width: 17px; height: 17px; color: var(--blue); }
    .why-title { font-size: 13.5px; font-weight: 700; color: var(--ink); margin-bottom: 5px; }
    .why-desc { font-size: 12.5px; color: var(--ink-light); line-height: 1.6; }

    /* TESTIMONIALS */
    .testimonials-section { padding: 36px 24px; background: var(--surface); border-top: 1px solid var(--border); }
    .testimonials-inner { max-width: 1320px; margin: 0 auto; }
    .testimonials-head { text-align: center; margin-bottom: 24px; }
    .testimonials-head h2 { font-size: 21px; font-weight: 700; color: var(--ink); margin-bottom: 4px; }
    .testimonials-head p { font-size: 14px; color: var(--ink-light); }
    .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .testi-card { background: var(--canvas); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 20px; }
    .testi-stars { color: #c08000; font-size: 14px; margin-bottom: 10px; }
    .testi-text { font-size: 13.5px; color: var(--ink-mid); line-height: 1.65; margin-bottom: 14px; font-style: italic; }
    .testi-footer { display: flex; align-items: center; gap: 10px; }
    .testi-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--blue-bg); display: flex; align-items: center; justify-content: center; font-size: 13px; font-weight: 700; color: var(--blue); flex-shrink: 0; }
    .testi-name { font-size: 13px; font-weight: 600; color: var(--ink); }
    .testi-loc { font-size: 11px; color: var(--ink-faint); }

    /* FAQ */
    .faq-section { padding: 36px 24px; }
    .faq-inner { max-width: 800px; margin: 0 auto; }
    .faq-head { text-align: center; margin-bottom: 24px; }
    .faq-head h2 { font-size: 21px; font-weight: 700; color: var(--ink); margin-bottom: 4px; }
    .faq-head p { font-size: 14px; color: var(--ink-light); }
    .faq-item { border: 1px solid var(--border); border-radius: var(--radius-md); margin-bottom: 8px; overflow: hidden; }
    .faq-q { width: 100%; background: var(--canvas); border: none; padding: 16px 18px; display: flex; align-items: center; justify-content: space-between; gap: 12px; cursor: pointer; font-size: 14px; font-weight: 600; color: var(--ink-mid); font-family: 'Inter', sans-serif; text-align: left; transition: background 0.15s; }
    .faq-q:hover { background: var(--surface); }
    .faq-q.open { color: var(--blue); border-bottom: 1px solid var(--border-mid); }
    .faq-q svg { width: 16px; height: 16px; flex-shrink: 0; transition: transform 0.2s; color: var(--ink-faint); }
    .faq-q.open svg { transform: rotate(45deg); color: var(--blue); }
    .faq-a { display: none; padding: 14px 18px; font-size: 13.5px; color: var(--ink-light); line-height: 1.7; background: var(--surface); }
    .faq-a.open { display: block; }
    .faq-a a { color: var(--blue); font-weight: 500; }
    .faq-a a:hover { text-decoration: underline; }

    /* SEO CONTENT */
    .seo-content { border-top: 1px solid var(--border-mid); padding: 32px 24px; background: var(--canvas); }
    .seo-content-inner { max-width: 900px; margin: 0 auto; }
    .seo-content h2 { font-size: 17px; font-weight: 700; color: var(--ink); margin-bottom: 10px; }
    .seo-content p { font-size: 13.5px; color: var(--ink-light); line-height: 1.8; margin-bottom: 10px; }
    .seo-content a { color: var(--blue); font-weight: 500; }
    .seo-content a:hover { text-decoration: underline; }

    /* FOOTER */
    .footer { background: #0e1629; padding: 40px 24px 20px; }
    .footer-inner { max-width: 1320px; margin: 0 auto; }
    .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 36px; margin-bottom: 28px; }
    .footer-logo { font-size: 20px; font-weight: 800; color: #fff; margin-bottom: 10px; display: block; }
    .footer-logo em { color: #90c0ff; font-style: normal; }
    .footer-tagline { font-size: 13px; color: #4e6a8a; line-height: 1.7; margin-bottom: 16px; }
    .footer-contact a { display: block; font-size: 13px; color: #6b88aa; margin-bottom: 5px; }
    .footer-contact a:hover { color: #d4e5f5; }
    .footer-col-title { font-size: 10px; font-weight: 700; color: #3d5a80; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 12px; }
    .footer-links { list-style: none; }
    .footer-links li { margin-bottom: 7px; }
    .footer-links a { font-size: 13px; color: #4e6a8a; transition: color 0.15s; }
    .footer-links a:hover { color: #d4e5f5; }
    .footer-bottom { border-top: 1px solid rgba(255,255,255,0.07); padding-top: 16px; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 8px; }
    .footer-bottom p { font-size: 12px; color: #3d5a80; }

    /* SEO TAGS */
    .seo-tags { border-top: 1px solid rgba(255,255,255,0.05); padding: 14px 24px; background: #091020; }
    .seo-tags-inner { max-width: 1320px; margin: 0 auto; display: flex; flex-wrap: wrap; gap: 6px; }
    .seo-tag { font-size: 11.5px; color: #3d5a80; border: 1px solid #1a2d50; border-radius: 4px; padding: 3px 9px; background: #0e1629; transition: color 0.12s, border-color 0.12s; }
    .seo-tag:hover { color: #90c0ff; border-color: #3d5a80; }

    /* RESPONSIVE */
    @media (max-width: 1100px) {
      .product-grid { grid-template-columns: repeat(4, 1fr); }
      .budget-grid { grid-template-columns: repeat(4, 1fr); }
      .hero-inner { grid-template-columns: 1fr; }
      .hero-right { display: none; }
    }
    @media (max-width: 900px) {
      .product-grid { grid-template-columns: repeat(3, 1fr); }
      .budget-grid { grid-template-columns: repeat(3, 1fr); }
      .how-grid { grid-template-columns: repeat(2, 1fr); }
      .how-grid::before { display: none; }
      .why-grid { grid-template-columns: repeat(2, 1fr); }
      .footer-grid { grid-template-columns: 1fr 1fr; }
      .testimonials-grid { grid-template-columns: 1fr 1fr; }
      .promo-banners { grid-template-columns: 1fr; }
      /* Trust bar: 2-up grid on tablet */
      .trust-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 0; justify-items: start; }
      .trust-item { border-right: none; border-bottom: 1px solid var(--border-mid); padding: 10px 16px; width: 100%; }
      .trust-item:nth-child(odd) { border-right: 1px solid var(--border-mid); }
      .trust-item:nth-last-child(-n+2) { border-bottom: none; }
    }
    @media (max-width: 700px) {
      .product-grid { grid-template-columns: repeat(2, 1fr); }
      .budget-grid { grid-template-columns: repeat(2, 1fr); }
      .hero-text h1 { font-size: 28px; }
      .hero-text p { font-size: 14px; }
      /* Trust bar: keep 2-col on mobile */
      .trust-inner { grid-template-columns: 1fr 1fr; }
    }
    @media (max-width: 500px) {
      .header-search { display: none; }
      .brand-grid { grid-template-columns: repeat(4, 1fr); }
      .brand-chip { padding: 10px 4px 8px; }
      .brand-logo-wrap { height: 34px; }
      .brand-chip-sub { font-size: 10px; }
      .how-grid { grid-template-columns: 1fr; }
      .footer-grid { grid-template-columns: 1fr; }
      .testimonials-grid { grid-template-columns: 1fr; }
      /* Trust bar: full-width single column on very small screens */
      .trust-inner { grid-template-columns: 1fr; }
      .trust-item { border-right: none !important; border-bottom: 1px solid var(--border-mid); }
      .trust-item:last-child { border-bottom: none; }
    }
  </style>
</head>
