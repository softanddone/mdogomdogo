---
import { products } from '../../data/product2.js';
import {
  DEPOSIT_FILTERS,
  STORAGE_FILTERS,
  ALL_BRANDS,
  brandSlug,
  brandSlugall,
  parseDeposit,
  parseStorageSlug,
} from '../../data/filter-config.js';
import Gift from '../../components/Gift.astro';
import Nav from '../../components/Nav.astro';

// ─── getStaticPaths ───────────────────────────────────────────────────────────

export async function getStaticPaths() {
  const { products } = await import('../../data/product2.js');
  const {
    DEPOSIT_FILTERS, STORAGE_FILTERS,
    ALL_BRANDS, brandSlug,
  } = await import('../../data/filter-config.js');

  const paths = [];

  // 1. All
  paths.push({
    params: { filterSlug: 'lipa-mdogo-mdogo-nairobi' },
    props:  { depositFilter: null, brandFilter: null, storageFilter: null, label: 'All Phones on Lipa Mdogo Mdogo' },
  });

  // 2. Deposit-only
  for (const dep of DEPOSIT_FILTERS) {
    paths.push({
      params: { filterSlug: dep.key },
      props:  { depositFilter: dep, brandFilter: null, storageFilter: null, label: dep.h1 },
    });
  }

  // 3. Brand-only
  for (const brand of ALL_BRANDS) {
    paths.push({
      params: { filterSlug: brandSlugall(brand) },
      props:  { depositFilter: null, brandFilter: brand, storageFilter: null, label: `${brand} Phones on Installments` },
    });
  }

  // 4. Brand x Deposit
  for (const brand of ALL_BRANDS) {
    for (const dep of DEPOSIT_FILTERS) {
      paths.push({
        params: { filterSlug: `${brandSlugall(brand)}-${dep.key}` },
        props:  { depositFilter: dep, brandFilter: brand, storageFilter: null, label: `${brand} ${dep.h1}` },
      });
    }
  }

  // 5. Storage-only
  for (const stor of STORAGE_FILTERS) {
    paths.push({
      params: { filterSlug: stor.key },
      props:  { depositFilter: null, brandFilter: null, storageFilter: stor, label: `${stor.label} Storage Phones on Installments` },
    });
  }

  // 6. Brand x Storage
  for (const brand of ALL_BRANDS) {
    for (const stor of STORAGE_FILTERS) {
      paths.push({
        params: { filterSlug: `${brandSlugall(brand)}-${stor.key}` },
        props:  { depositFilter: null, brandFilter: brand, storageFilter: stor, label: `${brand} ${stor.label} Phones on Installments` },
      });
    }
  }

  return paths;
}

// ─── PAGE DATA ────────────────────────────────────────────────────────────────

const { filterSlug } = Astro.params;
const { depositFilter, brandFilter, storageFilter, label } = Astro.props;

const CARDS_PER_PAGE = 20;

const filteredProducts = products.filter(p => {
  const deposit = parseDeposit(p.deposit);
  const matchesDeposit  = !depositFilter  || (deposit >= depositFilter.min && deposit <= depositFilter.max);
  const matchesBrand    = !brandFilter    || (p.brand?.toLowerCase() === brandFilter.toLowerCase());
  const matchesStorage  = !storageFilter  || (parseStorageSlug(p.storage) === storageFilter.key);
  return matchesDeposit && matchesBrand && matchesStorage;
});

const totalPages = Math.ceil(filteredProducts.length / CARDS_PER_PAGE);

const pageTitle = `${label} — Lipa Mdogo Mdogo | MdogomdogoDeals Nairobi`;

const metaDesc = [
  `${label} — get the phone you want today and pay in small daily or weekly M-Pesa installments.`,
  depositFilter ? `Starting deposit: ${depositFilter.label}. Spread the balance at your own pace.` : '',
  storageFilter ? `${storageFilter.label} storage phones ready to order online.` : '',
  `No credit check. No guarantor. Same-day delivery across Nairobi. ${filteredProducts.length} phones in stock.`,
].filter(Boolean).join(' ');

const canonicalUrl = `https://mdogomdogodeals.co.ke/phones/${filterSlug}`;

const breadcrumbs = [
  { label: 'Home',       href: '/' },
  { label: 'All Phones', href: '/phones/lipa-mdogo-mdogo-nairobi' },
  ...(brandFilter   ? [{ label: `${brandFilter} Phones`,          href: `/phones/${brandSlugall(brandFilter)}`  }] : []),
  ...(depositFilter ? [{ label: depositFilter.label,              href: `/phones/${depositFilter.key}`          }] : []),
  ...(storageFilter ? [{ label: `${storageFilter.label} Storage`, href: `/phones/${storageFilter.key}`          }] : []),
];

const hasFilters = !!(brandFilter || depositFilter || storageFilter);

function renderStars(rating) {
  const full = Math.floor(rating);
  return '★'.repeat(full) + '☆'.repeat(5 - full);
}
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={metaDesc} />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:type"        content="website" />
  <meta property="og:title"       content={pageTitle} />
  <meta property="og:description" content={metaDesc} />
  <meta property="og:url"         content={canonicalUrl} />
  <meta property="og:site_name"   content="MdogomdogoDeals" />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": label,
    "description": metaDesc,
    "numberOfItems": filteredProducts.length,
    "itemListElement": filteredProducts.slice(0, 20).map((p, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "item": {
        "@type": "Product",
        "name": p.fullname ?? p.name,
        "brand": { "@type": "Brand", "name": p.brand },
        "image": p.source,
        "url": `https://mdogomdogodeals.co.ke/${p.slug}`,
        "offers": {
          "@type": "Offer",
          "priceCurrency": "KES",
          "price": p.deposit?.replace(/[^0-9]/g, '') ?? "0",
          "availability": "https://schema.org/InStock",
          "seller": { "@type": "Organization", "name": "MdogomdogoDeals" }
        }
      }
    }))
  })} />

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": breadcrumbs.map((b, i) => ({
      "@type": "ListItem",
      "position": i + 1,
      "name": b.label,
      "item": `https://mdogomdogodeals.co.ke${b.href}`
    }))
  })} />

  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --ink:    #0e1117;
      --ink-2:  #3d4350;
      --ink-3:  #7b8194;
      --paper:  #f7f8fb;
      --white:  #ffffff;
      --accent: #0057ff;
      --accent-dim: #e6eeff;
      --gold:   #f5a800;
      --green:  #00a86b;
      --red:    #e8234a;
      --border: #e2e5ed;
      --shadow: 0 2px 12px rgba(0,0,0,0.07);
      --shadow-hover: 0 10px 36px rgba(0,87,255,0.13);
      --radius: 10px;
      --font-head: 'Syne', sans-serif;
      --font-body: 'DM Sans', sans-serif;
    }
    body { font-family: var(--font-body); background: var(--paper); color: var(--ink); -webkit-font-smoothing: antialiased; }

    /* ── Announcement bar ── */
    .top-banner {
      background: var(--ink); color: #fff;
      text-align: center; padding: 10px 16px;
      font-size: 13px; font-weight: 500; letter-spacing: 0.01em;
    }
    .top-banner strong { color: var(--gold); }

    /* ── Breadcrumbs ── */
    .breadcrumb-bar { background: var(--white); border-bottom: 1px solid var(--border); padding: 10px 20px; }
    .breadcrumb-list { display: flex; align-items: center; gap: 6px; flex-wrap: wrap; list-style: none; }
    .breadcrumb-list li { font-size: 12.5px; color: var(--ink-3); }
    .breadcrumb-list li a { color: var(--accent); text-decoration: none; font-weight: 600; }
    .breadcrumb-list li a:hover { text-decoration: underline; }
    .breadcrumb-list li.sep { color: var(--border); }

    /* ══════════════════════════════════════════
       PAGE HEADER (with mobile filter toggle)
    ══════════════════════════════════════════ */
    .page-header-strip {
      background: var(--white);
      border-bottom: 1px solid var(--border);
      padding: 20px 24px;
    }
    .page-header-inner {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 16px;
    }
    .page-header-inner h1 {
      font-family: var(--font-head);
      font-size: clamp(18px, 3vw, 28px);
      font-weight: 800;
      color: var(--ink);
      line-height: 1.2;
      margin-bottom: 6px;
    }
    .page-header-inner p {
      font-size: 13.5px;
      color: var(--ink-3);
      line-height: 1.6;
    }
    .result-count {
      display: inline-block;
      background: var(--accent-dim); color: var(--accent);
      border-radius: 6px; padding: 2px 10px;
      font-size: 13px; font-weight: 700;
      margin-left: 10px; vertical-align: middle;
    }

    /* Mobile filter toggle button */
    .filter-drawer-toggle {
      display: none; /* hidden on desktop */
      align-items: center; gap: 7px;
      background: var(--white); border: 1.5px solid var(--border);
      border-radius: 8px; padding: 8px 14px;
      font-family: var(--font-body); font-size: 13.5px; font-weight: 600;
      color: var(--ink); cursor: pointer; white-space: nowrap;
      flex-shrink: 0;
      transition: border-color 0.15s, color 0.15s;
      position: relative;
    }
    .filter-drawer-toggle:hover { border-color: var(--accent); color: var(--accent); }
    .filter-active-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--accent);
      position: absolute; top: 6px; right: 6px;
    }
    @media (max-width: 900px) {
      .filter-drawer-toggle { display: inline-flex; }
    }

    /* Active filter chips bar */
    .active-chips-bar {
      max-width: 1400px;
      margin: 12px auto 0;
      display: flex; align-items: center; flex-wrap: wrap; gap: 7px;
    }
    .active-chip {
      display: inline-flex; align-items: center; gap: 6px;
      background: var(--accent-dim); border: 1.5px solid var(--accent);
      color: var(--accent); border-radius: 999px; padding: 5px 13px;
      font-size: 13px; font-weight: 600; text-decoration: none;
      transition: background 0.15s;
    }
    .active-chip:hover { background: #d0deff; }
    .chip-clear {
      display: inline-flex; align-items: center;
      font-size: 13px; color: var(--red); font-weight: 600;
      text-decoration: none; padding: 5px 13px; border-radius: 999px;
      border: 1.5px solid var(--red); background: #fdeef1;
      transition: opacity 0.15s;
    }
    .chip-clear:hover { opacity: 0.75; }

    /* ══════════════════════════════════════════
       MAIN LAYOUT — sidebar + content
    ══════════════════════════════════════════ */
    .phones-layout {
      max-width: 1400px;
      margin: 0 auto;
      display: flex;
      align-items: flex-start;
      gap: 0;
      padding: 24px 20px;
    }

    /* ══════════════════════════════════════════
       FILTER SIDEBAR
    ══════════════════════════════════════════ */
    .filter-sidebar {
      width: 230px;
      flex-shrink: 0;
      background: var(--white);
      border: 1.5px solid var(--border);
      border-radius: var(--radius);
      overflow-y: auto;
      max-height: calc(100vh - 32px);
      position: sticky;
      top: 16px;
      align-self: flex-start;
      margin-right: 20px;
      z-index: 10;
    }

    /* Sidebar header */
    .fs-head {
      display: flex; align-items: center; gap: 8px;
      padding: 14px 16px 12px;
      border-bottom: 1px solid var(--border);
    }
    .fs-title { font-family: var(--font-head); font-size: 15px; font-weight: 800; color: var(--ink); flex: 1; }
    .fs-clear { font-size: 12px; color: var(--red); font-weight: 600; text-decoration: none; }
    .fs-clear:hover { text-decoration: underline; }
    .fs-close {
      display: none; /* hidden on desktop */
      background: none; border: none;
      font-size: 18px; color: var(--ink-3);
      cursor: pointer; line-height: 1; padding: 2px 4px;
    }

    /* Accordion filter groups */
    .filter-group { border-bottom: 1px solid var(--border); }
    .filter-group:last-child { border-bottom: none; }

    .fg-toggle {
      width: 100%; display: flex; align-items: center; justify-content: space-between;
      padding: 12px 16px; background: none; border: none;
      cursor: pointer; font-family: var(--font-body);
      text-align: left;
    }
    .fg-toggle-label { font-size: 13px; font-weight: 700; color: var(--ink); }
    .fg-arrow { font-size: 16px; color: var(--ink-3); transition: transform 0.2s; line-height: 1; }
    .fg-toggle.open .fg-arrow { transform: rotate(90deg); }

    .fg-body { padding: 6px 12px 12px; }

    .fg-sublabel {
      display: block;
      font-size: 10px; font-weight: 700; color: var(--ink-3);
      text-transform: uppercase; letter-spacing: 0.09em;
      margin: 8px 0 5px;
    }

    /* Filter pills */
    .fp-wrap { display: flex; flex-direction: column; gap: 3px; }
    .fp {
      display: block; padding: 6px 10px; border-radius: 6px;
      font-size: 13px; font-weight: 500; color: var(--ink-2);
      text-decoration: none; transition: background 0.12s, color 0.12s;
    }
    .fp:hover { background: var(--accent-dim); color: var(--accent); }
    .fp.fp-active { background: var(--accent); color: #fff; font-weight: 700; }
    .fp-sub { display: block; font-size: 11px; color: var(--ink-3); margin-top: 1px; }
    .fp.fp-active .fp-sub { color: rgba(255,255,255,0.75); }

    /* Quick picks */
    .fs-quicklinks { padding: 12px 16px 14px; }
    .fs-ql-head {
      display: block; font-size: 10px; font-weight: 700; color: var(--ink-3);
      text-transform: uppercase; letter-spacing: 0.09em; margin-bottom: 8px;
    }
    .fs-ql-link {
      display: block; font-size: 12.5px; color: var(--accent); font-weight: 600;
      text-decoration: none; padding: 4px 0;
    }
    .fs-ql-link:hover { text-decoration: underline; }

    /* ── Mobile overlay ── */
    .filter-overlay {
      display: none;
      position: fixed; inset: 0; z-index: 9998;
      background: rgba(0,0,0,0.45);
    }
    .filter-overlay.overlay-show { display: block; }

    /* ── Mobile drawer behaviour ── */
    @media (max-width: 900px) {
      .phones-layout { padding-top: 0; }

      .filter-sidebar {
        position: fixed;
        top: 0; left: 0; bottom: 0;
        width: 280px;
        max-width: 85vw;
        max-height: 100vh;
        z-index: 9999;
        border-radius: 0;
        border: none;
        border-right: 1.5px solid var(--border);
        transform: translateX(-110%);
        transition: transform 0.28s cubic-bezier(0.4,0,0.2,1);
        overflow-y: auto;
        margin-right: 0;
      }
      .filter-sidebar.drawer-open { transform: translateX(0); }
      .fs-close { display: block; }
    }

    /* ══════════════════════════════════════════
       CONTENT AREA
    ══════════════════════════════════════════ */
    .phones-main { flex: 1; min-width: 0; }

    /* ── Product grid ── */
    .product-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 14px;
    }
    @media (max-width: 1200px) { .product-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 900px)  { .product-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 480px)  { .product-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; } }

    .card {
      display: none; flex-direction: column;
      background: var(--white); border-radius: var(--radius);
      overflow: hidden; border: 1.5px solid var(--border);
      box-shadow: var(--shadow);
      transition: border-color 0.18s, box-shadow 0.18s, transform 0.18s;
      cursor: pointer; position: relative;
      text-decoration: none; color: inherit;
    }
    .card.visible { display: flex; }
    .card:hover { border-color: var(--accent); box-shadow: var(--shadow-hover); transform: translateY(-4px); }

    .badge {
      position: absolute; top: 10px; left: 10px; z-index: 2;
      padding: 3px 9px; border-radius: 5px;
      font-family: var(--font-head); font-size: 11px; font-weight: 800;
      letter-spacing: 0.06em; text-transform: uppercase; color: #fff;
    }
    .badge-new  { background: var(--green); }
    .badge-hot  { background: var(--red); }
    .badge-sale { background: var(--accent); }

    .card-img-wrap {
      width: 100%; aspect-ratio: 4/3; overflow: hidden;
      background: var(--paper);
      display: flex; align-items: center; justify-content: center;
    }
    .card-img { width: 100%; height: 100%; object-fit: contain; object-position: center; display: block; transition: transform 0.3s; }
    .card:hover .card-img { transform: scale(1.06); }

    .card-body { padding: 12px 13px 11px; flex: 1; display: flex; flex-direction: column; }
    .card-brand { font-size: 10.5px; font-weight: 700; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.09em; margin-bottom: 3px; }
    .card-name  { font-size: 13.5px; font-weight: 600; color: var(--ink); line-height: 1.35; margin-bottom: 7px; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }

    .card-specs { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 8px; }
    .spec-tag { background: var(--paper); border: 1px solid var(--border); color: var(--ink-3); border-radius: 4px; padding: 2px 7px; font-size: 11px; }

    .stars { color: var(--gold); font-size: 12.5px; }
    .rating-count { font-size: 11px; color: var(--ink-3); }
    .card-rating { display: flex; align-items: center; gap: 5px; margin-bottom: 9px; }

    .price-current { font-family: var(--font-head); font-size: 20px; font-weight: 800; color: var(--accent); }
    .price-save    { font-size: 11.5px; font-weight: 700; color: var(--green); }
    .card-price    { display: flex; align-items: baseline; gap: 7px; flex-wrap: wrap; margin-bottom: 6px; }

    .installment-note {
      font-size: 11.5px; color: var(--accent); font-weight: 600;
      background: var(--accent-dim); padding: 4px 9px; border-radius: 5px;
      margin-bottom: 11px; display: inline-block;
    }

    .card-cta { display: flex; gap: 7px; margin-top: auto; }
    .btn-cart {
      flex: 1; background: var(--accent); color: #fff; border: none;
      border-radius: 7px; padding: 9px 10px; font-size: 13px; font-weight: 700;
      cursor: pointer; font-family: var(--font-body); transition: background 0.15s;
    }
    .btn-cart:hover { background: #0044cc; }
    .btn-buy {
      flex: 1; background: var(--ink); color: #fff; border: none;
      border-radius: 7px; padding: 9px 10px; font-size: 13px; font-weight: 700;
      cursor: pointer; font-family: var(--font-body); transition: background 0.15s;
    }
    .btn-buy:hover { background: #1e2533; }

    .empty-state { grid-column: 1/-1; text-align: center; padding: 70px 20px; }
    .empty-state h2 { font-family: var(--font-head); font-size: 22px; color: var(--ink-3); margin-bottom: 8px; }
    .empty-state a { color: var(--accent); font-weight: 600; }

    /* ── Pagination ── */
    .pagination-wrap { padding: 4px 0 36px; }
    .pagination-info { text-align: center; font-size: 13px; color: var(--ink-3); margin-bottom: 14px; }
    .pagination-bar  { display: flex; align-items: center; justify-content: center; gap: 5px; flex-wrap: wrap; }
    .page-btn {
      display: inline-flex; align-items: center; justify-content: center;
      min-width: 40px; height: 40px; padding: 0 12px;
      border: 1.5px solid var(--border); background: var(--white); color: var(--ink);
      border-radius: 8px; font-size: 14px; font-weight: 600;
      font-family: var(--font-body); cursor: pointer; transition: all 0.15s;
    }
    .page-btn:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }
    .page-btn.active { border-color: var(--accent); background: var(--accent); color: #fff; pointer-events: none; }
    .page-btn.disabled { opacity: 0.3; cursor: not-allowed; pointer-events: none; }
    .page-ellipsis { display: inline-flex; align-items: flex-end; justify-content: center; width: 32px; height: 40px; color: var(--ink-3); font-size: 16px; padding-bottom: 4px; user-select: none; }

    /* ── Related filter pills ── */
    .related-filters { padding: 0 0 36px; }
    .related-filters h2 { font-family: var(--font-head); font-size: 18px; font-weight: 800; color: var(--ink); margin-bottom: 12px; }
    .related-grid { display: flex; flex-wrap: wrap; gap: 7px; }
    .related-link {
      display: inline-block; background: var(--white); border: 1.5px solid var(--border);
      border-radius: 8px; padding: 7px 14px; font-size: 13px; font-weight: 600;
      color: var(--ink-2); text-decoration: none;
      transition: border-color 0.15s, color 0.15s, background 0.15s;
    }
    .related-link:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-dim); }
    .related-link .count { font-size: 11px; color: var(--ink-3); margin-left: 3px; }

    /* ── SEO content block ── */
    .seo-section { padding: 0 0 64px; }
    .seo-section hr { border: none; border-top: 1px solid var(--border); margin-bottom: 32px; }
    .seo-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px 48px; }
    .seo-col h3 { font-family: var(--font-head); font-size: 13px; font-weight: 800; color: var(--ink-3); text-transform: uppercase; letter-spacing: 0.09em; margin-bottom: 10px; }
    .seo-col p { font-size: 13px; color: var(--ink-3); line-height: 1.8; }
    .seo-col p a { color: var(--ink-3); text-decoration: underline; text-decoration-color: var(--border); text-underline-offset: 3px; }
    .seo-col p a:hover { color: var(--accent); text-decoration-color: var(--accent); }
    .seo-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-top: 18px; }
    .seo-tag { display: inline-block; background: var(--white); border: 1px solid var(--border); border-radius: 6px; padding: 4px 10px; font-size: 12px; color: var(--ink-3); text-decoration: none; transition: all 0.12s; }
    .seo-tag:hover { border-color: var(--accent); color: var(--accent); }

    @media (max-width: 800px)  { .seo-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 560px)  { .seo-grid { grid-template-columns: 1fr; } }
  </style>
</head>
<body>

  <Gift/>
