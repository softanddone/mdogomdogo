  <!-- ── Scripts ── -->
  <script define:vars={{ totalPages, CARDS_PER_PAGE, totalProducts: filteredProducts.length }}>
  (function () {
    // ── Pagination ──────────────────────────────────────────────────────────
    const cards  = Array.from(document.querySelectorAll('#product-grid .card'));
    const infoEl = document.getElementById('pagination-info');
    const barEl  = document.getElementById('pagination-bar');

    if (!cards.length || totalPages <= 1) {
      cards.forEach(c => c.classList.add('visible'));
    } else {
      let currentPage = 1;

      function showPage(page) {
        currentPage = page;
        const start = (page - 1) * CARDS_PER_PAGE;
        const end   = start + CARDS_PER_PAGE;
        cards.forEach((c, i) => c.classList.toggle('visible', i >= start && i < end));
        infoEl.textContent = `Showing ${start + 1}–${Math.min(end, totalProducts)} of ${totalProducts} phones`;
        buildBar(page);
        document.getElementById('product-grid').scrollIntoView({ behavior: 'smooth', block: 'start' });
      }

      function buildBar(active) {
        barEl.innerHTML = '';
        const make = (label, page, cls) => {
          const btn = document.createElement('button');
          btn.className = 'page-btn' + (cls ? ' ' + cls : '');
          btn.innerHTML = label;
          if (page !== null) btn.addEventListener('click', () => showPage(page));
          return btn;
        };
        const dot = () => {
          const s = document.createElement('span');
          s.className = 'page-ellipsis';
          s.textContent = '…';
          return s;
        };
        const prev = make('&#8592;', active - 1);
        if (active === 1) prev.classList.add('disabled');
        barEl.appendChild(prev);
        const nums = [...new Set([1, totalPages, active, active - 1, active + 1].filter(p => p >= 1 && p <= totalPages))].sort((a, b) => a - b);
        let last = 0;
        nums.forEach(p => {
          if (p - last > 1) barEl.appendChild(dot());
          barEl.appendChild(make(p, p, p === active ? 'active' : ''));
          last = p;
        });
        const next = make('&#8594;', active + 1);
        if (active === totalPages) next.classList.add('disabled');
        barEl.appendChild(next);
      }

      showPage(1);
    }

    // ── Accordion toggles ───────────────────────────────────────────────────
    document.querySelectorAll('.fg-toggle').forEach(btn => {
      btn.addEventListener('click', () => {
        const body  = btn.nextElementSibling;
        const arrow = btn.querySelector('.fg-arrow');
        const isOpen = btn.classList.toggle('open');
        body.style.display  = isOpen ? '' : 'none';
        arrow.style.transform = isOpen ? 'rotate(90deg)' : 'rotate(0deg)';
      });
    });

    // ── Drawer (mobile) ─────────────────────────────────────────────────────
    const sidebar    = document.getElementById('filterSidebar');
    const overlay    = document.getElementById('filterOverlay');
    const toggleBtn  = document.getElementById('filterToggleBtn');
    const closeBtn   = document.getElementById('filterCloseBtn');

    function openDrawer() {
      sidebar.classList.add('drawer-open');
      overlay.classList.add('overlay-show');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      sidebar.classList.remove('drawer-open');
      overlay.classList.remove('overlay-show');
      document.body.style.overflow = '';
    }

    toggleBtn?.addEventListener('click', openDrawer);
    closeBtn?.addEventListener('click', closeDrawer);
    overlay?.addEventListener('click', closeDrawer);

    // Close drawer whenever user navigates to a new filter (any <a> inside sidebar)
    sidebar?.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeDrawer);
    });
  })();
  </script>

</body>
</html>
