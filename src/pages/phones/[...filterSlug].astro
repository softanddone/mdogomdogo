    </aside>

    <!-- ── Content area ── -->
    <main class="phones-main" id="phonesMain">

      <!-- Product grid -->
      <div class="product-grid" id="product-grid">
        {filteredProducts.length === 0 ? (
          <div class="empty-state">
            <h2>😕 No phones match this filter</h2>
            <p><a href="/phones/lipa-mdogo-mdogo-nairobi">Browse all phones</a> or try a different filter.</p>
          </div>
        ) : filteredProducts.map((p, i) => {
          const statusLower = p.status?.toLowerCase();
          const badgeClass  = statusLower === 'new' ? 'badge-new' : statusLower === 'hot' ? 'badge-hot' : 'badge-sale';
          const badgeLabel  = p.status ?? 'NEW';
          const specs       = [p.phonedisplay, p.processor?.split(' ').slice(-2).join(' '), p.battery?.split(',')[0]].filter(Boolean).slice(0, 3);
          const rating      = p.reviews?.averageRating ?? 4.5;
          const reviewCount = p.reviews?.reviewCount ?? 0;
          const altText     = [
            p.fullname ?? p.name, p.brand,
            depositFilter ? `Deposit ${depositFilter.label}` : 'Lipa Mdogo Mdogo',
            'Buy Nairobi Kenya Installments',
          ].filter(Boolean).join(' ');
          return (
            <a href={`/${p.slug}`} class="card" data-index={i} style="text-decoration:none; color:inherit;">
              <span class={`badge ${badgeClass}`}>{badgeLabel}</span>
              <div class="card-img-wrap">
                <img class="card-img" src={p.source} alt={altText} loading="lazy" width="300" height="225" decoding="async" />
              </div>
              <div class="card-body">
                <div class="card-brand">{p.brand}</div>
                <div class="card-name">{p.fullname}</div>
                <div class="card-specs">{specs.map(s => <span class="spec-tag">{s}</span>)}</div>
                <div class="card-rating">
                  <span class="stars">{renderStars(rating)}</span>
                  <span class="rating-count">({reviewCount})</span>
                </div>
                <div class="card-price">
                  <span class="price-current">{p.deposit}</span>
                  {p.discount && <span class="price-save">{p.discount}</span>}
                </div>
                <div class="installment-note">💳 Deposit {p.deposit} · Pay the rest daily or weekly</div>
                <div class="card-cta">
                  <button class="btn-cart">🛒 Add to Cart</button>
                  <button class="btn-buy">Buy Now</button>
                </div>
              </div>
            </a>
          );
        })}
      </div>

      <!-- Pagination -->
      {filteredProducts.length > CARDS_PER_PAGE && (
        <div class="pagination-wrap" id="pagination-wrap">
          <p class="pagination-info" id="pagination-info"></p>
          <div class="pagination-bar" id="pagination-bar"></div>
        </div>
      )}

      <!-- Related filter suggestions -->
      {filteredProducts.length > 0 && (
        <section class="related-filters">
          <h2>Explore More</h2>
          <div class="related-grid">
            {ALL_BRANDS.map(brand => {
              const count = products.filter(p => p.brand?.toLowerCase() === brand.toLowerCase()).length;
              return (
                <a href={`/phones/${brandSlugall(brand)}`} class="related-link">
                  {brand} <span class="count">({count})</span>
                </a>
              );
            })}
            {DEPOSIT_FILTERS.map(dep => {
              const count = products.filter(p => {
                const d = parseInt((p.deposit ?? '').replace(/[^0-9]/g, ''), 10) || 0;
                return d >= dep.min && d <= dep.max;
              }).length;
              return (
                <a href={`/phones/${dep.key}`} class="related-link">
                  {dep.label} <span class="count">({count})</span>
                </a>
              );
            })}
            {STORAGE_FILTERS.map(stor => (
              <a href={`/phones/${stor.key}`} class="related-link">{stor.label} Storage</a>
            ))}
          </div>
        </section>
      )}

      <!-- SEO content block -->
      <section class="seo-section" aria-label="About installment phones in Nairobi">
        <hr />
        <div class="seo-grid">
          <div class="seo-col">
            <h3>Pay Small, Own Big</h3>
            <p>
              Lipa mdogo mdogo means exactly what it says — pay a little, get a lot.
              Put down a small deposit, walk out with your phone, then send the balance via M-Pesa in daily or weekly bites that fit your budget.
              {brandFilter
                ? ` We stock the full range of ${brandFilter} phones on installment — from entry-level to flagship — all available without a credit check.`
                : depositFilter
                ? ` With a ${depositFilter.label} deposit you can own a brand-new smartphone today. No salary slip, no bank account, no guarantor needed.`
                : storageFilter
                ? ` All ${storageFilter.label} phones in our catalog are available on flexible installments — store more, pay less at a time.`
                : ' Samsung, Tecno, Infinix, Oppo, Redmi, Apple — every brand, any budget, all on easy installments in Nairobi.'
              }
            </p>
            <div class="seo-tags">
              <a href="/phones/lipa-mdogo-mdogo-nairobi"  class="seo-tag">buy phone pay later Kenya</a>
              <a href="/phones/deposit-under-3000"         class="seo-tag">phones deposit under 3000</a>
              <a href="/phones/deposit-under-5000"         class="seo-tag">phones deposit under 5000</a>
              <a href="/phones/deposit-under-10000"        class="seo-tag">phones deposit under 10000</a>
              <a href="/phones/lipa-mdogo-mdogo-nairobi"  class="seo-tag">daily installment phone Kenya</a>
              <a href="/phones/lipa-mdogo-mdogo-nairobi"  class="seo-tag">weekly M-Pesa phone payment</a>
              <a href="/phones/lipa-mdogo-mdogo-nairobi"  class="seo-tag">lipa pole pole phones Nairobi</a>
              <a href="/phones/deposit-under-3000"         class="seo-tag">budget phone small deposit</a>
            </div>
          </div>
          <div class="seo-col">
            <h3>Top Brands, Better Deals</h3>
            <p>
              Not sure which brand to pick?
              <a href="/phones/samsung">Samsung Galaxy A Series</a> leads on camera quality and resale value.
              <a href="/phones/tecno">Tecno Spark & Camon</a> punch above their weight on battery and selfie performance.
              <a href="/phones/infinix">Infinix Hot Series</a> gives you a huge screen and all-day battery at one of the lowest deposits available.
              <a href="/phones/redmi">Redmi</a> is the go-to for 4G speed and clean software at a fair price.
            </p>
            <div class="seo-tags">
              <a href="/phones/samsung"                    class="seo-tag">Samsung lipa mdogo mdogo</a>
              <a href="/phones/samsung-deposit-under-10000" class="seo-tag">Samsung deposit under 10000</a>
              <a href="/phones/tecno"                      class="seo-tag">Tecno Camon installment</a>
              <a href="/phones/tecno-deposit-under-5000"   class="seo-tag">Tecno deposit under 5000</a>
              <a href="/phones/infinix"                    class="seo-tag">Infinix Hot lipa mdogo mdogo</a>
              <a href="/phones/redmi"                      class="seo-tag">Redmi 4G installment Kenya</a>
              <a href="/phones/lipa-mdogo-mdogo-nairobi"  class="seo-tag">5G phones lipa mdogo mdogo</a>
              <a href="/phones/lipa-mdogo-mdogo-nairobi"  class="seo-tag">best camera phone pay later</a>
            </div>
          </div>
          <div class="seo-col">
            <h3>How It Works</h3>
            <p>
              Pick your phone, agree on a deposit, and we deliver same day anywhere in Nairobi CBD.
              After that, just send your installment via M-Pesa — daily, weekly, or monthly, whichever suits you.
              No hidden fees, no interest surprises, no credit bureau checks.
              Most customers are fully paid up within 3–6 months.
              <a href="/phones/lipa-mdogo-mdogo-nairobi">Start browsing</a> and find your next phone today.
            </p>
            <div class="seo-tags">
              <a href="/phones/lipa-mdogo-mdogo-nairobi"  class="seo-tag">phone installment delivery Nairobi</a>
              <a href="/phones/lipa-mdogo-mdogo-nairobi"  class="seo-tag">order phone online Kenya</a>
              <a href="/phones/deposit-under-10000"        class="seo-tag">phone deposit below 10000 Nairobi</a>
              <a href="/phones/storage-128gb"              class="seo-tag">128GB installment phone</a>
              <a href="/phones/storage-256gb"              class="seo-tag">256GB pay later Kenya</a>
              <a href="/phones/lipa-mdogo-mdogo-nairobi"  class="seo-tag">big battery phone installment</a>
              <a href="/phones/lipa-mdogo-mdogo-nairobi"  class="seo-tag">large screen lipa mdogo mdogo</a>
