
---
export const prerender = true;

import ProductLayout from "../layouts/ProductLayout.astro";
import Nav from "../components/Nav.astro";
import Gift from "../components/Gift.astro";
import { products } from "../data/product2";

import {
  FEATURE_FILTERS,
  getProductFeatures,
  featureHref,
  comboHref,
  COMBO_PAIRS,
} from '../data/feature-config.js';
import { brandSlugall } from '../data/filter-config.js';


export async function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
  }));
}

const { slug } = Astro.params;
const currentProduct = products.find((p) => p.slug === slug);



const productFeatureKeys    = getProductFeatures(currentProduct);
const productFeatureObjects = FEATURE_FILTERS.filter(f => productFeatureKeys.includes(f.key));





if (!currentProduct) {
  return Astro.redirect("/404");
}

// ── Smart related products: unique per product page ──────────────────────────
const currentDeposit = parseInt((currentProduct.deposit ?? '').replace(/[^0-9]/g, ''), 10) || 0;
const PRICE_TIER_RANGE = 3000;

function seededShuffle<T>(arr: T[], seed: number): T[] {
  const a = [...arr];
  let s = seed >>> 0;
  for (let i = a.length - 1; i > 0; i--) {
    s = Math.imul(s ^ (s >>> 16), 0x45d9f3b);
    s = Math.imul(s ^ (s >>> 16), 0x45d9f3b);
    s = s ^ (s >>> 16);
    const j = Math.abs(s) % (i + 1);
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const slugSeed = currentProduct.slug.split('').reduce((n, c, i) => n + c.charCodeAt(0) * (i + 7), 0);

const otherProducts = products.filter((p) => p.id !== currentProduct.id);

const tier1 = seededShuffle(
  otherProducts.filter((p) => {
    const dep = parseInt((p.deposit ?? '').replace(/[^0-9]/g, ''), 10) || 0;
    return p.brand === currentProduct.brand && Math.abs(dep - currentDeposit) <= PRICE_TIER_RANGE;
  }),
  slugSeed
);

const tier1ids = new Set(tier1.map((p) => p.id));
const tier2 = seededShuffle(
  otherProducts.filter((p) => p.brand === currentProduct.brand && !tier1ids.has(p.id)),
  slugSeed + 1
);

const tier12ids = new Set([...tier1, ...tier2].map((p) => p.id));
const tier3 = seededShuffle(
  otherProducts.filter((p) => {
    const dep = parseInt((p.deposit ?? '').replace(/[^0-9]/g, ''), 10) || 0;
    return p.brand !== currentProduct.brand
      && Math.abs(dep - currentDeposit) <= PRICE_TIER_RANGE
      && !tier12ids.has(p.id);
  }),
  slugSeed + 2
);

const currentStorage = (currentProduct.storage ?? '').replace(/[^0-9]/g, '');
const tier123ids = new Set([...tier1, ...tier2, ...tier3].map((p) => p.id));
const tier4 = seededShuffle(
  otherProducts.filter((p) => {
    const s = (p.storage ?? '').replace(/[^0-9]/g, '');
    return s === currentStorage && s !== '' && !tier123ids.has(p.id);
  }),
  slugSeed + 3
);

const tier1234ids = new Set([...tier1, ...tier2, ...tier3, ...tier4].map((p) => p.id));
const tier5 = seededShuffle(
  otherProducts.filter((p) => !tier1234ids.has(p.id)),
  slugSeed + 4
);

const pool: typeof products = [];
for (const tier of [tier1, tier2, tier3, tier4, tier5]) {
  for (const p of tier) {
    if (pool.length >= 4) break;
    if (!pool.find((x) => x.id === p.id)) pool.push(p);
  }
  if (pool.length >= 4) break;
}

const relatedProducts = pool.slice(0, 4);

const faqs = [
  {
    question: `How does Lipa Mdogo Mdogo work for the ${currentProduct.name}?`,
    answer: `It works like this — we bring the phone straight to your door. You inspect it, switch it on, and test it yourself. Only once you are satisfied do you pay the deposit of KES ${currentProduct.deposit}. After a free grace period, you pay KES ${currentProduct.daily} daily — or choose weekly or monthly — until the balance is cleared. No upfront payment is required to place your order.`,
  },
  {
    question: "Do I pay anything before the phone is delivered?",
    answer: "Nothing at all. We deliver first, you inspect second, you pay third. The deposit is only collected once you have seen the phone in person and confirmed you are happy with it. There are no booking fees, no delivery charges, and no payment required before we arrive.",
  },
  {
    question: "Which areas do you deliver to?",
    answer: "We offer same-day delivery across Nairobi, Kiambu, Machakos, and Kajiado counties. This covers most of greater Nairobi and the surrounding region. Call or WhatsApp us on 0100028823 to confirm your exact location before placing an order.",
  },
  {
    question: "How do I place an order?",
    answer: `Three easy ways: (1) Call us on 0100028823, (2) WhatsApp us on 0100028823 — the quickest option, or (3) complete the order form on this page. Once we receive your order we will confirm same-day delivery details with you directly.`,
  },
  {
    question: `Is the ${currentProduct.name} original and genuine?`,
    answer: `Yes — every ${currentProduct.brand} ${currentProduct.name} we sell is 100% genuine, brand new, and sourced directly from authorised ${currentProduct.brand} distributors in Kenya. Each unit comes with a full manufacturer warranty.`,
  },
  {
    question: `What colours are available for the ${currentProduct.name}?`,
    answer: `The ${currentProduct.brand} ${currentProduct.name} is available in: ${currentProduct.color}. Just mention your preferred colour when you place your order and we will confirm availability.`,
  },
  {
    question: "What warranty comes with the phone?",
    answer: `Every unit includes a 2-year manufacturer warranty covering hardware defects, backed by ${currentProduct.brand} and ${currentProduct.seller}. You also benefit from our after-sales support throughout your instalment period.`,
  },
  {
    question: "What happens if I miss a daily payment?",
    answer: "Life happens — we understand. Just reach out to us as soon as you can. We offer flexible grace periods and are always willing to work out a revised payment schedule. There are no automatic penalties for genuine cases.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer },
  })),
};

const keyFeatures = [
  currentProduct.ram       ? `${currentProduct.ram} RAM`         : null,
  currentProduct.storage   ? `${currentProduct.storage} Storage` : null,
  currentProduct.camera    ? `${currentProduct.camera} Camera`   : null,
  currentProduct.battery   ? `${currentProduct.battery} Battery` : null,
  currentProduct.display   ? `${currentProduct.display} Display` : null,
  currentProduct.processor ? `${currentProduct.processor}`       : null,
].filter(Boolean);

const detailedSpecs = {
  general: [
    { label: "Brand",            value: currentProduct.brand },
    { label: "Model",            value: currentProduct.name },
    { label: "Release Year",     value: currentProduct.releaseYear || "2024" },
    { label: "Operating System", value: currentProduct.os || "Android" },
    { label: "SIM Type",         value: currentProduct.simType || "Dual SIM (Nano-SIM)" },
    { label: "Color Options",    value: currentProduct.color },
    { label: "Condition",        value: currentProduct.condition || "New" },
    { label: "Warranty",         value: "2 Years Manufacturer Warranty" },
  ],
  display: [
    { label: "Screen Size",  value: currentProduct.display || currentProduct.screenSize },
    { label: "Display Type", value: currentProduct.displayType || "AMOLED" },
    { label: "Resolution",   value: currentProduct.resolution || "Full HD+" },
    { label: "Refresh Rate", value: currentProduct.refreshRate || "60Hz" },
    { label: "Protection",   value: currentProduct.screenProtection || "Corning Gorilla Glass" },
  ],
  performance: [
    { label: "Processor",          value: currentProduct.processor || currentProduct.chipset },
    { label: "CPU",                value: currentProduct.cpu || "Octa-core" },
    { label: "GPU",                value: currentProduct.gpu || "Integrated" },
    { label: "RAM",                value: currentProduct.ram },
    { label: "Internal Storage",   value: currentProduct.storage },
    { label: "Expandable Storage", value: currentProduct.expandableStorage || "Up to 512GB via microSD" },
  ],
  camera: [
    { label: "Rear Camera",     value: currentProduct.camera || currentProduct.rearCamera },
    { label: "Front Camera",    value: currentProduct.frontCamera || currentProduct.selfieCamera },
    { label: "Video Recording", value: currentProduct.videoRecording || "4K @ 30fps" },
    { label: "Camera Features", value: currentProduct.cameraFeatures || "LED Flash, HDR, Panorama, Night Mode" },
  ],
  battery: [
    { label: "Battery Capacity",  value: currentProduct.battery || currentProduct.batteryCapacity },
    { label: "Charging",          value: currentProduct.charging || "Fast Charging 33W" },
    { label: "Wireless Charging", value: currentProduct.wirelessCharging || "Not Available" },
    { label: "Battery Type",      value: "Li-Po, Non-removable" },
  ],
  connectivity: [
    { label: "Network",    value: "2G, 3G, 4G LTE" },
    { label: "Wi-Fi",      value: currentProduct.wifi || "Wi-Fi 802.11 a/b/g/n/ac" },
    { label: "Bluetooth",  value: currentProduct.bluetooth || "Bluetooth 5.0" },
    { label: "GPS",        value: "Yes, with A-GPS, GLONASS" },
    { label: "NFC",        value: currentProduct.nfc || "Yes" },
    { label: "USB",        value: currentProduct.usb || "USB Type-C" },
    { label: "Audio Jack", value: currentProduct.audioJack || "No" },
  ],
  physical: [
    { label: "Dimensions",       value: currentProduct.dimensions || "N/A" },
    { label: "Weight",           value: currentProduct.weight || "N/A" },
    { label: "Build Material",   value: currentProduct.buildMaterial || "Glass front, Plastic back" },
    { label: "Water Resistance", value: currentProduct.waterResistance || "Splash Resistant" },
  ],
};

const brandSlug   = currentProduct.brand.toLowerCase().replace(/\s+/g, "-");
const rating      = currentProduct.reviews?.averageRating ?? 4.5;
const reviewCount = currentProduct.reviews?.reviewCount ?? 0;
const quickSpecs  = [
  currentProduct.phonedisplay,
  currentProduct.processor?.split(' ').slice(-2).join(' '),
  currentProduct.battery?.split(',')[0],
].filter(Boolean).slice(0, 3);

function renderStars(r: number) {
  const full = Math.floor(r);
  return '★'.repeat(full) + '☆'.repeat(5 - full);
}
---

