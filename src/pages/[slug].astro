    font-size: 12px; font-weight: 800; letter-spacing: .07em;
    text-transform: uppercase; color: #fff; pointer-events: none;
  }
  .pdp-badge-new  { background: var(--badge-new); }
  .pdp-badge-hot  { background: var(--badge-hot); }
  .pdp-badge-sale { background: var(--badge-sale); }

  .zoom-hint {
    position: absolute; bottom: 50px; left: 50%; transform: translateX(-50%);
    z-index: 3; background: rgba(0,0,0,0.55); color: #fff;
    font-size: 11px; font-weight: 600; padding: 5px 10px;
    border-radius: 20px; display: flex; align-items: center; gap: 5px;
    pointer-events: none; transition: opacity 0.3s; white-space: nowrap;
  }
  @media (max-width: 768px) { .zoom-hint { display: none; } }

  .zoom-container {
    width: 100%; height: 100%; position: relative; cursor: crosshair;
    display: flex; align-items: center; justify-content: center;
  }
  .main-product-img {
    width: 100%; height: 100%; object-fit: cover; object-position: center;
    display: block; transition: transform 0.3s ease;
    user-select: none; pointer-events: none;
  }
  .zoom-lens {
    display: none; position: absolute;
