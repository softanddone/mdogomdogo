        &nbsp;<a href="#price-kenya">View lipa mdogo mdogo pricing &amp; instalments &darr;</a>
      </p>
    </div>

    <!-- ═══════════════════════════════════════════════════════
         HERO
    ═══════════════════════════════════════════════════════ -->
    <section class="hero-section">

      <!-- ── GALLERY COLUMN ── -->
      <div class="gallery-col">

        <div class="main-stage" id="main-stage">
          {currentProduct.status && (
            <span class={`pdp-badge pdp-badge-${
              currentProduct.status?.toLowerCase() === 'new' ? 'new' :
