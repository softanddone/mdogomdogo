  ],
  connectivity: [
    { label: "Network",    value: "2G, 3G, 4G LTE" },
    { label: "Wi-Fi",      value: currentProduct.wifi || "Wi-Fi 802.11 a/b/g/n/ac" },
    { label: "Bluetooth",  value: currentProduct.bluetooth || "Bluetooth 5.0" },
