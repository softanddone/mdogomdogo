---
export const prerender = true;

import ProductLayout from "../layouts/ProductLayout.astro";
import ProductCard from "../components/ProductCard.astro";
import Nav from "../components/Nav.astro";
import Gift from "../components/Gift.astro";
import { products } from "../data/product2";

export async function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
  }));
}

const { slug } = Astro.params;
const currentProduct = products.find((p) => p.slug === slug);

if (!currentProduct) {
  return Astro.redirect("/404");
}

const relatedProducts = products
  .filter(
    (p) =>
      p.id !== currentProduct.id &&
      (p.brand === currentProduct.brand ||
        p.categoryPath.some((cat) =>
          currentProduct.categoryPath.includes(cat),
        )),
  )
  .slice(0, 4);

const faqs = [
  {
    question: `How does Lipa Mdogo Mdogo work for the ${currentProduct.name}?`,
    answer: `It is simple — we deliver the phone to you first. You inspect it, and only then pay the deposit of KES ${currentProduct.deposit}. After a free grace period, you begin paying KES ${currentProduct.daily} daily (or weekly or monthly) until fully paid. There is no upfront payment required to place an order.`,
  },
  {
    question: "Do I pay anything before delivery?",
    answer: "No. There is no payment before delivery. We bring the phone to you first. You inspect it, confirm you are happy, and only then pay the deposit. That is it.",
  },
  {
    question: "Which areas do you deliver to?",
    answer: "We deliver same-day to Nairobi, Kiambu, Machakos, and Kajiado counties. Call or WhatsApp us to confirm your exact location before ordering.",
  },
  {
    question: "How do I place an order?",
    answer: `You can order in three ways: (1) Call us on 0100028823, (2) WhatsApp us on 0100028823, or (3) fill in the order form on this page. We will confirm your order and arrange same-day delivery.`,
  },
  {
    question: `Is the ${currentProduct.name} genuine?`,
    answer: `Yes, 100% genuine ${currentProduct.brand} ${currentProduct.name} with manufacturer warranty, sourced from authorized distributors in Kenya.`,
  },
  {
    question: `What colors are available for the ${currentProduct.name}?`,
    answer: `Available in: ${currentProduct.color}. Mention your preferred color when ordering.`,
  },
  {
    question: "What warranty is included?",
    answer: `Every unit comes with a 2-year manufacturer warranty covering hardware defects, with support from ${currentProduct.brand} and ${currentProduct.seller}.`,
  },
  {
    question: "What if I miss a daily payment?",
    answer: "No cash penalties for missing to pay in time. Your phone will be unlocked the following time you pay.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer },
  })),
};

const keyFeatures = [
  currentProduct.ram       ? `${currentProduct.ram} RAM`         : null,
  currentProduct.storage   ? `${currentProduct.storage} Storage` : null,
  currentProduct.camera    ? `${currentProduct.camera} Camera`   : null,
  currentProduct.battery   ? `${currentProduct.battery} Battery` : null,
  currentProduct.display   ? `${currentProduct.display} Display` : null,
  currentProduct.processor ? `${currentProduct.processor}`       : null,
].filter(Boolean);

const detailedSpecs = {
  general: [
    { label: "Brand",            value: currentProduct.brand },
    { label: "Model",            value: currentProduct.name },
    { label: "Release Year",     value: currentProduct.releaseYear || "2024" },
    { label: "Operating System", value: currentProduct.os || "Android" },
    { label: "SIM Type",         value: currentProduct.simType || "Dual SIM (Nano-SIM)" },
    { label: "Color Options",    value: currentProduct.color },
    { label: "Condition",        value: currentProduct.condition || "New" },
    { label: "Warranty",         value: "2 Years Manufacturer Warranty" },
  ],
  display: [
    { label: "Screen Size",  value: currentProduct.display || currentProduct.screenSize },
    { label: "Display Type", value: currentProduct.displayType || "AMOLED" },
    { label: "Resolution",   value: currentProduct.resolution || "Full HD+" },
    { label: "Refresh Rate", value: currentProduct.refreshRate || "60Hz" },
    { label: "Protection",   value: currentProduct.screenProtection || "Corning Gorilla Glass" },
  ],
  performance: [
    { label: "Processor",          value: currentProduct.processor || currentProduct.chipset },
    { label: "CPU",                value: currentProduct.cpu || "Octa-core" },
    { label: "GPU",                value: currentProduct.gpu || "Integrated" },
    { label: "RAM",                value: currentProduct.ram },
    { label: "Internal Storage",   value: currentProduct.storage },
    { label: "Expandable Storage", value: currentProduct.expandableStorage || "Up to 512GB via microSD" },
  ],
  camera: [
    { label: "Rear Camera",     value: currentProduct.camera || currentProduct.rearCamera },
    { label: "Front Camera",    value: currentProduct.frontCamera || currentProduct.selfieCamera },
    { label: "Video Recording", value: currentProduct.videoRecording || "4K @ 30fps" },
    { label: "Camera Features", value: currentProduct.cameraFeatures || "LED Flash, HDR, Panorama, Night Mode" },
  ],
  battery: [
    { label: "Battery Capacity",  value: currentProduct.battery || currentProduct.batteryCapacity },
    { label: "Charging",          value: currentProduct.charging || "Fast Charging 33W" },
    { label: "Wireless Charging", value: currentProduct.wirelessCharging || "Not Available" },
    { label: "Battery Type",      value: "Li-Po, Non-removable" },
  ],
  connectivity: [
    { label: "Network",    value: "2G, 3G, 4G LTE" },
    { label: "Wi-Fi",      value: currentProduct.wifi || "Wi-Fi 802.11 a/b/g/n/ac" },
    { label: "Bluetooth",  value: currentProduct.bluetooth || "Bluetooth 5.0" },
    { label: "GPS",        value: "Yes, with A-GPS, GLONASS" },
    { label: "NFC",        value: currentProduct.nfc || "Yes" },
    { label: "USB",        value: currentProduct.usb || "USB Type-C" },
    { label: "Audio Jack", value: currentProduct.audioJack || "No" },
  ],
  physical: [
    { label: "Dimensions",       value: currentProduct.dimensions || "N/A" },
    { label: "Weight",           value: currentProduct.weight || "N/A" },
    { label: "Build Material",   value: currentProduct.buildMaterial || "Glass front, Plastic back" },
    { label: "Water Resistance", value: currentProduct.waterResistance || "Splash Resistant" },
  ],
};

const brandSlug   = currentProduct.brand.toLowerCase().replace(/\s+/g, "-");
const rating      = currentProduct.reviews?.averageRating ?? 4.5;
const reviewCount = currentProduct.reviews?.reviewCount ?? 0;
const quickSpecs  = [
  currentProduct.phonedisplay,
  currentProduct.processor?.split(' ').slice(-2).join(' '),
  currentProduct.battery?.split(',')[0],
].filter(Boolean).slice(0, 3);

function renderStars(r: number) {
  const full = Math.floor(r);
  return '★'.repeat(full) + '☆'.repeat(5 - full);
}
---

<ProductLayout product={currentProduct} additionalSchemas={[faqSchema]}>
  <Gift />
  <Nav />

  <div class="top-banner">
    Same-day delivery &nbsp;|&nbsp; <span>Lipa Mdogo Mdogo</span> &mdash; Pay only after delivery &nbsp;|&nbsp; 0100028823
  </div>

  <header class="site-header">
    <a href="/" class="logo">Mdogomdogo<span>Deals</span></a>
  </header>

  <main class="product-page">

    <!-- BREADCRUMB -->
    <nav class="breadcrumb-bar" aria-label="Breadcrumb">
      <ol class="breadcrumb-list">
        <li><a href="/">Home</a></li>
        <li class="sep">›</li>
        <li><a href="/filter/all">All Phones</a></li>
        <li class="sep">›</li>
        <li><a href={`/filter/${brandSlug}`}>{currentProduct.brand}</a></li>
        <li class="sep">›</li>
        <li>{currentProduct.brand} {currentProduct.name}</li>
      </ol>
    </nav>

    <!-- ═══════════════════════════════════════════════════════
         HERO
         ═══════════════════════════════════════════════════════ -->
    <section class="hero-section">

      <!-- Gallery column -->
      <div class="gallery-col">
        <div class="main-img-wrap">
          {currentProduct.status && (
            <span class={`pdp-badge pdp-badge-${
              currentProduct.status?.toLowerCase() === 'new' ? 'new' :
              currentProduct.status?.toLowerCase() === 'hot' ? 'hot' : 'sale'
            }`}>{currentProduct.status}</span>
          )}
          <img
            id="main-product-img"
            src={currentProduct.source}
            alt={`${currentProduct.brand} ${currentProduct.name} — Lipa Mdogo Mdogo Kenya`}
            class="main-product-img"
            loading="eager"
            width="560" height="560"
          />
        </div>

        <div class="thumb-row">
          <button class="thumb active" data-src={currentProduct.source} aria-label="View image 1">
            <img src={currentProduct.source} alt="" width="72" height="72" />
          </button>
          {currentProduct.source2 && (
            <button class="thumb" data-src={currentProduct.source2} aria-label="View image 2">
              <img src={currentProduct.source2} alt="" width="72" height="72" loading="lazy" />
            </button>
          )}
          {currentProduct.source3 && (
            <button class="thumb" data-src={currentProduct.source3} aria-label="View image 3">
              <img src={currentProduct.source3} alt="" width="72" height="72" loading="lazy" />
            </button>
          )}
        </div>

        <div class="quick-specs">
          {quickSpecs.map(s => <span class="spec-pill">{s}</span>)}
        </div>
      </div>

      <!-- Info column -->
      <div class="info-col">

        <div class="info-brand-row">
          <span class="brand-tag">{currentProduct.brand}</span>
          <span class="stock-tag">In Stock</span>
        </div>

        <h1 class="product-title">
          {currentProduct.brand} {currentProduct.fullname ?? currentProduct.name}
        </h1>

        {reviewCount > 0 && (
          <div class="rating-row">
            <span class="stars">{renderStars(rating)}</span>
            <span class="rating-val">{rating}</span>
            <span class="rating-sep">·</span>
            <a href="#tab-faq" class="rating-link">{reviewCount} reviews</a>
          </div>
        )}

        <!-- Delivery trust strip -->
        <div class="trust-strip">
          <span>Same-day delivery</span>
          <span>Nairobi · Kiambu · Machakos · Kajiado</span>
          <span>Pay on delivery</span>
        </div>

        <!-- Pricing -->
        <div class="pricing-card">
          <div class="pricing-row">
            <div class="price-block">
              <span class="price-label">Deposit — paid on delivery</span>
              <span class="price-big">{currentProduct.deposit}</span>
            </div>
            <div class="divider-v"></div>
            <div class="price-block">
              <span class="price-label">Then from</span>
              <span class="price-big accent">{currentProduct.daily}<span class="price-per">/day</span></span>
            </div>
          </div>
          <div class="installment-note">
            Or from <strong>{currentProduct.from}/week</strong> &mdash; choose daily, weekly, or monthly instalments after the free grace period
          </div>
          <ul class="pricing-bullets">
            <li>No payment before delivery</li>
            <li>Inspect the phone first, then pay deposit</li>
            <li>No interest &mdash; no hidden fees &mdash; no credit check</li>
          </ul>
        </div>

        <!-- ── ORDER METHODS ── -->
        <div class="order-block">
          <p class="order-heading">How would you like to order?</p>

          <a
            href={`https://wa.me/254100028823?text=Hi, I want to order the ${currentProduct.brand} ${currentProduct.name}`}
            class="btn-order-wa"
            target="_blank" rel="noopener"
          >
            Order via WhatsApp
          </a>

          <a href="tel:+254100028823" class="btn-order-call">
            Call Us — 0100028823
          </a>

          <button class="btn-order-form" id="toggle-form-btn" type="button">
            Fill in an Order Form
          </button>
        </div>

        <!-- Inline order form (hidden by default) -->
        <div class="order-form-wrap" id="order-form-wrap" hidden>
          <p class="form-title">Place Your Order</p>
          <div class="form-fields">
            <input class="form-input" type="text"  id="f-name"  placeholder="Your full name" />
            <input class="form-input" type="tel"   id="f-phone" placeholder="Phone number" />
            <input class="form-input" type="text"  id="f-area"  placeholder="Delivery area  (e.g. Nairobi, Kiambu, Machakos, Kajiado)" />
            <textarea class="form-input form-textarea" id="f-notes" rows="2" placeholder="Any notes — optional"></textarea>
          </div>
          <button class="btn-submit" id="submit-order-btn" type="button">Confirm Order via WhatsApp</button>
          <p class="form-note">We will call you to confirm delivery within minutes.</p>
        </div>

        <!-- Trust badges -->
        <div class="trust-badges">
          <div class="trust-badge">
            <span class="tbadge-icon">&#10003;</span>
            <span>100% Genuine<br/>Products</span>
          </div>
          <div class="trust-badge">
            <span class="tbadge-icon">&#9685;</span>
            <span>2-Year<br/>Warranty</span>
          </div>
          <div class="trust-badge">
            <span class="tbadge-icon">&#9654;</span>
            <span>Same-Day<br/>Delivery</span>
          </div>
          <div class="trust-badge">
            <span class="tbadge-icon">&#9432;</span>
            <span>Pay After<br/>Delivery</span>
          </div>
        </div>

        <p class="seller-line">
          Sold by <a href={`/${brandSlug}-phones`}>{currentProduct.seller}</a> &middot; Nairobi, Kenya
        </p>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         TAB NAV
         ═══════════════════════════════════════════════════════ -->
    <div class="tab-nav" id="tab-nav" role="tablist">
      <button class="tab-btn active" data-tab="overview" role="tab">Overview</button>
      <button class="tab-btn"        data-tab="specs"    role="tab">Specifications</button>
      <button class="tab-btn"        data-tab="delivery" role="tab">Delivery &amp; Payment</button>
      <button class="tab-btn"        data-tab="faq"      role="tab">FAQ</button>
    </div>

    <!-- ═══════════════════════════════════════════════════════
         TAB: OVERVIEW
         ═══════════════════════════════════════════════════════ -->
    <section class="tab-panel active" id="tab-overview" role="tabpanel">

      {keyFeatures.length > 0 && (
        <div class="section-card">
          <h2 class="section-title">Key Features</h2>
          <div class="features-grid">
            {keyFeatures.map(f => (
              <div class="feature-item">
                <span class="feat-check">&#10003;</span>
                <span>{f}</span>
              </div>
            ))}
          </div>
        </div>
      )}

      <div class="section-card">
        <h2 class="section-title">About the {currentProduct.brand} {currentProduct.name}</h2>
        <div class="prose">
          <p>
            {currentProduct.description ||
              `The ${currentProduct.brand} ${currentProduct.name} is one of the most popular smartphones available in Kenya right now. Sold on flexible Lipa Mdogo Mdogo instalments — delivered to your door first, deposit paid on arrival, then daily or weekly payments at your own pace.`}
          </p>
          {currentProduct.ram && (
            <p><strong>Performance:</strong> With {currentProduct.ram} of RAM the {currentProduct.brand} {currentProduct.name} handles multitasking, browsing, and gaming without lag.</p>
          )}
          {currentProduct.storage && (
            <p><strong>Storage:</strong> {currentProduct.storage} of internal storage for photos, videos, apps, and documents.</p>
          )}
          {currentProduct.camera && (
            <p><strong>Camera:</strong> The {currentProduct.camera} camera lets you capture Kenya's landscapes and everyday moments in sharp detail.</p>
          )}
          {currentProduct.battery && (
            <p><strong>Battery:</strong> The {currentProduct.battery} keeps you going through long commutes and busy workdays without needing a recharge.</p>
          )}
          {currentProduct.display && (
            <p><strong>Display:</strong> The {currentProduct.display} screen delivers vivid, sharp visuals — great for streaming, browsing, and gaming.</p>
          )}
        </div>
      </div>

      <div class="section-card">
        <h2 class="section-title">Ideal For</h2>
        <div class="use-cases-grid">
          <div class="use-case"><strong>Students</strong><p>Online classes, research, and learning apps run smoothly.</p></div>
          <div class="use-case"><strong>Professionals</strong><p>Email, video calls, and banking apps — fast and reliable.</p></div>
          <div class="use-case"><strong>Content Creators</strong><p>Powerful camera and processor for social media content.</p></div>
          <div class="use-case"><strong>Gamers</strong><p>Smooth performance on popular mobile games.</p></div>
          <div class="use-case"><strong>Social Media</strong><p>Stay connected on WhatsApp, Instagram, TikTok, and more.</p></div>
          <div class="use-case"><strong>Everyday Use</strong><p>Reliable battery and display for all-day use across Kenya.</p></div>
        </div>
      </div>

      <div class="section-card">
        <h2 class="section-title">What's in the Box</h2>
        <ul class="box-list">
          <li>1 &times; {currentProduct.brand} {currentProduct.name} handset</li>
          <li>1 &times; USB charging cable</li>
          <li>1 &times; Charging adapter</li>
          <li>1 &times; SIM ejector pin</li>
          <li>1 &times; User manual and warranty card</li>
          <li>Original retail packaging</li>
        </ul>
      </div>

    </section>

    <!-- ═══════════════════════════════════════════════════════
         TAB: SPECIFICATIONS
         ═══════════════════════════════════════════════════════ -->
    <section class="tab-panel" id="tab-specs" role="tabpanel">
      <div class="section-card">
        <h2 class="section-title">{currentProduct.brand} {currentProduct.name} &mdash; Full Specifications</h2>

        {[
          { title: 'General',              rows: detailedSpecs.general },
          { title: 'Display & Screen',     rows: detailedSpecs.display },
          { title: 'Performance & Storage',rows: detailedSpecs.performance },
          { title: 'Camera System',        rows: detailedSpecs.camera },
          { title: 'Battery & Charging',   rows: detailedSpecs.battery },
          { title: 'Connectivity',         rows: detailedSpecs.connectivity },
          { title: 'Physical',             rows: detailedSpecs.physical },
        ].map(group => (
          <div class="spec-group">
            <h3 class="spec-group-title">{group.title}</h3>
            <table class="spec-table">
              <tbody>
                {group.rows.filter(r => r.value).map(row => (
                  <tr>
                    <td class="spec-key">{row.label}</td>
                    <td class="spec-val">{row.value}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        ))}

        <div class="spec-group">
          <h3 class="spec-group-title">Kenya Network Compatibility</h3>
          <table class="spec-table">
            <tbody>
              <tr><td class="spec-key">Kenyan Networks</td><td class="spec-val">Safaricom, Airtel, Telkom Kenya</td></tr>
              <tr><td class="spec-key">International Roaming</td><td class="spec-val">Yes</td></tr>
              <tr><td class="spec-key">VoLTE Support</td><td class="spec-val">Yes</td></tr>
              <tr><td class="spec-key">Wi-Fi Calling</td><td class="spec-val">Yes</td></tr>
            </tbody>
          </table>
          <div class="network-note">
            The {currentProduct.brand} {currentProduct.name} works fully on all major Kenyan networks — Safaricom 4G/LTE, Airtel Kenya 4G, and Telkom Kenya.
          </div>
        </div>

        <div class="spec-group">
          <h3 class="spec-group-title">Additional Features</h3>
          <div class="add-features-grid">
            <div class="add-feat"><strong>Security</strong><p>Fingerprint sensor, Face unlock, PIN / Pattern</p></div>
            <div class="add-feat"><strong>Audio</strong><p>Stereo speakers, Dolby Atmos, Hi-Res audio</p></div>
            <div class="add-feat"><strong>Gaming</strong><p>Game mode, GPU turbo, Optimised performance</p></div>
            <div class="add-feat"><strong>Display</strong><p>Night mode, Reading mode, Eye comfort shield</p></div>
            <div class="add-feat"><strong>Sensors</strong><p>Accelerometer, Gyroscope, Proximity, Compass</p></div>
            <div class="add-feat"><strong>Smart Features</strong><p>AI Assistant, Smart gestures, Split screen</p></div>
          </div>
        </div>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         TAB: DELIVERY & PAYMENT
         ═══════════════════════════════════════════════════════ -->
    <section class="tab-panel" id="tab-delivery" role="tabpanel">
      <div class="section-card">

        <h2 class="section-title">How It Works</h2>
        <ol class="payment-steps">
          <li>
            <div class="step-circle">1</div>
            <div>
              <strong>Order</strong> — call us, WhatsApp us, or fill in the order form on this page.
              No payment is needed to place your order.
            </div>
          </li>
          <li>
            <div class="step-circle">2</div>
            <div>
              <strong>Delivery</strong> — we deliver the {currentProduct.brand} {currentProduct.name} to you same day
              within Nairobi, Kiambu, Machakos, or Kajiado.
            </div>
          </li>
          <li>
            <div class="step-circle">3</div>
            <div>
              <strong>Inspect</strong> — check the phone.Make sure you are fully satisfied.
              You pay nothing until you approve.
            </div>
          </li>
          <li>
            <div class="step-circle">4</div>
            <div>
              <strong>Pay deposit</strong> — once happy, pay the deposit of <strong>KES {currentProduct.deposit}</strong>
              via M-Pesa on the spot. The phone is yours to take home.
            </div>
          </li>
          <li>
            <div class="step-circle">5</div>
            <div>
              <strong>Start instalments</strong> — after a free grace period, pay
              <strong> KES {currentProduct.daily}/day</strong> or <strong>
  KES {parseInt(currentProduct.daily.replace(/\D/g, '')) * 7}/week
</strong>
              at your own pace until the balance is cleared.
            </div>
          </li>
        </ol>

        <div class="benefits-banner">
          <span>No payment before delivery</span>
          <span>Inspect before you pay</span>
          <span>No interest or hidden fees</span>
          <span>No credit check required</span>
          <span>Daily, weekly or monthly payments</span>
        </div>

        <h2 class="section-title" style="margin-top:2.5rem;">Delivery Areas</h2>
        <div class="counties-grid">
          <div class="county-card">
            <strong>Nairobi</strong>
            <p>CBD, Westlands, Kilimani, Kasarani, Embakasi, Eastleigh, South B &amp; C, Langata, and all estates.</p>
          </div>
          <div class="county-card">
            <strong>Kiambu</strong>
            <p>Thika, Ruiru, Juja, Kiambu Town, Kikuyu, Limuru, Karuri, Githurai, and surrounding areas.</p>
          </div>
          <div class="county-card">
            <strong>Machakos</strong>
            <p>Machakos Town, Athi River, Mavoko, Kangundo, Kathiani, and nearby areas.</p>
          </div>
          <div class="county-card">
            <strong>Kajiado</strong>
            <p>Ngong, Kitengela, Ongata Rongai, Kiserian, Kajiado Town, and surrounding areas.</p>
          </div>
        </div>
        <p class="delivery-note">Not sure if we cover your exact location? Call 0100028823 to confirm before ordering.</p>

      </div>
    </section>

    <!-- ═══════════════════════════════════════════════════════
         TAB: FAQ
         ═══════════════════════════════════════════════════════ -->
    <section class="tab-panel" id="tab-faq" role="tabpanel">
      <div class="section-card">
        <h2 class="section-title">Frequently Asked Questions</h2>
        <div class="faq-list">
          {faqs.map((faq, i) => (
            <details class="faq-item" open={i === 0}>
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- RELATED PRODUCTS -->
    {relatedProducts.length > 0 && (
      <section class="related-section">
        <h2 class="related-title">More {currentProduct.brand} Phones on Instalments</h2>
        <div class="related-grid">
          {relatedProducts.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      </section>
    )}

    <!-- BOTTOM CTA -->
    <section class="bottom-cta">
      <div class="cta-inner">
