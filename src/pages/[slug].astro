---
export const prerender = true;

import ProductLayout from "../layouts/ProductLayout.astro";
import Nav from "../components/Nav.astro";
import Gift from "../components/Gift.astro";
import { products } from "../data/product2";

import {
  FEATURE_FILTERS,
  getProductFeatures,
  featureHref,
  comboHref,
  COMBO_PAIRS,
} from '../data/feature-config.js';
import { brandSlugall } from '../data/filter-config.js';

export async function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
  }));
}

const { slug } = Astro.params;
const currentProduct = products.find((p) => p.slug === slug);

const productFeatureKeys    = getProductFeatures(currentProduct);
const productFeatureObjects = FEATURE_FILTERS.filter(f => productFeatureKeys.includes(f.key));

if (!currentProduct) {
  return Astro.redirect("/404");
}

// ── Smart related products ────────────────────────────────────────────────────
const currentDeposit = parseInt((currentProduct.deposit ?? '').replace(/[^0-9]/g, ''), 10) || 0;
const PRICE_TIER_RANGE = 3000;

function seededShuffle<T>(arr: T[], seed: number): T[] {
  const a = [...arr];
  let s = seed >>> 0;
  for (let i = a.length - 1; i > 0; i--) {
    s = Math.imul(s ^ (s >>> 16), 0x45d9f3b);
    s = Math.imul(s ^ (s >>> 16), 0x45d9f3b);
    s = s ^ (s >>> 16);
    const j = Math.abs(s) % (i + 1);
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const slugSeed = currentProduct.slug.split('').reduce((n, c, i) => n + c.charCodeAt(0) * (i + 7), 0);
const otherProducts = products.filter((p) => p.id !== currentProduct.id);

const tier1 = seededShuffle(
  otherProducts.filter((p) => {
    const dep = parseInt((p.deposit ?? '').replace(/[^0-9]/g, ''), 10) || 0;
    return p.brand === currentProduct.brand && Math.abs(dep - currentDeposit) <= PRICE_TIER_RANGE;
  }), slugSeed);

const tier1ids = new Set(tier1.map((p) => p.id));
const tier2 = seededShuffle(
  otherProducts.filter((p) => p.brand === currentProduct.brand && !tier1ids.has(p.id)),
  slugSeed + 1);

const tier12ids = new Set([...tier1, ...tier2].map((p) => p.id));
const tier3 = seededShuffle(
  otherProducts.filter((p) => {
    const dep = parseInt((p.deposit ?? '').replace(/[^0-9]/g, ''), 10) || 0;
    return p.brand !== currentProduct.brand
      && Math.abs(dep - currentDeposit) <= PRICE_TIER_RANGE
      && !tier12ids.has(p.id);
  }), slugSeed + 2);

const currentStorage = (currentProduct.storage ?? '').replace(/[^0-9]/g, '');
const tier123ids = new Set([...tier1, ...tier2, ...tier3].map((p) => p.id));
const tier4 = seededShuffle(
  otherProducts.filter((p) => {
    const s = (p.storage ?? '').replace(/[^0-9]/g, '');
    return s === currentStorage && s !== '' && !tier123ids.has(p.id);
  }), slugSeed + 3);

const tier1234ids = new Set([...tier1, ...tier2, ...tier3, ...tier4].map((p) => p.id));
const tier5 = seededShuffle(
  otherProducts.filter((p) => !tier1234ids.has(p.id)), slugSeed + 4);

const pool: typeof products = [];
for (const tier of [tier1, tier2, tier3, tier4, tier5]) {
  for (const p of tier) {
    if (pool.length >= 4) break;
    if (!pool.find((x) => x.id === p.id)) pool.push(p);
  }
  if (pool.length >= 4) break;
}
const relatedProducts = pool.slice(0, 4);

// ── FAQ ───────────────────────────────────────────────────────────────────────
const faqs = [
  {
    question: `How does the instalment plan work for the ${currentProduct.name}?`,
    answer: `We deliver the phone directly to your location in Nairobi, Kiambu, Machakos, or Kajiado — no advance payment required. Once it arrives, you turn it on, test every feature, and try it for yourself. Only when you are completely satisfied do you pay the deposit of KES ${currentProduct.deposit}. After that, a short grace period begins before your daily payments of KES ${currentProduct.daily} kick in. You can also choose to pay weekly or monthly instead — whatever matches your cash flow best.`,
  },
  {
    question: "Do I need to pay anything before delivery?",
    answer: "No. We deliver first, you inspect second, you pay third. The deposit is only collected once the phone is physically with you and you have confirmed it meets your expectations. There are no hidden booking fees, no upfront processing charges, and no payment of any kind before our rider arrives at your door.",
  },
  {
    question: "Which areas do you cover for free delivery?",
    answer: "We offer free same-day delivery across Nairobi, Kiambu, Machakos, and Kajiado counties. This includes Nairobi CBD, Westlands, Kasarani, Embakasi, Thika, Ruiru, Athi River, Kitengela, Ngong, and many more. Not sure whether we reach your exact location? Call or WhatsApp us on 0100028823 before ordering and we will confirm right away.",
  },
  {
    question: "How do I place an order?",
    answer: `Three options: (1) WhatsApp us on 0100028823 for the fastest response, (2) call us directly on 0100028823, or (3) fill in the order form on this page. As soon as we receive your order, we confirm your delivery date and estimated arrival time the same day. Delivery is free and same-day for all areas within Nairobi, Kiambu, Machakos, and Kajiado.`,
  },
  {
    question: `Is the ${currentProduct.name} brand new and genuine?`,
    answer: `Yes. Every $ ${currentProduct.name} we sell is brand new, 100% genuine, and sourced exclusively through authorised ${currentProduct.brand} distributors in Kenya. No refurbished units, no grey-market imports. Every phone comes sealed in original retail packaging and includes a full manufacturer warranty.`,
  },
  {
    question: `What colour options are available for the ${currentProduct.name}?`,
    answer: `The ${currentProduct.name} is currently available in: ${currentProduct.color}. When placing your order, let us know your preferred colour and we will confirm availability immediately.`,
  },
  {
    question: "What warranty does the phone come with?",
    answer: `Every ${currentProduct.name} comes with a 2-year manufacturer warranty covering factory defects and hardware faults. You also benefit from our dedicated after-sales support team throughout your instalment period.`,
  },
  {
    question: "What happens if I am unable to make a payment on time?",
    answer: "Contact us proactively. Our team can arrange a revised payment schedule, extend a grace period, or pause instalments temporarily depending on your situation. There are no automatic penalties for customers who communicate with us honestly.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer },
  })),
};

// ── Specs ─────────────────────────────────────────────────────────────────────
const detailedSpecs = {
  general: [
    { label: "Brand",            value: currentProduct.brand },
    { label: "Model",            value: currentProduct.name },
    { label: "Release Year",     value: currentProduct.releaseYear || "2024" },
    { label: "Operating System", value: currentProduct.os || "Android" },
    { label: "SIM Type",         value: currentProduct.simType || "Dual SIM (Nano-SIM)" },
    { label: "Colour Options",   value: currentProduct.color },
    { label: "Condition",        value: currentProduct.condition || "New" },
    { label: "Warranty",         value: "2 Years Manufacturer Warranty" },
  ],
  display: [
    { label: "Screen Size",  value: currentProduct.display || currentProduct.screenSize },
    { label: "Display Type", value: currentProduct.displayType || "AMOLED" },
    { label: "Resolution",   value: currentProduct.resolution || "Full HD+" },
    { label: "Refresh Rate", value: currentProduct.refreshRate || "60Hz" },
    { label: "Protection",   value: currentProduct.screenProtection || "Corning Gorilla Glass" },
  ],
  performance: [
    { label: "Processor",          value: currentProduct.processor || currentProduct.chipset },
    { label: "CPU",                value: currentProduct.cpu || "Octa-core" },
    { label: "GPU",                value: currentProduct.gpu || "Integrated" },
    { label: "RAM",                value: currentProduct.ram },
    { label: "Internal Storage",   value: currentProduct.storage },
    { label: "Expandable Storage", value: currentProduct.expandableStorage || "Up to 512GB via microSD" },
  ],
  camera: [
    { label: "Rear Camera",     value: currentProduct.camera || currentProduct.rearCamera },
    { label: "Front Camera",    value: currentProduct.frontCamera || currentProduct.selfieCamera },
    { label: "Video Recording", value: currentProduct.videoRecording || "4K @ 30fps" },
    { label: "Camera Features", value: currentProduct.cameraFeatures || "LED Flash, HDR, Panorama, Night Mode" },
  ],
  battery: [
    { label: "Battery Capacity",  value: currentProduct.battery || currentProduct.batteryCapacity },
    { label: "Charging",          value: currentProduct.charging || "Fast Charging 33W" },
    { label: "Wireless Charging", value: currentProduct.wirelessCharging || "Not Available" },
    { label: "Battery Type",      value: "Li-Po, Non-removable" },
  ],
  connectivity: [
    { label: "Network",    value: "2G, 3G, 4G LTE" },
    { label: "Wi-Fi",      value: currentProduct.wifi || "Wi-Fi 802.11 a/b/g/n/ac" },
    { label: "Bluetooth",  value: currentProduct.bluetooth || "Bluetooth 5.0" },
    { label: "GPS",        value: "Yes, with A-GPS, GLONASS" },
    { label: "NFC",        value: currentProduct.nfc || "Yes" },
    { label: "USB",        value: currentProduct.usb || "USB Type-C" },
    { label: "Audio Jack", value: currentProduct.audioJack || "No" },
  ],
  physical: [
    { label: "Dimensions",       value: currentProduct.dimensions || "N/A" },
    { label: "Weight",           value: currentProduct.weight || "N/A" },
    { label: "Build Material",   value: currentProduct.buildMaterial || "Glass front, Plastic back" },
    { label: "Water Resistance", value: currentProduct.waterResistance || "Splash Resistant" },
  ],
};

const brandSlug   = currentProduct.brand.toLowerCase().replace(/\s+/g, "-");
const rating      = currentProduct.reviews?.averageRating ?? 4.5;
const reviewCount = currentProduct.reviews?.reviewCount ?? 0;

const galleryImages = [
  currentProduct.source,
  currentProduct.source2,
  currentProduct.source3,
].filter(Boolean);

const dailyNum = parseInt(currentProduct.daily.replace(/\D/g, ''));
const weeklyNum = dailyNum * 7;

function renderStars(r: number) {
  const full = Math.floor(r);
  return '★'.repeat(full) + '☆'.repeat(5 - full);
}

const keyHighlights = [
  currentProduct.ram       ? { icon: '⚡', label: 'Performance', value: `${currentProduct.ram} RAM` }         : null,
  currentProduct.storage   ? { icon: '💾', label: 'Storage',     value: currentProduct.storage }               : null,
  currentProduct.camera    ? { icon: '📷', label: 'Camera',      value: currentProduct.camera }                : null,
  currentProduct.battery   ? { icon: '🔋', label: 'Battery',     value: currentProduct.battery }               : null,
  currentProduct.display   ? { icon: '🖥', label: 'Display',     value: currentProduct.display }               : null,
  currentProduct.processor ? { icon: '🔧', label: 'Processor',   value: currentProduct.processor }             : null,
].filter(Boolean);
---

<ProductLayout product={currentProduct} additionalSchemas={[faqSchema]}>
  <Gift />
  <Nav />

  <main class="pdp">

    <!-- BREADCRUMB -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <ol>
        <li><a href="/">Home</a></li>
        <li aria-hidden="true">›</li>
        <li><a href="/phones/lipa-mdogo-mdogo-nairobi">All Phones</a></li>
        <li aria-hidden="true">›</li>
        <li><a href={`/phones/${brandSlug}`}>{currentProduct.brand}</a></li>
        <li aria-hidden="true">›</li>
        <li aria-current="page">{currentProduct.brand} {currentProduct.name}</li>
      </ol>
    </nav>

    <!-- ═══════════════════════════════════
         HERO
    ════════════════════════════════════ -->
    <div class="hero">

      <!-- Gallery -->
      <div class="gallery" id="gallery">
        <div class="gallery__stage" id="gallery-stage">
          {currentProduct.status && (
            <span class={`badge badge--${currentProduct.status.toLowerCase()}`}>{currentProduct.status}</span>
          )}

          <div class="gallery__zoom-wrap" id="zoom-wrap">
            <img
              id="main-img"
              src={currentProduct.source}
              alt={`${currentProduct.name} — buy on instalments in Kenya`}
              class="gallery__main-img"
              loading="eager"
              width="560" height="560"
            />
            <div class="gallery__lens" id="zoom-lens" aria-hidden="true"></div>
          </div>

          <div class="gallery__zoom-result" id="zoom-result" aria-hidden="true"></div>

          <button class="gallery__fullscreen" id="btn-fullscreen" aria-label="View fullscreen" type="button">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
          </button>

          {galleryImages.length > 1 && (
            <>
              <button class="gallery__arrow gallery__arrow--prev" id="arrow-prev" aria-label="Previous image" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button class="gallery__arrow gallery__arrow--next" id="arrow-next" aria-label="Next image" type="button">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
              <div class="gallery__dots" id="dot-row">
                {galleryImages.map((_, i) => (
                  <button class={`gallery__dot ${i === 0 ? 'is-active' : ''}`} data-index={i} aria-label={`Image ${i + 1}`} type="button"></button>
                ))}
              </div>
            </>
          )}
        </div>

        {galleryImages.length > 1 && (
          <div class="gallery__thumbs" id="thumb-strip">
            {galleryImages.map((src, i) => (
              <button
                class={`gallery__thumb ${i === 0 ? 'is-active' : ''}`}
                data-index={i}
                data-src={src}
                aria-label={`View image ${i + 1}`}
                type="button"
              >
                <img
                  src={src}
                  alt={`${currentProduct.name} view ${i + 1}`}
                  width="72" height="72"
                  loading={i === 0 ? 'eager' : 'lazy'}
                />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Info -->
      <div class="info">
        <div class="info__meta">
          <span class="info__brand">{currentProduct.brand}</span>
          <span class="info__stock">In Stock</span>
        </div>

        <h1 class="info__title">
          {currentProduct.brand} {currentProduct.fullname ?? currentProduct.name}
        </h1>

        {reviewCount > 0 && (
          <div class="info__rating">
            <span class="info__stars" aria-label={`Rated ${rating} out of 5`}>{renderStars(rating)}</span>
            <span class="info__rating-val">{rating}</span>
            <span class="info__rating-count">({reviewCount} reviews)</span>
          </div>
        )}

        <div class="info__delivery-strip">
          <span>Free same-day delivery — Nairobi &amp; surrounds</span>
          <span>Pay only after delivery</span>
          <span>No credit check</span>
        </div>

        <!-- Pricing -->
        <div class="pricing">
          <div class="pricing__grid">
            <div class="pricing__item">
              <span class="pricing__label">Deposit — paid on delivery</span>
              <span class="pricing__amount">{currentProduct.deposit}</span>
            </div>
            <div class="pricing__divider" aria-hidden="true"></div>
            <div class="pricing__item">
              <span class="pricing__label">Then from</span>
              <span class="pricing__amount pricing__amount--accent">{currentProduct.daily}<small>/day</small></span>
            </div>
          </div>
          <p class="pricing__note">
            Or <strong>KES {weeklyNum}/week</strong> — choose daily, weekly, or monthly payments
          </p>
          <ul class="pricing__perks">
            <li>Zero payment before delivery — free delivery today</li>
            <li>Inspect the phone first — deposit only after you approve</li>
            <li>No interest · No hidden fees · No credit check</li>
          </ul>
        </div>

        <!-- Order block -->
        <div class="order">
          <p class="order__heading">How would you like to order?</p>
          <a
            href={`https://wa.me/254100028823?text=Hi, I want to order the ${currentProduct.name} on instalments`}
            class="btn btn--wa"
            target="_blank" rel="noopener"
          >
            Order via WhatsApp — Free Delivery Today
          </a>
          <a href="tel:+254100028823" class="btn btn--call">
            Call Us — 0100028823
          </a>
          <button class="btn btn--form" id="toggle-form-btn" type="button">
            Fill In an Order Form
          </button>
        </div>

        <!-- Order form (hidden by default) -->
        <div class="order-form" id="order-form-wrap" hidden>
          <p class="order-form__title">Place Your Order</p>
          <div class="order-form__fields">
            <input class="order-form__input" type="text"  id="f-name"  placeholder="Your full name" autocomplete="name" />
            <input class="order-form__input" type="tel"   id="f-phone" placeholder="Phone number" autocomplete="tel" />
            <input class="order-form__input" type="text"  id="f-area"  placeholder="Delivery area (e.g. Nairobi, Kiambu)" />
            <div class="order-form__row">
              <div class="order-form__field">
                <label class="order-form__label" for="f-date">Delivery date</label>
                <input class="order-form__input" type="date" id="f-date" />
              </div>
              <div class="order-form__field">
                <label class="order-form__label" for="f-time">Preferred time</label>
                <select class="order-form__input" id="f-time">
                  <option value="">Select time slot</option>
                  <option value="Morning (8am – 12pm)">Morning (8am–12pm)</option>
                  <option value="Afternoon (12pm – 4pm)">Afternoon (12pm–4pm)</option>
                  <option value="Evening (4pm – 7pm)">Evening (4pm–7pm)</option>
                  <option value="Anytime today">Anytime — ASAP</option>
                </select>
              </div>
            </div>
            <textarea class="order-form__input order-form__textarea" id="f-notes" rows="2" placeholder="Any notes (optional)"></textarea>
          </div>
          <button class="btn btn--submit" id="submit-order-btn" type="button">Confirm Order via WhatsApp</button>
          <p class="order-form__note">We will call you within minutes to confirm your free delivery slot.</p>
        </div>

        <!-- Trust badges -->
        <div class="trust">
          <div class="trust__item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            <span>100% Genuine</span>
          </div>
          <div class="trust__item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            <span>2-Year Warranty</span>
          </div>
          <div class="trust__item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/></svg>
            <span>Free Delivery</span>
          </div>
          <div class="trust__item">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            <span>Pay Gradually</span>
          </div>
        </div>
      </div>
    </div>

    <!-- ═══════════════════════════════════
         KEY HIGHLIGHTS (always visible)
    ════════════════════════════════════ -->
    {keyHighlights.length > 0 && (
      <section class="highlights" aria-label="Key specifications">
        <h2 class="highlights__title">Key Specifications</h2>
        <div class="highlights__grid">
          {keyHighlights.map(h => (
            <div class="highlights__item">
              <span class="highlights__icon" aria-hidden="true">{h.icon}</span>
              <span class="highlights__label">{h.label}</span>
              <span class="highlights__value">{h.value}</span>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- ═══════════════════════════════════
         ABOUT (SEO content, always visible)
    ════════════════════════════════════ -->
    <section class="content-section" id="about">
      <h2> {currentProduct.fullname ?? currentProduct.name} — Overview</h2>

      <p>
        The <strong>{currentProduct.name}</strong> is one of the most popular smartphones in Kenya right now,
        and for good reason. Whether you are a student, professional, content creator, or simply someone ready to upgrade,
        this phone delivers genuine value without requiring a large upfront payment.
        Through <strong>MdogomdogoDeals</strong>, you can own it today — delivered free to your door in Nairobi, Kiambu, Machakos, or Kajiado,
        with the deposit collected only after you inspect and approve the phone.
      </p>

      {currentProduct.ram && (
        <p>
          <strong>Performance:</strong> Powered by
          {currentProduct.processor && ` a ${currentProduct.processor} chipset and`} {currentProduct.ram} RAM,
          the {currentProduct.name} handles M-Pesa, video calls, YouTube, and heavy multitasking without lag.
        </p>
      )}

      {currentProduct.storage && (
        <p>
          <strong>Storage:</strong> With {currentProduct.storage} of built-in storage, you have plenty of room for apps,
          photos, WhatsApp media, and documents — without constantly clearing space.
          {currentProduct.expandableStorage && ` MicroSD expansion is supported for even more room.`}
        </p>
      )}

      {currentProduct.camera && (
        <p>
          <strong>Camera:</strong> The {currentProduct.camera} system captures sharp photos and clean video
          in all conditions — portrait shots, low-light scenes, selfies, and 4K recording alike.
        </p>
      )}

      {currentProduct.battery && (
        <p>
          <strong>Battery:</strong> The {currentProduct.battery} battery is built for full Kenyan days — early mornings to late evenings —
          without anxiety about running out.
          {currentProduct.charging && ` ${currentProduct.charging} gets you back up to speed quickly when you do plug in.`}
        </p>
      )}

      {currentProduct.display && (
        <p>
          <strong>Display:</strong> The {currentProduct.display} screen delivers vivid, accurate colours
          for streaming, gaming, video calls, and everyday browsing.
        </p>
      )}

      <p>
        Every {currentProduct.name} sold by MdogomdogoDeals is brand new and sealed, sourced through
        authorised {currentProduct.brand} distributors in Kenya, fully compatible with Safaricom, Airtel, and Telkom networks out of the box,
        and covered by a <strong>2-year manufacturer warranty</strong>.
      </p>
    </section>

    <!-- ═══════════════════════════════════
         PRICE IN KENYA (always visible)
    ════════════════════════════════════ -->
    <section class="content-section" id="price-kenya">
      <h2> {currentProduct.name} Price in Kenya</h2>

      <div class="price-table">
        <div class="price-table__row price-table__row--featured">
          <span class="price-table__label">Deposit — paid on delivery</span>
          <span class="price-table__value">{currentProduct.deposit}</span>
        </div>
        <div class="price-table__row">
          <span class="price-table__label">Daily instalment</span>
          <span class="price-table__value price-table__value--accent">{currentProduct.daily}<small>/day</small></span>
        </div>
        <div class="price-table__row">
          <span class="price-table__label">Weekly instalment</span>
          <span class="price-table__value price-table__value--accent">KES {weeklyNum}<small>/week</small></span>
        </div>
        <div class="price-table__row">
          <span class="price-table__label">Delivery fee</span>
          <span class="price-table__value price-table__value--free">FREE — Same Day</span>
        </div>
      </div>

      <p>
        The <strong> {currentProduct.name} price in Kenya</strong> starts at a deposit of <strong>{currentProduct.deposit}</strong> — 
        collected only after free delivery and your inspection. You pay nothing to place an order.
        Once satisfied, pay the deposit and continue with <strong>{currentProduct.daily} per day</strong> or <strong>KES {weeklyNum} per week</strong> until the balance is cleared.
        No interest. No hidden fees. No credit check.
      </p>

      <div class="why-grid">
