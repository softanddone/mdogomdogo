    border: 2px solid var(--primary); border-radius: 4px;
    background: rgba(26,115,232,0.08); pointer-events: none; z-index: 5;
  }
  .zoom-result {
    display: none; position: absolute;
    left: calc(100% + 12px); top: 0;
    width: 340px; height: 340px;
    border: 1.5px solid var(--gray-2); border-radius: var(--radius);
    background-repeat: no-repeat; background-color: #fff;
    box-shadow: 0 8px 32px rgba(13,27,42,0.14);
    z-index: 100; pointer-events: none; overflow: hidden;
  }
  @media (max-width: 1100px) {
    .zoom-result { display: none !important; }
    .zoom-lens   { display: none !important; }
  }

  .btn-fullscreen {
    position: absolute; bottom: 12px; right: 12px; z-index: 4;
    width: 34px; height: 34px; border-radius: 6px;
    background: rgba(255,255,255,0.92); border: 1.5px solid var(--gray-2);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: var(--text-light); transition: background 0.15s, color 0.15s;
  }
  .btn-fullscreen:hover { background: #fff; color: var(--primary); }

  .gallery-arrow {
    position: absolute; top: 50%; transform: translateY(-50%);
    z-index: 4; width: 36px; height: 36px; border-radius: 50%;
    background: rgba(255,255,255,0.92); border: 1.5px solid var(--gray-2);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: var(--text); opacity: 0;
    transition: opacity 0.2s, background 0.15s, color 0.15s;
  }
  .main-stage:hover .gallery-arrow { opacity: 1; }
  .gallery-arrow:hover { background: #fff; color: var(--primary); border-color: var(--primary); }
  .gallery-arrow-prev { left: 10px; }
  .gallery-arrow-next { right: 50px; }

  .dot-row {
    position: absolute; bottom: 12px; left: 50%; transform: translateX(-50%);
    display: flex; gap: 6px; z-index: 4;
  }
  .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: rgba(255,255,255,0.6); border: 1.5px solid rgba(255,255,255,0.8);
    cursor: pointer; padding: 0; transition: background 0.2s, transform 0.2s;
  }
  .dot.active { background: #fff; transform: scale(1.25); }

  .thumb-strip {
    display: flex; gap: 8px; flex-wrap: nowrap;
    overflow-x: auto; padding-bottom: 4px;
    scrollbar-width: thin; scrollbar-color: var(--gray-2) transparent;
  }
  .thumb-strip::-webkit-scrollbar { height: 4px; }
  .thumb-strip::-webkit-scrollbar-track { background: transparent; }
  .thumb-strip::-webkit-scrollbar-thumb { background: var(--gray-2); border-radius: 2px; }
  .thumb-item {
    flex-shrink: 0; width: 72px; height: 72px; padding: 4px;
    border: 2px solid var(--gray-2); border-radius: 8px;
    background: var(--gray-1); cursor: pointer; overflow: hidden;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  .thumb-item img { width: 100%; height: 100%; object-fit: contain; display: block; transition: transform 0.2s; }
  .thumb-item:hover img { transform: scale(1.07); }
  .thumb-item:hover { border-color: var(--primary); }
  .thumb-item.active { border-color: var(--primary); background: var(--primary-light); box-shadow: 0 0 0 3px rgba(26,115,232,0.18); }

  .quick-specs { display: flex; gap: 6px; flex-wrap: wrap; }
  .spec-pill {
    background: var(--gray-1); border: 1px solid var(--gray-2);
    color: var(--text-light); border-radius: 4px;
    padding: 3px 9px; font-size: 11.5px; font-weight: 500;
  }

  /* Info column */
  .info-col { display: flex; flex-direction: column; gap: 14px; }

  .info-brand-row { display: flex; align-items: center; gap: 10px; }
  .brand-tag {
    background: var(--primary); color: #fff;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 12px; font-weight: 700;
