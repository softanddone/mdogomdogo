      </div>
    </section>

    {productFeatureObjects.length > 0 && (
      <section class="product-feature-links">
        <h2>Explore Similar Phones on Lipa Mdogo Mdogo</h2>
        <div class="feat-link-grid">

          {productFeatureObjects.map(feat => (
            <a href={featureHref(feat.key)} class="feat-link">
              All {feat.label} Phones in Kenya — Lipa Mdogo Mdogo
            </a>
          ))}

          {currentProduct.brand && productFeatureObjects.map(feat => (
            <a href={featureHref(feat.key, currentProduct.brand)} class="feat-link brand-feat">
              {currentProduct.brand} {feat.label} Phones — Lipa Pole Pole
            </a>
          ))}

          {(() => {
            const links = [];
            for (let i = 0; i < productFeatureKeys.length; i++) {
              for (let j = i + 1; j < productFeatureKeys.length; j++) {
                const href = comboHref(productFeatureKeys[i], productFeatureKeys[j]);
                if (!href) continue;
                const fa = FEATURE_FILTERS.find(f => f.key === productFeatureKeys[i]);
                const fb = FEATURE_FILTERS.find(f => f.key === productFeatureKeys[j]);
                links.push(
                  <a href={href} class="feat-link combo-feat">
                    {fa.label} + {fb.label} Phones in Kenya
                  </a>
                );
              }
            }
            return links;
          })()}

          <a href="/phones/lipa-mdogo-mdogo-nairobi" class="feat-link">
            All Lipa Mdogo Mdogo Phones — Free Delivery Nairobi
          </a>
          {currentProduct.brand && (
            <a href={`/phones/${brandSlugall(currentProduct.brand)}`} class="feat-link">
              All {currentProduct.brand} Phones on Lipa Mdogo Mdogo
            </a>
          )}

        </div>
      </section>
    )}

  </main>

  <!-- LIGHTBOX MODAL -->
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Image viewer" hidden>
    <button class="lightbox-close" id="lightbox-close" aria-label="Close" type="button">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <button class="lightbox-arrow lightbox-prev" id="lightbox-prev" aria-label="Previous" type="button">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <div class="lightbox-img-wrap">
      <img id="lightbox-img" src="" alt="Product image fullscreen" />
    </div>
    <button class="lightbox-arrow lightbox-next" id="lightbox-next" aria-label="Next" type="button">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
    <div class="lightbox-counter" id="lightbox-counter">1 / 1</div>
    <div class="lightbox-thumbs" id="lightbox-thumbs"></div>
  </div>

</ProductLayout>

<script>
// ─── SEO TAB FIX ─────────────────────────────────────────────────────────────
// All tab panels are visible in SSR HTML (for Google to index).
// After JS loads, we signal the body so CSS can hide inactive panels.
// This way Googlebot always sees all content; users get the tab UX.
document.documentElement.classList.add('js-tabs-ready');

// ─── Gallery Data ─────────────────────────────────────────────────────────────
const thumbItems = Array.from(document.querySelectorAll<HTMLButtonElement>('.thumb-item'));
const galleryImages: string[] = thumbItems.length
  ? thumbItems.map(t => t.dataset.src ?? '')
  : [document.querySelector<HTMLImageElement>('#main-product-img')?.src ?? ''];

let currentIndex = 0;

const mainImg       = document.getElementById('main-product-img') as HTMLImageElement | null;
const zoomContainer = document.getElementById('zoom-container') as HTMLElement | null;
const zoomLens      = document.getElementById('zoom-lens') as HTMLElement | null;
const zoomResult    = document.getElementById('zoom-result') as HTMLElement | null;
const zoomHint      = document.getElementById('zoom-hint') as HTMLElement | null;
const dotRow        = document.getElementById('dot-row');
const arrowPrev     = document.getElementById('arrow-prev');
const arrowNext     = document.getElementById('arrow-next');
const btnFullscreen = document.getElementById('btn-fullscreen');

function setActiveImage(index: number) {
  if (index < 0) index = galleryImages.length - 1;
  if (index >= galleryImages.length) index = 0;
  currentIndex = index;
  const src = galleryImages[index];
  if (mainImg) mainImg.src = src;
  thumbItems.forEach((t, i) => t.classList.toggle('active', i === index));
  dotRow?.querySelectorAll<HTMLButtonElement>('.dot').forEach((d, i) => d.classList.toggle('active', i === index));
  if (zoomResult && mainImg) zoomResult.style.backgroundImage = `url('${src}')`;
}

thumbItems.forEach((btn, i) => btn.addEventListener('click', () => setActiveImage(i)));
dotRow?.querySelectorAll<HTMLButtonElement>('.dot').forEach((dot, i) => {
  dot.addEventListener('click', () => setActiveImage(i));
});
arrowPrev?.addEventListener('click', () => setActiveImage(currentIndex - 1));
arrowNext?.addEventListener('click', () => setActiveImage(currentIndex + 1));

document.addEventListener('keydown', (e) => {
  if (galleryImages.length <= 1) return;
  if (e.key === 'ArrowLeft')  setActiveImage(currentIndex - 1);
  if (e.key === 'ArrowRight') setActiveImage(currentIndex + 1);
  if (e.key === 'Escape') closeLightbox();
});

// ─── Zoom ─────────────────────────────────────────────────────────────────────
const ZOOM_FACTOR = 2.5;

function moveLens(e: MouseEvent) {
  if (!zoomContainer || !zoomLens || !zoomResult || !mainImg) return;
  const rect  = zoomContainer.getBoundingClientRect();
  const lensW = zoomLens.offsetWidth;
  const lensH = zoomLens.offsetHeight;
  let x = e.clientX - rect.left - lensW / 2;
  let y = e.clientY - rect.top  - lensH / 2;
  x = Math.max(0, Math.min(x, rect.width  - lensW));
  y = Math.max(0, Math.min(y, rect.height - lensH));
  zoomLens.style.left = `${x}px`;
  zoomLens.style.top  = `${y}px`;
  zoomResult.style.backgroundPosition = `${-(x * ZOOM_FACTOR)}px ${-(y * ZOOM_FACTOR)}px`;
  zoomResult.style.backgroundSize     = `${rect.width * ZOOM_FACTOR}px ${rect.height * ZOOM_FACTOR}px`;
}

zoomContainer?.addEventListener('mouseenter', () => {
  if (!zoomLens || !zoomResult || !mainImg) return;
  if (window.innerWidth < 768) return;
  zoomLens.style.display   = 'block';
  zoomResult.style.display = 'block';
  zoomResult.style.backgroundImage = `url('${mainImg.src}')`;
  if (zoomHint) zoomHint.style.opacity = '0';
});
zoomContainer?.addEventListener('mouseleave', () => {
  if (zoomLens) zoomLens.style.display   = 'none';
  if (zoomResult) zoomResult.style.display = 'none';
  if (zoomHint) zoomHint.style.opacity = '1';
});
zoomContainer?.addEventListener('mousemove', moveLens);

// ─── Touch swipe ──────────────────────────────────────────────────────────────
let touchStartX = 0;
zoomContainer?.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
zoomContainer?.addEventListener('touchend', (e) => {
  const diff = touchStartX - e.changedTouches[0].clientX;
  if (Math.abs(diff) > 40) diff > 0 ? setActiveImage(currentIndex + 1) : setActiveImage(currentIndex - 1);
});

// ─── Lightbox ─────────────────────────────────────────────────────────────────
const lightbox        = document.getElementById('lightbox') as HTMLElement | null;
const lightboxImg     = document.getElementById('lightbox-img') as HTMLImageElement | null;
const lightboxClose   = document.getElementById('lightbox-close');
const lightboxPrev    = document.getElementById('lightbox-prev');
const lightboxNext    = document.getElementById('lightbox-next');
const lightboxCounter = document.getElementById('lightbox-counter');
const lightboxThumbs  = document.getElementById('lightbox-thumbs');

function openLightbox(index: number) {
  if (!lightbox || !lightboxImg) return;
  lightbox.removeAttribute('hidden');
  document.body.style.overflow = 'hidden';
  updateLightbox(index);
  if (lightboxThumbs && lightboxThumbs.children.length === 0) {
    galleryImages.forEach((src, i) => {
      const btn = document.createElement('button');
      btn.type = 'button'; btn.className = 'lb-thumb';
      btn.dataset.index = String(i);
      const img = document.createElement('img');
      img.src = src; img.width = 60; img.height = 60; img.alt = `Image ${i + 1}`;
      btn.appendChild(img);
      btn.addEventListener('click', () => updateLightbox(i));
      lightboxThumbs.appendChild(btn);
    });
  }
}

function updateLightbox(index: number) {
  if (index < 0) index = galleryImages.length - 1;
  if (index >= galleryImages.length) index = 0;
  currentIndex = index;
  if (lightboxImg) {
    lightboxImg.style.opacity = '0';
    lightboxImg.src = galleryImages[index];
    lightboxImg.onload = () => { lightboxImg.style.opacity = '1'; };
  }
  if (lightboxCounter) lightboxCounter.textContent = `${index + 1} / ${galleryImages.length}`;
  lightboxThumbs?.querySelectorAll<HTMLButtonElement>('.lb-thumb').forEach((t, i) => t.classList.toggle('active', i === index));
}

function closeLightbox() {
  lightbox?.setAttribute('hidden', '');
  document.body.style.overflow = '';
}

btnFullscreen?.addEventListener('click', () => openLightbox(currentIndex));
lightboxClose?.addEventListener('click', closeLightbox);
lightboxPrev?.addEventListener('click',  () => updateLightbox(currentIndex - 1));
lightboxNext?.addEventListener('click',  () => updateLightbox(currentIndex + 1));
lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
zoomContainer?.addEventListener('dblclick', () => openLightbox(currentIndex));

// ─── Tab switching ─────────────────────────────────────────────────────────────
(function () {
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn');
  const panels  = document.querySelectorAll<HTMLElement>('.tab-panel');

  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      tabBtns.forEach(b => { b.classList.remove('active'); b.setAttribute('aria-selected', 'false'); });
      panels.forEach(p  => p.classList.remove('active'));
      btn.classList.add('active');
      btn.setAttribute('aria-selected', 'true');
      const panel = document.getElementById(`tab-${btn.dataset.tab}`);
      if (panel) {
        panel.classList.add('active');
        document.getElementById('tab-nav')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
      }
    });
  });

  // Activate first tab (overview)
  const firstPanel = document.getElementById('tab-overview');
  if (firstPanel) firstPanel.classList.add('active');
})();

// ─── Order form toggle + WhatsApp submit ──────────────────────────────────────
(function () {
  const toggleBtn = document.getElementById('toggle-form-btn');
  const formWrap  = document.getElementById('order-form-wrap');

  const dateInput = document.getElementById('f-date') as HTMLInputElement | null;
  if (dateInput) {
    const today = new Date();
    const yyyy = today.getFullYear();
    const mm = String(today.getMonth() + 1).padStart(2, '0');
    const dd = String(today.getDate()).padStart(2, '0');
    dateInput.value = `${yyyy}-${mm}-${dd}`;
    dateInput.min   = `${yyyy}-${mm}-${dd}`;
  }

  toggleBtn?.addEventListener('click', () => {
    if (formWrap?.hasAttribute('hidden')) formWrap.removeAttribute('hidden');
    else formWrap?.setAttribute('hidden', '');
  });

  document.getElementById('submit-order-btn')?.addEventListener('click', () => {
    const name  = (document.getElementById('f-name')  as HTMLInputElement)?.value.trim();
    const phone = (document.getElementById('f-phone') as HTMLInputElement)?.value.trim();
    const area  = (document.getElementById('f-area')  as HTMLInputElement)?.value.trim();
    const date  = (document.getElementById('f-date')  as HTMLInputElement)?.value.trim();
    const time  = (document.getElementById('f-time')  as HTMLSelectElement)?.value.trim();
    const notes = (document.getElementById('f-notes') as HTMLTextAreaElement)?.value.trim();

    if (!name || !phone || !area) {
      alert('Please fill in your name, phone number, and delivery area.');
      return;
    }

    let deliveryDate = date;
    if (date) {
      const d = new Date(date + 'T00:00:00');
      deliveryDate = d.toLocaleDateString('en-KE', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
    }

    const product = document.querySelector<HTMLHeadingElement>('.product-title')?.textContent?.trim() ?? 'this phone';
    const msg = [
      `Lipa Mdogo Mdogo Order: ${product}`,
      `Name: ${name}`,
      `Phone: ${phone}`,
      `Delivery area: ${area}`,
      date  ? `Preferred delivery date: ${deliveryDate}` : '',
      time  ? `Preferred delivery time: ${time}` : '',
      notes ? `Notes: ${notes}` : '',
    ].filter(Boolean).join('\n');

    window.open(`https://wa.me/254100028823?text=${encodeURIComponent(msg)}`, '_blank');
  });
})();
</script>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --primary:       #1a73e8;
    --primary-dark:  #1557b0;
    --primary-light: #e8f0fe;
    --gold:          #f5a623;
    --navy:          #0d1b2a;
    --green:         #00b96b;
    --red:           #e53935;
    --gray-1:        #f5f7fa;
    --gray-2:        #e8eaed;
    --gray-3:        #9aa0a6;
    --text:          #202124;
    --text-light:    #5f6368;
    --badge-new:     #00b96b;
    --badge-hot:     #e53935;
    --badge-sale:    #1a73e8;
    --radius:        10px;
    --shadow:        0 2px 12px rgba(13,27,42,0.08);
  }
  body { font-family: 'Barlow', sans-serif; background: var(--gray-1); color: var(--text); }

  /* ══════════════════════════════════════════════════
     SEO TAB FIX
     Without js-tabs-ready: all panels are visible (Google sees everything).
     With js-tabs-ready: only the .active panel is shown.
  ══════════════════════════════════════════════════ */
  .tab-panel { display: block; }
  .js-tabs-ready .tab-panel { display: none; }
  .js-tabs-ready .tab-panel.active { display: block; }

  /* ══════════════════════════════════════════════════
     LAYOUT
  ══════════════════════════════════════════════════ */
