<script>
// ── Gallery ───────────────────────────────────────────────────────────────────
const thumbBtns = Array.from(document.querySelectorAll<HTMLButtonElement>('.gallery__thumb'));
const galleryImages: string[] = thumbBtns.length
  ? thumbBtns.map(t => t.dataset.src ?? '')
  : [(document.getElementById('main-img') as HTMLImageElement)?.src ?? ''];

let currentIndex = 0;

const mainImg   = document.getElementById('main-img') as HTMLImageElement | null;
const zoomWrap  = document.getElementById('zoom-wrap') as HTMLElement | null;
const zoomLens  = document.getElementById('zoom-lens') as HTMLElement | null;
const zoomRes   = document.getElementById('zoom-result') as HTMLElement | null;
const dotRow    = document.getElementById('dot-row');

function setImage(idx: number) {
  if (idx < 0) idx = galleryImages.length - 1;
  if (idx >= galleryImages.length) idx = 0;
  currentIndex = idx;
  if (mainImg) mainImg.src = galleryImages[idx];
  thumbBtns.forEach((t, i) => t.classList.toggle('is-active', i === idx));
  dotRow?.querySelectorAll<HTMLButtonElement>('.gallery__dot').forEach((d, i) => d.classList.toggle('is-active', i === idx));
  if (zoomRes && mainImg) zoomRes.style.backgroundImage = `url('${galleryImages[idx]}')`;
}

thumbBtns.forEach((btn, i) => btn.addEventListener('click', () => setImage(i)));
dotRow?.querySelectorAll<HTMLButtonElement>('.gallery__dot').forEach((dot, i) => dot.addEventListener('click', () => setImage(i)));
document.getElementById('arrow-prev')?.addEventListener('click', () => setImage(currentIndex - 1));
document.getElementById('arrow-next')?.addEventListener('click', () => setImage(currentIndex + 1));

// Swipe
let touchStartX = 0;
zoomWrap?.addEventListener('touchstart', (e) => { touchStartX = e.touches[0].clientX; }, { passive: true });
zoomWrap?.addEventListener('touchend', (e) => {
  const diff = touchStartX - e.changedTouches[0].clientX;
  if (Math.abs(diff) > 40) diff > 0 ? setImage(currentIndex + 1) : setImage(currentIndex - 1);
});

// Keyboard
document.addEventListener('keydown', (e) => {
  if (e.key === 'ArrowLeft')  setImage(currentIndex - 1);
  if (e.key === 'ArrowRight') setImage(currentIndex + 1);
  if (e.key === 'Escape') closeLightbox();
});

// Zoom
const ZOOM = 2.5;
zoomWrap?.addEventListener('mouseenter', () => {
  if (window.innerWidth < 1024 || !zoomLens || !zoomRes || !mainImg) return;
  zoomLens.style.display = 'block';
  zoomRes.style.display  = 'block';
  zoomRes.style.backgroundImage = `url('${mainImg.src}')`;
});
zoomWrap?.addEventListener('mouseleave', () => {
  if (zoomLens) zoomLens.style.display = 'none';
  if (zoomRes)  zoomRes.style.display  = 'none';
});
zoomWrap?.addEventListener('mousemove', (e) => {
  if (!zoomWrap || !zoomLens || !zoomRes) return;
  const rect  = zoomWrap.getBoundingClientRect();
  const lw = zoomLens.offsetWidth, lh = zoomLens.offsetHeight;
  let x = Math.max(0, Math.min(e.clientX - rect.left - lw / 2, rect.width - lw));
  let y = Math.max(0, Math.min(e.clientY - rect.top  - lh / 2, rect.height - lh));
  zoomLens.style.left = `${x}px`;
  zoomLens.style.top  = `${y}px`;
  zoomRes.style.backgroundPosition = `${-x * ZOOM}px ${-y * ZOOM}px`;
  zoomRes.style.backgroundSize     = `${rect.width * ZOOM}px ${rect.height * ZOOM}px`;
});

// ── Lightbox ──────────────────────────────────────────────────────────────────
const lightbox     = document.getElementById('lightbox') as HTMLElement | null;
const lbImg        = document.getElementById('lightbox-img') as HTMLImageElement | null;
const lbCounter    = document.getElementById('lightbox-counter');
const lbThumbs     = document.getElementById('lightbox-thumbs');

function openLightbox(idx: number) {
  if (!lightbox) return;
  lightbox.removeAttribute('hidden');
  document.body.style.overflow = 'hidden';
  updateLightbox(idx);
  if (lbThumbs && lbThumbs.children.length === 0) {
    galleryImages.forEach((src, i) => {
      const btn = document.createElement('button');
      btn.type = 'button'; btn.className = 'lightbox__thumb'; btn.dataset.index = String(i);
      const img = document.createElement('img'); img.src = src; img.width = 60; img.height = 60; img.alt = `Image ${i + 1}`;
      btn.appendChild(img);
      btn.addEventListener('click', () => updateLightbox(i));
      lbThumbs.appendChild(btn);
    });
  }
}
function updateLightbox(idx: number) {
  if (idx < 0) idx = galleryImages.length - 1;
  if (idx >= galleryImages.length) idx = 0;
  currentIndex = idx;
  if (lbImg) { lbImg.style.opacity = '0'; lbImg.src = galleryImages[idx]; lbImg.onload = () => { lbImg.style.opacity = '1'; }; }
  if (lbCounter) lbCounter.textContent = `${idx + 1} / ${galleryImages.length}`;
  lbThumbs?.querySelectorAll<HTMLButtonElement>('.lightbox__thumb').forEach((t, i) => t.classList.toggle('is-active', i === idx));
}
function closeLightbox() {
  lightbox?.setAttribute('hidden', '');
  document.body.style.overflow = '';
}

document.getElementById('btn-fullscreen')?.addEventListener('click', () => openLightbox(currentIndex));
zoomWrap?.addEventListener('dblclick', () => openLightbox(currentIndex));
document.getElementById('lightbox-close')?.addEventListener('click', closeLightbox);
document.getElementById('lightbox-prev')?.addEventListener('click', () => updateLightbox(currentIndex - 1));
document.getElementById('lightbox-next')?.addEventListener('click', () => updateLightbox(currentIndex + 1));
lightbox?.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });

// ── Order form ────────────────────────────────────────────────────────────────
const toggleBtn = document.getElementById('toggle-form-btn');
const formWrap  = document.getElementById('order-form-wrap');
const dateInput = document.getElementById('f-date') as HTMLInputElement | null;
if (dateInput) {
  const today = new Date();
  const y = today.getFullYear();
  const m = String(today.getMonth() + 1).padStart(2, '0');
  const d = String(today.getDate()).padStart(2, '0');
  dateInput.value = dateInput.min = `${y}-${m}-${d}`;
}
toggleBtn?.addEventListener('click', () => {
  formWrap?.hasAttribute('hidden') ? formWrap.removeAttribute('hidden') : formWrap?.setAttribute('hidden', '');
});
document.getElementById('submit-order-btn')?.addEventListener('click', () => {
  const name  = (document.getElementById('f-name')  as HTMLInputElement)?.value.trim();
  const phone = (document.getElementById('f-phone') as HTMLInputElement)?.value.trim();
  const area  = (document.getElementById('f-area')  as HTMLInputElement)?.value.trim();
  const date  = (document.getElementById('f-date')  as HTMLInputElement)?.value.trim();
  const time  = (document.getElementById('f-time')  as HTMLSelectElement)?.value.trim();
  const notes = (document.getElementById('f-notes') as HTMLTextAreaElement)?.value.trim();
  if (!name || !phone || !area) { alert('Please fill in your name, phone number, and delivery area.'); return; }
  let displayDate = date;
  if (date) {
    const dt = new Date(date + 'T00:00:00');
    displayDate = dt.toLocaleDateString('en-KE', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });
  }
  const product = document.querySelector<HTMLHeadingElement>('.info__title')?.textContent?.trim() ?? 'this phone';
  const msg = [
    `Order (Instalment Plan): ${product}`,
    `Name: ${name}`,
    `Phone: ${phone}`,
    `Delivery area: ${area}`,
    date  ? `Preferred date: ${displayDate}` : '',
    time  ? `Preferred time: ${time}` : '',
    notes ? `Notes: ${notes}` : '',
  ].filter(Boolean).join('\n');
  window.open(`https://wa.me/254100028823?text=${encodeURIComponent(msg)}`, '_blank');
});
</script>

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy:    #0d1b2a;
    --navy-2:  #162537;
    --primary: #1a6fe8;
    --pri-lt:  #e8f0fe;
    --pri-dk:  #1254b8;
    --gold:    #e6a817;
    --green:   #00a85a;
    --red:     #d93025;
    --gray-1:  #f6f8fb;
    --gray-2:  #e4e8ef;
    --gray-3:  #9aa3ae;
    --text:    #1c2333;
    --text-2:  #4a5568;
    --radius:  10px;
    --shadow:  0 1px 6px rgba(13,27,42,0.07), 0 4px 18px rgba(13,27,42,0.05);
    --shadow-md: 0 2px 12px rgba(13,27,42,0.10), 0 8px 32px rgba(13,27,42,0.07);
  }

  body { font-family: 'Barlow', sans-serif; background: var(--gray-1); color: var(--text); }

  /* ── Breadcrumb ── */
  .breadcrumb {
    background: #fff;
    border-bottom: 1px solid var(--gray-2);
    padding: 10px 20px;
  }
  .breadcrumb ol {
    max-width: 1280px; margin: 0 auto;
    display: flex; align-items: center; flex-wrap: wrap; gap: 5px;
    list-style: none; font-size: 13px; color: var(--gray-3);
  }
  .breadcrumb a { color: var(--primary); text-decoration: none; font-weight: 500; }
  .breadcrumb a:hover { text-decoration: underline; }
  .breadcrumb [aria-current="page"] { color: var(--text-2); font-weight: 500; }

  /* ── Page wrapper ── */
  .pdp { max-width: 1280px; margin: 0 auto; padding: 20px 20px 64px; }

  /* ═══════════════════════════════════════
     HERO
  ═══════════════════════════════════════ */
  .hero {
    display: grid;
    grid-template-columns: 460px 1fr;
    gap: 28px;
    background: #fff;
    border: 1px solid var(--gray-2);
    border-radius: var(--radius);
    padding: 28px;
    margin-bottom: 20px;
    box-shadow: var(--shadow);
  }
  @media (max-width: 900px) { .hero { grid-template-columns: 1fr; } }

  /* Gallery */
  .gallery { display: flex; flex-direction: column; gap: 10px; position: relative; }

  .gallery__stage {
    position: relative;
    aspect-ratio: 1 / 1;
    max-height: 440px;
    border-radius: var(--radius);
    background: var(--gray-1);
    border: 1px solid var(--gray-2);
    overflow: hidden;
  }

  .gallery__zoom-wrap {
    width: 100%; height: 100%;
    position: relative;
    display: flex; align-items: center; justify-content: center;
    cursor: crosshair;
  }

  .gallery__main-img {
    width: 100%; height: 100%;
    object-fit: cover; object-position: center;
    display: block; user-select: none; pointer-events: none;
    transition: opacity 0.2s;
  }

  .gallery__lens {
    display: none; position: absolute;
    width: 130px; height: 130px;
    border: 2px solid var(--primary);
    border-radius: 4px;
    background: rgba(26,111,232,0.07);
    pointer-events: none; z-index: 5;
  }

  .gallery__zoom-result {
    display: none;
    position: absolute;
    left: calc(100% + 14px); top: 0;
    width: 320px; height: 320px;
    border: 1px solid var(--gray-2);
    border-radius: var(--radius);
    background-repeat: no-repeat;
    background-color: #fff;
    box-shadow: var(--shadow-md);
    z-index: 100; pointer-events: none; overflow: hidden;
  }
  @media (max-width: 1100px) { .gallery__zoom-result, .gallery__lens { display: none !important; } }

  .gallery__fullscreen {
    position: absolute; bottom: 10px; right: 10px; z-index: 4;
    width: 32px; height: 32px; border-radius: 7px;
    background: rgba(255,255,255,0.9); border: 1px solid var(--gray-2);
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; color: var(--text-2);
    transition: background 0.15s, color 0.15s;
  }
  .gallery__fullscreen:hover { background: #fff; color: var(--primary); }

  .gallery__arrow {
    position: absolute; top: 50%; transform: translateY(-50%); z-index: 4;
