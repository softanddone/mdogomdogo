    background: #fff; border-bottom: 1px solid var(--gray-2); padding: 10px 20px;
  }
  .seo-intro {
    background: #fff; border-bottom: 1px solid var(--gray-2); padding: 14px 20px;
  }
  .seo-intro p {
    max-width: 1280px; margin: 0 auto;
    font-size: 14px; color: var(--text-light); line-height: 1.75;
  }
  .seo-intro strong { color: var(--text); }
  .seo-intro a { color: var(--primary); text-decoration: none; font-weight: 600; }
  .seo-intro a:hover { text-decoration: underline; }

  .breadcrumb-list {
    display: flex; align-items: center; gap: 6px; flex-wrap: wrap;
    list-style: none; font-size: 13px; color: var(--text-light);
  }
  .breadcrumb-list a { color: var(--primary); text-decoration: none; font-weight: 500; }
  .breadcrumb-list a:hover { text-decoration: underline; }
  .breadcrumb-list .sep { color: var(--gray-3); }

  .product-page { max-width: 1280px; margin: 0 auto; padding: 20px 20px 56px; }

  /* ══════════════════════════════════════════════════
     HERO
  ══════════════════════════════════════════════════ */
  .hero-section {
    display: grid; grid-template-columns: 460px 1fr; gap: 28px;
    background: #fff; border: 1.5px solid var(--gray-2);
    border-radius: var(--radius); padding: 28px;
    margin-bottom: 16px; box-shadow: var(--shadow);
  }
  @media (max-width: 960px) { .hero-section { grid-template-columns: 1fr; } }

  /* Gallery */
  .gallery-col { display: flex; flex-direction: column; gap: 10px; position: relative; }

  .main-stage {
    position: relative; background: var(--gray-1);
