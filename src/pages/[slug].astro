          <div class="zoom-container" id="zoom-container">
            <img
              id="main-product-img"
              src={currentProduct.source}
              alt={mainImgAlt}
              class="main-product-img"
              loading="eager"
              width="560" height="560"
            />
            <div class="zoom-lens" id="zoom-lens"></div>
          </div>

          <div class="zoom-result" id="zoom-result"></div>

          <button class="btn-fullscreen" id="btn-fullscreen" aria-label="View fullscreen" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"/></svg>
          </button>

          {galleryImages.length > 1 && (
            <>
              <button class="gallery-arrow gallery-arrow-prev" id="arrow-prev" aria-label="Previous image" type="button">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <button class="gallery-arrow gallery-arrow-next" id="arrow-next" aria-label="Next image" type="button">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </>
          )}

          {galleryImages.length > 1 && (
            <div class="dot-row" id="dot-row">
              {galleryImages.map((_, i) => (
