            </table>
          </div>
        ))}

        <!-- Kenya networks -->
        <div class="spec-group">
          <h3 class="spec-group-title">🇰🇪 Kenya Network Compatibility</h3>
          <table class="spec-table">
            <tbody>
              <tr><td class="spec-key">Kenyan Networks</td><td class="spec-val">Safaricom, Airtel, Telkom Kenya</td></tr>
              <tr><td class="spec-key">International Roaming</td><td class="spec-val">Yes</td></tr>
              <tr><td class="spec-key">VoLTE Support</td><td class="spec-val">Yes</td></tr>
              <tr><td class="spec-key">Wi-Fi Calling</td><td class="spec-val">Yes</td></tr>
            </tbody>
          </table>
          <div class="network-note">
            The {currentProduct.brand} {currentProduct.name} is fully compatible with <strong>Safaricom 4G/LTE</strong>, <strong>Airtel Kenya 4G</strong>, and <strong>Telkom Kenya</strong>. Enjoy fast internet wherever you are in Kenya.
          </div>
        </div>

        <!-- Additional features grid -->
        <div class="spec-group">
          <h3 class="spec-group-title">✨ Additional Features</h3>
          <div class="add-features-grid">
            <div class="add-feat"><span>🔐</span><div><strong>Security</strong><p>Fingerprint, Face unlock, PIN/Pattern</p></div></div>
            <div class="add-feat"><span>🔊</span><div><strong>Audio</strong><p>Stereo speakers, Dolby Atmos, Hi-Res</p></div></div>
            <div class="add-feat"><span>🎮</span><div><strong>Gaming</strong><p>Game mode, GPU turbo, Optimised perf.</p></div></div>
            <div class="add-feat"><span>🌙</span><div><strong>Display</strong><p>Night mode, Reading mode, Eye comfort</p></div></div>
            <div class="add-feat"><span>📡</span><div><strong>Sensors</strong><p>Accelerometer, Gyro, Proximity, Compass</p></div></div>
            <div class="add-feat"><span>🎯</span><div><strong>Smart</strong><p>AI Assistant, Gestures, Split screen</p></div></div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── TAB: DELIVERY & PAYMENT ── -->
    <section class="tab-panel" id="tab-delivery">
      <div class="section-card">
        <h2 class="section-title">Delivery in Kenya</h2>
        <div class="prose">
          <p>We offer <strong>free same-day delivery in Nairobi CBD</strong> for the {currentProduct.brand} {currentProduct.name}. Orders placed before midday are typically delivered the same day. We ship nationwide to all 47 counties.</p>
          <p><strong>Delivery areas include:</strong> Nairobi (CBD, Westlands, Kilimani, Parklands, Eastleigh, Kasarani, Embakasi), Mombasa, Kisumu, Nakuru, Eldoret, Thika, Machakos, Kitale, Malindi, Kakamega, Nyeri, Meru and all major towns across Kenya.</p>
        </div>

        <h2 class="section-title" style="margin-top:2rem">Lipa Mdogo Mdogo Payment Steps</h2>
        <ol class="payment-steps">
          <li>
            <div class="step-circle">1</div>
            <div><strong>Pay KES {currentProduct.deposit} deposit</strong> via M-Pesa Paybill, Till, or bank transfer.</div>
          </li>
          <li>
            <div class="step-circle">2</div>
            <div><strong>Receive your phone immediately</strong> — same-day delivery in Nairobi after deposit confirmation.</div>
          </li>
          <li>
            <div class="step-circle">3</div>
            <div><strong>Pay KES {currentProduct.daily} daily</strong> through M-Pesa at your own pace — daily or weekly.</div>
          </li>
          <li>
            <div class="step-circle">4</div>
            <div><strong>Complete all payments</strong> and own your phone outright with no further obligations.</div>
          </li>
        </ol>

        <div class="benefits-banner">
          <span>✓ No interest charges</span>
          <span>✓ No hidden fees</span>
          <span>✓ No credit checks required</span>
          <span>✓ M-Pesa, Airtel Money accepted</span>
        </div>
      </div>
    </section>

    <!-- ── TAB: FAQ ── -->
    <section class="tab-panel" id="tab-faq">
      <div class="section-card">
        <h2 class="section-title">Frequently Asked Questions</h2>
        <div class="faq-list">
          {faqs.map((faq, i) => (
            <details class="faq-item" open={i === 0}>
              <summary>{faq.question}</summary>
              <p>{faq.answer}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- ── RELATED PRODUCTS ── -->
    {relatedProducts.length > 0 && (
      <section class="related-section">
        <h2 class="related-title">More {currentProduct.brand} Phones — Lipa Mdogo Mdogo</h2>
        <div class="related-grid">
          {relatedProducts.map((product) => (
            <ProductCard product={product} />
          ))}
        </div>
      </section>
    )}

    <!-- ── BOTTOM CTA ── -->
    <section class="bottom-cta">
      <div class="cta-inner">
        <h2>Ready to Own the {currentProduct.brand} {currentProduct.name}?</h2>
        <p>Deposit just <strong>KES {currentProduct.deposit}</strong> today — same-day delivery in Nairobi</p>
        <div class="cta-btns">
          <a href="tel:+254720202167" class="btn-primary">📞 Call Now</a>
          <a
            href={`https://wa.me/254720202167?text=Hi, I want to buy ${currentProduct.brand} ${currentProduct.name}`}
            class="btn-whatsapp"
            target="_blank"
            rel="noopener"
          >💬 WhatsApp Us</a>
        </div>
      </div>
    </section>

  </main>
</ProductLayout>

<script>
// ── Image gallery ──
(function() {
  const mainImg = document.getElementById('main-product-img');
  const thumbs  = document.querySelectorAll('.thumb');
  thumbs.forEach(btn => {
    btn.addEventListener('click', () => {
      if (mainImg) mainImg.src = btn.dataset.src;
      thumbs.forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
    });
  });
})();

// ── Tab switching ──
(function() {
  const tabBtns  = document.querySelectorAll('.tab-btn');
  const panels   = document.querySelectorAll('.tab-panel');
  tabBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const target = btn.dataset.tab;
      tabBtns.forEach(b => b.classList.remove('active'));
      panels.forEach(p => p.classList.remove('active'));
      btn.classList.add('active');
      document.getElementById(`tab-${target}`)?.classList.add('active');
      document.getElementById('tab-nav')?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    });
  });
})();
</script>

<style>
  /* ============================================================
     ROOT — matches parent CSS variables exactly
