---
export const prerender = true;

import ProductLayout from "../layouts/ProductLayout.astro";
import Nav from "../components/Nav.astro";
import Gift from "../components/Gift.astro";
import { products } from "../data/product2";

import {
  FEATURE_FILTERS,
  getProductFeatures,
  featureHref,
  comboHref,
  COMBO_PAIRS,
} from '../data/feature-config.js';
import { brandSlugall } from '../data/filter-config.js';


export async function getStaticPaths() {
  return products.map((product) => ({
    params: { slug: product.slug },
  }));
}

const { slug } = Astro.params;
const currentProduct = products.find((p) => p.slug === slug);

const productFeatureKeys    = getProductFeatures(currentProduct);
const productFeatureObjects = FEATURE_FILTERS.filter(f => productFeatureKeys.includes(f.key));

if (!currentProduct) {
  return Astro.redirect("/404");
}

// ── Smart related products: unique per product page ──────────────────────────
const currentDeposit = parseInt((currentProduct.deposit ?? '').replace(/[^0-9]/g, ''), 10) || 0;
const PRICE_TIER_RANGE = 3000;

function seededShuffle<T>(arr: T[], seed: number): T[] {
  const a = [...arr];
  let s = seed >>> 0;
  for (let i = a.length - 1; i > 0; i--) {
    s = Math.imul(s ^ (s >>> 16), 0x45d9f3b);
    s = Math.imul(s ^ (s >>> 16), 0x45d9f3b);
    s = s ^ (s >>> 16);
    const j = Math.abs(s) % (i + 1);
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const slugSeed = currentProduct.slug.split('').reduce((n, c, i) => n + c.charCodeAt(0) * (i + 7), 0);

const otherProducts = products.filter((p) => p.id !== currentProduct.id);

const tier1 = seededShuffle(
  otherProducts.filter((p) => {
    const dep = parseInt((p.deposit ?? '').replace(/[^0-9]/g, ''), 10) || 0;
    return p.brand === currentProduct.brand && Math.abs(dep - currentDeposit) <= PRICE_TIER_RANGE;
  }),
  slugSeed
);

const tier1ids = new Set(tier1.map((p) => p.id));
const tier2 = seededShuffle(
  otherProducts.filter((p) => p.brand === currentProduct.brand && !tier1ids.has(p.id)),
  slugSeed + 1
);

const tier12ids = new Set([...tier1, ...tier2].map((p) => p.id));
const tier3 = seededShuffle(
  otherProducts.filter((p) => {
    const dep = parseInt((p.deposit ?? '').replace(/[^0-9]/g, ''), 10) || 0;
    return p.brand !== currentProduct.brand
      && Math.abs(dep - currentDeposit) <= PRICE_TIER_RANGE
      && !tier12ids.has(p.id);
  }),
  slugSeed + 2
);

const currentStorage = (currentProduct.storage ?? '').replace(/[^0-9]/g, '');
const tier123ids = new Set([...tier1, ...tier2, ...tier3].map((p) => p.id));
const tier4 = seededShuffle(
  otherProducts.filter((p) => {
    const s = (p.storage ?? '').replace(/[^0-9]/g, '');
    return s === currentStorage && s !== '' && !tier123ids.has(p.id);
  }),
  slugSeed + 3
);

const tier1234ids = new Set([...tier1, ...tier2, ...tier3, ...tier4].map((p) => p.id));
const tier5 = seededShuffle(
  otherProducts.filter((p) => !tier1234ids.has(p.id)),
  slugSeed + 4
);

const pool: typeof products = [];
for (const tier of [tier1, tier2, tier3, tier4, tier5]) {
  for (const p of tier) {
    if (pool.length >= 4) break;
    if (!pool.find((x) => x.id === p.id)) pool.push(p);
  }
  if (pool.length >= 4) break;
}

const relatedProducts = pool.slice(0, 4);

const faqs = [
  {
    question: `How does the Lipa Mdogo Mdogo instalment plan work for the ${currentProduct.name}?`,
    answer: `It is straightforward. We deliver the phone directly to your location in Nairobi, Kiambu, Machakos, or Kajiado — no advance payment required. Once it arrives, you turn it on, test every feature, and try it for yourself. Only when you are completely satisfied do you pay the deposit of KES ${currentProduct.deposit}. After that, a short grace period begins before your daily payments of KES ${currentProduct.daily} kick in. You can also choose to pay weekly or monthly instead — whatever matches your cash flow best. This is the most flexible lipa mdogo mdogo plan available in Kenya today: no booking fee, no delivery charge, nothing owed before the phone is in your hands.`,
  },
  {
    question: "What is Lipa Mdogo Mdogo and how is it different from Lipa Pole Pole?",
    answer: "Lipa mdogo mdogo and lipa pole pole are both popular Kenyan phrases describing the same idea: paying for something gradually in small, manageable instalments rather than all at once. At MdogomdogoDeals, we use both terms interchangeably. Whether you call it lipa mdogo mdogo, lipa pole pole, or simply phone instalments, the system is the same — we deliver your phone first, you inspect it, then you pay a small deposit and continue with daily, weekly, or monthly payments until the balance is cleared. No lump sum, no credit check, no guarantor.",
  },
  {
    question: "Do I need to pay anything before delivery?",
    answer: "Absolutely not. MdogomdogoDeals operates on a simple principle: we deliver first, you inspect second, you pay third. The deposit is only collected once the phone is physically with you and you have confirmed it meets your expectations. There are no hidden booking fees, no upfront processing charges, and no payment of any kind before our rider arrives at your door. This is what makes our lipa mdogo mdogo plan the most trusted phone instalment service in Nairobi.",
  },
  {
    question: "Which counties and areas in Nairobi do you cover for free delivery?",
    answer: "We offer free same-day delivery across Nairobi, Kiambu, Machakos, and Kajiado counties — covering the entire greater Nairobi metropolitan area and surrounding regions. This includes Nairobi CBD, Westlands, Kasarani, Embakasi, Thika, Ruiru, Athi River, Kitengela, Ngong, and many more. Not sure whether we reach your exact location? Call or WhatsApp us on 0100028823 before ordering and we will confirm right away.",
  },
  {
    question: "How do I place an order for the phone on lipa mdogo mdogo?",
    answer: `Ordering on our lipa mdogo mdogo plan is easy — three options are available: (1) WhatsApp us on 0100028823 for the fastest response, (2) call us directly on 0100028823 to speak with our team, or (3) fill in the order form on this page. As soon as we receive your order, we will confirm your delivery date and estimated arrival time the same day. Delivery is free and happens the same day you place your order for all areas within Nairobi, Kiambu, Machakos, and Kajiado.`,
  },
  {
    question: `Is the ${currentProduct.name} brand new and genuine?`,
    answer: `Yes, without exception. Every ${currentProduct.brand} ${currentProduct.name} we sell is brand new, 100% genuine, and sourced exclusively through authorised ${currentProduct.brand} distributors operating in Kenya. No refurbished units, no grey-market imports, no imitations. Every phone comes sealed in original ${currentProduct.brand} retail packaging and includes a full manufacturer warranty for your peace of mind.`,
  },
  {
    question: `What colour options are available for the ${currentProduct.name}?`,
    answer: `The ${currentProduct.brand} ${currentProduct.name} is currently available in the following colours: ${currentProduct.color}. When placing your order, simply let us know your preferred colour and we will confirm availability. If your first choice is out of stock, we will advise you immediately so you can choose an alternative without any delay to your delivery.`,
  },
  {
    question: "What warranty does the phone come with?",
    answer: `Every ${currentProduct.brand} ${currentProduct.name} purchased through MdogomdogoDeals comes with a 2-year manufacturer warranty covering factory defects and hardware faults, backed by ${currentProduct.brand} and ${currentProduct.seller}. In addition, you benefit from our dedicated after-sales support team throughout your instalment period — so you are never left without assistance.`,
  },
  {
    question: "What happens if I am unable to make a payment on time?",
    answer: "We understand that life does not always go to plan. If you are going through a difficult period, the most important thing is to contact us proactively. Our team is trained to work with customers compassionately — we can arrange a revised payment schedule, extend a grace period, or pause instalments temporarily depending on your situation. There are no automatic penalties for customers who communicate with us honestly.",
  },
];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: { "@type": "Answer", text: faq.answer },
  })),
};

const keyFeatures = [
  currentProduct.ram       ? `${currentProduct.ram} RAM`         : null,
  currentProduct.storage   ? `${currentProduct.storage} Storage` : null,
  currentProduct.camera    ? `${currentProduct.camera} Camera`   : null,
  currentProduct.battery   ? `${currentProduct.battery} Battery` : null,
  currentProduct.display   ? `${currentProduct.display} Display` : null,
  currentProduct.processor ? `${currentProduct.processor}`       : null,
].filter(Boolean);

// ── Only include spec rows where the value is genuinely known (not a hardcoded fallback) ──
// Mark fallback-only fields so we can skip them if the product doesn't have the real data.
const detailedSpecs = {
  general: [
    { label: "Brand",            value: currentProduct.brand },
    { label: "Model",            value: currentProduct.name },
    { label: "Release Year",     value: currentProduct.releaseYear || null },
    { label: "Operating System", value: currentProduct.os || null },
    { label: "SIM Type",         value: currentProduct.simType || null },
    { label: "Color Options",    value: currentProduct.color || null },
    { label: "Condition",        value: currentProduct.condition || "Brand New" },
    { label: "Warranty",         value: "2 Years Manufacturer Warranty" },
  ],
  display: [
    { label: "Screen Size",  value: currentProduct.display || currentProduct.screenSize || null },
    { label: "Display Type", value: currentProduct.displayType || null },
    { label: "Resolution",   value: currentProduct.resolution || null },
    { label: "Refresh Rate", value: currentProduct.refreshRate || null },
    { label: "Protection",   value: currentProduct.screenProtection || null },
  ],
  performance: [
    { label: "Processor",          value: currentProduct.processor || currentProduct.chipset || null },
    { label: "CPU",                value: currentProduct.cpu || null },
    { label: "GPU",                value: currentProduct.gpu || null },
    { label: "RAM",                value: currentProduct.ram || null },
    { label: "Internal Storage",   value: currentProduct.storage || null },
    { label: "Expandable Storage", value: currentProduct.expandableStorage || null },
  ],
  camera: [
    { label: "Rear Camera",     value: currentProduct.camera || currentProduct.rearCamera || null },
    { label: "Front Camera",    value: currentProduct.frontCamera || currentProduct.selfieCamera || null },
    { label: "Video Recording", value: currentProduct.videoRecording || null },
    { label: "Camera Features", value: currentProduct.cameraFeatures || null },
  ],
  battery: [
    { label: "Battery Capacity",  value: currentProduct.battery || currentProduct.batteryCapacity || null },
    { label: "Charging",          value: currentProduct.charging || null },
    { label: "Wireless Charging", value: currentProduct.wirelessCharging || null },
  ],
  connectivity: [
    { label: "Network",    value: currentProduct.network || null },
    { label: "Wi-Fi",      value: currentProduct.wifi || null },
    { label: "Bluetooth",  value: currentProduct.bluetooth || null },
    { label: "NFC",        value: currentProduct.nfc || null },
    { label: "USB",        value: currentProduct.usb || null },
    { label: "Audio Jack", value: currentProduct.audioJack || null },
  ],
  physical: [
    { label: "Dimensions",       value: currentProduct.dimensions || null },
    { label: "Weight",           value: currentProduct.weight || null },
    { label: "Build Material",   value: currentProduct.buildMaterial || null },
    { label: "Water Resistance", value: currentProduct.waterResistance || null },
  ],
};

const brandSlug  = currentProduct.brand.toLowerCase().replace(/\s+/g, "-");
const quickSpecs = [
  currentProduct.phonedisplay,
  currentProduct.processor?.split(' ').slice(-2).join(' '),
  currentProduct.battery?.split(',')[0],
].filter(Boolean).slice(0, 3);

// Build gallery images array
const galleryImages = [
  currentProduct.source,
  currentProduct.source2,
  currentProduct.source3,
].filter(Boolean);

// ── Descriptive alt text — what the image actually shows ──
const mainImgAlt = [
  currentProduct.brand,
  currentProduct.fullname ?? currentProduct.name,
  currentProduct.color ? `in ${currentProduct.color}` : '',
  '— front view',
].filter(Boolean).join(' ');
---

