  .price-per { font-size: 13px; font-weight: 400; }
  .price-divider {
    font-size: 12px; font-weight: 600; color: var(--primary-dark);
    padding: 0 10px; opacity: 0.6; align-self: flex-end; padding-bottom: 4px;
  }
