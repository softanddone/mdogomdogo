<style is:global>
  /* ============================================================
     PROFESSIONAL E-COMMERCE NAVBAR — NavStyle.astro
     Font: DM Sans (brand/display) + Inter (UI/body)
     Palette: Deep Navy · Warm Gold · Emerald · Slate · Alert Red
     ============================================================ */

  @import url('https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,600;0,9..40,700;1,9..40,400&family=Inter:wght@400;500;600&display=swap');

  /* ── Design Tokens ─────────────────────────────────────────── */
  :root {
    /* Brand colours */
    --brand:           #0f172a;   /* Deep navy — headings, CTAs, logo    */
    --brand-hover:     #1e293b;   /* Slightly lighter navy on hover      */
    --accent:          #c8973a;   /* Warm gold — active states, accents  */
    --accent-light:    #fef3c7;   /* Pale gold — badge backgrounds       */
    --accent-dark:     #92400e;   /* Dark amber — badge text             */
    --success:         #0a8a52;   /* Emerald — prices, delivery, stock   */
    --success-light:   #d1fae5;   /* Mint — delivery badge text          */
    --danger:          #e53e3e;   /* Alert red — cart count, sale tags   */
    --danger-light:    #fff5f5;   /* Pale red — error surfaces           */

    /* Neutrals */
    --text-primary:    #0f172a;   /* Headings, bold UI labels            */
    --text-secondary:  #374151;   /* Body copy, nav links                */
    --text-muted:      #9aa3b2;   /* Placeholders, meta, captions        */
    --surface:         #f8f9fb;   /* Page background, bottom nav bg      */
    --surface-hover:   #f1f4f8;   /* Hover state surface                 */
    --border:          #e2e5ea;   /* Default borders                     */
    --border-focus:    #c8973a;   /* Focus ring colour (gold)            */
    --white:           #ffffff;

    /* Typography */
    --font-display: 'DM Sans', -apple-system, BlinkMacSystemFont, sans-serif;
    --font-ui:      'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;

    /* Font sizes */
    --text-xs:   11px;
    --text-sm:   12px;
    --text-base: 14px;
    --text-md:   15px;
    --text-lg:   16px;
    --text-xl:   18px;
    --text-2xl:  22px;

    /* Font weights */
    --weight-regular:  400;
    --weight-medium:   500;
    --weight-semibold: 600;
    --weight-bold:     700;

    /* Letter-spacing */
    --tracking-tight:   -0.03em;  /* Brand name, large headings          */
    --tracking-snug:    -0.01em;  /* Sub-headings                        */
    --tracking-normal:   0em;
    --tracking-wide:     0.02em;  /* CTA buttons                         */
    --tracking-wider:    0.05em;  /* Nav labels                          */
    --tracking-widest:   0.08em;  /* Uppercase badges/labels             */

    /* Layout */
    --radius-sm: 4px;
    --radius:    8px;
    --radius-md: 10px;
    --radius-lg: 12px;

    /* Motion */
    --transition:      0.2s ease;
    --transition-slow: 0.35s ease;
  }


  /* ── Reset ─────────────────────────────────────────────────── */
  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }


  /* ── Utility ───────────────────────────────────────────────── */
  .cart-total {
    display: none;
  }

  .cart-link {
    text-decoration: none;
  }

  .logo-img {
    width: 50px;
    height: 50px;
    overflow: hidden;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .logo-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Visually hidden but accessible to screen readers */
  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }


  /* ── Navbar Shell ──────────────────────────────────────────── */
  .navbar {
    position: sticky;
    top: 0;
    width: 100%;
    background: var(--white);
    border-bottom: 1px solid var(--border);
    box-shadow: 0 1px 0 0 var(--border);
    z-index: 1000;
    font-family: var(--font-ui);
  }


  /* ── Container ─────────────────────────────────────────────── */
  .container {
    max-width: 1280px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
  }


  /* ── Logo ──────────────────────────────────────────────────── */
  .logo a {
    text-decoration: none;
    display: inline-flex;
    align-items: center;
  }


  /* ── Search Container ──────────────────────────────────────── */
  .search-container {
    flex: 1;
    max-width: 480px;
    position: relative;
  }

  .search-input-wrapper {
    position: relative;
    width: 100%;
  }

  .search-input {
    width: 100%;
    padding: 11px 48px 11px 16px;
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: var(--weight-regular);
    color: var(--text-primary);
    letter-spacing: var(--tracking-normal);
    transition: border-color var(--transition), box-shadow var(--transition), background var(--transition);
  }

  .search-input:hover {
    border-color: #c5cad3;
    background: var(--white);
  }

  .search-input:focus {
    background: var(--white);
    border-color: var(--border-focus);
    box-shadow: 0 0 0 3px rgba(200, 151, 58, 0.15);
    outline: none;
  }

  /* Hide real placeholder */
  .search-input::placeholder {
    opacity: 0;
  }

  /* Animated fake placeholder */
  .fake-placeholder {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: var(--weight-regular);
    color: var(--text-muted);
    pointer-events: none;
    white-space: nowrap;
    transition: opacity 0.15s ease;
  }

  /* Hide fake placeholder when input has focus or value */
  .search-input:focus ~ .fake-placeholder,
  .search-input:not(:placeholder-shown) ~ .fake-placeholder {
    opacity: 0;
  }


  /* ── Placeholder Animations ────────────────────────────────── */
  @keyframes bounceInFromTop {
    0%   { opacity: 0; transform: translateY(-50%) translateY(-40px) scale(0.8); }
    50%  { opacity: 0.8; transform: translateY(-50%) translateY(10px) scale(1.05); }
    70%  { transform: translateY(-50%) translateY(-5px) scale(0.98); }
    85%  { transform: translateY(-50%) translateY(3px) scale(1.01); }
    100% { opacity: 1; transform: translateY(-50%) translateY(0) scale(1); }
  }

  @keyframes bounceOutToBottom {
    0%   { opacity: 1; transform: translateY(-50%) translateY(0) scale(1); }
    30%  { opacity: 0.7; transform: translateY(-50%) translateY(-5px) scale(1.02); }
    100% { opacity: 0; transform: translateY(-50%) translateY(35px) scale(0.9); }
  }

  @keyframes slideInFromLeft {
    0%   { opacity: 0; transform: translateY(-50%) translateX(-50px) rotate(-5deg); }
    60%  { opacity: 1; transform: translateY(-50%) translateX(10px) rotate(2deg); }
    80%  { transform: translateY(-50%) translateX(-5px) rotate(-1deg); }
    100% { opacity: 1; transform: translateY(-50%) translateX(0) rotate(0deg); }
  }

  @keyframes slideOutToRight {
    0%   { opacity: 1; transform: translateY(-50%) translateX(0) rotate(0deg); }
    100% { opacity: 0; transform: translateY(-50%) translateX(50px) rotate(5deg); }
  }

  @keyframes scalePopIn {
    0%   { opacity: 0; transform: translateY(-50%) scale(0.3) rotate(-10deg); }
    50%  { opacity: 0.9; transform: translateY(-50%) scale(1.15) rotate(3deg); }
    70%  { transform: translateY(-50%) scale(0.95) rotate(-2deg); }
    85%  { transform: translateY(-50%) scale(1.03) rotate(1deg); }
    100% { opacity: 1; transform: translateY(-50%) scale(1) rotate(0deg); }
  }

  @keyframes scalePopOut {
    0%   { opacity: 1; transform: translateY(-50%) scale(1) rotate(0deg); }
    50%  { opacity: 0.5; transform: translateY(-50%) scale(1.1) rotate(-5deg); }
    100% { opacity: 0; transform: translateY(-50%) scale(0.3) rotate(10deg); }
  }

  .fake-placeholder.animation-1-in  { animation: bounceInFromTop  0.7s cubic-bezier(0.34, 1.56, 0.64, 1); }
  .fake-placeholder.animation-1-out { animation: bounceOutToBottom 0.5s cubic-bezier(0.55, 0.085, 0.68, 0.53); }
  .fake-placeholder.animation-2-in  { animation: slideInFromLeft   0.7s cubic-bezier(0.34, 1.2, 0.64, 1); }
  .fake-placeholder.animation-2-out { animation: slideOutToRight   0.4s cubic-bezier(0.55, 0.085, 0.68, 0.53); }
  .fake-placeholder.animation-3-in  { animation: scalePopIn        0.8s cubic-bezier(0.68, -0.55, 0.265, 1.55); }
  .fake-placeholder.animation-3-out { animation: scalePopOut       0.5s cubic-bezier(0.6, 0.04, 0.98, 0.335); }


  /* ── Search Button ─────────────────────────────────────────── */
  .search-btn {
    position: absolute;
    right: 8px;
    top: 50%;
    transform: translateY(-50%);
    background: var(--brand);
    border: none;
    padding: 6px;
    border-radius: var(--radius-sm);
    color: var(--white);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background var(--transition), transform var(--transition);
  }

  .search-btn:hover {
    background: var(--brand-hover);
  }

  .search-btn:active {
    transform: translateY(-50%) scale(0.95);
  }

  .search-btn:focus {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }


  /* ── Search Results Dropdown ───────────────────────────────── */
  .search-results {
    display: none;
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    right: 0;
    background: var(--white);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    box-shadow: 0 8px 24px rgba(15, 23, 42, 0.10);
    max-height: 480px;
    overflow-y: auto;
    z-index: 1001;
  }

  .search-results.active {
    display: block;
  }

  .search-result-item {
    display: flex;
    align-items: center;
    padding: 12px 14px;
    border-bottom: 1px solid var(--surface);
    cursor: pointer;
    transition: background var(--transition);
    text-decoration: none;
    color: var(--text-primary);
    gap: 12px;
  }

  .search-result-item:last-child {
    border-bottom: none;
  }

  .search-result-item:hover,
  .search-result-item:focus {
    background: var(--surface);
    outline: none;
  }

  .search-result-image-wrapper {
    width: 58px;
    height: 58px;
    flex-shrink: 0;
    border-radius: var(--radius-sm);
    overflow: hidden;
    background: var(--surface);
    border: 1px solid var(--border);
  }

  .search-result-image-wrapper img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .search-result-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .search-result-name {
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-snug);
    color: var(--text-primary);
    line-height: 1.3;
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  .search-result-status {
    display: inline-block;
    padding: 2px 7px;
    background: var(--success);
    color: var(--success-light);
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }

  .search-result-price {
    font-family: var(--font-display);
    font-size: var(--text-md);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--success);
  }

  .no-results {
    padding: 24px;
    text-align: center;
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: var(--weight-regular);
    color: var(--text-muted);
  }


  /* ── Top Actions ───────────────────────────────────────────── */
  .top-actions {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .phone-link {
    display: flex;
    align-items: center;
    gap: 7px;
    background: none;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 8px 12px;
    border-radius: var(--radius);
    transition: background var(--transition), color var(--transition);
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-normal);
  }

  .phone-link:hover,
  .phone-link:focus {
    background: var(--surface);
    color: var(--text-primary);
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .phone-number {
    white-space: nowrap;
  }

  .delivery-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--success);
    color: var(--success-light);
    padding: 8px 14px;
    border-radius: var(--radius);
    font-family: var(--font-ui);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
  }


  /* ── Bottom Navigation Bar ─────────────────────────────────── */
  .navbar-bottom {
    background: var(--surface);
    border-top: 1px solid var(--border);
  }

  .nav-menu {
    list-style: none;
    display: flex;
    gap: 4px;
  }

  .nav-menu a {
    text-decoration: none;
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-wider);
    color: var(--text-secondary);
    padding: 12px 14px;
    position: relative;
    transition: color var(--transition);
    display: block;
  }

  .nav-menu a::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 14px;
    right: 14px;
    height: 2px;
    background: var(--accent);
    border-radius: 2px 2px 0 0;
    transform: scaleX(0);
    transition: transform var(--transition);
  }

  .nav-menu a:hover,
  .nav-menu a:focus {
    color: var(--text-primary);
    outline: none;
  }

  .nav-menu a:hover::after,
  .nav-menu a:focus::after,
  .nav-menu a.active::after {
    transform: scaleX(1);
  }

  .nav-menu a.active {
    font-weight: var(--weight-semibold);
    color: var(--brand);
  }


  /* ── Cart Button ───────────────────────────────────────────── */
  .cart-btn {
    position: relative;
    background: var(--brand);
    border: none;
    padding: 9px 14px;
    border-radius: var(--radius);
    color: var(--white);
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-ui);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    letter-spacing: var(--tracking-wide);
    transition: background var(--transition), transform var(--transition);
  }

  .cart-btn:hover {
    background: var(--brand-hover);
    transform: translateY(-1px);
  }

  .cart-btn:active {
    transform: translateY(0);
  }

  .cart-btn:focus {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  .cart-count {
    position: absolute;
    top: -7px;
    right: -7px;
    background: var(--danger);
    color: var(--white);
    font-family: var(--font-ui);
    font-size: 10px;
    font-weight: var(--weight-bold);
    letter-spacing: 0;
    padding: 2px 5px;
    border-radius: 999px;
    min-width: 18px;
    text-align: center;
    line-height: 1.4;
    border: 2px solid var(--white);
  }


  /* ── Mobile Menu (Drawer) ──────────────────────────────────── */
  .mobile-menu {
    position: fixed;
    top: 0;
    left: -100%;
    width: 280px;
    height: 100vh;
    background: var(--white);
    border-right: 1px solid var(--border);
    box-shadow: 4px 0 20px rgba(15, 23, 42, 0.08);
    transition: left var(--transition-slow);
    z-index: 2000;
    overflow-y: auto;
  }

  .mobile-menu.active {
    left: 0;
  }

  .mobile-menu-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 20px;
    border-bottom: 1px solid var(--border);
  }

  .mobile-menu-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-tight);
    color: var(--text-primary);
    margin: 0;
  }

  .close-btn {
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    color: var(--text-secondary);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color var(--transition), background var(--transition);
  }

  .close-btn:hover,
  .close-btn:focus {
    color: var(--accent-dark);
    background: var(--accent-light);
    outline: none;
  }

  .mobile-nav-links {
    list-style: none;
    padding: 12px 0;
  }

  .mobile-nav-links a {
    display: flex;
    align-items: center;
    padding: 13px 24px;
    font-family: var(--font-ui);
    font-size: var(--text-md);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-normal);
    color: var(--text-secondary);
    text-decoration: none;
    border-left: 2px solid transparent;
    transition: background var(--transition), color var(--transition), padding-left var(--transition), border-left-color var(--transition);
  }

  .mobile-nav-links a:hover,
  .mobile-nav-links a:focus {
    background: var(--accent-light);
    color: var(--accent-dark);
    padding-left: 30px;
    border-left-color: var(--accent);
    outline: none;
  }


  /* ── Hamburger / Menu Button ───────────────────────────────── */
  .menu-btn {
    display: none;
  }

  .hamburger {
    width: 20px;
    height: 2px;
    background: var(--brand);
    border-radius: 2px;
  }


  /* ── Mobile Search (bottom bar) ────────────────────────────── */
  .search-mobile {
    display: none;
  }


  /* ── Responsive ────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .navbar-top .container {
      padding: 10px 12px;
      gap: 8px;
    }

    .menu-btn {
      display: flex;
      flex-direction: column;
      gap: 4px;
      background: none;
      border: none;
      cursor: pointer;
      padding: 6px;
      flex-shrink: 0;
    }

    .menu-btn:focus {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
      border-radius: var(--radius-sm);
    }

    .logo {
      flex-shrink: 0;
    }

    .logo-img {
      width: 40px;
      height: 40px;
    }

    .top-actions {
      display: flex;
      align-items: center;
      gap: 6px;
      flex-shrink: 0;
      margin-left: auto;
    }

    .phone-link {
      padding: 6px 8px;
      background: var(--surface);
      border-radius: var(--radius-sm);
    }

    .phone-link svg {
      width: 18px;
      height: 18px;
    }

    .phone-number {
      display: inline;
      font-size: var(--text-sm);
    }

    .delivery-badge {
      padding: 6px 8px;
      font-size: var(--text-xs);
    }

    .delivery-badge svg {
      width: 16px;
      height: 16px;
    }

    .delivery-badge span {
      display: none;
    }

    .navbar-top .search-container {
      display: none;
    }

    .search-mobile {
      display: block;
      flex: 1;
      max-width: 100%;
    }

    .nav-menu {
      display: none;
    }

    .navbar-bottom .container {
      padding: 10px 12px;
      gap: 10px;
    }

    .search-input {
      padding: 9px 42px 9px 12px;
      font-size: var(--text-sm);
    }

    .fake-placeholder {
      font-size: var(--text-sm);
      left: 12px;
    }
  }

  @media (max-width: 400px) {
    .phone-number {
      display: none;
    }

    .cart-btn span {
      display: none;
    }
  }
</style>
