---
import { products } from '../data/product2.js';
import {
  ALL_BRANDS,
  DEPOSIT_FILTERS,
  STORAGE_FILTERS,
  brandSlug,
  brandSlugall,
  parseDeposit,
} from '../data/filter-config.js';
import { FEATURE_FILTERS, featureHref } from '../data/feature-config.js';
import Gift from '../components/Gift.astro';
import Nav from '../components/Nav.astro';

const featured    = products.slice(0, 5);
const flashDeals = products.filter(p =>
  ["samsung-galaxy-s24-256gb", "tecno-camon-50-pro-max", "samsung-galaxy-s20-ultra"].includes(p.slug)
);

const budgetPicks = products.filter(p => parseDeposit(p.deposit) < 5000).slice(0, 5);
const samsungList = products.filter(p => p.brand?.toLowerCase() === 'samsung').slice(0, 5);
const tecnoList   = products.filter(p => p.brand?.toLowerCase() === 'tecno').slice(0, 5);
const infinixList = products.filter(p => p.brand?.toLowerCase() === 'infinix').slice(0, 5);

const featureLinks = FEATURE_FILTERS.map(feat => ({
  ...feat,
  count: products.filter(feat.match).length,
  href: `/features/${feat.key}-phones-kenya`,
})).filter(f => f.count > 0);

const featureIcons = {
  '5g':             { icon: '5G',  accent: '#d97706' },
  'gaming':         { icon: '🎮',  accent: '#b45309' },
  'amoled':         { icon: '✦',   accent: '#92400e' },
  '120hz':          { icon: '⚡',  accent: '#d97706' },
  '108mp-camera':   { icon: '◎',   accent: '#78350f' },
  'large-battery':  { icon: '▮',   accent: '#b45309' },
  'curved-display': { icon: '◠',   accent: '#92400e' },
  'fingerprint':    { icon: '◈',   accent: '#d97706' },
};

function renderStars(rating) {
  const full = Math.floor(rating ?? 4.5);
  return '★'.repeat(full) + '☆'.repeat(5 - full);
}

const siteUrl  = 'https://www.mdogomdogodeals.co.ke';
const siteName = 'MdogomdogoDeals';
const pageTitle = 'Lipa Mdogo Mdogo Phones Kenya 2026 — Buy Smartphones on Instalment | MdogomdogoDeals';
const pageDesc  = `Kenya's #1 lipa mdogo mdogo phone shop. Own a brand-new Samsung, Tecno, Infinix or iPhone from KSh 2,000 deposit. Pay via M-Pesa — no CRB, no guarantor, no payslip. Free same-day delivery Nairobi. ${products.length}+ phones in stock.`;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "LocalBusiness",
  "name": siteName,
  "description": "Kenya's leading lipa mdogo mdogo phone shop — genuine smartphones on M-Pesa instalment plans, no CRB check, no guarantor, free same-day delivery across Nairobi.",
  "url": siteUrl,
  "telephone": "+254100028823",
  "email": "hello@mdogomdogodeals.co.ke",
  "address": { "@type": "PostalAddress", "addressLocality": "Nairobi", "addressCountry": "KE" },
  "openingHours": "Mo-Sa 08:00-20:00",
  "priceRange": "KSh 2,000 – KSh 150,000",
  "currenciesAccepted": "KES",
  "paymentAccepted": "M-Pesa, Cash",
  "sameAs": ["https://wa.me/254100028823"]
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": `${siteUrl}/` }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    { "@type": "Question", "name": "What is the smallest deposit to get a phone on lipa mdogo mdogo?", "acceptedAnswer": { "@type": "Answer", "text": "The minimum deposit at MdogomdogoDeals is just KSh 2,000. No hidden costs, no surprises — 100% genuine phones only." } },
    { "@type": "Question", "name": "Do I need a payslip or CRB clearance for lipa mdogo mdogo in Kenya?", "acceptedAnswer": { "@type": "Answer", "text": "No. Buying a phone on lipa mdogo mdogo with us requires no payslip, no CRB check and no guarantor. Pay your deposit via M-Pesa and the phone is yours today." } },
    { "@type": "Question", "name": "How fast will my phone on instalment be delivered in Nairobi?", "acceptedAnswer": { "@type": "Answer", "text": "Order before 2 PM and your phone is delivered the same day, completely free, anywhere in Nairobi, Kiambu, Machakos or Kajiado. Inspect it at the door before paying." } },
    { "@type": "Question", "name": "Are lipa mdogo mdogo phones in Kenya genuine and warranted?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — every phone is 100% brand new, factory sealed, sourced from Kenya's authorized distributors, and covered by the full manufacturer's warranty." } },
    { "@type": "Question", "name": "Which brands can I buy on lipa pole pole in Kenya?", "acceptedAnswer": { "@type": "Answer", "text": `We stock ${products.length}+ smartphones — Samsung, Tecno, Infinix, Redmi, Oppo, Vivo, Itel and iPhones. All available on lipa pole pole via M-Pesa, with new models every week.` } },
    { "@type": "Question", "name": "Can I choose my own lipa pole pole repayment schedule?", "acceptedAnswer": { "@type": "Answer", "text": "Yes — choose daily, weekly or monthly M-Pesa payments. We offer 3-month and 6-month instalment options on selected phones so you can truly lipa pole pole at your own pace." } }
  ]
};
---

<Fragment>
  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;500;600;700;800&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet" />

  <!-- Primary SEO -->
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc} />
  <meta name="keywords" content="lipa mdogo mdogo phones Kenya, lipa mdogo mdogo phones Nairobi, lipa mdogo mdogo phones in Kenya, lipa pole pole phones Kenya, lipa pole pole smartphones Nairobi, phones on instalment Kenya, buy phone M-Pesa deposit Kenya, no CRB phone Kenya 2026, Samsung lipa mdogo mdogo Kenya, Tecno lipa mdogo mdogo, Infinix lipa pole pole Kenya, iPhone lipa mdogo mdogo Kenya, cheap phones on instalment Nairobi, phone on instalment Nairobi, lipa mdogo mdogo no payslip, smartphones on hire purchase Kenya" />
  <link rel="canonical" href={`${siteUrl}/`} />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
  <meta name="author" content={siteName} />
  <meta name="geo.region" content="KE-30" />
  <meta name="geo.placename" content="Nairobi, Kenya" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content={siteName} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:url" content={`${siteUrl}/`} />
  <meta property="og:locale" content="en_KE" />

  <!-- Twitter/X Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDesc} />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --clay:         #1c1208;
      --clay-mid:     #2e1f0a;
      --ink:          #0d0a06;
      --sand:         #f5ede0;
      --sand-mid:     #ede0cc;
      --sand-light:   #faf6f0;
      --amber:        #d97706;
      --amber-dark:   #b45309;
      --amber-pale:   #fef3c7;
      --amber-line:   #fde68a;
      --ember:        #c2410c;
      --ivory:        #fffbf5;
      --forest:       #14532d;
      --forest-bg:    #f0fdf4;
      --bark:         #78350f;
      --canvas:       #ffffff;
      --border:       #e5d5c0;
      --border-light: #f0e4d0;
      --muted:        #8a6a44;
      --muted-light:  #b89070;
      --r-sm: 4px;
      --r-md: 8px;
      --r-lg: 14px;
      --r-xl: 22px;
      --sh-sm: 0 2px 8px rgba(28,18,8,0.08);
      --sh-md: 0 6px 24px rgba(28,18,8,0.12);
      --sh-lg: 0 16px 48px rgba(28,18,8,0.16);
    }

    #root { font-family: 'Sora', sans-serif; background: var(--ivory); color: var(--clay); -webkit-font-smoothing: antialiased; }
    a { text-decoration: none; color: inherit; }
    img { display: block; }

    /* ─── ANNOUNCEMENT RIBBON ──────────────────────────── */
    .ribbon {
      background: var(--ink); color: #c4a87a;
      font-size: 11.5px; font-weight: 500; letter-spacing: 0.02em;
      display: flex; align-items: center;
      overflow: hidden; position: relative; height: 34px;
    }
    .ribbon-track {
      display: flex;
      animation: ribbonScroll 30s linear infinite;
      white-space: nowrap; will-change: transform;
    }
    @keyframes ribbonScroll {
      0%   { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
    .ribbon-item { display: inline-flex; align-items: center; gap: 8px; padding: 0 32px; }
    .ribbon-dot { width: 4px; height: 4px; background: var(--amber); border-radius: 50%; display: inline-block; flex-shrink: 0; }
    .ribbon-cta-bar {
      position: absolute; right: 0; top: 0; bottom: 0;
      background: var(--amber);
      display: flex; align-items: center; gap: 16px; padding: 0 16px; z-index: 2;
    }
    .ribbon-cta-bar a { color: var(--ink); font-weight: 700; font-size: 12px; display: flex; align-items: center; gap: 5px; white-space: nowrap; }
    .ribbon-cta-bar span { color: var(--ink); opacity: 0.4; font-size: 14px; }

    /* ─── SITE HEADER ───────────────────────────────────── */
    .site-header { background: var(--ivory); border-bottom: 1.5px solid var(--border); padding: 0 24px; }
    .header-inner {
      max-width: 1320px; margin: 0 auto;
      display: flex; align-items: center; height: 62px; gap: 20px;
    }
    .logo-mark {
      font-family: 'DM Serif Display', serif; font-size: 24px;
      color: var(--clay); letter-spacing: -0.5px;
      flex-shrink: 0; display: flex; align-items: baseline;
    }
    .logo-mark em { color: var(--amber); font-style: italic; }
    .logo-tag {
      font-size: 9px; font-weight: 600;
      background: var(--amber); color: var(--ink);
      padding: 2px 6px; border-radius: 3px;
      text-transform: uppercase; letter-spacing: 0.08em;
      margin-left: 8px; align-self: center;
    }
    .header-actions { display: flex; align-items: center; gap: 10px; margin-left: auto; flex-shrink: 0; }
    .hdr-btn-call {
      display: flex; align-items: center; gap: 6px;
      border: 1.5px solid var(--border); border-radius: 8px;
      padding: 8px 14px; font-size: 12.5px; font-weight: 600;
      color: var(--clay-mid); background: transparent;
      font-family: 'Sora', sans-serif; cursor: pointer; white-space: nowrap;
      transition: border-color 0.15s;
    }
    .hdr-btn-call:hover { border-color: var(--amber); }
    .hdr-btn-wa {
      display: flex; align-items: center; gap: 7px;
      background: #16a34a; color: #fff; border-radius: 8px;
      padding: 9px 16px; font-size: 12.5px; font-weight: 700;
      white-space: nowrap; font-family: 'Sora', sans-serif;
      transition: background 0.15s;
    }
    .hdr-btn-wa:hover { background: #15803d; }

    /* ─── NAV BAR ───────────────────────────────────────── */
    .nav-bar { background: var(--sand); border-bottom: 1.5px solid var(--border); padding: 0 24px; }
    .nav-bar ul { max-width: 1320px; margin: 0 auto; list-style: none; display: flex; overflow-x: auto; scrollbar-width: none; }
    .nav-bar ul::-webkit-scrollbar { display: none; }
    .nav-bar li a {
      display: block; padding: 11px 14px;
      font-size: 12.5px; font-weight: 600; color: var(--muted);
      white-space: nowrap; border-bottom: 2px solid transparent; margin-bottom: -1.5px;
      transition: color 0.15s, border-color 0.15s;
    }
    .nav-bar li a:hover, .nav-bar li a.active { color: var(--amber-dark); border-bottom-color: var(--amber); }

    /* ─── HERO ──────────────────────────────────────────── */
    @keyframes heroShift {
      0%   { background-position: 0% 50%; }
      50%  { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    .hero { position: relative; overflow: hidden; background: #F3E9DC; }
    .hero::before {
      content: ''; position: absolute; inset: 0; z-index: 0;
      background: linear-gradient(135deg, #F3E9DC 0%, #F5ECD8 15%, #F9F0E3 30%, wheat 45%, #FAF0DC 55%, #FDF6EE 70%, #ffffff 85%, #F3E9DC 100%);
      background-size: 300% 300%;
      animation: heroShift 12s ease-in-out infinite;
      will-change: background-position;
    }
    .hero::after {
      content: ''; position: absolute; inset: 0; z-index: 0;
      background: radial-gradient(ellipse 600px 400px at 85% 60%, rgba(217,119,6,0.08) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero-inner {
      max-width: 1320px; margin: 0 auto;
      padding: 56px 24px 52px;
      display: grid; grid-template-columns: 1fr 1fr; gap: 48px;
      align-items: center; position: relative; z-index: 1;
    }
    .hero-kicker {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(28,18,8,0.07); border: 1px solid rgba(28,18,8,0.14);
      border-radius: 20px; padding: 5px 14px 5px 6px; margin-bottom: 20px;
    }
    .hero-kicker-pill {
      background: var(--amber); color: var(--ink);
      font-size: 10px; font-weight: 700;
      text-transform: uppercase; letter-spacing: 0.08em;
      padding: 3px 8px; border-radius: 12px;
    }
    .hero-kicker span { font-size: 12px; font-weight: 600; color: var(--amber-dark); }
    .hero-h1 {
      font-family: 'DM Serif Display', serif; font-size: 52px;
      line-height: 1.05; color: var(--clay); letter-spacing: -1px; margin-bottom: 18px;
    }
    .hero-h1 em { color: var(--amber-dark); font-style: italic; }
    .hero-h1 .line-sm { font-size: 40px; display: block; }
    .hero-sub { font-size: 14.5px; line-height: 1.75; color: var(--muted); max-width: 460px; margin-bottom: 32px; }
    .hero-sub strong { color: var(--clay); font-weight: 700; }
    .hero-ctas { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 40px; }
    .cta-primary {
      background: var(--amber); color: var(--ink); border-radius: 8px;
      padding: 13px 28px; font-size: 14px; font-weight: 700;
      display: inline-flex; align-items: center; gap: 7px;
      font-family: 'Sora', sans-serif; transition: background 0.15s, transform 0.15s;
    }
    .cta-primary:hover { background: #f59e0b; transform: translateY(-1px); }
    .cta-ghost {
      background: rgba(28,18,8,0.06); color: var(--clay-mid);
      border: 1px solid rgba(28,18,8,0.18); border-radius: 8px;
      padding: 12px 22px; font-size: 14px; font-weight: 600;
      font-family: 'Sora', sans-serif; transition: background 0.15s;
    }
    .cta-ghost:hover { background: rgba(28,18,8,0.11); }
    .hero-stats {
      display: grid; grid-template-columns: repeat(4, 1fr);
      background: rgba(28,18,8,0.06); border: 1px solid rgba(28,18,8,0.1);
      border-radius: 10px; overflow: hidden;
    }
    .h-stat { padding: 14px 12px; border-right: 1px solid rgba(28,18,8,0.08); }
    .h-stat:last-child { border-right: none; }
    .h-stat .n { font-family: 'DM Serif Display', serif; font-size: 24px; color: var(--amber-dark); line-height: 1; margin-bottom: 3px; }
    .h-stat .l { font-size: 11px; color: var(--muted); font-weight: 500; }

    /* HERO RIGHT */
    .hero-right { display: flex; flex-direction: column; gap: 16px; }
    .dep-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .dep-card {
      background: rgba(255,255,255,0.55); border: 1px solid rgba(28,18,8,0.12);
      border-radius: 10px; padding: 18px 16px; text-align: center; cursor: pointer;
      transition: background 0.15s, border-color 0.2s, transform 0.15s;
    }
    .dep-card:hover { background: rgba(255,255,255,0.85); border-color: var(--amber); transform: translateY(-2px); }
    .dep-card .d-amt { font-family: 'DM Serif Display', serif; font-size: 21px; color: var(--clay); }
    .dep-card .d-lbl { font-size: 11px; color: var(--muted); margin-top: 3px; font-weight: 500; }
    .hero-trust { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
    .h-trust-item {
      background: rgba(255,255,255,0.5); border: 1px solid rgba(28,18,8,0.1);
      border-radius: 8px; padding: 12px 10px; text-align: center;
    }
    .h-trust-icon { font-size: 18px; margin-bottom: 5px; }
    .h-trust-lbl { font-size: 11px; color: var(--clay-mid); font-weight: 600; line-height: 1.4; }

    /* ─── TRUST STRIP ───────────────────────────────────── */
    .trust-strip { background: var(--sand-mid); border-bottom: 1.5px solid var(--border); padding: 0 24px; }
    .trust-strip-inner { max-width: 1320px; margin: 0 auto; display: flex; align-items: stretch; }
    .ts-item { flex: 1; display: flex; align-items: center; gap: 12px; padding: 14px 20px; border-right: 1px solid var(--border-light); font-size: 12.5px; }
    .ts-item:last-child { border-right: none; }
    .ts-icon { width: 34px; height: 34px; background: var(--amber-pale); border: 1px solid var(--amber-line); border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; font-size: 15px; }
    .ts-text strong { display: block; font-size: 12px; font-weight: 700; color: var(--clay); margin-bottom: 1px; }
    .ts-text span { font-size: 11px; color: var(--muted); }

    /* ─── PAGE BODY ─────────────────────────────────────── */
    .wrap { max-width: 1320px; margin: 0 auto; padding: 0 24px; }

    /* ─── SECTION HEADS ─────────────────────────────────── */
    .s-head {
      display: flex; align-items: flex-end; justify-content: space-between;
      padding-top: 40px; margin-bottom: 20px;
      border-bottom: 1.5px solid var(--border-light); padding-bottom: 14px;
    }
    .s-head-left { display: flex; align-items: center; gap: 10px; }
    .s-head h2 { font-family: 'DM Serif Display', serif; font-size: 22px; color: var(--clay); letter-spacing: -0.3px; }
    .s-chip { font-size: 10px; font-weight: 700; padding: 3px 9px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.06em; }
    .chip-amber { background: var(--amber-pale); color: var(--amber-dark); border: 1px solid var(--amber-line); }
    .chip-bark  { background: #fef9f0; color: var(--bark); border: 1px solid #f5e0c0; }
    .chip-sand  { background: var(--sand); color: var(--muted); border: 1px solid var(--border); }
    .see-all { font-size: 12.5px; font-weight: 700; color: var(--amber-dark); display: flex; align-items: center; gap: 5px; transition: gap 0.15s; }
    .see-all:hover { gap: 8px; }

    /* ─── FLASH DEALS ───────────────────────────────────── */
    .flash-section { background: var(--clay); padding: 32px 24px; position: relative; overflow: hidden; }
    .flash-section::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 800px 400px at 50% 100%, rgba(217,119,6,0.08) 0%, transparent 70%); pointer-events: none; }
    .flash-inner { max-width: 1320px; margin: 0 auto; position: relative; z-index: 1; }
    .flash-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 20px; }
    .flash-title-group { display: flex; align-items: center; gap: 12px; }
    .flash-title-group h2 { font-family: 'DM Serif Display', serif; font-size: 22px; color: #fef3c7; }
    .live-badge { display: inline-flex; align-items: center; gap: 5px; background: var(--ember); color: #fff; font-size: 10px; font-weight: 700; padding: 4px 10px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.06em; }
    .live-dot { width: 5px; height: 5px; background: #fff; border-radius: 50%; animation: blink 1s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
    .flash-see-all { font-size: 12.5px; font-weight: 600; color: var(--amber); }
    .flash-see-all:hover { color: #f59e0b; }
    .flash-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
    .flash-card {
      background: var(--clay-mid); border: 1px solid rgba(255,255,255,0.08);
      border-radius: var(--r-lg); overflow: hidden; display: flex; flex-direction: column;
      position: relative; text-decoration: none; color: inherit;
      transition: border-color 0.2s, transform 0.2s;
    }
    .flash-card:hover { border-color: rgba(217,119,6,0.5); transform: translateY(-4px); }
    .flash-accent-bar { height: 3px; background: linear-gradient(90deg, var(--amber), var(--ember)); }
    .flash-tag-hot { position: absolute; top: 14px; left: 12px; z-index: 3; background: var(--ember); color: #fff; font-size: 10px; font-weight: 700; padding: 3px 9px; border-radius: 4px; text-transform: uppercase; letter-spacing: 0.05em; }
    .flash-discount { position: absolute; top: 14px; right: 12px; z-index: 3; background: var(--amber); color: var(--ink); font-size: 11px; font-weight: 700; padding: 3px 9px; border-radius: 4px; }
    .flash-img-wrap { aspect-ratio: 4/3; background: rgba(255,255,255,0.03); display: flex; align-items: center; justify-content: center; overflow: hidden; }
    .flash-img { width: 82%; height: 82%; object-fit: contain; transition: transform 0.35s; }
    .flash-card:hover .flash-img { transform: scale(1.06); }
    .flash-body { padding: 14px; flex: 1; display: flex; flex-direction: column; }
    .flash-brand { font-size: 10px; font-weight: 700; color: var(--amber); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 4px; }
    .flash-name { font-size: 14px; font-weight: 600; color: #fef3c7; line-height: 1.4; margin-bottom: 10px; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .flash-specs { display: flex; gap: 5px; flex-wrap: wrap; margin-bottom: 12px; }
    .f-spec { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.1); color: #9a7d5a; border-radius: 4px; padding: 2px 7px; font-size: 10px; font-weight: 500; }
    .flash-price-row { display: flex; align-items: baseline; gap: 6px; margin-bottom: 5px; }
    .flash-price { font-family: 'DM Serif Display', serif; font-size: 28px; color: var(--amber); line-height: 1; }
