---
import { products } from '../data/product2.js';
import { ALL_BRANDS, DEPOSIT_FILTERS, brandSlugall, parseDeposit } from '../data/filter-config.js';
import { FEATURE_FILTERS } from '../data/feature-config.js';
import Gift from '../components/Gift.astro';
import Nav from '../components/Nav.astro';

const featured    = products.slice(0, 10);
const flashDeals  = products.filter(p => ["samsung-galaxy-s24-256gb","tecno-camon-50-pro-max","samsung-galaxy-s20-ultra"].includes(p.slug));
const budgetPicks = products.filter(p => parseDeposit(p.deposit) < 5000).slice(0, 6);
const samsungList = products.filter(p => p.brand?.toLowerCase() === 'samsung').slice(0, 5);
const tecnoList   = products.filter(p => p.brand?.toLowerCase() === 'tecno').slice(0, 5);
const infinixList = products.filter(p => p.brand?.toLowerCase() === 'infinix').slice(0, 5);

const featureLinks = FEATURE_FILTERS.map(f => ({
  ...f, count: products.filter(f.match).length,
  href: `/features/${f.key}-phones-kenya`,
})).filter(f => f.count > 0);

const featureIcons = { '5g':'5G','gaming':'Gaming','amoled':'AMOLED','120hz':'120Hz','108mp-camera':'108MP','large-battery':'Battery','curved-display':'Curved','fingerprint':'Secure' };

function stars(r){ const f=Math.floor(r??4.5); return '★'.repeat(f)+'☆'.repeat(5-f); }

const siteUrl='https://www.mdogomdogodeals.co.ke';
const siteName='MdogomdogoDeals';

// ── SEO: Tighter meta title for CTR ──────────────────────────────────────────
const pageTitle='Lipa Mdogo Mdogo Phones — From KSh 2,000 | MdogomdogoDeals';
const pageDesc=`Kenya's #1 smartphone instalment shop. Own a Samsung, Tecno, Infinix or iPhone from KSh 2,000 deposit. M-Pesa payments, no CRB, no guarantor. Free same-day delivery Nairobi. ${products.length}+ phones in stock.`;

const ldLocal={
  "@context":"https://schema.org","@type":"LocalBusiness","name":siteName,"url":siteUrl,
  "telephone":"+254100028823","email":"hello@mdogomdogodeals.co.ke",
  "address":{"@type":"PostalAddress","addressLocality":"Nairobi","addressCountry":"KE"},
  "openingHours":"Mo-Sa 08:00-20:00","priceRange":"KSh 2,000–KSh 150,000",
  "currenciesAccepted":"KES","paymentAccepted":"M-Pesa, Cash",
  "sameAs":["https://wa.me/254100028823"]
};

const ldFaq={
  "@context":"https://schema.org","@type":"FAQPage","mainEntity":[
    {"@type":"Question","name":"What is the minimum deposit for lipa mdogo mdogo?","acceptedAnswer":{"@type":"Answer","text":"Just KSh 2,000. No CRB, no payslip, no guarantor required."}},
    {"@type":"Question","name":"How fast is delivery in Nairobi?","acceptedAnswer":{"@type":"Answer","text":"Same day free delivery when you order before 2 PM."}},
    {"@type":"Question","name":"Are the phones genuine?","acceptedAnswer":{"@type":"Answer","text":"Yes — 100% brand new, factory sealed, from authorized Kenyan distributors with full manufacturer warranty."}},
    {"@type":"Question","name":"What happens if I miss an instalment payment?","acceptedAnswer":{"@type":"Answer","text":"Contact us immediately via WhatsApp or call 0100 028 823. We will work with you on a revised payment schedule. Early communication always helps."}},
    {"@type":"Question","name":"Is MdogomdogoDeals legitimate?","acceptedAnswer":{"@type":"Answer","text":"Yes. We are a registered Kenyan business supplying factory-sealed phones from authorized distributors. Customers inspect every phone before paying a deposit."}},
    {"@type":"Question","name":"What documents do I need to qualify?","acceptedAnswer":{"@type":"Answer","text":"No documents needed. No CRB check, no payslip, no guarantor. A valid M-Pesa number and your deposit is all that is required."}}
  ]
};

// ── SEO: Breadcrumb schema ────────────────────────────────────────────────────
const ldBreadcrumb={
  "@context":"https://schema.org","@type":"BreadcrumbList",
  "itemListElement":[
    {"@type":"ListItem","position":1,"name":"Home","item":siteUrl},
    {"@type":"ListItem","position":2,"name":"Lipa Mdogo Mdogo Phones","item":`${siteUrl}/phones/lipa-mdogo-mdogo-nairobi`}
  ]
};

// ── Comparison table rows ─────────────────────────────────────────────────────
const compRows=[
  ["Min. deposit","KSh 2,000","KSh 5,000+","KSh 3,000–10,000"],
  ["CRB / credit check","None","Required","Often required"],
  ["Inspect before paying","✅ Always","❌","❌"],
  ["Same-day delivery","✅ Free","❌ Courier only","❌"],
  ["M-Pesa instalments","Daily / weekly / monthly","Monthly only","Weekly / monthly"],
  ["Brand-new phones","✅ Factory sealed","✅","⚠️ Varies"],
  ["Flexible repayment","✅ Call or WhatsApp us","❌","⚠️ Varies"],
];
---

<Fragment>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,400;0,600;1,400;1,600&display=swap" rel="stylesheet" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDesc} />
  <link rel="canonical" href={`${siteUrl}/`} />
  <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
  <meta name="geo.region" content="KE-30" />
  <meta name="geo.placename" content="Nairobi, Kenya" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDesc} />
  <meta property="og:url" content={`${siteUrl}/`} />
  <meta property="og:locale" content="en_KE" />
  <!-- ── SEO: OG image for WhatsApp / social sharing ── -->
  <meta property="og:image" content={`${siteUrl}/og-image.jpg`} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:image:alt" content="Lipa Mdogo Mdogo Phones in Nairobi — From KSh 2,000 Deposit | MdogomdogoDeals" />

  <!-- Twitter / X -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:image" content={`${siteUrl}/og-image.jpg`} />

  <!-- Structured data -->
  <script type="application/ld+json" set:html={JSON.stringify(ldLocal)} />
  <script type="application/ld+json" set:html={JSON.stringify(ldFaq)} />
  <!-- ── SEO: Breadcrumb schema ── -->
  <script type="application/ld+json" set:html={JSON.stringify(ldBreadcrumb)} />

  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{
      --white:     #ffffff;
      --gray-50:   #f8fafc;
      --gray-100:  #f1f5f9;
      --gray-200:  #e2e8f0;
      --gray-300:  #cbd5e1;
      --gray-400:  #94a3b8;
      --gray-500:  #64748b;
      --gray-700:  #334155;
      --gray-900:  #0f172a;

      --blue-50:   #eff6ff;
      --blue-100:  #dbeafe;
      --blue-200:  #bfdbfe;
      --blue-500:  #3b82f6;
      --blue-600:  #2563eb;
      --blue-700:  #1d4ed8;

      --red-500:   #ef4444;
      --green-600: #16a34a;
      --orange-500:#f97316;
      --amber-400: #fbbf24;

      --font-body: 'Plus Jakarta Sans', system-ui, sans-serif;
      --font-serif:'Playfair Display', Georgia, serif;

      --max-w: 1340px;
      --px:    28px;

      --radius-sm:  6px;
      --radius-md:  10px;
      --radius-lg:  16px;
      --radius-xl:  22px;
      --radius-full:9999px;

      --shadow-xs: 0 1px 2px rgba(15,23,42,.06);
      --shadow-sm: 0 2px 8px rgba(15,23,42,.08);
      --shadow-md: 0 6px 20px rgba(15,23,42,.10);
      --shadow-lg: 0 16px 40px rgba(15,23,42,.14);
      --shadow-blue:0 4px 18px rgba(37,99,235,.28);
    }

    html{scroll-behavior:smooth}
    body{font-family:var(--font-body);background:var(--white);color:var(--gray-900);-webkit-font-smoothing:antialiased;font-size:15px;line-height:1.6}
    a{text-decoration:none;color:inherit}
    img{display:block;max-width:100%}
    button{font-family:var(--font-body);cursor:pointer}
    #root{background:var(--white)}

    /* ─── UTILS ─────────────────────── */
    .wrap{max-width:var(--max-w);margin:0 auto;padding:0 var(--px)}
    .sr-only{position:absolute;width:1px;height:1px;padding:0;overflow:hidden;clip:rect(0,0,0,0);white-space:nowrap;border:0}

    /* ─── BUTTONS ───────────────────── */
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:7px;border:none;border-radius:var(--radius-sm);font-family:var(--font-body);font-weight:600;cursor:pointer;transition:all .18s;white-space:nowrap;line-height:1}
    .btn-sm{padding:8px 16px;font-size:13px}
    .btn-md{padding:11px 22px;font-size:14px}
    .btn-lg{padding:14px 28px;font-size:15px;font-weight:700}
    .btn-primary{background:var(--blue-600);color:#fff;box-shadow:var(--shadow-blue)}
    .btn-primary:hover{background:var(--blue-700);box-shadow:0 6px 24px rgba(37,99,235,.36);transform:translateY(-1px)}
    .btn-secondary{background:var(--white);color:var(--blue-600);border:1.5px solid var(--blue-200)}
    .btn-secondary:hover{background:var(--blue-50);border-color:var(--blue-500)}
    .btn-ghost{background:transparent;color:var(--gray-700);border:1.5px solid var(--gray-200)}
    .btn-ghost:hover{background:var(--gray-50);border-color:var(--gray-300)}
    .btn-green{background:var(--green-600);color:#fff}
    .btn-green:hover{background:#15803d;transform:translateY(-1px)}

    /* ─── NOTICE BAR ────────────────── */
    .notice-bar{background:var(--blue-700);height:36px;display:flex;align-items:center;overflow:hidden;position:relative}
    .notice-ticker{display:flex;white-space:nowrap;animation:ticker 36s linear infinite}
    @keyframes ticker{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
    .notice-item{display:inline-flex;align-items:center;gap:10px;padding:0 40px;font-size:12.5px;font-weight:500;color:rgba(255,255,255,.85)}
    .notice-sep{color:rgba(255,255,255,.3)}
    .notice-end{position:absolute;right:0;top:0;bottom:0;display:flex;z-index:5}
    .notice-cta{display:flex;align-items:center;gap:7px;padding:0 20px;font-size:12.5px;font-weight:700;white-space:nowrap;transition:background .15s}
    .notice-cta-call{background:rgba(255,255,255,.12);color:#fff;border-left:1px solid rgba(255,255,255,.1)}
    .notice-cta-call:hover{background:rgba(255,255,255,.2)}
    .notice-cta-wa{background:var(--green-600);color:#fff}
    .notice-cta-wa:hover{background:#15803d}

    /* ─── HEADER ────────────────────── */
    .site-header{background:var(--white);border-bottom:1px solid var(--gray-200);position:sticky;top:0;z-index:200;box-shadow:var(--shadow-xs)}
    .header-inner{max-width:var(--max-w);margin:0 auto;padding:0 var(--px);display:grid;grid-template-columns:auto 1fr auto;align-items:center;height:66px;gap:24px}
    .site-logo{font-family:var(--font-serif);font-size:21px;color:var(--gray-900);display:flex;align-items:center;gap:2px;flex-shrink:0;letter-spacing:-.2px}
    .site-logo-blue{color:var(--blue-600)}
    .site-logo-badge{margin-left:9px;font-family:var(--font-body);font-size:9px;font-weight:700;background:var(--blue-600);color:#fff;padding:3px 7px;border-radius:var(--radius-sm);letter-spacing:.07em;text-transform:uppercase;align-self:center}
    .header-search{display:flex;align-items:center;background:var(--gray-50);border:1.5px solid var(--gray-200);border-radius:var(--radius-full);overflow:hidden;transition:border-color .15s,box-shadow .15s}
    .header-search:focus-within{border-color:var(--blue-500);box-shadow:0 0 0 3px rgba(59,130,246,.12);background:var(--white)}
    .header-search-input{flex:1;border:none;background:transparent;padding:10px 18px;font-size:14px;font-family:var(--font-body);color:var(--gray-900);outline:none}
    .header-search-input::placeholder{color:var(--gray-400)}
    .header-search-btn{background:var(--blue-600);color:#fff;border:none;padding:10px 22px;font-size:13.5px;font-weight:600;font-family:var(--font-body);display:flex;align-items:center;gap:7px;cursor:pointer;transition:background .15s;flex-shrink:0}
    .header-search-btn:hover{background:var(--blue-700)}
    .header-actions{display:flex;align-items:center;gap:6px;flex-shrink:0}
    .header-link-btn{display:flex;flex-direction:column;align-items:center;gap:2px;padding:8px 11px;border-radius:var(--radius-sm);color:var(--gray-500);font-size:11px;font-weight:600;transition:all .15s;border:none;background:transparent}
    .header-link-btn:hover{background:var(--gray-100);color:var(--blue-600)}
    .header-link-btn svg{width:20px;height:20px}

    /* ─── CATEGORY NAV ──────────────── */
    .cat-nav{background:var(--white);border-bottom:1px solid var(--gray-200)}
    .cat-nav-inner{max-width:var(--max-w);margin:0 auto;padding:0 var(--px);display:flex;gap:0;overflow-x:auto;scrollbar-width:none}
    .cat-nav-inner::-webkit-scrollbar{display:none}
    .cat-nav-link{display:flex;align-items:center;gap:6px;padding:12px 16px;font-size:13px;font-weight:500;color:var(--gray-500);white-space:nowrap;border-bottom:2px solid transparent;margin-bottom:-1px;transition:color .15s,border-color .15s}
    .cat-nav-link:hover{color:var(--blue-600);border-bottom-color:var(--blue-200)}
    .cat-nav-link.active{color:var(--blue-600);font-weight:600;border-bottom-color:var(--blue-600)}

    /* ─── HERO ──────────────────────── */
    .hero{background:var(--gray-50);border-bottom:1px solid var(--gray-200);padding:0 var(--px)}
    .hero-inner{max-width:var(--max-w);margin:0 auto;display:grid;grid-template-columns:260px 1fr 320px;gap:16px;padding:20px 0}

    /* Hero left — category sidebar */
    .hero-sidebar{background:var(--white);border:1px solid var(--gray-200);border-radius:var(--radius-lg);overflow:hidden;display:flex;flex-direction:column}
    .sidebar-item{display:flex;align-items:center;gap:10px;padding:11px 16px;font-size:13.5px;font-weight:500;color:var(--gray-700);border-bottom:1px solid var(--gray-100);cursor:pointer;transition:background .15s,color .15s;text-decoration:none}
    .sidebar-item:last-child{border-bottom:none}
    .sidebar-item:hover{background:var(--blue-50);color:var(--blue-600)}
    .sidebar-item-icon{font-size:15px;width:22px;text-align:center;flex-shrink:0}
    .sidebar-item-arrow{margin-left:auto;color:var(--gray-300);font-size:14px}

    /* Hero main banner */
    .hero-banner{border-radius:var(--radius-lg);overflow:hidden;position:relative;background:linear-gradient(115deg,#0f2d6b 0%,#1a3f8f 40%,#1e4fc2 70%,#2563eb 100%);min-height:360px;display:flex;align-items:center;padding:48px 52px}
    .hero-banner::before{content:'';position:absolute;inset:0;background:url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.03'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");pointer-events:none}
    .hero-banner::after{content:'';position:absolute;right:0;top:0;bottom:0;width:45%;background:radial-gradient(ellipse at 80% 50%,rgba(255,255,255,.06) 0%,transparent 70%);pointer-events:none}
    .hero-content{position:relative;z-index:1;max-width:480px}
    .hero-tag{display:inline-block;background:rgba(255,255,255,.15);color:rgba(255,255,255,.9);font-size:11.5px;font-weight:600;padding:4px 12px;border-radius:var(--radius-full);margin-bottom:18px;border:1px solid rgba(255,255,255,.2);letter-spacing:.04em;text-transform:uppercase}
    /* ── SEO: H1 targets exact keyword ── */
    .hero-h1{font-family:var(--font-serif);font-size:46px;font-weight:400;color:#fff;line-height:1.1;letter-spacing:-.3px;margin-bottom:14px}
    .hero-h1 em{font-style:italic;color:#93c5fd}
    .hero-sub{font-size:15px;color:rgba(255,255,255,.7);line-height:1.65;margin-bottom:28px;max-width:380px;font-weight:400}
    .hero-cta-row{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:32px}
    .hero-btn-main{background:#fff;color:var(--blue-700);border-radius:var(--radius-sm);padding:13px 26px;font-size:14.5px;font-weight:700;font-family:var(--font-body);display:inline-flex;align-items:center;gap:8px;transition:all .18s;border:none;cursor:pointer}
    .hero-btn-main:hover{background:#eff6ff;transform:translateY(-1px);box-shadow:0 8px 24px rgba(0,0,0,.2)}
    .hero-btn-ghost{background:rgba(255,255,255,.1);color:#fff;border:1.5px solid rgba(255,255,255,.25);border-radius:var(--radius-sm);padding:12px 22px;font-size:14px;font-weight:600;font-family:var(--font-body);display:inline-flex;align-items:center;gap:7px;transition:all .18s;cursor:pointer}
    .hero-btn-ghost:hover{background:rgba(255,255,255,.18)}
    .hero-badges{display:flex;gap:8px;flex-wrap:wrap}
    .hero-badge{display:flex;align-items:center;gap:6px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.15);border-radius:var(--radius-sm);padding:7px 12px;font-size:12px;color:rgba(255,255,255,.8);font-weight:500}

    /* Hero right — quick-pick */
    .hero-aside{display:flex;flex-direction:column;gap:12px}
    .aside-card{background:var(--white);border:1px solid var(--gray-200);border-radius:var(--radius-lg);overflow:hidden;box-shadow:var(--shadow-xs);transition:box-shadow .18s,border-color .18s}
    .aside-card:hover{box-shadow:var(--shadow-md);border-color:var(--blue-200)}
    .aside-card-hd{background:var(--gray-50);border-bottom:1px solid var(--gray-200);padding:11px 14px;font-size:12px;font-weight:700;color:var(--gray-500);text-transform:uppercase;letter-spacing:.07em;display:flex;align-items:center;justify-content:space-between}
    .aside-card-hd a{color:var(--blue-600);font-size:11.5px;text-transform:none;letter-spacing:0;font-weight:600}
    .aside-dep-list{padding:8px 0}
    .aside-dep-item{display:flex;align-items:center;justify-content:space-between;padding:9px 14px;font-size:13px;color:var(--gray-700);cursor:pointer;transition:background .12s;text-decoration:none}
    .aside-dep-item:hover{background:var(--blue-50);color:var(--blue-600)}
    .aside-dep-badge{font-size:11px;font-weight:700;color:var(--blue-600);background:var(--blue-50);padding:2px 7px;border-radius:var(--radius-full)}
    .aside-wa-card{background:linear-gradient(135deg,#064e3b,#065f46);border-radius:var(--radius-lg);padding:16px;display:flex;align-items:center;gap:12px;text-decoration:none;transition:opacity .15s}
    .aside-wa-card:hover{opacity:.9}
    .aside-wa-icon{width:40px;height:40px;background:rgba(255,255,255,.1);border-radius:var(--radius-md);display:flex;align-items:center;justify-content:center;font-size:20px;flex-shrink:0}
    .aside-wa-text strong{display:block;font-size:13px;font-weight:700;color:#fff;margin-bottom:2px}
    .aside-wa-text span{font-size:11.5px;color:rgba(255,255,255,.6)}

    /* ─── WHAT IS LIPA MDOGO MDOGO ──── */
    .explainer{background:var(--white);padding:48px 0 40px;border-bottom:1px solid var(--gray-200)}
    .explainer-inner{max-width:860px}
    .explainer-h2{font-family:var(--font-serif);font-size:26px;font-weight:600;color:var(--gray-900);margin-bottom:18px;line-height:1.3}
    .explainer-p{font-size:14.5px;color:var(--gray-500);line-height:1.85;margin-bottom:14px}
    .explainer-p:last-child{margin-bottom:0}

    /* ─── SECTION SCAFFOLDING ───────── */
    .section{padding:48px 0}
    .section-alt{background:var(--gray-50)}
    .section-head{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:22px;padding-bottom:16px;border-bottom:1px solid var(--gray-200)}
    .section-head-left{}
    .section-label{font-size:11.5px;font-weight:700;color:var(--blue-600);text-transform:uppercase;letter-spacing:.09em;margin-bottom:6px}
    .section-title{font-family:var(--font-serif);font-size:24px;font-weight:600;color:var(--gray-900);letter-spacing:-.2px;line-height:1.2}
    .see-all{font-size:13.5px;font-weight:600;color:var(--blue-600);display:flex;align-items:center;gap:4px;transition:gap .15s}
    .see-all:hover{gap:8px}

    /* ─── TRUST STRIP ───────────────── */
    .trust-strip{background:var(--white);border-top:1px solid var(--gray-200);border-bottom:1px solid var(--gray-200);padding:0 var(--px)}
    .trust-strip-inner{max-width:var(--max-w);margin:0 auto;display:grid;grid-template-columns:repeat(5,1fr)}
    .trust-item{display:flex;align-items:center;gap:12px;padding:18px 20px;border-right:1px solid var(--gray-100)}
    .trust-item:last-child{border-right:none}
    .trust-icon{width:36px;height:36px;border-radius:var(--radius-md);background:var(--blue-50);display:flex;align-items:center;justify-content:center;font-size:17px;flex-shrink:0}
    .trust-text strong{display:block;font-size:13px;font-weight:700;color:var(--gray-900);margin-bottom:2px}
    .trust-text span{font-size:11.5px;color:var(--gray-400);line-height:1.4}

    /* ─── TRUST PROOF BLOCK ─────────── */
    .trust-proof{background:var(--blue-700);padding:28px 0}
    .trust-proof-inner{max-width:var(--max-w);margin:0 auto;padding:0 var(--px);display:grid;grid-template-columns:repeat(4,1fr);gap:0}
    .trust-stat{text-align:center;padding:16px 20px;border-right:1px solid rgba(255,255,255,.12)}
    .trust-stat:last-child{border-right:none}
    .trust-stat-num{font-family:var(--font-serif);font-size:36px;font-weight:600;color:#fff;line-height:1;margin-bottom:6px}
    .trust-stat-label{font-size:12.5px;color:rgba(255,255,255,.65);font-weight:500}
    .trust-testimonials{max-width:var(--max-w);margin:0 auto;padding:24px var(--px) 0;display:grid;grid-template-columns:repeat(3,1fr);gap:14px}
    .testimonial{background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.12);border-radius:var(--radius-lg);padding:16px 18px}
    .testimonial-text{font-size:13px;color:rgba(255,255,255,.8);line-height:1.7;margin-bottom:10px;font-style:italic}
    .testimonial-author{font-size:12px;font-weight:700;color:rgba(255,255,255,.55);text-transform:uppercase;letter-spacing:.06em}

    /* ─── FLASH DEALS ───────────────── */
    .flash-track{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}

    /* ─── PRODUCT CARD ──────────────── */
    .prod-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:14px}
    .prod-grid-4{grid-template-columns:repeat(4,1fr)}

    .pcard{background:var(--white);border:1px solid var(--gray-200);border-radius:var(--radius-lg);overflow:hidden;display:flex;flex-direction:column;position:relative;text-decoration:none;color:inherit;box-shadow:var(--shadow-xs);transition:all .2s}
    .pcard:hover{box-shadow:var(--shadow-lg);border-color:var(--blue-200);transform:translateY(-4px)}

    .pcard-badge{position:absolute;top:10px;left:10px;z-index:3;font-size:10px;font-weight:700;padding:3px 8px;border-radius:var(--radius-sm);text-transform:uppercase;letter-spacing:.05em}
    .badge-new{background:#059669;color:#fff}
    .badge-hot{background:var(--red-500);color:#fff}
    .badge-sale{background:var(--orange-500);color:#fff}
    .pcard-disc{position:absolute;top:10px;right:10px;z-index:3;background:var(--red-500);color:#fff;font-size:10px;font-weight:700;padding:3px 8px;border-radius:var(--radius-sm)}
    .pcard-wish{position:absolute;top:38px;right:10px;z-index:3;width:28px;height:28px;background:var(--white);border:1px solid var(--gray-200);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;cursor:pointer;transition:all .15s;opacity:0}
    .pcard:hover .pcard-wish{opacity:1}
    .pcard-wish:hover{background:var(--blue-50);border-color:var(--blue-200)}

    /* Flash card image — larger */
    .pcard-flash .pcard-img{aspect-ratio:4/3;padding:24px}
    .pcard-flash .pcard-img img{width:180px;height:180px;object-fit:contain}

    .pcard-img{background:var(--gray-50);display:flex;align-items:center;justify-content:center;padding:20px;aspect-ratio:1/1;overflow:hidden}
    .pcard-img img{width:140px;height:140px;object-fit:contain;transition:transform .32s}
    .pcard:hover .pcard-img img{transform:scale(1.07)}

    .pcard-body{padding:14px;flex:1;display:flex;flex-direction:column;border-top:1px solid var(--gray-100)}
    .pcard-brand{font-size:10.5px;font-weight:700;color:var(--blue-600);text-transform:uppercase;letter-spacing:.1em;margin-bottom:4px}
    .pcard-name{font-size:13.5px;font-weight:600;color:var(--gray-900);line-height:1.45;margin-bottom:7px;flex:1;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .pcard-specs{display:flex;gap:4px;flex-wrap:wrap;margin-bottom:10px}
    .pcard-spec{background:var(--gray-100);color:var(--gray-500);border-radius:var(--radius-full);padding:2px 8px;font-size:10.5px;font-weight:500}
    .pcard-rating{display:flex;align-items:center;gap:5px;margin-bottom:10px}
    .pcard-stars{color:var(--amber-400);font-size:12px;letter-spacing:.2px}
    .pcard-rc{font-size:11px;color:var(--gray-400)}
    .pcard-price-row{margin-bottom:12px}
    .pcard-dep-label{font-size:10.5px;font-weight:600;color:var(--gray-400);text-transform:uppercase;letter-spacing:.06em;margin-bottom:2px}
    .pcard-price{font-family:var(--font-serif);font-size:24px;color:var(--gray-900);line-height:1;letter-spacing:-.3px}
    .pcard-install{font-size:11.5px;color:var(--green-600);font-weight:600;margin-top:3px}
    .pcard-actions{display:grid;grid-template-columns:1fr 1fr;gap:7px;margin-top:auto}
    .pcard-btn-cart{background:var(--blue-600);color:#fff;border:none;border-radius:var(--radius-sm);padding:9px 4px;font-size:12px;font-weight:700;cursor:pointer;font-family:var(--font-body);transition:background .15s}
    .pcard-btn-cart:hover{background:var(--blue-700)}
    .pcard-btn-view{background:var(--white);color:var(--blue-600);border:1.5px solid var(--blue-200);border-radius:var(--radius-sm);padding:9px 4px;font-size:12px;font-weight:600;cursor:pointer;font-family:var(--font-body);transition:all .15s}
    .pcard-btn-view:hover{background:var(--blue-50);border-color:var(--blue-500)}

    /* Flash deal card variant */
    .pcard-flash{scroll-snap-align:start}

    /* ─── BRANDS ────────────────────── */
    .brands-row{display:grid;grid-template-columns:repeat(8,1fr);gap:10px}
    .brand-card{background:var(--white);border:1px solid var(--gray-200);border-radius:var(--radius-lg);aspect-ratio:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:8px;text-decoration:none;cursor:pointer;transition:all .18s;padding:12px}
    .brand-card:hover{border-color:var(--blue-300);box-shadow:var(--shadow-md);transform:translateY(-3px)}
    .brand-card-logo{height:34px;display:flex;align-items:center;justify-content:center;width:100%}
    .brand-card-name{font-size:10.5px;font-weight:600;color:var(--gray-400);text-transform:uppercase;letter-spacing:.06em}

    /* ─── FEATURES ──────────────────── */
    .feat-row{display:grid;grid-template-columns:repeat(4,1fr);gap:10px}
    .feat-tile{background:var(--white);border:1px solid var(--gray-200);border-radius:var(--radius-lg);padding:20px;display:flex;align-items:center;gap:14px;text-decoration:none;color:inherit;transition:all .18s;position:relative;overflow:hidden}
    .feat-tile::before{content:'';position:absolute;bottom:0;left:0;right:0;height:2px;background:var(--blue-600);transform:scaleX(0);transform-origin:left;transition:transform .22s}
    .feat-tile:hover{border-color:var(--blue-200);box-shadow:var(--shadow-sm);transform:translateY(-2px)}
    .feat-tile:hover::before{transform:scaleX(1)}
    .feat-tile-icon{width:46px;height:46px;border-radius:var(--radius-md);background:var(--blue-50);border:1px solid var(--blue-100);display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:800;color:var(--blue-600);flex-shrink:0;letter-spacing:-.5px}
    .feat-tile-name{font-size:14px;font-weight:600;color:var(--gray-900);margin-bottom:3px}
    .feat-tile-count{font-size:12px;color:var(--gray-400)}
    .feat-tile-count strong{color:var(--blue-600);font-weight:700}

    /* ─── BUDGET SECTION ────────────── */
    .budget-wrap{background:var(--gray-900);border-radius:var(--radius-xl);padding:36px;margin:0}
    .budget-hd{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:24px}
    .budget-title{font-family:var(--font-serif);font-size:26px;color:#fff;font-weight:600}
    .budget-title em{font-style:italic;color:#93c5fd}
    .budget-see{font-size:13px;font-weight:600;color:#7dd3fc;display:flex;align-items:center;gap:4px;transition:gap .15s}
    .budget-see:hover{gap:8px}
    .budget-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:10px}
    .budget-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:var(--radius-lg);overflow:hidden;display:flex;flex-direction:column;text-decoration:none;color:inherit;transition:all .18s}
    .budget-card:hover{background:rgba(255,255,255,.08);border-color:rgba(96,165,250,.35);transform:translateY(-3px)}
    .budget-card-img{background:rgba(255,255,255,.03);padding:16px;display:flex;align-items:center;justify-content:center;aspect-ratio:1}
    .budget-card-img img{width:80px;height:80px;object-fit:contain;transition:transform .3s;filter:drop-shadow(0 4px 10px rgba(0,0,0,.35))}
    .budget-card:hover .budget-card-img img{transform:scale(1.08)}
    .budget-card-body{padding:10px 12px 14px;flex:1;display:flex;flex-direction:column}
    .budget-card-name{font-size:12px;color:rgba(255,255,255,.55);line-height:1.45;margin-bottom:8px;flex:1;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .budget-card-price{font-family:var(--font-serif);font-size:21px;color:#fff;line-height:1;margin-bottom:2px;letter-spacing:-.2px}
    .budget-card-label{font-size:10px;color:rgba(255,255,255,.3);font-weight:500;margin-bottom:10px}
    .budget-card-cta{display:block;text-align:center;background:rgba(59,130,246,.15);border:1px solid rgba(59,130,246,.3);color:#93c5fd;padding:7px;font-size:12px;font-weight:600;border-radius:var(--radius-sm);cursor:pointer;font-family:var(--font-body);transition:background .15s}
    .budget-card-cta:hover{background:rgba(59,130,246,.3)}

    /* ─── PROMO BLOCKS ──────────────── */
    .promo-grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .promo-banner{border-radius:var(--radius-xl);overflow:hidden;position:relative;display:flex;align-items:flex-end;padding:32px;min-height:180px;text-decoration:none;color:inherit;transition:opacity .18s}
    .promo-banner:hover{opacity:.93}
    .promo-a{background:linear-gradient(130deg,#1e3a5f 0%,#1d4ed8 100%)}
    .promo-b{background:linear-gradient(130deg,#064e3b 0%,#059669 100%)}
    .promo-banner::after{content:'';position:absolute;top:-40px;right:-40px;width:180px;height:180px;border-radius:50%;background:rgba(255,255,255,.05);pointer-events:none}
    .promo-content{position:relative;z-index:1}
    .promo-overline{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.55);margin-bottom:7px}
    .promo-heading{font-family:var(--font-serif);font-size:22px;color:#fff;line-height:1.25;margin-bottom:12px;font-weight:600}
    .promo-link-btn{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.2);color:#fff;padding:8px 16px;border-radius:var(--radius-sm);font-size:13px;font-weight:600;font-family:var(--font-body)}
    .promo-big{position:absolute;top:20px;right:28px;font-family:var(--font-serif);font-size:64px;color:rgba(255,255,255,.07);line-height:1;pointer-events:none;font-style:italic}

    /* ─── HOW IT WORKS ──────────────── */
    .steps-row{display:grid;grid-template-columns:repeat(4,1fr);position:relative;gap:0}
    .steps-row::before{content:'';position:absolute;top:28px;left:12.5%;right:12.5%;height:1px;background:linear-gradient(90deg,var(--blue-200),var(--blue-400),var(--blue-200));z-index:0}
    .step{display:flex;flex-direction:column;align-items:center;text-align:center;padding:0 20px;position:relative;z-index:1}
    .step-num-wrap{position:relative;margin-bottom:20px}
    .step-circle{width:56px;height:56px;border-radius:50%;background:var(--blue-600);color:#fff;display:flex;align-items:center;justify-content:center;font-size:20px;box-shadow:var(--shadow-blue)}
    .step-n{position:absolute;top:-4px;right:-4px;width:18px;height:18px;background:var(--white);border:2px solid var(--blue-600);border-radius:50%;font-size:9px;font-weight:800;color:var(--blue-600);display:flex;align-items:center;justify-content:center}
    .step-title{font-size:14px;font-weight:700;color:var(--gray-900);margin-bottom:8px}
    .step-desc{font-size:13px;color:var(--gray-400);line-height:1.65}

    /* ─── WHY US ────────────────────── */
    .why-split{display:grid;grid-template-columns:1fr 1fr;gap:56px;align-items:center}
    .why-left-head{font-family:var(--font-serif);font-size:36px;color:var(--gray-900);margin-bottom:14px;line-height:1.2;font-weight:600}
    .why-left-head em{font-style:italic;color:var(--blue-600)}
    .why-left-sub{font-size:14.5px;color:var(--gray-400);line-height:1.75;margin-bottom:28px}
    .why-ctas{display:flex;gap:10px}
    .why-features{display:flex;flex-direction:column;gap:12px}
    .why-feat{display:flex;align-items:flex-start;gap:14px;background:var(--white);border:1px solid var(--gray-200);border-radius:var(--radius-lg);padding:16px 18px;transition:all .18s}
    .why-feat:hover{border-color:var(--blue-200);box-shadow:var(--shadow-sm)}
    .why-feat-icon{width:40px;height:40px;border-radius:var(--radius-md);background:var(--blue-50);border:1px solid var(--blue-100);display:flex;align-items:center;justify-content:center;font-size:18px;flex-shrink:0}
    .why-feat-title{font-size:13.5px;font-weight:700;color:var(--gray-900);margin-bottom:4px}
    .why-feat-desc{font-size:12.5px;color:var(--gray-400);line-height:1.6}

    /* ─── COMPARISON TABLE ──────────── */
    .comp-table{width:100%;border-collapse:collapse;font-size:13.5px;min-width:560px}
    .comp-table thead tr{background:var(--blue-700);color:#fff}
    .comp-table th{padding:12px 16px;text-align:left;font-weight:700}
    .comp-table th:not(:first-child){text-align:center}
    .comp-table th:first-child{border-radius:8px 0 0 0}
    .comp-table th:last-child{border-radius:0 8px 0 0}
    .comp-table td{padding:11px 16px;border-bottom:1px solid var(--gray-200)}
    .comp-table td:not(:first-child){text-align:center}
    .comp-table td:first-child{font-weight:600;color:var(--gray-700)}
    .comp-table tr:nth-child(even) td{background:var(--gray-50)}
    .comp-table tr:nth-child(odd) td{background:var(--white)}
    .comp-us{color:var(--green-600);font-weight:700}
    .comp-other{color:var(--gray-500)}
    .comp-note{font-size:12px;color:var(--gray-400);margin-top:10px}

    /* ─── FAQ ───────────────────────── */
    .faq-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .faq-card{background:var(--white);border:1px solid var(--gray-200);border-radius:var(--radius-lg);overflow:hidden}
    .faq-trigger{width:100%;background:transparent;border:none;padding:16px 20px;display:flex;align-items:center;justify-content:space-between;gap:12px;cursor:pointer;font-size:13.5px;font-weight:600;color:var(--gray-900);font-family:var(--font-body);text-align:left;transition:color .15s}
    .faq-trigger:hover{color:var(--blue-600)}
    .faq-trigger.open{color:var(--blue-600);border-bottom:1px solid var(--gray-100)}
    .faq-icon{width:24px;height:24px;border-radius:50%;background:var(--gray-100);display:flex;align-items:center;justify-content:center;font-size:15px;color:var(--gray-400);flex-shrink:0;transition:all .2s}
    .faq-trigger.open .faq-icon{transform:rotate(45deg);background:var(--blue-50);color:var(--blue-600)}
    .faq-body{display:none;padding:14px 20px;font-size:13.5px;color:var(--gray-500);line-height:1.8;background:var(--gray-50)}
    .faq-body.open{display:block}
    .faq-body a{color:var(--blue-600);font-weight:600}

    /* ─── SEO COPY ──────────────────── */
    .seo-block{border-top:1px solid var(--gray-200);padding:40px 0}
    .seo-inner{max-width:860px}
    .seo-inner h2{font-family:var(--font-serif);font-size:20px;color:var(--gray-700);margin-bottom:14px;font-weight:600;font-style:italic}
    .seo-inner p{font-size:13.5px;color:var(--gray-400);line-height:1.9;margin-bottom:11px}
    .seo-inner a{color:var(--blue-600);font-weight:600}
    .seo-inner a:hover{text-decoration:underline}

    /* ─── FOOTER ────────────────────── */
    .footer-cta-band{background:var(--blue-700);padding:28px var(--px)}
    .footer-cta-inner{max-width:var(--max-w);margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:24px;flex-wrap:wrap}
    .footer-cta-text h3{font-family:var(--font-serif);font-size:22px;color:#fff;margin-bottom:4px;font-weight:600;font-style:italic}
    .footer-cta-text p{font-size:13px;color:rgba(255,255,255,.65)}
    .footer-cta-btns{display:flex;gap:10px;flex-shrink:0}
    .f-btn-call{display:flex;align-items:center;gap:7px;background:rgba(255,255,255,.12);color:#fff;border:1px solid rgba(255,255,255,.25);padding:10px 20px;border-radius:var(--radius-sm);font-size:13.5px;font-weight:700;white-space:nowrap;transition:background .15s;font-family:var(--font-body)}
    .f-btn-call:hover{background:rgba(255,255,255,.22)}
    .f-btn-wa{display:flex;align-items:center;gap:7px;background:var(--green-600);color:#fff;padding:10px 20px;border-radius:var(--radius-sm);font-size:13.5px;font-weight:700;white-space:nowrap;transition:background .15s}
    .f-btn-wa:hover{background:#15803d}
    .site-footer{background:#0c1629;padding:52px var(--px) 24px}
    .footer-grid{max-width:var(--max-w);margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:48px;margin-bottom:40px}
    .footer-brand-logo{font-family:var(--font-serif);font-size:22px;color:#fff;display:block;margin-bottom:12px}
    .footer-brand-logo span{color:#93c5fd}
    .footer-tagline{font-size:13px;color:rgba(255,255,255,.35);line-height:1.75;max-width:300px}
    .footer-col-hd{font-size:10px;font-weight:700;color:rgba(255,255,255,.2);text-transform:uppercase;letter-spacing:.14em;margin-bottom:16px}
    .footer-links{list-style:none}
    .footer-links li{margin-bottom:9px}
    .footer-links a{font-size:13px;color:rgba(255,255,255,.4);transition:color .15s}
    .footer-links a:hover{color:#93c5fd}
    .footer-divider{max-width:var(--max-w);margin:0 auto 20px;border:none;border-top:1px solid rgba(255,255,255,.06)}
    .footer-bottom{max-width:var(--max-w);margin:0 auto;display:flex;justify-content:space-between;flex-wrap:wrap;gap:6px}
    .footer-bottom p{font-size:12px;color:rgba(255,255,255,.18)}

    /* ─── KEYWORD STRIP (trimmed) ───── */
    .kw-strip{background:#06101f;padding:12px var(--px);border-top:1px solid rgba(255,255,255,.04)}
    .kw-inner{max-width:var(--max-w);margin:0 auto;display:flex;flex-wrap:wrap;gap:5px}
    .kw{font-size:11px;color:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.05);border-radius:var(--radius-sm);padding:3px 8px;transition:color .12s}
    .kw:hover{color:#93c5fd}

    /* ─── RESPONSIVE ────────────────── */
    @media(max-width:1100px){
      .prod-grid{grid-template-columns:repeat(4,1fr)}
      .hero-inner{grid-template-columns:1fr 1fr}
      .hero-sidebar{display:none}
      .brands-row{grid-template-columns:repeat(6,1fr)}
      .budget-grid{grid-template-columns:repeat(4,1fr)}
      .flash-track{grid-template-columns:repeat(3,1fr)}
      .trust-proof-inner{grid-template-columns:repeat(2,1fr)}
      .trust-testimonials{grid-template-columns:1fr 1fr}
    }
    @media(max-width:900px){
      .prod-grid{grid-template-columns:repeat(3,1fr)}
      .feat-row{grid-template-columns:repeat(2,1fr)}
      .steps-row{grid-template-columns:repeat(2,1fr)}.steps-row::before{display:none}
      .why-split{grid-template-columns:1fr}
      .faq-grid{grid-template-columns:1fr}
      .footer-grid{grid-template-columns:1fr 1fr}
      .trust-strip-inner{grid-template-columns:repeat(3,1fr)}
      .hero-inner{grid-template-columns:1fr}
      .hero-aside{display:none}
      .promo-grid{grid-template-columns:1fr}
      .flash-track{grid-template-columns:1fr 1fr}
      .trust-testimonials{grid-template-columns:1fr}
    }
    @media(max-width:700px){
      .prod-grid{grid-template-columns:repeat(2,1fr)}
      .brands-row{grid-template-columns:repeat(4,1fr)}
      .budget-grid{grid-template-columns:repeat(2,1fr)}
      .hero-h1{font-size:34px}
      .trust-strip-inner{grid-template-columns:repeat(2,1fr)}
      .flash-track{grid-template-columns:1fr}
    }
    @media(max-width:540px){
      .steps-row{grid-template-columns:1fr}
      .footer-grid{grid-template-columns:1fr}
      .trust-strip-inner{grid-template-columns:1fr}
      .trust-proof-inner{grid-template-columns:repeat(2,1fr)}
    }
    @media(prefers-reduced-motion:reduce){
      .notice-ticker{animation:none}
    }
  </style>
</Fragment>

