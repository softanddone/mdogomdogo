---
import { products } from '../data/product2.js';
import {
  ALL_BRANDS,
  DEPOSIT_FILTERS,
  STORAGE_FILTERS,
  brandSlug,
  brandSlugall,
  parseDeposit,
} from '../data/filter-config.js';
import { FEATURE_FILTERS, featureHref } from '../data/feature-config.js';
import Gift from '../components/Gift.astro';
import Nav from '../components/Nav.astro';

const featured    = products.slice(0, 5);
const flashDeals = products.filter(p => 
  ["samsung-galaxy-s24-256gb", "tecno-camon-50-pro-max", "samsung-galaxy-s20-ultra"].includes(p.slug)
);

const budgetPicks = products.filter(p => parseDeposit(p.deposit) < 5000).slice(0, 5);
const samsungList = products.filter(p => p.brand?.toLowerCase() === 'samsung').slice(0, 5);
const tecnoList   = products.filter(p => p.brand?.toLowerCase() === 'tecno').slice(0, 5);
const infinixList = products.filter(p => p.brand?.toLowerCase() === 'infinix').slice(0, 5);

// Feature links with live counts — only show features that have stock
const featureLinks = FEATURE_FILTERS.map(feat => ({
  ...feat,
  count: products.filter(feat.match).length,
  href: `/features/${feat.key}-phones-kenya`,
})).filter(f => f.count > 0);

// Colour/icon map — add more keys as FEATURE_FILTERS grows
const featureIcons = {
  '5g':             { icon: '5G',  color: '#1a56db', bg: '#eef3ff' },
  'gaming':         { icon: '🎮',  color: '#7c3aed', bg: '#f5f3ff' },
  'amoled':         { icon: '✨',  color: '#0a7c3e', bg: '#edfaf3' },
  '120hz':          { icon: '⚡',  color: '#c05a00', bg: '#fff7ed' },
  '108mp-camera':   { icon: '📷',  color: '#c92424', bg: '#fff2f2' },
  'large-battery':  { icon: '🔋',  color: '#0a7c3e', bg: '#edfaf3' },
  'curved-display': { icon: '⬡',  color: '#1a56db', bg: '#eef3ff' },
  'fingerprint':    { icon: '👆',  color: '#7c3aed', bg: '#f5f3ff' },
};

function renderStars(rating) {
  const full = Math.floor(rating ?? 4.5);
  return '★'.repeat(full) + '☆'.repeat(5 - full);
}
---

<Fragment>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --ink:        #1a1f2e;
      --ink-mid:    #2d3444;
      --ink-light:  #5a6478;
      --ink-faint:  #9aa3b2;
      --blue:       #1a56db;
      --blue-dark:  #1341b0;
      --blue-bg:    #eef3ff;
      --blue-line:  #c5d5fb;
      --green:      #0a7c3e;
      --green-bg:   #edfaf3;
      --red:        #c92424;
      --red-bg:     #fff2f2;
      --canvas:     #ffffff;
      --surface:    #f4f6f9;
      --border:     #dce1ea;
      --border-mid: #eaecf0;
      --radius-sm: 6px;
      --radius-md: 10px;
      --radius-lg: 14px;
      --shadow-sm: 0 1px 3px rgba(26,31,46,0.08);
      --shadow-md: 0 4px 18px rgba(26,31,46,0.1);
      --shadow-lg: 0 10px 36px rgba(26,31,46,0.13);
    }

    #page-root { font-family: 'Inter', sans-serif; background: var(--canvas); color: var(--ink-mid); -webkit-font-smoothing: antialiased; }
    a { text-decoration: none; color: inherit; }
    img { display: block; }

    /* ─── TOP BAR ────────────────────────────────────────────────── */
    .top-bar {
      background: #1a2744;
      color: #8fa3c0;
      font-size: 12px;
      font-weight: 500;
      padding: 6px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 10px;
    }
    .top-bar-pills {
      display: flex;
      align-items: center;
      gap: 6px;
      flex-wrap: wrap;
    }
    .top-pill {
      display: flex;
      align-items: center;
      gap: 5px;
      background: rgba(255,255,255,0.08);
      border: 1px solid rgba(255,255,255,0.14);
      border-radius: 20px;
      padding: 3px 10px;
      font-size: 11.5px;
      color: #d4e0f0;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .top-pill svg { width: 10px; height: 10px; color: #7eb3e8; flex-shrink: 0; }
    .top-bar-right { display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
    .top-phone { font-size: 11.5px; color: #d4e0f0; font-weight: 600; white-space: nowrap; }
    .top-wa { background: #1a7a35; color: #fff; border-radius: 6px; padding: 5px 12px; font-size: 11.5px; font-weight: 600; display: flex; align-items: center; gap: 5px; white-space: nowrap; }
    .top-wa svg { width: 12px; height: 12px; }

    @media (max-width: 700px) {
      .top-bar { flex-direction: column; align-items: stretch; gap: 0; padding: 0; }
      .top-bar-pills { flex-wrap: nowrap; overflow-x: auto; scrollbar-width: none; -webkit-overflow-scrolling: touch; gap: 6px; padding: 7px 14px; }
      .top-bar-pills::-webkit-scrollbar { display: none; }
      .top-bar-right { display: grid; grid-template-columns: 1fr 1fr; border-top: 1px solid rgba(255,255,255,0.1); }
      .top-phone { display: flex; align-items: center; justify-content: center; gap: 6px; padding: 8px 12px; border-right: 1px solid rgba(255,255,255,0.1); font-size: 12px; font-weight: 700; color: #d4e0f0; }
      .top-wa { justify-content: center; border-radius: 0; padding: 8px 12px; font-size: 12px; }
    }

    /* MAIN NAV */
    .main-nav { background: var(--canvas); border-bottom: 1px solid var(--border); }
    .main-nav ul { max-width: 1320px; margin: 0 auto; padding: 0 24px; list-style: none; display: flex; align-items: center; overflow-x: auto; scrollbar-width: none; }
    .main-nav ul::-webkit-scrollbar { display: none; }
    .main-nav li a { display: block; padding: 12px 14px; font-size: 13px; font-weight: 500; color: var(--ink-light); border-bottom: 2px solid transparent; margin-bottom: -1px; white-space: nowrap; transition: color 0.15s, border-color 0.15s; }
    .main-nav li a:hover { color: var(--blue); border-bottom-color: var(--blue-line); }
    .main-nav li a.active { color: var(--blue); border-bottom-color: var(--blue); font-weight: 600; }

    /* ─── HERO ─────────────────────────────────────────────────────── */
    @keyframes heroShift {
      0%   { background-position: 0% 50%; }
      50%  { background-position: 100% 50%; }
      100% { background-position: 0% 50%; }
    }
    .hero { position: relative; overflow: hidden; padding: 48px 24px 44px; background: #F3E9DC; }
    .hero::before { content: ''; position: absolute; inset: 0; background: linear-gradient(135deg,#F3E9DC 0%,#F5ECD8 15%,#F9F0E3 30%,wheat 45%,#FAF0DC 55%,#FDF6EE 70%,#ffffff 85%,#F3E9DC 100%); background-size: 300% 300%; animation: heroShift 12s ease-in-out infinite; z-index: 0; will-change: background-position; }
    .hero::after { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 600px 400px at 90% 60%, rgba(26,86,219,0.06) 0%, transparent 70%); pointer-events: none; z-index: 0; }
    .hero-inner { max-width: 1320px; margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; position: relative; z-index: 1; }
    .hero-eyebrow { display: inline-flex; align-items: center; gap: 6px; background: rgba(26,31,46,0.07); border: 1px solid rgba(26,31,46,0.14); border-radius: 20px; padding: 4px 12px; font-size: 11.5px; font-weight: 700; color: #1a56db; letter-spacing: 0.04em; text-transform: uppercase; margin-bottom: 14px; }
    .hero-eyebrow svg { width: 10px; height: 10px; color: #1a56db; }
    .hero-text h1 { font-size: 42px; font-weight: 800; color: var(--ink); line-height: 1.1; margin-bottom: 16px; letter-spacing: -1px; }
    .hero-text h1 em { font-style: normal; color: var(--blue); }
    .hero-text p { font-size: 15px; color: var(--ink-light); margin-bottom: 28px; line-height: 1.7; max-width: 440px; }
    .hero-text p strong { color: var(--ink); font-weight: 700; }
    .hero-btns { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 32px; }
    .btn-hero { background: var(--blue); color: #fff; border-radius: var(--radius-md); padding: 12px 28px; font-size: 14px; font-weight: 700; display: inline-flex; align-items: center; gap: 6px; transition: background 0.15s, transform 0.15s; letter-spacing: -0.2px; font-family: 'Inter', sans-serif; }
    .btn-hero:hover { background: var(--blue-dark); transform: translateY(-1px); }
    .btn-hero svg { width: 14px; height: 14px; }
    .btn-hero-ghost { background: rgba(26,31,46,0.06); color: var(--ink-mid); border: 1px solid rgba(26,31,46,0.18); border-radius: var(--radius-md); padding: 11px 24px; font-size: 14px; font-weight: 600; font-family: 'Inter', sans-serif; display: inline-block; transition: background 0.15s; }
    .btn-hero-ghost:hover { background: rgba(26,31,46,0.11); }
    .hero-stats { display: flex; gap: 24px; flex-wrap: wrap; }
    .hero-stat .num { font-size: 26px; font-weight: 800; color: var(--ink); letter-spacing: -0.5px; line-height: 1.2; }
    .hero-stat .lbl { font-size: 12px; color: var(--ink-light); margin-top: 1px; }
    .hero-right { display: flex; flex-direction: column; gap: 12px; }
    .dep-cards { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
    .dep-card { background: rgba(255,255,255,0.55); border: 1px solid rgba(26,31,46,0.12); border-radius: var(--radius-md); padding: 16px; text-align: center; transition: background 0.15s, border-color 0.15s; cursor: pointer; }
    .dep-card:hover { background: rgba(255,255,255,0.8); border-color: var(--blue); }
    .dep-card .amount { font-size: 20px; font-weight: 800; color: var(--ink); }
    .dep-card .sublabel { font-size: 11px; color: var(--ink-light); margin-top: 3px; }
    .hero-badges { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
    .hero-badge { background: rgba(255,255,255,0.5); border: 1px solid rgba(26,31,46,0.1); border-radius: var(--radius-sm); padding: 10px 8px; text-align: center; }
    .hero-badge svg { width: 18px; height: 18px; color: var(--blue); margin: 0 auto 5px; }
    .hero-badge span { display: block; font-size: 11px; color: var(--ink-mid); line-height: 1.4; font-weight: 600; }

    /* ─── FLASH DEALS ──────────────────────────────────────────────── */
    .flash-section { background: #fff9f0; border-top: 1px solid #f0d9b5; border-bottom: 1px solid #f0d9b5; padding: 24px; }
    .flash-section-inner { max-width: 1320px; margin: 0 auto; }
    .flash-section-head { display: flex; align-items: center; justify-content: space-between; margin-bottom: 18px; }
    .flash-section-title { display: flex; align-items: center; gap: 10px; }
    .flash-section-title h2 { font-size: 19px; font-weight: 700; color: var(--ink); letter-spacing: -0.4px; }
    .flash-pulse-badge { display: inline-flex; align-items: center; gap: 5px; background: var(--red); color: #fff; font-size: 11px; font-weight: 700; padding: 4px 10px; border-radius: 5px; letter-spacing: 0.05em; text-transform: uppercase; }
    .flash-pulse-badge svg { width: 12px; height: 12px; animation: pulse 1s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }
    .flash-see-all { font-size: 13px; font-weight: 600; color: var(--blue); display: flex; align-items: center; gap: 4px; }
    .flash-see-all:hover { text-decoration: underline; }
    .flash-see-all svg { width: 14px; height: 14px; }
    .flash-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .flash-card { display: flex; flex-direction: column; background: var(--canvas); border-radius: var(--radius-lg); border: 1px solid #f0c080; overflow: hidden; position: relative; transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s cubic-bezier(0.34,1.56,0.64,1); text-decoration: none; color: inherit; }
    .flash-card:hover { border-color: var(--red); box-shadow: var(--shadow-lg); transform: translateY(-4px); }
    .flash-card-accent { height: 4px; background: linear-gradient(90deg, #e05a00, var(--red)); flex-shrink: 0; }
    .flash-card-discount { position: absolute; top: 14px; right: 12px; z-index: 3; background: var(--red); color: #fff; font-size: 12px; font-weight: 700; padding: 4px 10px; border-radius: 5px; line-height: 1.4; }
    .flash-card-hot { position: absolute; top: 14px; left: 12px; z-index: 3; background: #e05a00; color: #fff; font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 5px; text-transform: uppercase; letter-spacing: 0.05em; }
    .flash-card-img-wrap { width: 100%; aspect-ratio: 4/3; background: var(--surface); display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0; }
    .flash-card-img { width: 85%; height: 85%; object-fit: contain; transition: transform 0.35s cubic-bezier(0.34,1.2,0.64,1); }
    .flash-card:hover .flash-card-img { transform: scale(1.06); }
    .flash-card-body { padding: 14px 14px 12px; flex: 1; display: flex; flex-direction: column; }
    .flash-card-brand { font-size: 10px; font-weight: 700; color: var(--blue); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 4px; }
    .flash-card-name { font-size: 14px; font-weight: 600; color: var(--ink); line-height: 1.4; margin-bottom: 8px; flex: 1; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
    .flash-card-specs { display: flex; gap: 4px; flex-wrap: wrap; margin-bottom: 10px; }
    .flash-spec-pill { background: var(--surface); border: 1px solid var(--border-mid); color: var(--ink-light); border-radius: 4px; padding: 2px 7px; font-size: 10.5px; font-weight: 500; white-space: nowrap; }
    .flash-card-pricing { display: flex; align-items: baseline; gap: 8px; margin-bottom: 6px; }
    .flash-price-deposit { font-size: 26px; font-weight: 800; color: var(--blue); letter-spacing: -0.5px; line-height: 1; }
    .flash-price-label { font-size: 12px; color: var(--ink-faint); font-weight: 400; }
    .flash-installment-note { font-size: 11.5px; color: var(--green); font-weight: 600; background: var(--green-bg); padding: 5px 10px; border-radius: 5px; margin-bottom: 12px; display: inline-block; }
    .flash-card-cta { display: flex; gap: 6px; margin-top: auto; }
    .flash-btn-cart { flex: 1; background: var(--red); color: #fff; border: none; border-radius: var(--radius-sm); padding: 10px 8px; font-size: 13px; font-weight: 700; cursor: pointer; font-family: 'Inter', sans-serif; transition: background 0.15s; }
    .flash-btn-cart:hover { background: #a40e26; }
    .flash-btn-buy { flex: 1; background: var(--ink); color: #fff; border: none; border-radius: var(--radius-sm); padding: 10px 8px; font-size: 13px; font-weight: 600; cursor: pointer; font-family: 'Inter', sans-serif; transition: background 0.15s; }
    .flash-btn-buy:hover { background: #24292f; }
    @media (max-width: 900px) { .flash-grid { grid-template-columns: repeat(2, 1fr); } }
    @media (max-width: 540px) { .flash-grid { grid-template-columns: 1fr; } }

    /* TRUST BAR */
    .trust-bar { background: var(--canvas); border-bottom: 1px solid var(--border); padding: 0 24px; }
    .trust-inner { max-width: 1320px; margin: 0 auto; display: flex; align-items: stretch; }
    .trust-item { display: flex; align-items: center; gap: 10px; font-size: 12.5px; font-weight: 600; color: var(--ink-mid); padding: 12px 20px; border-right: 1px solid var(--border-mid); flex: 1; }
    .trust-item:last-child { border-right: none; }
    .trust-item strong { display: block; font-size: 12.5px; font-weight: 700; color: var(--ink); }
    .trust-item span { color: var(--ink-light); }
    .trust-icon { width: 32px; height: 32px; background: var(--green-bg); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
    .trust-icon svg { width: 14px; height: 14px; color: var(--green); }

    /* PAGE WRAP */
    .page-wrap { max-width: 1320px; margin: 0 auto; padding: 0 24px; }

    /* SECTION HEADS */
    .section-head { display: flex; align-items: center; justify-content: space-between; padding-top: 32px; margin-bottom: 16px; }
    .section-head-left { display: flex; align-items: center; gap: 10px; }
    .section-head h2 { font-size: 19px; font-weight: 700; color: var(--ink); letter-spacing: -0.4px; }
    .section-rule { border: none; border-top: 1px solid var(--border-mid); margin: 4px 0 0; }
    .tag { display: inline-block; font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 4px; letter-spacing: 0.04em; text-transform: uppercase; }
    .tag-blue  { background: var(--blue-bg); color: var(--blue); }
    .tag-red   { background: var(--red-bg); color: var(--red); }
    .tag-ink   { background: var(--surface); color: var(--ink-light); }
    .see-all { font-size: 13px; font-weight: 600; color: var(--blue); display: flex; align-items: center; gap: 4px; }
    .see-all:hover { text-decoration: underline; }
    .see-all svg { width: 14px; height: 14px; }

    /* BRAND GRID */
    .brand-grid { display: grid; grid-template-columns: repeat(8, 1fr); gap: 10px; margin-bottom: 8px; }
    .brand-chip { background: var(--canvas); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 14px 8px 10px; text-align: center; transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s; cursor: pointer; display: flex; flex-direction: column; align-items: center; justify-content: center; min-width: 0; }
    .brand-chip:hover { border-color: var(--blue); box-shadow: var(--shadow-md); transform: translateY(-2px); }
    .brand-logo-wrap { display: flex; align-items: center; justify-content: center; height: 46px; margin-bottom: 6px; overflow: hidden; width: 100%; }
    .brand-logo-wrap svg, .brand-logo-wrap img { max-width: 100%; height: auto; }
    .brand-chip-sub { font-size: 11px; color: var(--ink-faint); font-weight: 500; }
    @media (max-width: 900px) {
      .brand-grid { display: flex; flex-wrap: nowrap; overflow-x: auto; gap: 8px; padding-bottom: 6px; scrollbar-width: none; -webkit-overflow-scrolling: touch; }
      .brand-grid::-webkit-scrollbar { display: none; }
      .brand-chip { flex: 0 0 90px; min-width: 90px; }
      .brand-logo-wrap { height: 38px; }
    }
    @media (max-width: 500px) {
      .brand-chip { flex: 0 0 78px; min-width: 78px; padding: 10px 6px 8px; }
      .brand-logo-wrap { height: 32px; }
      .brand-chip-sub { font-size: 10px; }
    }

    /* ─── FEATURE GRID ──────────────────────────────────────────────── */
    .feature-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 12px;
      margin-bottom: 8px;
    }
    .feature-card {
      display: flex;
      align-items: center;
      gap: 12px;
      background: var(--canvas);
      border: 1px solid var(--border);
      border-radius: var(--radius-md);
      padding: 14px 16px;
      text-decoration: none;
      color: inherit;
      transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
      position: relative;
      overflow: hidden;
    }
    .feature-card::before {
      content: '';
      position: absolute;
      inset: 0;
      background: var(--fc-bg, var(--blue-bg));
      opacity: 0;
      transition: opacity 0.15s;
      pointer-events: none;
    }
    .feature-card:hover { border-color: var(--fc-color, var(--blue)); box-shadow: var(--shadow-md); transform: translateY(-2px); }
    .feature-card:hover::before { opacity: 1; }
    .feature-icon-wrap {
      width: 42px;
      height: 42px;
      border-radius: var(--radius-sm);
      background: var(--fc-bg, var(--blue-bg));
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      font-size: 17px;
      font-weight: 900;
      color: var(--fc-color, var(--blue));
      position: relative;
      z-index: 1;
      transition: transform 0.15s;
      letter-spacing: -0.5px;
    }
    .feature-card:hover .feature-icon-wrap { transform: scale(1.1); }
    .feature-card-text { position: relative; z-index: 1; min-width: 0; }
    .feature-card-label { font-size: 13.5px; font-weight: 700; color: var(--ink); line-height: 1.3; margin-bottom: 2px; }
    .feature-card-count { font-size: 11.5px; color: var(--ink-faint); font-weight: 500; }
    .feature-card-count strong { color: var(--fc-color, var(--blue)); font-weight: 700; }

    @media (max-width: 1100px) { .feature-grid { grid-template-columns: repeat(3, 1fr); } }
    @media (max-width: 700px)  {
      .feature-grid { grid-template-columns: repeat(2, 1fr); gap: 8px; }
      .feature-card { padding: 11px 12px; }
      .feature-icon-wrap { width: 36px; height: 36px; font-size: 14px; }
      .feature-card-label { font-size: 12.5px; }
    }

    /* PRODUCT CARD */
    .product-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 14px; margin-bottom: 8px; }
    .card { display: flex; flex-direction: column; background: var(--canvas); border-radius: var(--radius-lg); border: 1px solid var(--border); overflow: hidden; position: relative; transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s cubic-bezier(0.34,1.56,0.64,1); text-decoration: none; color: inherit; }
    .card:hover { border-color: var(--blue-line); box-shadow: var(--shadow-lg); transform: translateY(-4px); }
    .card-badge { position: absolute; top: 10px; left: 10px; z-index: 3; padding: 3px 8px; border-radius: 5px; font-size: 10px; font-weight: 700; letter-spacing: 0.05em; text-transform: uppercase; color: #fff; line-height: 1; }
    .badge-new  { background: var(--green); }
    .badge-hot  { background: var(--red); }
    .badge-sale { background: var(--blue); }
    .card-discount { position: absolute; top: 10px; right: 10px; z-index: 3; background: var(--red); color: #fff; font-size: 10.5px; font-weight: 700; padding: 3px 8px; border-radius: 5px; line-height: 1.4; }
    .card-img-wrap { width: 100%; aspect-ratio: 4/3; background: var(--surface); display: flex; align-items: center; justify-content: center; overflow: hidden; flex-shrink: 0; }
