---
import { products } from '../data/product2.js';
import { ALL_BRANDS, DEPOSIT_FILTERS, brandSlugall, parseDeposit } from '../data/filter-config.js';
import { FEATURE_FILTERS } from '../data/feature-config.js';
import Gift from '../components/Gift.astro';
import Nav from '../components/Nav.astro';

const featured    = products.slice(0, 10);
const flashDeals  = products.filter(p => ["samsung-galaxy-s24-256gb","tecno-camon-50-pro-max","samsung-galaxy-s20-ultra"].includes(p.slug));
const budgetPicks = products.filter(p => parseDeposit(p.deposit) < 5000).slice(0, 6);
const samsungList = products.filter(p => p.brand?.toLowerCase() === 'samsung').slice(0, 5);
const tecnoList   = products.filter(p => p.brand?.toLowerCase() === 'tecno').slice(0, 5);
const infinixList = products.filter(p => p.brand?.toLowerCase() === 'infinix').slice(0, 5);

const featureLinks = FEATURE_FILTERS.map(f => ({
  ...f, count: products.filter(f.match).length,
  href: `/features/${f.key}-phones-kenya`,
})).filter(f => f.count > 0);

const featureIcons = { '5g':'5G','gaming':'🎮','amoled':'AMOLED','120hz':'120Hz','108mp-camera':'108MP','large-battery':'🔋','curved-display':'⬭','fingerprint':'🔒' };

function stars(r){ const f=Math.floor(r??4.5); return '★'.repeat(f)+'☆'.repeat(5-f); }

const compRows=[
  ["Min. deposit","KSh 2,000","KSh 5,000+","KSh 3,000–10,000"],
  ["CRB / credit check","None","Required","Often required"],
  ["Inspect before paying","✅ Always","❌","❌"],
  ["Same-day delivery","✅ Free","❌ Courier only","❌"],
  ["M-Pesa instalments","Daily / weekly / monthly","Monthly only","Weekly / monthly"],
  ["Brand-new phones","✅ Factory sealed","✅","⚠️ Varies"],
  ["Flexible repayment","✅ Call or WhatsApp us","❌","⚠️ Varies"],
];
---

<Fragment>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}

    :root{
      --navy:    #0D1B2A;
      --navy2:   #1B2D3F;
      --orange:  #FF6B00;
      --orange-d:#e05d00;
      --orange-l:#FF8C33;
      --yellow:  #FFD814;
      --green:   #008A00;
      --green-l: #00A300;
      --red:     #C7372F;
      --link:    #0077CC;
      --star:    #F0A500;
      --white:   #ffffff;
      --bg:      #F5F6F7;
      --border:  #E3E6E8;
      --text:    #0D1B2A;
      --muted:   #6B7785;
      --card-bg: #ffffff;
      --font:    'Plus Jakarta Sans', system-ui, sans-serif;
      --max-w:   1340px;
      --px:      16px;
      --r-sm:    6px;
      --r-md:    10px;
      --r-lg:    14px;
      --shadow-card: 0 1px 3px rgba(0,0,0,.08), 0 1px 2px rgba(0,0,0,.04);
      --shadow-hover: 0 4px 16px rgba(0,0,0,.12);
    }

    html{scroll-behavior:smooth}
    body{font-family:var(--font);background:var(--bg);color:var(--text);font-size:14px;line-height:1.5;-webkit-font-smoothing:antialiased}
    a{text-decoration:none;color:inherit}
    img{display:block;max-width:100%}
    button{font-family:var(--font);cursor:pointer}

    .wrap{max-width:var(--max-w);margin:0 auto;padding:0 var(--px)}

    /* ── TOPBAR ─────────────────────────────── */
    .topbar{background:var(--navy);height:36px;display:flex;align-items:center;overflow:hidden;position:relative}
    .topbar-ticker{display:flex;white-space:nowrap;animation:ticker 40s linear infinite}
    @keyframes ticker{0%{transform:translateX(0)}100%{transform:translateX(-50%)}}
    .topbar-item{display:inline-flex;align-items:center;gap:8px;padding:0 32px;font-size:12px;font-weight:500;color:rgba(255,255,255,.8)}
    .topbar-sep{color:rgba(255,255,255,.25)}
    .topbar-end{position:absolute;right:0;top:0;bottom:0;display:flex}
    .topbar-btn{display:flex;align-items:center;gap:6px;padding:0 14px;font-size:12px;font-weight:700;white-space:nowrap;color:#fff;font-family:var(--font);border:none;cursor:pointer;transition:background .15s}
    .topbar-call{background:rgba(255,255,255,.08);border-left:1px solid rgba(255,255,255,.1)}
    .topbar-call:hover{background:rgba(255,255,255,.16)}
    .topbar-wa{background:#25D366}
    .topbar-wa:hover{background:#1ebe5b}

    /* ── HEADER ─────────────────────────────── */
    .site-header{background:var(--navy);position:sticky;top:0;z-index:200;border-bottom:1px solid rgba(255,255,255,.06)}
    .header-inner{max-width:var(--max-w);margin:0 auto;padding:0 var(--px);display:grid;grid-template-columns:auto 1fr auto;align-items:center;height:60px;gap:16px}
    .logo{font-size:20px;font-weight:800;color:#fff;letter-spacing:-.3px;display:flex;align-items:center;gap:2px;flex-shrink:0}
    .logo span{color:var(--orange)}
    .logo-tag{margin-left:8px;font-size:9px;font-weight:700;background:var(--orange);color:#fff;padding:2px 6px;border-radius:4px;letter-spacing:.06em;text-transform:uppercase}
    .search-bar{display:flex;background:#fff;border-radius:var(--r-sm);overflow:hidden;border:2px solid var(--orange)}
    .search-bar input{flex:1;border:none;padding:9px 14px;font-size:13px;font-family:var(--font);outline:none;color:var(--text)}
    .search-bar input::placeholder{color:#aaa}
    .search-btn{background:var(--orange);border:none;padding:0 18px;font-size:13px;font-weight:700;color:#fff;font-family:var(--font);cursor:pointer;display:flex;align-items:center;gap:5px;transition:background .15s}
    .search-btn:hover{background:var(--orange-d)}
    .header-actions{display:flex;align-items:center;gap:2px;flex-shrink:0}
    .hdr-btn{display:flex;flex-direction:column;align-items:center;padding:5px 10px;border-radius:var(--r-sm);color:#fff;font-size:10px;font-weight:500;border:1px solid transparent;background:transparent;cursor:pointer;gap:1px;line-height:1.25;transition:border-color .15s}
    .hdr-btn:hover{border-color:rgba(255,255,255,.4)}
    .hdr-btn strong{font-size:12px;font-weight:700}

    /* ── CAT NAV ─────────────────────────────── */
    .cat-nav{background:var(--navy2);border-bottom:1px solid rgba(255,255,255,.06)}
    .cat-nav-inner{max-width:var(--max-w);margin:0 auto;padding:0 var(--px);display:flex;overflow-x:auto;scrollbar-width:none;gap:2px}
    .cat-nav-inner::-webkit-scrollbar{display:none}
    .cat-link{display:flex;align-items:center;gap:5px;padding:8px 12px;font-size:12.5px;font-weight:600;color:rgba(255,255,255,.78);white-space:nowrap;border:1px solid transparent;border-radius:var(--r-sm);margin:4px 0;transition:all .12s}
    .cat-link:hover,.cat-link.active{color:#fff;border-color:rgba(255,255,255,.45)}

    /* ── TRUST BAR ─────────────────────────────── */
    .trust-bar{background:#fff;border-bottom:1px solid var(--border)}
    .trust-bar-inner{max-width:var(--max-w);margin:0 auto;padding:0 var(--px);display:grid;grid-template-columns:repeat(5,1fr)}
    .trust-item{display:flex;align-items:center;gap:9px;padding:10px 12px;border-right:1px solid var(--border)}
    .trust-item:last-child{border-right:none}
    .trust-ico{width:28px;height:28px;border-radius:8px;background:rgba(255,107,0,.08);display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .trust-txt strong{display:block;font-size:12px;font-weight:700;color:var(--text)}
    .trust-txt span{font-size:11px;color:var(--muted)}

    /* ── HERO ─────────────────────────────── */
    .hero{background:#fff;padding:10px var(--px) 0}
    .hero-inner{max-width:var(--max-w);margin:0 auto;display:grid;grid-template-columns:220px 1fr 270px;gap:10px;padding:10px 0}

    /* sidebar */
    .sidebar{background:var(--card-bg);border:1px solid var(--border);border-radius:var(--r-md);overflow:hidden}
    .sidebar-hd{background:var(--navy);color:#fff;font-size:13px;font-weight:700;padding:10px 14px}
    .sidebar-link{display:flex;align-items:center;justify-content:space-between;padding:9px 14px;font-size:13px;color:var(--text);border-bottom:1px solid var(--border);transition:all .12s;cursor:pointer}
    .sidebar-link:last-child{border-bottom:none}
    .sidebar-link:hover{background:var(--bg);color:var(--link)}
    .sidebar-arrow{color:var(--border);font-size:15px}

    /* main banner */
    .hero-banner{border-radius:var(--r-lg);background:linear-gradient(125deg,#0D1B2A 0%,#1B3A5C 45%,#0D2840 100%);min-height:340px;display:flex;align-items:center;padding:44px 48px;position:relative;overflow:hidden}
    .hero-banner::after{content:'';position:absolute;inset:0;background-image:radial-gradient(rgba(255,255,255,.04) 1px,transparent 1px);background-size:22px 22px;pointer-events:none}
    .hero-glow{position:absolute;width:500px;height:500px;border-radius:50%;background:radial-gradient(circle,rgba(255,107,0,.18) 0%,transparent 70%);top:-100px;right:-100px;pointer-events:none}
    .hero-content{position:relative;z-index:1;max-width:480px}
    .hero-eyebrow{display:inline-flex;align-items:center;gap:6px;background:rgba(255,107,0,.15);border:1px solid rgba(255,107,0,.3);color:var(--orange-l);font-size:11px;font-weight:700;padding:4px 10px;border-radius:20px;margin-bottom:16px;text-transform:uppercase;letter-spacing:.05em}
    .hero-h1{font-size:40px;font-weight:800;color:#fff;line-height:1.05;letter-spacing:-.5px;margin-bottom:14px}
    .hero-h1 em{font-style:normal;color:var(--orange)}
    .hero-sub{font-size:14px;color:rgba(255,255,255,.65);line-height:1.7;margin-bottom:22px;max-width:400px}
    .hero-sub strong{color:rgba(255,255,255,.9)}
    .hero-ctas{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:24px}
    .hero-btn-main{background:var(--orange);color:#fff;border:none;border-radius:var(--r-sm);padding:12px 24px;font-size:14px;font-weight:700;font-family:var(--font);display:inline-flex;align-items:center;gap:7px;cursor:pointer;transition:background .15s}
    .hero-btn-main:hover{background:var(--orange-d)}
    .hero-btn-ghost{background:transparent;color:rgba(255,255,255,.85);border:1.5px solid rgba(255,255,255,.3);border-radius:var(--r-sm);padding:11px 20px;font-size:13px;font-weight:600;font-family:var(--font);display:inline-flex;align-items:center;gap:6px;cursor:pointer;transition:all .15s}
    .hero-btn-ghost:hover{border-color:rgba(255,255,255,.65);color:#fff}
    .hero-pills{display:flex;gap:7px;flex-wrap:wrap}
    .hero-pill{background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.12);color:rgba(255,255,255,.72);font-size:12px;font-weight:500;padding:4px 11px;border-radius:20px}

    /* right aside */
    .hero-aside{display:flex;flex-direction:column;gap:10px}
    .aside-card{background:#fff;border:1px solid var(--border);border-radius:var(--r-md);overflow:hidden}
    .aside-hd{background:var(--navy);color:#fff;padding:9px 12px;font-size:12px;font-weight:700;display:flex;align-items:center;justify-content:space-between}
    .aside-hd a{color:var(--orange-l);font-size:11px;font-weight:600}
    .aside-dep-link{display:flex;align-items:center;justify-content:space-between;padding:9px 12px;font-size:13px;color:var(--link);border-bottom:1px solid var(--border);transition:background .12s}
    .aside-dep-link:last-child{border-bottom:none}
    .aside-dep-link:hover{background:var(--bg)}
    .aside-dep-badge{font-size:10px;font-weight:700;color:var(--orange);background:rgba(255,107,0,.1);padding:2px 7px;border-radius:20px}
    .aside-wa{background:linear-gradient(135deg,#064e3b,#065f46);border-radius:var(--r-md);padding:14px;display:flex;align-items:center;gap:10px;cursor:pointer;transition:opacity .15s}
    .aside-wa:hover{opacity:.9}
    .aside-wa-icon{width:34px;height:34px;background:rgba(255,255,255,.1);border-radius:8px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .aside-wa strong{display:block;font-size:13px;font-weight:700;color:#fff;margin-bottom:1px}
    .aside-wa span{font-size:11px;color:rgba(255,255,255,.55)}
    .aside-stats{padding:10px;display:grid;grid-template-columns:1fr 1fr;gap:6px}
    .aside-stat{text-align:center;padding:8px;background:var(--bg);border-radius:8px;border:1px solid var(--border)}
    .aside-stat-n{font-size:18px;font-weight:800;color:var(--orange);line-height:1}
    .aside-stat-l{font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;margin-top:2px}

    /* mobile quick nav */
    .mobile-qnav{display:none;padding:10px 0}
    .mqn-label{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.08em;margin-bottom:8px}
    .mqn-scroll{display:flex;gap:7px;overflow-x:auto;padding-bottom:4px;scrollbar-width:none}
    .mqn-scroll::-webkit-scrollbar{display:none}
    .mqn-pill{flex-shrink:0;display:inline-flex;align-items:center;padding:6px 13px;background:#fff;border:1px solid var(--border);border-radius:20px;font-size:12px;font-weight:600;color:var(--link);white-space:nowrap}
    .mqn-chip{flex-shrink:0;background:var(--navy);color:#fff;padding:6px 13px;border-radius:20px;font-size:12px;font-weight:600;white-space:nowrap}
    .mqn-chip.active{background:var(--orange);color:#fff}

    /* ── SECTIONS ─────────────────────────────── */
    .section{padding:20px 0;background:#fff}
    .section-alt{background:var(--bg)}
    .section-sep{border-top:1px solid var(--border);border-bottom:1px solid var(--border)}

    .sec-head{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:14px}
    .sec-title{font-size:18px;font-weight:800;color:var(--text);letter-spacing:-.2px;display:flex;align-items:center;gap:8px}
    .sec-title::before{content:'';display:inline-block;width:3px;height:18px;background:var(--orange);border-radius:2px}
    .sec-sub{font-size:12.5px;color:var(--muted);margin-top:2px;font-weight:400}
    .see-all{font-size:13px;font-weight:600;color:var(--link);display:flex;align-items:center;gap:3px;white-space:nowrap}
    .see-all:hover{text-decoration:underline}

    /* ── PRODUCT CARD ─────────────────────────────── */
    .prod-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:10px}
    .pcard{background:#fff;border:1px solid var(--border);border-radius:var(--r-md);overflow:hidden;display:flex;flex-direction:column;position:relative;text-decoration:none;color:inherit;box-shadow:var(--shadow-card);transition:box-shadow .2s,border-color .2s;cursor:pointer}
    .pcard:hover{box-shadow:var(--shadow-hover);border-color:#ccc}
    .pcard-badge{position:absolute;top:8px;left:8px;z-index:3;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px;text-transform:uppercase;letter-spacing:.04em}
    .b-new{background:var(--green);color:#fff}
    .b-hot{background:var(--red);color:#fff}
    .b-sale{background:var(--orange);color:#fff}
    .pcard-disc{position:absolute;top:8px;right:8px;z-index:3;background:var(--red);color:#fff;font-size:10px;font-weight:700;padding:2px 7px;border-radius:4px}
    .pcard-img{background:#f8f9fa;display:flex;align-items:center;justify-content:center;aspect-ratio:1/1;overflow:hidden;padding:8px}
    .pcard-img img{width:100%;height:100%;object-fit:contain;transition:transform .3s}
    .pcard:hover .pcard-img img{transform:scale(1.05)}
    .pcard-body{padding:10px 11px 12px;flex:1;display:flex;flex-direction:column;border-top:1px solid var(--border)}
    .pcard-brand{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:3px}
    .pcard-name{font-size:13px;font-weight:500;color:var(--link);line-height:1.4;margin-bottom:6px;flex:1;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .pcard:hover .pcard-name{color:#0055a5;text-decoration:underline}
    .pcard-specs{display:flex;gap:3px;flex-wrap:wrap;margin-bottom:7px}
    .pcard-spec{background:var(--bg);color:var(--muted);border-radius:20px;padding:1px 7px;font-size:10px;font-weight:500}
    .pcard-rating{display:flex;align-items:center;gap:4px;margin-bottom:7px}
    .pcard-stars{color:var(--star);font-size:12px}
    .pcard-rc{font-size:11px;color:var(--muted)}
    .pcard-dep-label{font-size:10px;font-weight:600;color:var(--muted);text-transform:uppercase;letter-spacing:.04em;margin-bottom:1px}
    .pcard-price{font-size:20px;font-weight:800;color:var(--red);line-height:1;letter-spacing:-.3px}
    .pcard-install{font-size:11px;color:var(--green-l);font-weight:600;margin-top:2px;margin-bottom:10px}
    .pcard-actions{display:grid;grid-template-columns:1fr 1fr;gap:6px;margin-top:auto}
    .btn-buy{background:var(--orange);color:#fff;border:none;border-radius:var(--r-sm);padding:8px 4px;font-size:11px;font-weight:700;font-family:var(--font);cursor:pointer;transition:background .12s}
    .btn-buy:hover{background:var(--orange-d)}
    .btn-view{background:#fff;color:var(--link);border:1px solid var(--border);border-radius:var(--r-sm);padding:8px 4px;font-size:11px;font-weight:600;font-family:var(--font);cursor:pointer;transition:all .12s}
    .btn-view:hover{background:var(--bg);border-color:#bbb}

    /* ── FLASH CARD (wider) ─────────────────────────────── */
    .flash-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
    .flash-card{background:#fff;border:1px solid var(--border);border-radius:var(--r-md);overflow:hidden;display:flex;gap:0;position:relative;text-decoration:none;color:inherit;box-shadow:var(--shadow-card);transition:all .2s}
    .flash-card:hover{box-shadow:var(--shadow-hover);border-color:#ccc}
    .flash-card-img{width:130px;flex-shrink:0;background:#f8f9fa;display:flex;align-items:center;justify-content:center;padding:10px;overflow:hidden}
    .flash-card-img img{width:100%;height:100%;object-fit:contain;transition:transform .3s}
    .flash-card:hover .flash-card-img img{transform:scale(1.05)}
    .flash-card-body{padding:12px 14px;flex:1;display:flex;flex-direction:column;justify-content:center}
    .flash-save{display:inline-flex;align-items:center;gap:5px;background:rgba(199,55,47,.08);color:var(--red);font-size:11px;font-weight:700;padding:2px 8px;border-radius:20px;margin-bottom:7px;width:fit-content}
    .flash-name{font-size:13px;font-weight:600;color:var(--link);line-height:1.4;margin-bottom:6px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .flash-price{font-size:22px;font-weight:800;color:var(--red);line-height:1;letter-spacing:-.3px}
    .flash-install{font-size:11px;color:var(--green-l);font-weight:600;margin-top:2px;margin-bottom:10px}
    .flash-cta{background:var(--orange);color:#fff;border:none;border-radius:var(--r-sm);padding:8px 14px;font-size:12px;font-weight:700;font-family:var(--font);cursor:pointer;transition:background .12s;align-self:flex-start}
    .flash-cta:hover{background:var(--orange-d)}

    /* ── BRANDS ─────────────────────────────── */
    .brands-grid{display:grid;grid-template-columns:repeat(8,1fr);gap:8px}
    .brand-tile{background:#fff;border:1px solid var(--border);border-radius:var(--r-md);aspect-ratio:1;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:7px;text-decoration:none;cursor:pointer;transition:all .15s;padding:10px}
    .brand-tile:hover{border-color:var(--orange);box-shadow:0 2px 10px rgba(255,107,0,.15)}
    .brand-tile-logo{height:26px;display:flex;align-items:center;justify-content:center;width:100%}
    .brand-tile-name{font-size:10px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.05em;text-align:center}

    /* ── FEATURES ─────────────────────────────── */
    .feat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:8px}
    .feat-tile{background:#fff;border:1px solid var(--border);border-radius:var(--r-md);padding:14px;display:flex;align-items:center;gap:12px;text-decoration:none;color:inherit;transition:all .15s}
    .feat-tile:hover{border-color:var(--orange);box-shadow:0 2px 8px rgba(255,107,0,.12)}
    .feat-icon{width:38px;height:38px;border-radius:8px;background:rgba(255,107,0,.08);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:800;color:var(--orange);flex-shrink:0}
    .feat-name{font-size:13px;font-weight:700;color:var(--text);margin-bottom:2px}
    .feat-count{font-size:11px;color:var(--muted)}
    .feat-count strong{color:var(--link);font-weight:700}

    /* ── BUDGET ─────────────────────────────── */
    .budget-wrap{background:var(--navy);border-radius:var(--r-lg);padding:24px}
    .budget-hd{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px}
    .budget-title{font-size:20px;font-weight:800;color:#fff;letter-spacing:-.2px}
    .budget-title em{font-style:normal;color:var(--orange)}
    .budget-see{font-size:13px;font-weight:600;color:var(--orange-l);display:flex;align-items:center;gap:3px}
    .budget-see:hover{text-decoration:underline}
    .budget-grid{display:grid;grid-template-columns:repeat(6,1fr);gap:8px}
    .budget-card{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.08);border-radius:var(--r-md);overflow:hidden;display:flex;flex-direction:column;text-decoration:none;color:inherit;transition:all .15s}
    .budget-card:hover{background:rgba(255,255,255,.08);border-color:rgba(255,107,0,.4)}
    .budget-card-img{background:rgba(255,255,255,.03);aspect-ratio:1;display:flex;align-items:center;justify-content:center;padding:8px;overflow:hidden}
    .budget-card-img img{width:100%;height:100%;object-fit:contain;transition:transform .3s}
    .budget-card:hover .budget-card-img img{transform:scale(1.06)}
    .budget-card-body{padding:8px 10px 12px;flex:1;display:flex;flex-direction:column}
    .budget-card-name{font-size:11px;color:rgba(255,255,255,.5);line-height:1.4;margin-bottom:6px;flex:1;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
    .budget-card-price{font-size:18px;font-weight:800;color:var(--orange);line-height:1;margin-bottom:2px;letter-spacing:-.2px}
    .budget-card-label{font-size:10px;color:rgba(255,255,255,.3);margin-bottom:8px}
    .budget-cta{display:block;text-align:center;background:var(--orange);color:#fff;padding:6px;font-size:11px;font-weight:700;border-radius:var(--r-sm);border:none;font-family:var(--font);cursor:pointer;transition:background .12s}
    .budget-cta:hover{background:var(--orange-d)}

    /* ── PROMO BANNERS ─────────────────────────────── */
    .promo-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .promo-banner{border-radius:var(--r-lg);overflow:hidden;position:relative;display:flex;align-items:flex-end;padding:28px;min-height:150px;text-decoration:none;color:inherit;transition:opacity .15s}
    .promo-banner:hover{opacity:.92}
    .promo-a{background:linear-gradient(130deg,#0D1B2A 0%,#1B3A5C 100%)}
    .promo-b{background:linear-gradient(130deg,#064e3b 0%,#059669 100%)}
    .promo-big{position:absolute;top:10px;right:18px;font-size:64px;font-weight:800;color:rgba(255,255,255,.05);line-height:1;pointer-events:none;letter-spacing:-2px}
    .promo-content{position:relative;z-index:1}
    .promo-over{font-size:10px;font-weight:700;text-transform:uppercase;letter-spacing:.1em;color:rgba(255,255,255,.45);margin-bottom:5px}
    .promo-heading{font-size:18px;font-weight:800;color:#fff;line-height:1.2;margin-bottom:12px;letter-spacing:-.2px}
    .promo-btn{display:inline-flex;align-items:center;gap:5px;background:var(--orange);color:#fff;padding:7px 14px;border-radius:var(--r-sm);font-size:12px;font-weight:700;font-family:var(--font)}

    /* ── BRAND SECTIONS ─────────────────────────────── */
    .brand-sec-hd{display:flex;align-items:center;gap:10px;margin-bottom:14px}
    .brand-sec-logo{height:22px}

    /* ── STATS ─────────────────────────────── */
    .stats-band{background:var(--navy);padding:20px 0}
    .stats-inner{max-width:var(--max-w);margin:0 auto;padding:0 var(--px);display:grid;grid-template-columns:repeat(4,1fr)}
    .stat-item{text-align:center;padding:12px 16px;border-right:1px solid rgba(255,255,255,.08)}
    .stat-item:last-child{border-right:none}
    .stat-n{font-size:32px;font-weight:800;color:var(--orange);line-height:1;margin-bottom:4px;letter-spacing:-.5px}
    .stat-l{font-size:12px;color:rgba(255,255,255,.5)}

    /* ── REVIEWS ─────────────────────────────── */
    .reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:10px}
    .review-card{background:#fff;border:1px solid var(--border);border-radius:var(--r-md);padding:16px}
    .review-stars{color:var(--star);font-size:14px;margin-bottom:8px}
    .review-text{font-size:13px;color:#444;line-height:1.65;margin-bottom:10px;font-style:italic}
    .review-author{font-size:11px;font-weight:700;color:var(--muted);text-transform:uppercase;letter-spacing:.06em}

    /* ── HOW IT WORKS ─────────────────────────────── */
    .steps-row{display:grid;grid-template-columns:repeat(4,1fr);gap:0;position:relative}
    .steps-row::before{content:'';position:absolute;top:22px;left:12.5%;right:12.5%;height:2px;background:linear-gradient(90deg,var(--orange) 0%,rgba(255,107,0,.2) 100%);z-index:0}
    .step{display:flex;flex-direction:column;align-items:center;text-align:center;padding:0 16px;position:relative;z-index:1}
    .step-num{width:44px;height:44px;border-radius:50%;background:var(--orange);color:#fff;display:flex;align-items:center;justify-content:center;font-size:18px;margin-bottom:14px;box-shadow:0 2px 10px rgba(255,107,0,.35)}
    .step-title{font-size:13px;font-weight:700;color:var(--text);margin-bottom:6px}
    .step-desc{font-size:12px;color:var(--muted);line-height:1.6}

    /* ── WHY US ─────────────────────────────── */
    .why-split{display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:center}
    .why-h2{font-size:28px;font-weight:800;color:var(--text);letter-spacing:-.4px;margin-bottom:12px;line-height:1.2}
    .why-h2 em{font-style:normal;color:var(--orange)}
    .why-sub{font-size:14px;color:var(--muted);line-height:1.75;margin-bottom:22px}
    .why-ctas{display:flex;gap:10px}
    .why-feats{display:flex;flex-direction:column;gap:8px}
    .why-feat{display:flex;align-items:flex-start;gap:12px;background:#fff;border:1px solid var(--border);border-radius:var(--r-md);padding:13px 15px;transition:all .15s}
    .why-feat:hover{border-color:var(--orange);box-shadow:0 2px 8px rgba(255,107,0,.1)}
    .why-feat-ico{width:34px;height:34px;border-radius:8px;background:rgba(255,107,0,.08);display:flex;align-items:center;justify-content:center;flex-shrink:0}
    .why-feat-title{font-size:13px;font-weight:700;color:var(--text);margin-bottom:2px}
    .why-feat-desc{font-size:12px;color:var(--muted);line-height:1.5}

    /* ── COMPARE ─────────────────────────────── */
    .comp-table{width:100%;border-collapse:collapse;font-size:13px}
    .comp-table thead tr{background:var(--navy);color:#fff}
    .comp-table th{padding:11px 14px;text-align:left;font-weight:700;font-size:12.5px}
    .comp-table th:not(:first-child){text-align:center}
    .comp-table td{padding:10px 14px;border-bottom:1px solid var(--border)}
    .comp-table td:not(:first-child){text-align:center}
    .comp-table td:first-child{font-weight:600;color:var(--muted);font-size:12.5px}
    .comp-table tr:nth-child(even) td{background:var(--bg)}
    .comp-us{color:var(--green);font-weight:700}
    .comp-other{color:#999}

    /* ── FAQ ─────────────────────────────── */
    .faq-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
    .faq-card{background:#fff;border:1px solid var(--border);border-radius:var(--r-md);overflow:hidden}
    .faq-trigger{width:100%;background:transparent;border:none;padding:13px 15px;display:flex;align-items:center;justify-content:space-between;gap:10px;cursor:pointer;font-size:13px;font-weight:600;color:var(--text);font-family:var(--font);text-align:left;transition:color .12s}
    .faq-trigger:hover{color:var(--link)}
    .faq-trigger.open{color:var(--link);border-bottom:1px solid var(--border)}
    .faq-icon{width:20px;height:20px;border-radius:50%;background:var(--bg);display:flex;align-items:center;justify-content:center;font-size:13px;color:var(--muted);flex-shrink:0;transition:all .18s}
    .faq-trigger.open .faq-icon{transform:rotate(45deg);background:rgba(255,107,0,.1);color:var(--orange)}
    .faq-body{display:none;padding:12px 15px;font-size:13px;color:var(--muted);line-height:1.75;background:var(--bg)}
    .faq-body.open{display:block}
    .faq-body a{color:var(--link);font-weight:600}

    /* ── FOOTER CTA ─────────────────────────────── */
    .footer-cta{background:var(--orange);padding:20px var(--px)}
    .footer-cta-inner{max-width:var(--max-w);margin:0 auto;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap}
    .footer-cta-text h2{font-size:20px;font-weight:800;color:#fff;margin-bottom:2px;letter-spacing:-.2px}
    .footer-cta-text p{font-size:12px;color:rgba(255,255,255,.75)}
    .footer-cta-btns{display:flex;gap:8px;flex-shrink:0}
    .fc-btn{display:flex;align-items:center;gap:6px;padding:9px 18px;border-radius:var(--r-sm);font-size:13px;font-weight:700;white-space:nowrap;font-family:var(--font);border:none;cursor:pointer;transition:background .12s}
    .fc-call{background:var(--navy);color:#fff}
    .fc-call:hover{background:var(--navy2)}
    .fc-wa{background:#25D366;color:#fff}
    .fc-wa:hover{background:#1ebe5b}

    /* ── SITE FOOTER ─────────────────────────────── */
    .site-footer{background:var(--navy);padding:40px var(--px) 20px}
    .footer-grid{max-width:var(--max-w);margin:0 auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:36px;margin-bottom:28px}
    .footer-logo{font-size:18px;font-weight:800;color:#fff;display:block;margin-bottom:10px}
    .footer-logo span{color:var(--orange)}
    .footer-tagline{font-size:12px;color:rgba(255,255,255,.3);line-height:1.7;max-width:260px}
    .footer-col-hd{font-size:10px;font-weight:700;color:rgba(255,255,255,.4);text-transform:uppercase;letter-spacing:.12em;margin-bottom:12px;padding-bottom:6px;border-bottom:1px solid rgba(255,255,255,.06)}
    .footer-links{list-style:none}
    .footer-links li{margin-bottom:7px}
    .footer-links a{font-size:12px;color:rgba(255,255,255,.3);transition:color .12s}
    .footer-links a:hover{color:var(--orange)}
    .footer-bottom{max-width:var(--max-w);margin:0 auto;padding-top:16px;border-top:1px solid rgba(255,255,255,.06);display:flex;justify-content:space-between;flex-wrap:wrap;gap:6px}
    .footer-bottom p{font-size:11px;color:rgba(255,255,255,.18)}

    /* ── KEYWORD STRIP ─────────────────────────────── */
    .kw-strip{background:#07111d;padding:12px var(--px);border-top:1px solid rgba(255,255,255,.05)}
    .kw-inner{max-width:var(--max-w);margin:0 auto;display:flex;flex-wrap:wrap;gap:5px}
    .kw{font-size:11.5px;color:rgba(255,255,255,.35);border:1px solid rgba(255,255,255,.08);border-radius:4px;padding:3px 9px;transition:color .12s}
    .kw:hover{color:var(--orange);border-color:rgba(255,107,0,.3)}

    /* ── BUTTONS ─────────────────────────────── */
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:7px;border-radius:var(--r-sm);font-family:var(--font);font-weight:700;cursor:pointer;transition:all .15s;white-space:nowrap;line-height:1;border:none;font-size:14px;padding:11px 22px}
    .btn-primary{background:var(--orange);color:#fff}
    .btn-primary:hover{background:var(--orange-d)}
    .btn-outline{background:#fff;color:var(--link);border:1.5px solid var(--border)}
    .btn-outline:hover{background:var(--bg);border-color:#bbb}

    /* ── SEO COPY BLOCK ─────────────────────────────── */
    .seo-block{padding:28px 0;background:#fff;border-top:1px solid var(--border)}
    .seo-inner{max-width:760px}
    .seo-inner h2{font-size:16px;font-weight:800;color:var(--text);margin-bottom:10px}
    .seo-inner h3{font-size:13.5px;font-weight:700;color:var(--text);margin:16px 0 6px}
    .seo-inner p{font-size:13px;color:var(--muted);line-height:1.8;margin-bottom:8px}
    .seo-inner a{color:var(--link);font-weight:500}
    .seo-inner strong{color:var(--text)}

    /* ── RESPONSIVE ─────────────────────────────── */
    @media(max-width:1100px){
      .prod-grid{grid-template-columns:repeat(4,1fr)}
      .hero-inner{grid-template-columns:1fr 1fr}
      .sidebar{display:none}
      .brands-grid{grid-template-columns:repeat(4,1fr)}
      .budget-grid{grid-template-columns:repeat(4,1fr)}
      .flash-grid{grid-template-columns:repeat(3,1fr)}
      .stats-inner{grid-template-columns:repeat(2,1fr)}
      .reviews-grid{grid-template-columns:1fr 1fr}
    }
    @media(max-width:900px){
      .prod-grid{grid-template-columns:repeat(3,1fr)}
      .feat-grid{grid-template-columns:repeat(2,1fr)}
      .steps-row{grid-template-columns:repeat(2,1fr)}.steps-row::before{display:none}
      .why-split{grid-template-columns:1fr}
      .faq-grid{grid-template-columns:1fr}
      .footer-grid{grid-template-columns:1fr 1fr}
      .hero-inner{grid-template-columns:1fr}
      .hero-aside{display:none}
      .promo-grid{grid-template-columns:1fr}
      .flash-grid{grid-template-columns:1fr 1fr}
      .reviews-grid{grid-template-columns:1fr}
      .mobile-qnav{display:block}
      .brands-grid{grid-template-columns:repeat(4,1fr)}
      .trust-bar-inner{grid-template-columns:repeat(3,1fr)}
    }
    @media(max-width:700px){
      .prod-grid{grid-template-columns:repeat(2,1fr)}
      .budget-grid{grid-template-columns:repeat(2,1fr)}
      .hero-h1{font-size:28px}
      .trust-bar-inner{grid-template-columns:repeat(2,1fr)}
      .flash-grid{grid-template-columns:1fr 1fr}
    }
    @media(max-width:480px){
      .brands-grid{grid-template-columns:repeat(2,1fr);gap:6px}
      .brand-tile{aspect-ratio:auto;flex-direction:row;justify-content:flex-start;gap:10px;padding:10px 14px}
      .brand-tile-logo{height:20px;width:auto;flex-shrink:0}
      .brand-tile-name{font-size:12px;text-align:left;text-transform:capitalize;font-weight:700;color:var(--text)}
      .prod-grid{grid-template-columns:repeat(2,1fr)}
      .flash-grid{grid-template-columns:1fr}
      .trust-bar-inner{grid-template-columns:1fr 1fr}
      .stats-inner{grid-template-columns:repeat(2,1fr)}
      .steps-row{grid-template-columns:1fr}
      .footer-grid{grid-template-columns:1fr}
      .budget-grid{grid-template-columns:repeat(2,1fr)}
      .feat-grid{grid-template-columns:1fr 1fr}
      .promo-grid{grid-template-columns:1fr}
    }
    @media(prefers-reduced-motion:reduce){
      .topbar-ticker{animation:none}
    }
