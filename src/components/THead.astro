<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Lipa Mdogo Mdogo — Kenya's #1 Phone Installment Store</title>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,700;0,9..144,900;1,9..144,800&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <style>

    /* ─── TOKENS ──────────────────────────────────────────────────── */
    :root {
      --lmm-or:       #F47B20;
      --lmm-or-dk:    #C95F00;
      --lmm-or-xdk:   #9E4700;
      --lmm-or-lt:    #FFF4E6;
      --lmm-or-md:    #FFE0B2;
      --lmm-wa:       #22C55E;
      --lmm-wa-dk:    #16A34A;
      --lmm-ink:      #0F0A05;
      --lmm-ink2:     #3B2F22;
      --lmm-slate:    #7A6A58;
      --lmm-rule:     rgba(15,10,5,.08);
      --lmm-surface:  #FFFCF8;
      --lmm-white:    #ffffff;
      --lmm-r-xl:     24px;
      --lmm-r-md:     14px;
      --lmm-r-sm:     10px;
      --lmm-sh1:      0 1px 3px rgba(0,0,0,.06), 0 4px 12px rgba(0,0,0,.06);
      --lmm-sh2:      0 2px 4px rgba(0,0,0,.04), 0 16px 48px rgba(0,0,0,.11);
      --lmm-sh3:      0 4px 8px rgba(0,0,0,.05), 0 28px 72px rgba(0,0,0,.16);
      --lmm-ease:     cubic-bezier(.22,.68,0,1.2);
      --lmm-ffd:      'Fraunces', Georgia, serif;
      --lmm-ffb:      'Manrope', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--lmm-ffb);
      background: #EDE6DA;
      padding: 24px 16px 48px;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── HERO WRAPPER ────────────────────────────────────────────── */
    .lmm-hero-wrap {
      width: 100%;
      max-width: 1200px;
      margin: 0 auto;
    }

    /* ─── CARD ────────────────────────────────────────────────────── */
    .lmm-hero-card {
      background: var(--lmm-white);
      border-radius: var(--lmm-r-xl);
      border: 1px solid var(--lmm-rule);
      box-shadow: var(--lmm-sh3);
      overflow: hidden;
      position: relative;
    }

    /* animated top stripe */
    .lmm-hero-card::before {
      content: '';
      position: absolute; top: 0; left: 0; right: 0; height: 3px;
      background: linear-gradient(90deg, var(--lmm-or-xdk), var(--lmm-or), #FFB347, var(--lmm-or), var(--lmm-or-xdk));
      background-size: 300% 100%;
      animation: lmm-stripe 4s linear infinite;
      z-index: 5;
    }

    @keyframes lmm-stripe {
      0%   { background-position: 0% 50%; }
      100% { background-position: 300% 50%; }
    }

    /* ─── TWO-COL GRID ────────────────────────────────────────────── */
    .lmm-hero-grid {
      display: grid;
      grid-template-columns: 1fr 400px;
    }

    /* ─────────────────────────────────────────────────────────────── */
    /* LEFT COLUMN                                                     */
    /* ─────────────────────────────────────────────────────────────── */
    .lmm-hero-left {
      padding: 56px 48px 52px 52px;
      display: flex;
      flex-direction: column;
      gap: 28px;
      border-right: 1px solid var(--lmm-rule);
      position: relative;
    }

    /* dot-grid texture */
    .lmm-hero-left::after {
      content: '';
      position: absolute; inset: 0;
      background-image: radial-gradient(circle, rgba(244,123,32,.065) 1px, transparent 1px);
      background-size: 28px 28px;
      pointer-events: none; z-index: 0;
    }
    .lmm-hero-left > * { position: relative; z-index: 1; }

    /* Trust pill */
    .lmm-trust-pill {
      display: inline-flex; align-items: center; gap: 8px;
      background: var(--lmm-or-lt);
      border: 1.5px solid var(--lmm-or-md);
      color: var(--lmm-or-xdk);
      border-radius: 999px;
      padding: 7px 16px;
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.03em;
      width: fit-content;
      animation: lmm-up .5s var(--lmm-ease) both;
    }

    .lmm-trust-dot {
      width: 7px; height: 7px; border-radius: 50%;
      background: var(--lmm-or); flex-shrink: 0;
      animation: lmm-blink 2s ease-in-out infinite;
    }

    @keyframes lmm-blink {
      0%,100% { transform: scale(1); opacity: 1; }
      50%      { transform: scale(1.5); opacity: .5; }
    }

    /* Headline */
    .lmm-hero-headline {
      font-family: var(--lmm-ffd);
      font-size: clamp(2rem, 3.4vw, 3.2rem);
      font-weight: 900;
      line-height: 1.09;
      letter-spacing: -0.034em;
      color: var(--lmm-ink);
      animation: lmm-up .55s .05s var(--lmm-ease) both;
    }

    .lmm-hero-headline-em {
      font-style: italic;
      background: linear-gradient(108deg, var(--lmm-or-xdk) 0%, var(--lmm-or) 55%, #FFB347 100%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }

    .lmm-hero-headline-tag {
      display: block;
      font-family: var(--lmm-ffb);
      font-size: 0.34em; font-weight: 700;
      letter-spacing: 0.13em; text-transform: uppercase;
      color: var(--lmm-slate); -webkit-text-fill-color: var(--lmm-slate);
      margin-top: 10px;
    }

    /* Description */
    .lmm-hero-desc {
      font-size: 0.96rem; line-height: 1.78;
      color: var(--lmm-ink2); max-width: 500px;
      animation: lmm-up .6s .1s var(--lmm-ease) both;
    }

    /* Brand chips — plain labels, no fake links */
    .lmm-brand-list {
      display: flex; flex-wrap: wrap; gap: 7px;
      animation: lmm-up .62s .12s var(--lmm-ease) both;
    }

    .lmm-brand-chip {
      font-size: 0.68rem; font-weight: 700;
      padding: 5px 11px; border-radius: 7px;
      background: var(--lmm-surface);
      border: 1px solid var(--lmm-rule);
      color: var(--lmm-ink2);
      box-shadow: var(--lmm-sh1);
      white-space: nowrap;
    }

    /* Feature cards */
    .lmm-feat-grid {
      list-style: none;
      display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
      animation: lmm-up .65s .15s var(--lmm-ease) both;
    }

    .lmm-feat-item {
      display: flex; align-items: flex-start; gap: 11px;
      padding: 14px 15px;
      background: var(--lmm-surface);
      border: 1px solid var(--lmm-rule);
      border-radius: var(--lmm-r-md);
      box-shadow: var(--lmm-sh1);
      transition: transform .2s var(--lmm-ease), box-shadow .2s, border-color .2s;
    }

    .lmm-feat-item:hover {
      transform: translateY(-3px);
      box-shadow: 0 8px 24px rgba(244,123,32,.11);
      border-color: var(--lmm-or-md);
    }

    .lmm-feat-icon {
      width: 34px; height: 34px; border-radius: 8px;
      background: var(--lmm-or-lt);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.05rem; flex-shrink: 0;
    }

    .lmm-feat-body strong {
      display: block; font-size: 0.81rem; font-weight: 800;
      color: var(--lmm-ink); margin-bottom: 3px; letter-spacing: -0.01em;
    }

    .lmm-feat-body span {
      font-size: 0.71rem; color: var(--lmm-slate); line-height: 1.45;
    }

    /* CTA buttons */
    .lmm-cta-group {
      display: flex; gap: 12px; flex-wrap: wrap;
      animation: lmm-up .7s .2s var(--lmm-ease) both;
    }

    .lmm-cta-btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 14px 24px; border-radius: var(--lmm-r-sm);
      font-family: var(--lmm-ffb); font-size: 0.89rem; font-weight: 800;
      text-decoration: none; letter-spacing: 0.01em; white-space: nowrap;
      transition: transform .15s var(--lmm-ease), box-shadow .2s, background .2s;
    }

    .lmm-cta-btn:active { transform: scale(.97); }

    .lmm-cta-primary {
      background: linear-gradient(135deg, var(--lmm-or-dk) 0%, var(--lmm-or) 100%);
      color: #fff;
      box-shadow: 0 4px 18px rgba(244,123,32,.42);
    }
    .lmm-cta-primary:hover {
      box-shadow: 0 8px 28px rgba(244,123,32,.52);
      transform: translateY(-2px);
    }

    .lmm-cta-whatsapp {
      background: var(--lmm-wa); color: #fff;
      box-shadow: 0 4px 14px rgba(34,197,94,.28);
    }
    .lmm-cta-whatsapp:hover {
      background: var(--lmm-wa-dk);
      box-shadow: 0 8px 24px rgba(34,197,94,.38);
      transform: translateY(-2px);
    }

    /* Stats row */
    .lmm-stats-row {
      display: flex; align-items: center;
      padding-top: 8px; border-top: 1px solid var(--lmm-rule);
      flex-wrap: wrap;
      animation: lmm-up .75s .25s var(--lmm-ease) both;
    }

    .lmm-stat-item {
      display: flex; flex-direction: column; gap: 2px;
      padding: 0 24px 0 0; margin-right: 24px;
      border-right: 1px solid var(--lmm-rule);
    }
    .lmm-stat-item:last-child { border-right: none; margin-right: 0; padding-right: 0; }

    .lmm-stat-item strong {
      font-family: var(--lmm-ffd);
      font-size: 1.2rem; font-weight: 900;
      color: var(--lmm-ink); line-height: 1;
    }
    .lmm-stat-item span {
      font-size: 0.66rem; font-weight: 600; color: var(--lmm-slate);
      letter-spacing: 0.04em; text-transform: uppercase;
    }

    /* ─────────────────────────────────────────────────────────────── */
    /* RIGHT COLUMN                                                    */
    /* ─────────────────────────────────────────────────────────────── */
    .lmm-hero-right {
      background: linear-gradient(165deg, #FFF8F0 0%, #FFEFD6 100%);
      padding: 40px 32px;
      display: flex; flex-direction: column; gap: 16px;
    }

    .lmm-right-eyebrow {
      font-size: 0.61rem; font-weight: 800;
      letter-spacing: 0.15em; text-transform: uppercase;
      color: var(--lmm-or-xdk);
    }

    /* How-it-works card */
    .lmm-how-card {
      background: var(--lmm-white);
      border: 1px solid rgba(244,123,32,.14);
      border-radius: 18px;
      overflow: hidden;
      box-shadow: var(--lmm-sh2);
      flex: 1;
    }

    .lmm-how-header {
      padding: 20px 24px 16px;
      background: linear-gradient(135deg, var(--lmm-or-xdk) 0%, var(--lmm-or-dk) 45%, var(--lmm-or) 100%);
      position: relative; overflow: hidden;
    }
    .lmm-how-header::after {
      content: '📲';
      position: absolute; right: 18px; top: 50%;
      transform: translateY(-50%);
      font-size: 2.8rem; opacity: .14; pointer-events: none;
    }

    .lmm-how-label {
      font-size: 0.6rem; font-weight: 700;
      letter-spacing: .14em; text-transform: uppercase;
      color: rgba(255,255,255,.7); margin-bottom: 4px;
    }
    .lmm-how-title {
      font-family: var(--lmm-ffd);
      font-size: 1.1rem; font-weight: 900;
      color: #fff; letter-spacing: -0.02em;
    }

    .lmm-steps-list {
      list-style: none;
      padding: 20px 24px;
      display: flex; flex-direction: column; gap: 16px;
    }

    .lmm-step-item { display: flex; align-items: flex-start; gap: 13px; }

    .lmm-step-num {
      width: 30px; height: 30px; border-radius: 50%;
      background: var(--lmm-or-lt); border: 2px solid var(--lmm-or-md);
      color: var(--lmm-or-xdk); font-size: 0.77rem; font-weight: 800;
      display: flex; align-items: center; justify-content: center;
      flex-shrink: 0;
    }

    .lmm-step-body { padding-top: 2px; }
    .lmm-step-body strong {
      display: block; font-size: 0.84rem; font-weight: 800;
      color: var(--lmm-ink); margin-bottom: 3px; letter-spacing: -0.01em;
    }
    .lmm-step-body p { font-size: 0.72rem; color: var(--lmm-slate); line-height: 1.55; }

    .lmm-step-item-highlight {
      background: linear-gradient(120deg, #FFF4E6 0%, #FFE9CC 100%);
      border: 1.5px solid var(--lmm-or-md);
      border-radius: 12px;
      padding: 13px 15px; margin: 0 -2px;
    }
    .lmm-step-num-highlight {
      background: var(--lmm-or); color: #fff; border-color: var(--lmm-or-dk);
    }

    .lmm-how-footer { padding: 0 24px 18px; }
    .lmm-how-link {
      font-size: 0.76rem; font-weight: 700; color: var(--lmm-or-xdk);
      text-decoration: none;
      display: inline-flex; align-items: center; gap: 5px;
      transition: gap .2s, color .2s;
    }
    .lmm-how-link:hover { gap: 9px; color: var(--lmm-or); }

    /* M-Pesa security tile */
    .lmm-mpesa-tile {
      display: flex; align-items: center; gap: 13px;
      background: var(--lmm-white);
      border: 1px solid rgba(244,123,32,.12);
      border-radius: var(--lmm-r-md);
      padding: 13px 16px;
      box-shadow: var(--lmm-sh1);
    }
    .lmm-mpesa-icon {
      width: 42px; height: 42px; border-radius: 10px;
      background: linear-gradient(135deg, #00a651, #007838);
      display: flex; align-items: center; justify-content: center;
      font-size: 1.3rem; flex-shrink: 0;
      box-shadow: 0 2px 8px rgba(0,166,81,.28);
    }
    .lmm-mpesa-text strong {
      display: block; font-size: 0.82rem; font-weight: 800;
      color: var(--lmm-ink); margin-bottom: 2px;
    }
    .lmm-mpesa-text span { font-size: 0.69rem; color: var(--lmm-slate); line-height: 1.4; }

    /* ─── ANIMATIONS ──────────────────────────────────────────────── */
    @keyframes lmm-up {
      from { opacity: 0; transform: translateY(16px); }
      to   { opacity: 1; transform: translateY(0); }
    }

    /* ─── RESPONSIVE ──────────────────────────────────────────────── */

    /* ≤ 960px — stack columns */
    @media (max-width: 960px) {
      .lmm-hero-grid {
        grid-template-columns: 1fr;
      }
      .lmm-hero-left {
        padding: 44px 40px;
        border-right: none;
        border-bottom: 1px solid var(--lmm-rule);
      }
      .lmm-hero-right {
        padding: 36px 40px 44px;
      }
    }

    /* ≤ 700px — tighten everything */
    @media (max-width: 700px) {
      body { padding: 16px 12px 36px; }
      .lmm-hero-left { padding: 32px 24px; gap: 22px; }
      .lmm-hero-headline { font-size: clamp(1.95rem, 7vw, 2.6rem); }
      .lmm-hero-right { padding: 28px 24px 32px; }
      .lmm-feat-grid { grid-template-columns: 1fr 1fr; gap: 10px; }
    }

    /* ≤ 520px — full mobile */
    @media (max-width: 520px) {
      body { padding: 12px 10px 28px; }
      .lmm-hero-card { border-radius: 18px; }
      .lmm-hero-left { padding: 26px 18px; gap: 20px; }
      .lmm-hero-headline { font-size: clamp(1.75rem, 8.5vw, 2.2rem); }
      .lmm-hero-headline-tag { font-size: 0.3em; }
      .lmm-hero-desc { font-size: 0.88rem; }
      .lmm-feat-grid { grid-template-columns: 1fr; gap: 9px; }
      .lmm-feat-item { padding: 12px 13px; }
      .lmm-cta-group { flex-direction: column; gap: 10px; }
      .lmm-cta-btn { width: 100%; justify-content: center; padding: 15px 20px; }
      .lmm-stats-row { gap: 10px 0; }
      .lmm-stat-item {
        flex: 1 1 40%;
        border-right: none; padding-right: 0; margin-right: 0;
      }
      .lmm-stat-item:nth-child(odd) {
        border-right: 1px solid var(--lmm-rule);
        padding-right: 14px; margin-right: 14px;
      }
      .lmm-hero-right { padding: 22px 18px 26px; gap: 14px; }
      .lmm-steps-list { padding: 16px 18px; gap: 13px; }
      .lmm-how-header { padding: 16px 18px 13px; }
      .lmm-how-footer { padding: 0 18px 16px; }
      .lmm-trust-pill { font-size: 0.68rem; padding: 6px 13px; }
    }

    /* ≤ 380px — very small phones */
    @media (max-width: 380px) {
      .lmm-hero-headline { font-size: 1.65rem; }
      .lmm-hero-left { padding: 22px 14px; }
      .lmm-hero-right { padding: 18px 14px 22px; }
      .lmm-feat-grid { gap: 8px; }
    }

  </style>
</head>
<body>

<div class="lmm-hero-wrap">
  <section class="lmm-hero-card" aria-label="Lipa Mdogo Mdogo — own any phone on installment">

    <div class="lmm-hero-grid">

      <!-- ── LEFT ──────────────────────────────────────────────── -->
      <div class="lmm-hero-left">

        <div class="lmm-trust-pill">
          <span class="lmm-trust-dot" aria-hidden="true"></span>
          🇰🇪 Kenya's #1 Installment Phone Store &mdash; 50,000+ Happy Customers
        </div>

        <h1 class="lmm-hero-headline">
          Own Any Phone,<br/>
          Pay <span class="lmm-hero-headline-em">Lipa Mdogo Mdogo</span>
          <span class="lmm-hero-headline-tag">No Bank &nbsp;·&nbsp; No Stress &nbsp;·&nbsp; Just M-Pesa</span>
        </h1>

        <p class="lmm-hero-desc">
          Browse 200+ brand-new smartphones and walk away today with just a small deposit.
          Clear the balance daily, weekly, or monthly via <strong>M-Pesa</strong> — at your own pace, zero hidden charges.
        </p>

        <div class="lmm-brand-list" aria-label="Available brands">
          <span class="lmm-brand-chip">Samsung</span>
          <span class="lmm-brand-chip">iPhone</span>
          <span class="lmm-brand-chip">Tecno</span>
          <span class="lmm-brand-chip">Infinix</span>
          <span class="lmm-brand-chip">Itel</span>
          <span class="lmm-brand-chip">Oppo</span>
          <span class="lmm-brand-chip">Vivo</span>
          <span class="lmm-brand-chip">HMD</span>
        </div>

        <ul class="lmm-feat-grid" role="list" aria-label="Key benefits">
          <li class="lmm-feat-item">
            <div class="lmm-feat-icon" aria-hidden="true">💸</div>
            <div class="lmm-feat-body">
              <strong>From KSh 2,000 Deposit</strong>
              <span>Take your phone home today — pay the rest gradually</span>
            </div>
          </li>
          <li class="lmm-feat-item">
            <div class="lmm-feat-icon" aria-hidden="true">✅</div>
            <div class="lmm-feat-body">
              <strong>100% Genuine Devices</strong>
              <span>Brand-new, verified, and fully warranted smartphones</span>
            </div>
          </li>
          <li class="lmm-feat-item">
            <div class="lmm-feat-icon" aria-hidden="true">📅</div>
            <div class="lmm-feat-body">
              <strong>Flexible Repayments</strong>
              <span>Daily, weekly or monthly — you set the pace</span>
            </div>
          </li>
          <li class="lmm-feat-item">
            <div class="lmm-feat-icon" aria-hidden="true">🚚</div>
            <div class="lmm-feat-body">
              <strong>Free Same-Day Delivery</strong>
              <span>Nairobi, Kiambu, Machakos &amp; Kajiado counties</span>
            </div>
          </li>
        </ul>

        <div class="lmm-cta-group">
          <a href="/" class="lmm-cta-btn lmm-cta-primary">
            <span aria-hidden="true">📱</span> Browse All Phones
          </a>
          <a href="https://wa.me/254720202167?text=Habari%2C%20I%20want%20to%20order%20a%20phone%20on%20installment"
             class="lmm-cta-btn lmm-cta-whatsapp"
             target="_blank" rel="noopener noreferrer">
            <span aria-hidden="true">💬</span> Order on WhatsApp
          </a>
        </div>

        <div class="lmm-stats-row" role="list" aria-label="Store achievements">
          <div class="lmm-stat-item" role="listitem">
            <strong>50K+</strong>
            <span>Customers Served</span>
          </div>
          <div class="lmm-stat-item" role="listitem">
            <strong>200+</strong>
            <span>Phone Models</span>
          </div>
          <div class="lmm-stat-item" role="listitem">
            <strong>4.9 ★</strong>
            <span>Customer Rating</span>
          </div>
          <div class="lmm-stat-item" role="listitem">
            <strong>Same Day</strong>
            <span>Nairobi Delivery</span>
          </div>
        </div>

      </div>

      <!-- ── RIGHT ─────────────────────────────────────────────── -->
      <aside class="lmm-hero-right" aria-label="How it works">

        <p class="lmm-right-eyebrow">Simple &amp; Fast Process</p>

        <div class="lmm-how-card">
          <div class="lmm-how-header">
            <div class="lmm-how-label">How It Works</div>
            <div class="lmm-how-title">Get your phone in 4 steps 🎉</div>
          </div>

          <ol class="lmm-steps-list" role="list">
            <li class="lmm-step-item">
              <div class="lmm-step-num" aria-label="Step 1">1</div>
              <div class="lmm-step-body">
                <strong>Pick Your Dream Phone</strong>
                <p>Browse 200+ models — Samsung, iPhone, Tecno, Infinix and more</p>
              </div>
            </li>
            <li class="lmm-step-item">
              <div class="lmm-step-num" aria-label="Step 2">2</div>
              <div class="lmm-step-body">
                <strong>We Deliver to Your Door</strong>
                <p>Free, fast delivery anywhere in Nairobi — same day guaranteed</p>
              </div>
            </li>
            <li class="lmm-step-item">
              <div class="lmm-step-num" aria-label="Step 3">3</div>
              <div class="lmm-step-body">
                <strong>Inspect &amp; Pay Deposit</strong>
                <p>Check the phone in your hands, then activate with a small M-Pesa deposit</p>
              </div>
