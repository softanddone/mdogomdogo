---
---

<style>
  @keyframes ab-fadeup {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  @keyframes ab-pulse {
    0%, 100% { transform: scale(1); }
    50%       { transform: scale(1.05); }
  }
  @keyframes ab-float {
    0%, 100% { transform: translateY(0); }
    50%      { transform: translateY(-3px); }
  }
  @keyframes ab-glow {
    0%, 100% { box-shadow: 0 2px 8px rgba(255, 153, 0, 0.25); }
    50%      { box-shadow: 0 4px 16px rgba(255, 153, 0, 0.5); }
  }
  @keyframes ab-shimmer {
    0%   { background-position: -800px 0; }
    100% { background-position:  800px 0; }
  }

  .ab-wrap {
    background: #131921;
    border-bottom: 1px solid #3a4553;
    overflow: hidden;
    position: relative;
    animation: ab-fadeup 0.8s ease-out both;
    font-family: 'Roboto', Arial, sans-serif;
  }

  .ab-wrap::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent, rgba(255, 153, 0, 0.04), transparent);
    background-size: 800px 100%;
    animation: ab-shimmer 3s linear infinite;
    pointer-events: none;
  }

  .ab-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    max-width: 1340px;
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    position: relative;
  }

  .ab-left {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex: 1;
    animation: ab-fadeup 0.8s ease-out 0.15s both;
  }

  .ab-logo-group {
    display: flex;
    align-items: center;
    gap: 0;
  }

  .ab-logo {
    font-size: 1.15rem;
    font-weight: 800;
    color: #ffffff;
    letter-spacing: 0.3px;
    white-space: nowrap;
    text-decoration: none;
    transition: color 0.2s;
  }

  .ab-logo:hover {
    color: #FF9900;
  }

  .ab-tagline {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.45);
    font-weight: 600;
    white-space: nowrap;
    margin-left: 6px;
  }

  .ab-mid {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    animation: ab-fadeup 0.8s ease-out 0.3s both;
  }

  .ab-badge {
    background: #1a2634;
    border: 1px solid #3a4553;
    border-radius: 4px;
    padding: 0.2rem 0.55rem;
    font-size: 0.65rem;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.75);
    white-space: nowrap;
    animation: ab-float 3s ease-in-out infinite;
  }

  .ab-event-text {
    font-size: 0.85rem;
    font-weight: 800;
    color: #FF9900;
    white-space: nowrap;
  }

  .ab-event-sub {
    font-size: 0.85rem;
    font-weight: 800;
    color: #ffffff;
    white-space: nowrap;
  }

  .ab-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    animation: ab-fadeup 0.8s ease-out 0.45s both;
    flex-shrink: 0;
  }

  .ab-pill {
    background: #FF9900;
    color: #131921;
    padding: 0.28rem 0.75rem;
    border-radius: 20px;
    font-size: 0.68rem;
    font-weight: 800;
    white-space: nowrap;
    animation: ab-pulse 2s ease-in-out infinite;
    letter-spacing: 0.02em;
  }

  .ab-disc {
    background: #FF9900;
    border-radius: 6px;
    padding: 0.45rem 0.85rem;
    display: flex;
    align-items: baseline;
    gap: 0.25rem;
    flex-shrink: 0;
    animation: ab-glow 2s ease-in-out infinite;
    cursor: pointer;
    transition: transform 0.3s;
    text-decoration: none;
  }

  .ab-disc:hover {
    transform: scale(1.08) rotate(-2deg);
  }

  .ab-up-to {
    font-size: 0.6rem;
    font-weight: 700;
    color: #131921;
    text-transform: uppercase;
  }

  .ab-pct {
    font-size: 1.3rem;
    font-weight: 900;
    line-height: 1;
    color: #131921;
  }

  .ab-off {
    font-size: 0.6rem;
    font-weight: 700;
    color: #131921;
    text-transform: uppercase;
  }

  @media (max-width: 1100px) {
    .ab-inner {
      gap: 1rem;
    }
    .ab-left {
      gap: 1rem;
    }
  }

  @media (max-width: 768px) {
    .ab-inner {
      padding: 0.55rem 1rem;
      gap: 0.75rem;
    }
    .ab-logo {
      font-size: 1rem;
    }
    .ab-event-text,
    .ab-event-sub {
      font-size: 0.75rem;
    }
    .ab-pct {
      font-size: 1.1rem;
    }
    .ab-tagline {
      display: none;
    }
  }

  @media (max-width: 480px) {
    .ab-pill {
      display: none;
    }
    .ab-mid {
      display: none;
    }
    .ab-right {
      gap: 0.5rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ab-wrap,
    .ab-left,
    .ab-mid,
    .ab-right {
      animation: none;
    }
    .ab-wrap::before {
      animation: none;
    }
    .ab-badge {
      animation: none;
    }
    .ab-pill {
      animation: none;
    }
    .ab-disc {
      animation: none;
    }
  }
</style>

<div class="ab-wrap" role="banner" aria-label="Promotions">
  <div class="ab-inner">

    <div class="ab-left">
      <div class="ab-logo-group">
        <a href="/" class="ab-logo">MdogomdogoDeals</a>
        <span class="ab-tagline">• Upgrade your phone today</span>
      </div>

      <div class="ab-mid">
        <div class="ab-badge">Samsung &amp; Tecno</div>
        <span class="ab-event-text">Black Friday</span>
        <span class="ab-event-sub">Deals</span>
      </div>
    </div>

    <div class="ab-right">
      <div class="ab-pill">Limited Time Sale</div>
      <a href="/phones/lipa-mdogo-mdogo-nairobi" class="ab-disc" aria-label="Shop deals — up to 45% off">
        <span class="ab-up-to">Up to</span>
        <span class="ab-pct">45%</span>
        <span class="ab-off">OFF</span>
      </a>
    </div>

  </div>
</div>
